{
  "name": "Daily Quote Emailer (FlowDex Starter Sample)",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "days" }] } },
      "name": "Every Day",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [260, 300]
    },
    {
      "parameters": { "url": "https://api.quotable.io/random", "options": {} },
      "name": "Get Quote",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 300]
    },
    {
      "parameters": {
        "subject": "Your daily quote",
        "message": "={{ $json.content }} — {{ $json.author }}"
      },
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [700, 300]
    }
  ],
  "connections": {
    "Every Day": { "main": [[{ "node": "Get Quote", "type": "main", "index": 0 }]] },
    "Get Quote": { "main": [[{ "node": "Send Email", "type": "main", "index": 0 }]] }
  },
  "meta": { "note": "FlowDex starter sample — free to share. Replace or keep as a lead magnet." }
}
