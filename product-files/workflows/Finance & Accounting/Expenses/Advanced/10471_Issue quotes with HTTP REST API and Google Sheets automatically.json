      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming invoice records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    invoiceId: String(j.invoiceId ?? j.id ?? '').trim(),\n    amount: typeof j.amount === 'string' ? j.amount.trim() : j.amount ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
