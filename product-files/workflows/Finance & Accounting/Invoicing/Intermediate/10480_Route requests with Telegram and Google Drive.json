{"name":"Route requests with Telegram and Google Drive","nodes":[{"parameters":{"formTitle":"Route requests with Telegram and Google Drive","formFields":{"values":[{"fieldLabel":"Amount","requiredField":true},{"fieldLabel":"Duedate","requiredField":false},{"fieldLabel":"Vendor","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"e281f010-1175-4c74-8ce9-229d7a0538b4","name":"New Invoice Form Submission","webhookId":"3c4a5931-691e-4077-9edf-d49bdad3855d"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming invoice records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    invoiceId: String(j.invoiceId ?? j.id ?? '').trim(),\n    amount: typeof j.amount === 'string' ? j.amount.trim() : j.amount ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"0e06a796-aa3b-4ec3-a126-d79dbdb30541","name":"Normalize Invoice Payload"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c365e360-3c88-4842-8fe6-1d07d68370fb","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"auto-approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"auto-approve"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"be58b003-81b5-4c69-b95f-929d503fd1f3","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"needs-review","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"needs-review"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion"