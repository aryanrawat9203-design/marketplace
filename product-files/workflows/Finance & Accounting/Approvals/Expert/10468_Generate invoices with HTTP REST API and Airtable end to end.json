    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Build an HTML digest table from the aggregated rows\nconst rows = $input.all().map(i => i.json);\nconst tr = rows.map(r =>\n  `<tr><td>${r.invoiceId ?? ''}</td><td>${r.amount ?? ''}</td><td>${r.count ?? 1}</td></tr>`\n).join('');\nconst html = `<h2>Invoice digest</h2><table border=\"1\" cellpadding=\"4\">\n<tr><th>ID</th><th>amount</th><th>Count</th></tr>${tr}</table>`;\nreturn [{ json: { html, rowCount: rows.length, generatedAt: new Date().toISOString() } }];"
      },
