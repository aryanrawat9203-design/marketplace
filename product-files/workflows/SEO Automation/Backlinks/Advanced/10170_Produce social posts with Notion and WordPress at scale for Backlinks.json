        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality backlinks content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
