,"retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mergeByFields":{"values":[{"field1":"url","field2":"url"}]},"options":{}},"type":"n8n-nodes-base.compareDatasets","typeVersion":2.3,"position":[1674,400],"id":"c549ea55-5533-4663-826c-e68c0bba047c","name":"Diff vs Last Run"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#seo","cachedResultName":"#seo"},"text":"=🆕 {{ $json.title }} — {{ $json.price }} ({{ $json.url }})","otherOptions":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[2646,-80],"id":"79c9b4c7-e572-4b66-9f0a-8e65fa6f98a5","name":"Alert New Findings","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Page Database"},"title":"={{ $json.url || $json.pageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2970,460],"id":"da20be8d-e8c0-40cc-98bd-a17f8669ae2b","name":"Update Changed Rows","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Page Database"},"title":"={{ $json.url || $json.pageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[3294,970],"id":"4aa46e07-423d-4543-987b-a324da893611","name":"Write Fresh Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3942,400],"id":"c4ff9a5e-28cd-4345-9848-89f311d395f5","name":"Merge Diff Outcomes"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"position","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","type