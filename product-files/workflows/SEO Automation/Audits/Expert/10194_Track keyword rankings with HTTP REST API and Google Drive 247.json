.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7830,400],"id":"34ce8d23-c16d-467c-b224-e66355641b55","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Pages"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[8154,400],"id":"d512a8b1-310d-4303-ab7a-14532e3dd84c","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8478,400],"id":"cdd961cf-2a2c-448d-898e-19fd1cc76df3","name":"Record Sub-workflow Result"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"977fc217-2048-4b59-ba40-c46f6fccab37","leftValue":"={{ $json.url }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8802,400],"id":"081ede4f-3086-4363-8ab2-d31a7928934e","name":"Guard Non-Empty url"},{"parameters":{"assignments":{"assignments":[{"id":"e1c9bf57-62ad-42ab-b7e3-c6e39eff3367","name":"pipeline","value":"Audits","type":"string"},{"id":"a72f29cf-b4e9-4c46-be43-798f77051978","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9126,400],"id":"29dfe4fd-76ce-4e29-96f2-438b96f45b09","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"pageId","value":"={{ $json.pageId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[9450,400],