2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Audit keyword rankings with HTTP / REST API and Google Sheets for your — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[6858,400],"id":"5d961c3f-0f7f-4969-8e8b-b004377a4729","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"5739d0f4-c107-4ebf-951b-f3d689199435","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"cab4f0d4-09cf-4fbf-b5d0-6bdd2915f267","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"8d6d4fe6-6638-4942-9f17-b7736a89f8ec","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,1420],"id":"c960745f-abbc-4944-98d8-d670cf42f97c","name":"Capture Failure Context"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[6534,1420],"id":"835357ed-792b-4b7e-9eaf-d901d9b110a0","name":"Escalate Failure to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 4 h. No input data; downstream nodes fetch what they need.\n\nNext: Probe Endpoint A","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"331e59a8-cff1-9ab4-0e77-64f9565be8aa","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Probe Endpoint A\n\nGET https://service-a.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"d117c0b4-fe93-5820-6e65-64a1ca27d65c","name":"Note: Probe Endpoint A"},{"parameters":{"content":"### Probe Endpoint B\n\nGET https://service-b.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,760],"id":"d065c768-931f-5c71-bdf8-8531a91f5877","name":"Note: Probe Endpoint B"},{"parameters":{"content":"### Probe Endpoint C\n\nGET https://service-c.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1270],"id":"877847e4-a790-a2a2-fe26-d58b6b5bd9f0","name":"Note: Probe Endpoint C"},{"parameters":{"content":"### Combine Probe Results\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: All Healthy?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"93a51a87-049e-b4f4-a9b7-6a7f6e0cae5b","name":"Note: Combine Probe Results"},{"parameters":{"content":"### All Healthy?\n\nTwo-way gate on `={{ ($json.statusCode || 200) < 400 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Record Uptime Metric · ②→ Already Alerted? (State Check)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"899f13e9-70f4-0688-3ee3-c07db7bd67c2","name":"Note: All Healthy?"},{"parameters":{"content":"### Record Uptime Metric\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Tag Pipeline Metadata · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,280],"id":"b340c2bf-9ccd-6e1a-fb52-a8e864dc1499","name":"Note: Record Uptime Metric"},{"parameters":{"content":"### Already Alerted? (State Check)\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Page On-Call via Twilio","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,880],"id":"28d436fa-bbaf-79dc-3228-cfab5e7c95ad","name":"Note: Already Alerted? (State Check)"},{"parameters":{"content":"### Page On-Call via Twilio\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,880],"id":"36e9ff1b-e32b-1ffc-b9d1-9a9c7ffc4265","name":"Note: Page On-Call via Twilio"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Pages Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"e08cd085-9453-d68b-ffa1-e2351767eb10","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Pages Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Guard Non-Empty url","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"de52be0a-3f32-6d5e-2557-4d54895d24e3","name":"Note: Sort Pages Newest First"},{"parameters":{"content":"### Guard Non-Empty url\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"a8382ede-cd45-c466-cd92-99e2e4f2a917","name":"Note: Guard Non-Empty url"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"e40ad46e-32c4-3438-7d32-6b24717b301d","name":"Note: Align Field Names"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"e98f0144-b53c-a382-0309-5d05ec4c966d","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"7812208b-820c-4ada-d8cf-96ef8f801f09","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"5d8f8a29-2159-0d2a-831b-576ade86f8ad","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"376feb72-296b-e686-1d10-c1e159db93ed","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Twilio","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"16632308-b829-6593-8bac-e49e4bbc983f","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Twilio SID + token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"9a71bc2c-d5d0-7de7-30e4-68966306dd70","name":"Note: Escalate Failure to Twilio"},{"parameters":{"content":"# Audit keyword rankings with HTTP / REST API and Google Sheets for your team\n\n**Pattern:** SEO Audit · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nAudit keyword rankings with HTTP / REST API and Google Sheets for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual content seo is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Probe Endpoint A → Combine Probe Results → All Healthy? → Record Uptime Metric → Tag Pipeline Metadata → Sort Pages Newest First → …\n\n## Use it for\n- Teams that want to seo audit without manual effort\n- Anyone automating content seo in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Standardizes the process every time\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Slack OAuth2; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"cf7c7dd2-0082-eb56-1cd9-fb5e627f450f","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"dcbe0224-b950-b1cf-aa09-2df2d27b5900","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"eaf0ee77-fc2a-ef96-f61c-8049245a6423","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your content seo process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"ab5bb161-6973-3ef8-5ec8-42328be50ee0","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Probe Endpoint A","type":"main","index":0},{"node":"Probe Endpoint B","type":"main","index":0},{"node":"Probe Endpoint C","type":"main","index":0}]]},"Probe Endpoint A":{"main":[[{"node":"Combine Probe Results","type":"main","index":0}]]},"Probe Endpoint B":{"main":[[{"node":"Combine Probe Results","type":"main","index":1}]]},"Probe Endpoint C":{"main":[[{"node":"Combine Probe Results","type":"main","index":2}]]},"Combine Probe Results":{"main":[[{"node":"All Healthy?","type":"main","index":0}]]},"All Healthy?":{"main":[[{"node":"Record Uptime Metric","type":"main","index":0}],[{"node":"Already Alerted? (State Check)","type":"main","index":0}]]},"Already Alerted? (State Check)":{"main":[[{"node":"Page On-Call via Twilio","type":"main","index":0}]]},"Record Uptime Metric":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Pages Newest First","type":"main","index":0}]]},"Sort Pages Newest First":{"main":[[{"node":"Guard Non-Empty url","type":"main","index":0}]]},"Guard Non-Empty url":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Twilio","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Twilio","type":"main","index":0}]]},"Page On-Call via Twilio":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Twilio":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"323460fe-5918-4f4d-aedc-d822b5f8409c","id":"FDX10129"}