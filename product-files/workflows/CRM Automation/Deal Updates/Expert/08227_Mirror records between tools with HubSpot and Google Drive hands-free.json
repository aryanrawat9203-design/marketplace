{
  "name": "Mirror records between tools with HubSpot and Google Drive hands-free",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 6
            }
          ]
        }
      },
      "id": "1a0f64c1-da8d-4287-ad35-2ea69d1f2844",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "bbe5058e-e1de-4cad-b55c-50dcc13ae9a1",
