{
  "name": "Mirror records between tools with HubSpot and Google Sheets automatically",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 9
            }
          ]
        }
      },
      "id": "ee087a82-ae98-447b-be00-2d695ad28af9",
