    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "765f9b72-12b2-47ee-9bc9-b00542396663",
              "name": "count",
              "value": "={{ $json.items ? $json.items.length : 1 }}",
              "type": "number"
            },
            {
              "id": "e78003c6-0726-42ed-aceb-5e8471f96f85",
              "name": "summary",
              "value": "={{ JSON.stringify($json).slice(0, 280) }}",
              "type": "string"
