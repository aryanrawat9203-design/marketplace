{"name":"Mirror records between tools with HubSpot and Google Sheets for your team","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":12}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"88555e62-d083-480b-8bb1-7991ca3e4db9","name":"Hourly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"0de1cb5c-3661-4075-a975-e72e456d7a27","name":"contactId","value":"={{ $json.body?.contactId || $json.body?.id }}","type":"string"},{"id":"a1f6eabf-d31c-42ac-ad7b-fe7be2f9d5de","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"9f014fe7-8c46-4cdf-b72a-7a4efd9d9bc0","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"ac303124-d56a-4ef0-901d-28565e73bcb4","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a4173c7b-3171-40df-8cd8-01d5e319a0ff","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6f2e4100-fd2e-468a-80b3-43eef53713c0","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4b7146a2-fa99-4337-a0fc-56c95bc55406","leftValue":"={{ $json.kind }}","rightValue":"deleted","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"deleted"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-ba