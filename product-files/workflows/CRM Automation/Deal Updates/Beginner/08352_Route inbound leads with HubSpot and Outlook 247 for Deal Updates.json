"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"5dd132be-3e56-4d3c-ac45-094c32a16fff","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4266,400],"id":"cbd52ab9-f3e7-4dc1-9da5-ba1346e41375","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[4590,400],"id":"da5eaf2d-5ae1-4faa-8b81-365ee450c3ff","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6042a47e-9e2d-47bb-980d-876a97e577ca","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"290698f3-9353-4d8e-b451-c61d9134269b","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"831a2f25-34c9-45c2-87cf-a4c98d09379c","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"85fa7433-591f-4b24-b809-541bfcc3b232","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main