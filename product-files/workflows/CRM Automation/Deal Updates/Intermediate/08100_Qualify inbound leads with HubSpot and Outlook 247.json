{"name":"Qualify inbound leads with HubSpot and Outlook 24/7","nodes":[{"parameters":{"formTitle":"Qualify inbound leads with HubSpot and Outlook 24/7","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Dealstage","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"1fa4325a-9c37-4dd8-aff2-07a61a14a225","name":"New Contact Form Submission","webhookId":"81c4226d-fd8d-4156-bb66-09b3e033da6a"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"21e8866e-4085-49ce-84ea-d0acb87978d5","leftValue":"={{ $json.contactId || $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"e846001b-15f4-490a-8c35-c364cdc61ea8","name":"Keep Valid Contacts"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"contactId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"9d70634f-99ad-48b4-846b-9a9e21ce7fbf","name":"Remove Duplicate Contacts"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,400],"id":"f4c72b7a-82ca-439e-b6f2-7affa3c1022f","name":"Enrich — Primary Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e6ef7dd4-641b-475d-bd1e-bbf3ad76f10b","leftValue":"={{ $json.company || $json.name }}","rightValue":"","operator":{"type"