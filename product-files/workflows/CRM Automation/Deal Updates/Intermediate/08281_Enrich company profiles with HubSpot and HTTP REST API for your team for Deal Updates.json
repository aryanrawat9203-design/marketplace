;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"213ea2bb-ffae-4e1b-94f3-466252e7860c","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Contacts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5238,400],"id":"51247eb7-ad81-4690-a68a-f94a8a19e06c","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"ecc14088-d309-41f6-a1fa-0e44e8a5525f","name":"Record Sub-workflow Result"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5886,400],"id":"dac9928b-bb67-4d93-bec2-6aa6ed743a3f","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6210,400],"id":"de4625f6-c2c6-4056-9ba9-2d0a8ced0b85","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"b6dfd273-821c-4bf4-812f-044c427c8c44","name":"pipeline","value":"Deal Updates","type":"string"},{"id":"89983ec9-6af2-4afb-b8d5-76c891a22ca6","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6534,400],"id":"5d0c5014-1f7e-4070-9cfb-4f3e0e44960d","name":"Tag Pipeline Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2c2528ef-2a25-4b06-9a56-e810ead25d1f","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":