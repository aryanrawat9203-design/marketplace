{
  "name": "Follow up upcoming appointments with Google Drive and Outlook automatically",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 18
            }
          ]
        }
      },
      "id": "4e589081-0a69-4c14-8ce5-89fd00d07a96",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "4fe1d3d3-a297-4cd2-a5b4-a442ec2fb880",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "f3605fcc-48bf-44eb-8518-cbdf0f9414e4",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "1a152236-5da3-4ecc-875a-f0c32d5ddcd9",
      "name": "Validate Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        560,
        300
      ],
      "notes": "Validate & normalize the input before downstream steps (§9.1)."
    },
    {
      "parameters": {
        "resource": "file",
        "operation": "upload",
        "name": "={{ $json.filename }}",
        "options": {}
      },
      "id": "2ffe65e1-ec13-4468-a639-adf0fbbca535",
      "name": "Save to Google Drive",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        800,
        300
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "b93b0b81-a626-41ce-92ac-6c698084c7ee",
              "leftValue": "={{ $json.score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "4b0503e6-7fc2-401b-a6ae-95c268d09f38",
      "name": "Filter Items",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [
        1040,
        300
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "subject": "Automated update",
        "bodyContent": "={{ $json.summary }}",
        "toRecipients": "={{ $json.email }}"
      },
      "id": "85ac6fc7-02b4-4a8f-8ef1-7d080b15a5ec",
      "name": "Send Outlook Message",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [
        1280,
        300
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "content": "## Follow up upcoming appointments with Google Drive and Outlook automatically\n\n**Pattern:** Reminders & Follow-ups\n**Trigger:** Scheduled\n**Integrations:** Google Drive, Outlook\n\nImport, add your credentials, then adjust parameters. Original FlowDex template.",
        "height": 260,
        "width": 360,
        "color": 4
      },
      "id": "ca884dc0-2206-4c2d-9acd-513b2617823f",
      "name": "Sticky Note",
