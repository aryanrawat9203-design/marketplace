p Status","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"336f51d8-e59d-4888-8b36-8d896f1a084c","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"1720075a-cff9-4ddd-83d4-2882ffbc9555","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"60b304cb-97b9-4292-b574-060ffe6f9559","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,400],"id":"dbfa68c7-3838-4ba6-a95f-ddaf10d10b4d","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO contact_log (contactId, email, company, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.contactId, $json.email, $json.company ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4266,400],"id":"a5853c8b-19a8-4df8-8558-ba5a5b3e25fd","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Follow up upcoming appointments with PostgreSQL and Slack at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4590,400],"id":"f80cd623-1c98-4c53-8f1a-c2970e02cfdb","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"0f39f884-95e4-4252-9efc-f173d3a64afd","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"75d53afc-ff9f-47f6-88e0-8280a4a57fc0","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"cd0383c3-b13d-462e-8380-1a96625ad2a3","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,1420],"id":"2275033e-6319-4826-b4b7-029c929f9a54","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,1420],"id":"affa2376-60eb-4edb-be22-f37432db267e","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"executeQuery","query":"INSERT INTO contact_log (contactId, email, company, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.contactId, $json.email, $json.company ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4590,1420],"id":"0a36f7fa-a1d6-45df-b8bb-7a91799017eb","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 6:00. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Contact","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"1fa8563f-8bc2-8279-3651-8b63f824d31c","name":"Note: Daily Schedule"},{"parameters":{"content":"### Stamp & Shape Contact\n\nShapes the item: writes `contactId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"1da55b9a-e771-101f-a8b7-ea25462f207d","name":"Note: Stamp & Shape Contact"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.contactId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Segment Audience · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"3a79cd57-b926-73b8-d62e-a5dd8390899b","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"84bb0d97-9a21-f5b4-c6bf-89e6f8162e52","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Segment Audience\n\nTwo-way gate on `={{ ($json.score ?? 50) >= 50 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 1 — Welcome (Slack) · ②→ Tag for Slow Nurture","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"858acab1-30f0-ecc7-4447-a241734f5715","name":"Note: Segment Audience"},{"parameters":{"content":"### Step 1 — Welcome (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Wait Before Step 2 · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,280],"id":"1c2455a6-8c4b-2922-a63c-d4bb72f33d68","name":"Note: Step 1 — Welcome (Slack)"},{"parameters":{"content":"### Tag for Slow Nurture\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,880],"id":"747abd09-cb49-c17b-1910-d8ec8a641885","name":"Note: Tag for Slow Nurture"},{"parameters":{"content":"### Wait Before Step 2\n\nPauses 3 days — spacing calls to respect rate limits.\n\nNext: Converted Already?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"19e3ea6f-6048-a1d1-e89e-fdb313832bfc","name":"Note: Wait Before Step 2"},{"parameters":{"content":"### Converted Already?\n\nTwo-way gate on `={{ $json.status }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 2 — Value Nudge (Slack) · ②→ Mark Converted — Stop Drip","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"2c0643e8-d852-c09f-35bb-f8197f27e065","name":"Note: Converted Already?"},{"parameters":{"content":"### Step 2 — Value Nudge (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Wait Before Final Step · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,280],"id":"433dee2c-3957-5588-2f1d-17bd2c8ab573","name":"Note: Step 2 — Value Nudge (Slack)"},{"parameters":{"content":"### Mark Converted — Stop Drip\n\npostgres — `executeQuery` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,880],"id":"9e9f5b1d-a31f-3704-2e7b-c4ab599edb81","name":"Note: Mark Converted — Stop Drip"},{"parameters":{"content":"### Wait Before Final Step\n\nPauses 3 days — spacing calls to respect rate limits.\n\nNext: Step 3 — Final Offer (Slack)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"bb29797e-8733-a288-1019-29093b529479","name":"Note: Wait Before Final Step"},{"parameters":{"content":"### Step 3 — Final Offer (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Update Drip Status · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"32d4e7f1-8ef1-5350-9742-b6ac6a1c3f4b","name":"Note: Step 3 — Final Offer (Slack)"},{"parameters":{"content":"### Update Drip Status\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"c0571bf3-3a55-c8e5-8542-567c05282eb8","name":"Note: Update Drip Status"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"86598789-e27c-ab50-60d5-f31aaa06f3fe","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"b235d520-c39a-d755-e1e4-5272f509c58a","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"7cc11aa2-9e0d-4975-c6a9-1452288ac713","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"b54a4ad6-b2a7-dc4a-0f95-bb6c48c1c2fc","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,1540],"id":"2cca0307-af2c-2512-ace9-f8b2b2881488","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\npostgres — `executeQuery` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Postgres connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"5ecd84d0-eff0-0753-32e0-67ae83dda755","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Follow up upcoming appointments with PostgreSQL and Slack at scale\n\n**Pattern:** Reminders & Follow-ups · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nFollow up upcoming appointments with PostgreSQL and Slack at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual deal updates is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Stamp & Shape Contact → Payload Valid? → Segment Audience → Step 1 — Welcome (Slack) → Wait Before Step 2 → Converted Already? → …\n\n## Use it for\n- Teams that want to reminders & follow-ups without manual effort\n- Anyone automating deal updates in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Has retries and error handling built in\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"be6e6819-bbd6-95d0-9082-35b90b0763a8","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"2c8bf186-3275-e5bd-b29e-e875c7d76732","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"7fb7fc61-11f0-c077-0d6f-1985a357f49f","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your deal updates process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"a89befc6-ec05-591e-bc4e-34b627262f89","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Stamp & Shape Contact","type":"main","index":0}]]},"Stamp & Shape Contact":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Segment Audience","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Segment Audience":{"main":[[{"node":"Step 1 — Welcome (Slack)","type":"main","index":0}],[{"node":"Tag for Slow Nurture","type":"main","index":0}]]},"Step 1 — Welcome (Slack)":{"main":[[{"node":"Wait Before Step 2","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Wait Before Step 2":{"main":[[{"node":"Converted Already?","type":"main","index":0}]]},"Converted Already?":{"main":[[{"node":"Step 2 — Value Nudge (Slack)","type":"main","index":0}],[{"node":"Mark Converted — Stop Drip","type":"main","index":0}]]},"Step 2 — Value Nudge (Slack)":{"main":[[{"node":"Wait Before Final Step","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Wait Before Final Step":{"main":[[{"node":"Step 3 — Final Offer (Slack)","type":"main","index":0}]]},"Step 3 — Final Offer (Slack)":{"main":[[{"node":"Update Drip Status","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Update Drip Status":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Tag for Slow Nurture":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Mark Converted — Stop Drip":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"e14f63cc-eeea-463e-9308-c565a239d352","id":"FDX08349"}