ateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[2322,220],"id":"4f8c35ef-ddfd-48e4-a175-191573557ebe","name":"Count In-Sync Rows"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Database"},"title":"={{ $json.email || $json.contactId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2646,640],"id":"be6fb74e-8201-44c0-ac3e-3f5a08b4ff48","name":"Apply Updates to Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[2970,1060],"id":"23f4c2c6-7694-4127-91f6-07ab0bf30527","name":"Backfill into HubSpot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3618,400],"id":"86e995e0-b365-48cd-9957-23bb81a14ef5","name":"Gather Sync Results"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per contact (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.contactId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4590,400],"id":"2925a072-8768-404f-bb8e-805335a232d6","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4914,400],"id":"a23d6173-6dd7-4528-bd04-c4d24b87ba0c","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5238,400],"id":"4e320e4e-7704-4901-9d77-ddec16272469","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"40d95508-400d-40b0-9b8e-12e085d014e7","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5886,400],"id":"e7427bf9-e05f-4b1b-930e-0a3515ecea23","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Database"},"title":"={{ $json.email || $json.contactId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6210,400],"id":"b355a21e-aaa5-4ea1-b05a-cda0692d5fa8","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6534,400],"id":"a9879cac-e2d3-4fd2-8953-31f01870b95f","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"1143d611-97e6-48f6-8a21-3a104499c99c","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"48eb107e-46ea-468b-8710-bffc75db3ae0","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"1c5d8c99-2ca1-4bb8-abfd-0c78694087af","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"3bfdc85d-be15-4a2e-abee-86e87b4e9267","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"fa52e31e-1472-400e-8718-cb8498e8363e","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"ffbec26b-9093-43d2-a191-6242b72a084c","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"8ff64cc7-9c25-4ca2-b2cb-4e20de7df2e1","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[7506,400],"id":"b4910c28-19a1-4484-8c13-81982ce351bf","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Sync records between tools with HubSpot and Notion at scale — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[7830,400],"id":"19ba57f0-e9df-4513-a869-f99092b2eda9","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"92725004-ca0e-4298-b0a5-a47aa50cac0c","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"114f5286-e246-46f5-94f7-4d1866e390e0","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"c97b0d78-5184-4cab-bcd7-fdcfb72802f0","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,1420],"id":"d13a330b-3b01-49db-ae4e-340fa7919aac","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7506,1420],"id":"650e3b12-9be5-4ef8-b230-61cb7e2e9728","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7830,1420],"id":"64665f7e-1cad-4a72-a321-508533cd92a7","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Pull Side A (HubSpot)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"df523b1b-8f6f-68d9-bf10-a3e7ac268454","name":"Note: Daily Schedule"},{"parameters":{"content":"### Pull Side A (HubSpot)\n\nhubspot — `search` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"2884791a-2b78-8066-a9dc-7fd63c3cfd95","name":"Note: Pull Side A (HubSpot)"},{"parameters":{"content":"### Pull Side B (Notion)\n\nnotion — `getAll` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,790],"id":"3fecc570-90f2-aa45-eff6-53baefcac672","name":"Note: Pull Side B (Notion)"},{"parameters":{"content":"### Diff the Two Systems\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Create Missing in Notion · ②→ Count In-Sync Rows · ③→ Apply Updates to Notion · ④→ Backfill into HubSpot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"7e71a99e-a52a-02b8-702b-4b52f8168375","name":"Note: Diff the Two Systems"},{"parameters":{"content":"### Create Missing in Notion\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,-80],"id":"5ba0a025-25c7-6a1a-7f5e-e1c82e83dd03","name":"Note: Create Missing in Notion"},{"parameters":{"content":"### Count In-Sync Rows\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Gather Sync Results","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,340],"id":"91231a28-5379-8d4f-649d-b38586960b06","name":"Note: Count In-Sync Rows"},{"parameters":{"content":"### Apply Updates to Notion\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,760],"id":"2076cbff-dff9-cce5-bce2-85f480c677ad","name":"Note: Apply Updates to Notion"},{"parameters":{"content":"### Backfill into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,1180],"id":"02bfec8c-db0d-bfcd-849e-69baab6cb04a","name":"Note: Backfill into HubSpot"},{"parameters":{"content":"### Gather Sync Results\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"a8a0b42e-057a-b290-df17-422c21a72635","name":"Note: Gather Sync Results"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per contact (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"9e2e4be5-61f1-0928-6160-008fbaf1e641","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"9295a6cb-4821-a534-893d-5efffb393cff","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"91484731-b2cb-641d-7e65-23c8a0f7a877","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"0cd95ce3-d15e-58c4-3d38-77e56e4d567d","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"fb2d4e49-2baf-f694-750c-a80863209056","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"9c2d4577-5bd2-65a9-0477-ffd2f2853406","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"dead213a-3a7e-54d1-f8dd-1f4f97780e87","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"0514b923-1d49-9095-01b3-6fabe214f382","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"8a99c73e-b35f-4917-aff2-ed0f7c71fe5a","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"63a75c36-f562-df60-779b-cf716f883cbd","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"8283085b-3ddf-c6d4-5691-90c06e11ae99","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"4bc60e7b-a955-9754-abd4-4aefde033367","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"8806371a-0138-a9fa-784a-c5336ae9c2fa","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,1540],"id":"474542b9-3cf3-c201-d31f-5769bbfeee41","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Sync records between tools with HubSpot and Notion at scale\n\n**Pattern:** Two-System Sync · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nSync records between tools with HubSpot and Notion at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual follow-ups is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Pull Side A (HubSpot) → Diff the Two Systems → Create Missing in Notion → Gather Sync Results → Fingerprint for Idempotency → Drop Already-Processed Items → …\n\n## Use it for\n- Teams that want to two-system sync without manual effort\n- Anyone automating follow-ups in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Responds in seconds\n- Standardizes the process every time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; HubSpot private-app token; Notion integration token; Slack OAuth2; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"95012257-dc29-cbe7-337b-fd2aec591cc3","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-620],"id":"1ca40f1f-c970-c2ff-81bb-dfeb751dd322","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-620],"id":"a7893e55-5997-0bc4-ad05-defe89ba3d22","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your follow-ups process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-620],"id":"b13b03bc-42e0-766f-f7c2-2b7bac690dd0","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Pull Side A (HubSpot)","type":"main","index":0},{"node":"Pull Side B (Notion)","type":"main","index":0}]]},"Pull Side A (HubSpot)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Pull Side B (Notion)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff the Two Systems":{"main":[[{"node":"Create Missing in Notion","type":"main","index":0}],[{"node":"Count In-Sync Rows","type":"main","index":0}],[{"node":"Apply Updates to Notion","type":"main","index":0}],[{"node":"Backfill into HubSpot","type":"main","index":0}]]},"Create Missing in Notion":{"main":[[{"node":"Gather Sync Results","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count In-Sync Rows":{"main":[[{"node":"Gather Sync Results","type":"main","index":1}]]},"Apply Updates to Notion":{"main":[[{"node":"Gather Sync Results","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backfill into HubSpot":{"main":[[{"node":"Gather Sync Results","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Gather Sync Results":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Twilio","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","ind