inator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7182,400],"id":"0d1b4979-72d5-4740-af90-cb680bb51b9e","name":"Guard Non-Empty email"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"contactId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7506,400],"id":"591bc5d3-14ba-4192-9765-3e094eaa073f","name":"Align Field Names"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"dealStage","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7830,400],"id":"e6b6cfcd-8d65-484a-9e06-ffbd0915842e","name":"Sort Contacts Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"24aee536-6f63-4749-bb14-b3684758b91c","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"1e40bd0e-99b4-498b-851c-79760c6340b1","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"4048fca6-4d31-4cf0-bcd8-4b20b9565f83","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"2c27d9ad-8f22-48ad-83d8-f0801524ad8d","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Database"},"title":"={{ $json.email || $json.contactId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8478,400],"id":"0799a060-a5e8-4047-af72-8a3ba5be530e","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Mirror contacts across systems with HubSpot and Google Drive without m — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[8802,400],"id":"d7b32a84-baff-4e05-a561-5a8cd1578be0","n