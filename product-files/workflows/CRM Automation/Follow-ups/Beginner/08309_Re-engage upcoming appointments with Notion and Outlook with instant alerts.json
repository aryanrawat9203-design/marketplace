{"name":"Re-engage upcoming appointments with Notion and Outlook with instant alerts","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":17,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"9ee47b33-053b-488f-a6ab-7cd7f59fcc9c","name":"Daily Schedule"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[54,400],"id":"c8dd3750-f990-48b9-b2d4-0319703c9ae5","name":"Read Pending Queue (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c7793587-6711-4976-89eb-f0c0fbf24f2d","leftValue":"={{ $json.contactId || $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[378,400],"id":"39b5ac98-3382-464c-9414-a1d053598cfc","name":"Keep Valid Contacts"},{"parameters":{"batchSize":5,"options":{"reset":false}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[702,400],"id":"e0320448-2270-4525-b043-6a9cf7fc1083","name":"Work in Batches"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/contacts","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1026,880],"id":"349cca15-47bd-4f93-85f9-a76ee4fef5e2","name":"Process Batch Item","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":2,"unit":"seconds"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1674,8