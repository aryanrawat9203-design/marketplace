st drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"fa9034fc-e7a6-46b2-aada-0c4130e10f96","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"e188613c-e975-49bc-a43e-bb577b3ed167","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6ea34963-7cdb-4d6e-8e8c-1519e5b56f18","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"be0d9c75-bfcc-402e-86c8-ba45c0545fc5","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"492d0b50-3e32-4ec4-a7ab-dab0bc580ae8","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per contact (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.contactId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"3ee765d2-2c7b-4906-8988-8ecfc96ffe85","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"remo