,"jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"79fc6ab4-5bba-47bc-acbb-cd7a7ccadee4","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Contacts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5238,400],"id":"e6f261e6-ec20-4358-89e7-361c58e43b76","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"ddd238e7-12ab-4ba8-a42e-01eb97262334","name":"Record Sub-workflow Result"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5886,400],"id":"cf279ecb-4eaa-44e0-979c-5af02fae4293","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[6210,400],"id":"003a5e04-2ecb-4b73-b812-e7703905f4b7","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6534,400],"id":"d816f8d4-893a-478f-9e98-da3cc666c167","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"87b67ad3-b72d-4812-90bf-b158cd1d0081","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per contact (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.contactId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"ecd01b7d-1503-46c7-bca2-8601b409b2e2","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[7506,400],"id":"67bf9d05-dab3-4166-9652-82e7deffb09a","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[7830,400],"id":"317cfa34-5d3c-49c5-90bb-cb06ec59dd64","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"54f4e403-3833-4f1e-8304-7fde92692bb9","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"84ef5542-ba50-4c99-af0e-6d8711ae9b51","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"a522f782-4c11-4e50-be5b-d53e0fa44e68","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"d8b3d0d5-b355-4e9d-a3fa-5b7da4c18158","name":"pipeline","value":"Follow-ups","type":"string"},{"id":"c79c2ea2-15cd-4fd0-96b9-eb3f03114c9f","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,400],"id":"6f67f83a-f3d2-4122-b7d4-c6559b3b059c","name":"Tag Pipeline Metadata"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8802,400],"id":"368c91d8-45ca-4826-a5b5-bc5bf00600fe","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"dealStage","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[9126,400],"id":"d3deb962-e982-47d5-ab44-d57cb4003eae","name":"Sort Contacts Newest First"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7f700c63-893e-493f-ac6e-57ecd15d2d53","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[9450,400],"id":"cde1799b-1fe8-43cb-b9b7-f6ae51db0be0","name":"Guard Non-Empty email"},{"parameters":{"dataToSave":{"values":[{"key":"contactId","value":"={{ $json.contactId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[9774,400],"id":"8bf41e14-a70f-494a-af1d-fda92f1fb887","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"a667039d-e8f4-48ec-b4f6-7b5ce2dc0200","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"06f29683-6242-4eb9-85de-dbf6488f601f","name":"itemCount","v