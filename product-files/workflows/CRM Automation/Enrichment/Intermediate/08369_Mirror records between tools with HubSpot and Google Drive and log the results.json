{
  "name": "Mirror records between tools with HubSpot and Google Drive and log the results",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 2
            }
          ]
        }
      },
      "id": "7df876b7-646f-4b77-a9c8-6443030b0825",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "8fd73e56-53a9-4490-b180-6e17097c27ff",
              "name": "receivedAt",
