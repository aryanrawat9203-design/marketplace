{
  "name": "Mirror records between tools with HubSpot and Google Drive on autopilot",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 18
            }
          ]
        }
      },
      "id": "9e1e2f55-cd94-4eb4-8d4c-3c10ba569552",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "ae92055c-0a17-438c-a909-6a9e0ade987c",
              "name": "receivedAt",
