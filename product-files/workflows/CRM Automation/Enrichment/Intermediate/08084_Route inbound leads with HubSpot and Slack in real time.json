{"name":"Route inbound leads with HubSpot and Slack in real time","nodes":[{"parameters":{"formTitle":"Route inbound leads with HubSpot and Slack in real time","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Dealstage","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"9887b1d0-0e61-4366-9595-7f6834bb555b","name":"New Contact Form Submission","webhookId":"27dfca54-20ed-4310-9a90-2f797d7acf72"},{"parameters":{"assignments":{"assignments":[{"id":"e63b0b4e-029e-4eda-a58b-87dffbe185e7","name":"contactId","value":"={{ $json.contactId || $json.id || $execution.id }}","type":"string"},{"id":"149048cd-652c-476d-a776-69ab28527ac9","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"26d2c380-367e-4edc-8040-ea5567b9b990","name":"Stamp & Shape Contact"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ceef9487-7678-46ed-8009-f6c5e653ac01","leftValue":"={{ $json.contactId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"456fdfe2-3111-42ba-8b8b-c5cb4d9ff928","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[378,910],"id":"8cbd9685-1c80-4a59-844b-325c187a6c03","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"compare":"selectedFields","fieldsToCompare":"contactId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[702,400],"id":"6cac0549-c3ab-4af9-b563-53b6551c725f","name":"Remove Duplicate Contacts"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1026,400],"id":"b3a05b68-1613-4edb-99b5-06886aa8b9cc","name":"Enrich — Primary Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8064f08d-0c32-4af3-b814-e5198debcc44","leftValue":"={{ $json.company || $json.name }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"e46101f5-9adf-449c-b614-b3e1c896b18e","name":"Primary Hit?"},{"parameters":{"method":"GET","url":"https://fallback-enrich.example.com/v1/person","sendQuery":true,"queryParameters":{"parameters":[{"name":"email","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1674,880],"id":"8229797c-b20d-4315-879d-22cdeeb43e53","name":"Enrich — Fallback Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"e4c5985a-4dc6-4fad-9b4c-4e65375b4a89","name":"Merge Enrichment Paths"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each contact 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.email) score += 20;\n  if (j.company) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3294,400],"id":"d1120db2-7f63-4d06-a1c1-eec1abc71300","name":"Score Enriched Records"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[3618,400],"id":"ed104cc9-62ec-4c56-b501-2c664a0938d3","name":"Upsert into HubSpot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4e38522c-1799-4a47-943f-7a0734e0ac61","leftValue":"={{ $json.score >= 80 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[3942,400],"id":"23f00709-f852-4c6a-b049-9638aeddb1be","name":"Hot Lead?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🔥 Hot {{ $json.company || $json.email }} (score {{ $json.score }}) — reach out now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,160],"id":"fbb38439-d1d0-4d1b-adfd-e17a7705e460","name":"Ping Owner Immediately","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"4323b9bf-069b-4e60-9002-202aca3aa71b","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"e5167084-8dd0-4740-bd2f-517c7631585e","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per contact (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.contactId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5238,400],"id":"8f025f8e-9c76-43c8-a52b-c0ab15a7dbb8","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5562,400],"id":"933c0671-0e4c-4e23-b6a3-199d31cc1e5a","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"d2102c33-e78d-4b22-a92c-c12f755a74c9","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"391acf5a-d52a-4950-a304-4870580e576d","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"6fae04fa-6494-45dc-8fd8-03a68ec4e8e0","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"50fbb378-beb6-409c-bdb5-b853df7d21d5","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[6210,400],"id":"342a52a4-157b-4a04-a4ab-dacb36126e5d","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Route inbound leads with HubSpot and Slack in real time — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,400],"id":"3e88b638-65bc-4210-8128-661304adb667","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"cde47b3d-d4cc-428a-b090-223a55de9b93","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"3dbad039-7132-4442-bff4-a28e0c65ec9d","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"378b4c43-3a40-4b13-8669-2c9d770c876c","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"22c24144-e85d-4ffd-93fe-e658be9a6108","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,1420],"id":"24ca269e-4cd6-4f78-b59b-d7bbd2dea915","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6534,1420],"id":"f1de3a37-e853-4e7e-b6ff-db6b62f06589","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Contact Form Submission\n\nServes an n8n-hosted form (Email, Company, Dealstage). Each submission becomes one execution.\n\nNext: Stamp & Shape Contact","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"dd521007-40f7-dcf1-1503-a4d413ad3249","name":"Note: New Contact Form Submission"},{"parameters":{"content":"### Stamp & Shape Contact\n\nShapes the item: writes `contactId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"e913568a-3777-5c22-3c38-c33c37e6297b","name":"Note: Stamp & Shape Contact"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.contactId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Remove Duplicate Contacts · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"835afa4d-a33e-a2f1-6f37-0b799a050214","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nhubspot — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"f37aa81b-a824-bab6-5f3c-cb16a097e700","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Remove Duplicate Contacts\n\nDrops duplicates within this run (compared on `contactId`).\n\nNext: Enrich — Primary Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"012ca2a9-3fdc-87c5-a235-3b9d4e74b3ea","name":"Note: Remove Duplicate Contacts"},{"parameters":{"content":"### Enrich — Primary Provider\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Primary Hit? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"043f1d3c-8a94-09c0-41a0-ac48a866ca16","name":"Note: Enrich — Primary Provider"},{"parameters":{"content":"### Primary Hit?\n\nTwo-way gate on `={{ $json.company || $json.name }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Enrich — Fallback Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"a3a58014-4c02-0974-4a72-c732e64cc0b3","name":"Note: Primary Hit?"},{"parameters":{"content":"### Enrich — Fallback Provider\n\nGET https://fallback-enrich.example.com/v1/person — retries 3× with backoff on failure.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"77860fce-cf01-becf-34f9-247d88f0f06f","name":"Note: Enrich — Fallback Provider"},{"parameters":{"content":"### Merge Enrichment Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Score Enriched Records","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"10b768ca-fdf0-e20e-219c-9892896d3404","name":"Note: Merge Enrichment Paths"},{"parameters":{"content":"### Score Enriched Records\n\nCustom JavaScript: Score each contact 0-100 from simple heuristics\n\nNext: Upsert into HubSpot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"83516e43-1285-0834-42cb-1357bffa3546","name":"Note: Score Enriched Records"},{"parameters":{"content":"### Upsert into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Hot Lead? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"41a306a7-1c70-67be-764c-62e755ccbad2","name":"Note: Upsert into HubSpot"},{"parameters":{"content":"### Hot Lead?\n\nTwo-way gate on `={{ $json.score >= 80 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Ping Owner Immediately · ②→ Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"2c70f57f-4581-36a8-941c-28090d715384","name":"Note: Hot Lead?"},{"parameters":{"content":"### Ping Owner Immediately\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,280],"id":"de103e98-917e-9061-6c4f-cc5f04ac6a89","name":"Note: Ping Owner Immediately"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"dca1d384-3572-b295-7467-802327c0a36c","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"27cb7de7-3af5-0d71-926f-1d7cb5e2e73d","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per contact (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"5edf256a-ccea-1f58-4eb8-c391c2bcd254","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"6bfdc38e-2cd4-d28c-eef5-abf23826e706","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"15da573b-c454-306b-824d-274f7137f5e9","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"6ce75d84-6ef6-4087-2eb8-97cb77f09f02","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"12d02d68-f693-4d24-ae27-7b0f90c56dcd","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"92706f77-caff-1a6c-5461-c31d59d16d72","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"aba67892-8a10-ae22-5f13-6a2162ce50ff","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"707f1375-eb6c-2bbc-a0bb-9f61157f6287","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Route inbound leads with HubSpot and Slack in real time\n\n**Pattern:** Lead Capture & Routing · **Level:** Production · **Trigger:** Form\n\n## What it does\nRoute inbound leads with HubSpot and Slack in real time. It starts from a hosted form submission.\n\n## Why it exists\nManual enrichment is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Contact Form Submission → Stamp & Shape Contact → Payload Valid? → Remove Duplicate Contacts → Enrich — Primary Provider → Primary Hit? → Merge Enrichment Paths → …\n\n## Use it for\n- Teams that want to lead capture & routing without manual effort\n- Anyone automating enrichment in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Responds in seconds\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; HubSpot private-app token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"deb9bdd1-9fb3-c5a3-d094-55e4ecc2ee49","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"ba5a210e-e8cb-49bc-54cc-30a8738a8b03","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"8d01a99a-cbda-65ea-9b5c-e41ccfe40323","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your enrichment process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"a3b9cfd4-2b06-1f50-1a9c-5aa090a5c4f8","name":"🛠 Customize me"}],"connections":{"New Contact Form Submission":{"main":[[{"node":"Stamp & Shape Contact","type":"main","index":0}]]},"Stamp & Shape Contact":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Remove Duplicate Contacts","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Remove Duplicate Contacts":{"main":[[{"node":"Enrich — Primary Provider","type":"main","index":0}]]},"Enrich — Primary Provider":{"main":[[{"node":"Primary Hit?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Primary Hit?":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":0}],[{"node":"Enrich — Fallback Provider","type":"main","index":0}]]},"Enrich — Fallback Provider":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Enrichment Paths":{"main":[[{"node":"Score Enriched Records","type":"main","index":0}]]},"Score Enriched Records":{"main":[[{"node":"Upsert into HubSpot","type":"main","index":0}]]},"Upsert into HubSpot":{"main":[[{"node":"Hot Lead?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hot Lead?":{"main":[[{"node":"Ping Owner Immediately","type":"main","index":0}],[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Ping Owner Immediately":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"dd911897-d73c-41a6-a456-49872eb34558","id":"FDX08084"}