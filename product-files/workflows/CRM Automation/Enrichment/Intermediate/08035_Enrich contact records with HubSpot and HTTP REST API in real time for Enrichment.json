length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8154,400],"id":"37e2c87c-98b5-466b-9ff3-a7e24212e834","name":"Persist Run Metadata"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8478,400],"id":"5b85193e-fdd8-450f-89b5-34e8c5c507f6","name":"Cap Batch Volume"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"contactId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8802,400],"id":"6aca1352-bf21-4b71-88f3-cdad7f016278","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"db013ac8-c4b1-41f3-89ff-e45f8de9bfcb","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[9126,400],"id":"e88fabce-61f8-4bd7-9f22-a1a1a07dacd1","name":"Guard Non-Empty email"},{"parameters":{"assignments":{"assignments":[{"id":"837c33f7-4e93-4a86-8982-eafdb6128e8d","name":"pipeline","value":"Enrichment","type":"string"},{"id":"306c4c12-4251-4139-b476-00aa2a4929bc","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9450,400],"id":"98e3b04f-af65-4394-a6b5-b56735a81c36","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"3f55b3c2-09d7-450f-a93c-827bfb05b158","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"999134e4-e723-4e77-8157-65f5c92abae9","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"bb22786f-9625-40eb-8445-f70caa05346e","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9774,400],"id":"dc93255e-3d3b-4d31-bd43-7f37097332a9","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__