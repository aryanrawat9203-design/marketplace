code","typeVersion":2,"position":[3294,400],"id":"5a08b579-e3ef-4da4-935c-1a81e3f361d3","name":"Score Enriched Records"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[3618,400],"id":"6ad5f44f-5c2b-4d22-9cd2-61d87d9d5e15","name":"Upsert into HubSpot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e5d99310-ff18-4638-a82a-17db21c1ca43","leftValue":"={{ $json.score >= 80 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[3942,400],"id":"30670522-e1cf-4440-bb6c-e002364dd775","name":"Hot Lead?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🔥 Hot {{ $json.company || $json.email }} (score {{ $json.score }}) — reach out now","otherOptions":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[4266,160],"id":"8e574c9e-1090-43e0-8f7c-bac47a77e7ec","name":"Ping Owner Immediately","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6975dec4-bba6-414a-9944-7698d6d8f6e4","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9cc9107f-8776-49e1-954f-9a4fea30fd84","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"809410d4-8fd2-4acb-853a-9ca60c2b8117","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"0ed27bb9-b081-4f75-ad90-fa5527fdc855","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[4914,400],"id":"bd7e8b1a-68cf-441c-b9b0-9e4f7b011025","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Route demo requests with HubSpot and Twilio — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5238,400],"id":"caf1f629-12e4-4eae-ba15-994a84273aef","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"666cfb8a-cee8-4b57-9a91-1c0b2bc8bf96","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"9904802a-8087-434d-b56a-7c9449e1840d","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ef1f66c5-8fd5-4919-8f3f-c96c532a7b7e","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,1420],"id":"1458dd91-2be3-4f27-8ff8-120d41a706e0","name":"Capture Failure Context"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[4914,1420],"id":"80994337-6302-40be-969b-b11c25d37618","name":"Escalate Failure to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Contact Form Submission\n\nServes an n8n-hosted form (Email, Company, Dealstage). Each submission becomes one execution.\n\nNext: Stamp & Shape Contact","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d95a70e1-c1a1-eac9-6f94-348ac0929a19","name":"Note: New Contact Form Submission"},{"parameters":{"content":"### Stamp & Shape Contact\n\nShapes the item: writes `contactId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"08ffec3e-b30c-77c5-d593-a7ac093bedcd","name":"Note: Stamp & Shape Contact"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.contactId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Remove Duplicate Contacts · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"18dd0a02-9879-4b96-a554-ef4287b24ed4","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nhubspot — `contact` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"c4768490-4508-12a5-7aff-f146fb0ff6c3","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Remove Duplicate Contacts\n\nDrops duplicates within this run (compared on `contactId`).\n\nNext: Enrich — Primary Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"d605555f-5d94-ae21-f644-81865937b793","name":"Note: Remove Duplicate Contacts"},{"parameters":{"content":"### Enrich — Primary Provider\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Primary Hit? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"dafbe5b4-d10e-8394-63a2-7cfeba1dc535","name":"Note: Enrich — Primary Provider"},{"parameters":{"content":"### Primary Hit?\n\nTwo-way gate on `={{ $json.company || $json.name }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Enrich — Fallback Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"8a32bf75-c372-30fc-1463-3b4fffccdad9","name":"Note: Primary Hit?"},{"parameters":{"content":"### Enrich — Fallback Provider\n\nGET https://fallback-enrich.example.com/v1/person — retries 3× with backoff on failure.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"d0b0e85e-383c-dec2-0976-d0cfb9ab9e09","name":"Note: Enrich — Fallback Provider"},{"parameters":{"content":"### Merge Enrichment Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Score Enriched Records","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"c0847506-bcac-caa9-2a99-04c2c713c8ee","name":"Note: Merge Enrichment Paths"},{"parameters":{"content":"### Score Enriched Records\n\nCustom JavaScript: Score each contact 0-100 from simple heuristics\n\nNext: Upsert into HubSpot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"23fd3f55-d0e1-801e-cddd-49e1873b4921","name":"Note: Score Enriched Records"},{"parameters":{"content":"### Upsert into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Hot Lead? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"f2a34390-55a4-1752-9334-c4fd53f040f5","name":"Note: Upsert into HubSpot"},{"parameters":{"content":"### Hot Lead?\n\nTwo-way gate on `={{ $json.score >= 80 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Ping Owner Immediately · ②→ Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"5346f4d2-32d3-74b4-2b18-fee6aa9c6e0d","name":"Note: Hot Lead?"},{"parameters":{"content":"### Ping Owner Immediately\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,280],"id":"b29a9eb5-9248-aeba-1d36-3705cba55c58","name":"Note: Ping Owner Immediately"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"fe696d55-5c63-2a4b-5451-46d3684cd62a","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"73c8af6a-4164-8f3a-564f-639659467682","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"bc2faba3-4f93-b8d5-d600-7ed014f5932f","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Twilio","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"4c3edc33-8e7c-db6e-0a4f-6ba599afb209","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Twilio SID + token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"fe2d3406-db4a-c0e8-d1c5-fccac62afd24","name":"Note: Escalate Failure to Twilio"},{"parameters":{"content":"# Route demo requests with HubSpot and Twilio\n\n**Pattern:** Lead Capture & Routing · **Level:** Advanced · **Trigger:** Form\n\n## What it does\nRoute demo requests with HubSpot and Twilio. It starts from a hosted form submission.\n\n## Why it exists\nManual enrichment is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Contact Form Submission → Stamp & Shape Contact → Payload Valid? → Remove Duplicate Contacts → Enrich — Primary Provider → Primary Hit? → Merge Enrichment Paths → …\n\n## Use it for\n- Teams that want to lead capture & routing without manual effort\n- Anyone automating enrichment in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Scales without extra headcount\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: API key / bearer for the target API; HubSpot private-app token; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"00afa1d3-b59b-fdb0-9629-5d3f15f43176","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"d6c71a6d-c659-7a91-e3c0-2a1f83c89731","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"3f5ed01a-3f25-2d06-1450-d5156e12629b","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your enrichment process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"7a35f9ab-e4b7-76b9-0a38-832d8042d55a","name":"🛠 Customize me"}],"connections":{"New Contact Form Submission":{"main":[[{"node":"Stamp & Shape Contact","type":"main","index":0}]]},"Stamp & Shape Contact":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Remove Duplicate Contacts","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Remove Duplicate Contacts":{"main":[[{"node":"Enrich — Primary Provider","type":"main","index":0}]]},"Enrich — Primary Provider":{"main":[[{"node":"Primary Hit?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Primary Hit?":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":0}],[{"node":"Enrich — Fallback Provider","type":"main","index":0}]]},"Enrich — Fallback Provider":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Enrichment Paths":{"main":[[{"node":"Score Enriched Records","type":"main","index":0}]]},"Score Enriched Records":{"main":[[{"node":"Upsert into HubSpot","type":"main","index":0}]]},"Upsert into HubSpot":{"main":[[{"node":"Hot Lead?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hot Lead?":{"main":[[{"node":"Ping Owner Immediately","type":"main","index":0}],[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Twilio","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Twilio","type":"main","index":0}]]},"Ping Owner Immediately":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Twilio":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"de3c228c-8391-44a4-bf3c-3f005079bbd1","id":"FDX08062"}