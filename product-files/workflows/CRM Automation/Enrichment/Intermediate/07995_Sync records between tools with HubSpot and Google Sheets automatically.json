{"name":"Sync records between tools with HubSpot and Google Sheets automatically","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[1],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"035b7f70-4b38-49a2-aa74-481919c34d35","name":"Weekly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"09d119e2-9d69-44a0-a654-9699146bac0d","name":"contactId","value":"={{ $json.body?.contactId || $json.body?.id }}","type":"string"},{"id":"3d86a407-0ec0-4928-a1e9-c402f1b27110","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"f721c89c-9128-4113-8781-3efda5686803","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"e3db4ef3-5a37-4fc5-8c03-c76f75e9cb34","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"130b484c-878b-4bf9-a7d2-db010a9efa2c","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"38f6a901-084e-4f2d-8bc7-8a580c90db62","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b748de28-63a2-45ca-bbb5-4fbc035d1eac","leftValue":"={{ $json.kind }}","rightValue":"deleted","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"deleted"}]},"options":{"fallbackOutput":"extra"}},"typ