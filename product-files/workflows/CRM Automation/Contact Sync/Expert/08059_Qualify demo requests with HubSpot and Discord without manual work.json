atus","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[2970,400],"id":"f4f4d5b2-165b-4b7f-ae36-ce78301dacbd","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"dealStage","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3294,400],"id":"601ef28e-ff01-419b-ba00-523eed15f02f","name":"Sort Contacts Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"0900ffb7-cfb5-42c2-91a0-9c79c53ac0ac","name":"pipeline","value":"Contact Sync","type":"string"},{"id":"b65096eb-08b9-499b-9afc-c28e4f8fffc8","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"b78ad6da-1bb7-4d57-8a64-96968c72107f","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"7112c105-1ff3-4407-90e7-d586c8545c6e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"2333aa3e-a391-407e-a2ed-2bb7c5db2bf5","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"59fdf6b4-f39e-4e0c-89e8-0618591c2fe4","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,400],"id":"e3b12217-007a-4705-98aa-f8c5eed0a9bd","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[4266,400],"id":"833f499b-5ebe-4d0d-9ec4-68f79f0252af","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=✅ Qualify demo requests with HubSpot and Discord without manual work — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[4590,400],"id":"7b47160a-743e-466e-8245-224e67fe9032","name":"Send Summary to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"076ccc37-42ef-4c7c-840c-9d1ff2bf0d7e","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"8d8dc677-e333-473d-b037-b74b73ea8248","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ee6bff6d-9dfc-4dcb-a1d8-1d709e40f38e","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,1420],"id":"35083d2c-cca0-473f-84c7-9de37f4270d0","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,1420],"id":"a41ced72-fc42-496f-a0c4-cdf466301f1c","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Contact Form Submission\n\nServes an n8n-hosted form (Email, Company, Dealstage). Each submission becomes one execution.\n\nNext: Keep Valid Contacts","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ccb4400e-2f34-9b3a-7db2-44b1ca091894","name":"Note: New Contact Form Submission"},{"parameters":{"content":"### Keep Valid Contacts\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Segment Audience","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"5e56afab-e826-687c-b287-1cf2df5316e6","name":"Note: Keep Valid Contacts"},{"parameters":{"content":"### Segment Audience\n\nTwo-way gate on `={{ ($json.score ?? 50) >= 50 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 1 — Welcome (Discord) · ②→ Tag for Slow Nurture","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"d351a9c8-4902-e651-65c6-c935fbe03490","name":"Note: Segment Audience"},{"parameters":{"content":"### Step 1 — Welcome (Discord)\n\ndiscord — `action` operation against the connected account.\n\nPorts: ①→ Wait Before Step 2 · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,280],"id":"afbc7e4d-3c4e-513b-c37d-e3720c478ae8","name":"Note: Step 1 — Welcome (Discord)"},{"parameters":{"content":"### Tag for Slow Nurture\n\nhubspot — `contact` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,880],"id":"17f84483-9419-c126-91c4-1a250f408a9e","name":"Note: Tag for Slow Nurture"},{"parameters":{"content":"### Wait Before Step 2\n\nPauses 2 days — spacing calls to respect rate limits.\n\nNext: Converted Already?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"00e9680e-0fa0-19da-9d88-5b56ca5b22e9","name":"Note: Wait Before Step 2"},{"parameters":{"content":"### Converted Already?\n\nTwo-way gate on `={{ $json.status }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 2 — Value Nudge (Discord) · ②→ Mark Converted — Stop Drip","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"8aa813a2-f538-1b48-b4d7-ebe6b6c323d0","name":"Note: Converted Already?"},{"parameters":{"content":"### Step 2 — Value Nudge (Discord)\n\ndiscord — `action` operation against the connected account.\n\nPorts: ①→ Update Drip Status · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,280],"id":"3e17a505-ea11-f9fd-f755-a1de23e9fea6","name":"Note: Step 2 — Value Nudge (Discord)"},{"parameters":{"content":"### Mark Converted — Stop Drip\n\nhubspot — `contact` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,880],"id":"2a10b89c-11a4-2a77-8c27-9cd30ce20211","name":"Note: Mark Converted — Stop Drip"},{"parameters":{"content":"### Update Drip Status\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Cap Batch Volume · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"13e772d4-2758-1738-4369-ca9d58dcc65c","name":"Note: Update Drip Status"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Sort Contacts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"13658f7e-5ccf-dcc8-2978-1a12843f8f68","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Sort Contacts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"c636a345-4752-2648-0a3d-689fc4a9e993","name":"Note: Sort Contacts Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"fa1ff3d7-aeb9-6fd1-a474-768254f5ad3b","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"6da41848-0f6d-2d0f-e108-679928036552","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Discord · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"abcfb248-fe92-3118-f5a0-0ce56b84c9b0","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Discord\n\ndiscord — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"14b7ff65-cf8d-e1c4-76b6-adb68544d400","name":"Note: Send Summary to Discord"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"38277c21-3fe8-d25f-6f13-1866e4ff482c","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,1540],"id":"a9bbc226-1058-3ce7-733d-4e8a2fde1ad9","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Qualify demo requests with HubSpot and Discord without manual work\n\n**Pattern:** Lead Capture & Routing · **Level:** Advanced · **Trigger:** Form\n\n## What it does\nQualify demo requests with HubSpot and Discord without manual work. It starts from a hosted form submission.\n\n## Why it exists\nManual contact sync is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Contact Form Submission → Keep Valid Contacts → Segment Audience → Step 1 — Welcome (Discord) → Wait Before Step 2 → Converted Already? → Step 2 — Value Nudge (Discord) → …\n\n## Use it for\n- Teams that want to lead capture & routing without manual effort\n- Anyone automating contact sync in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Runs 24/7 in the background\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Discord webhook URL; HubSpot private-app token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"16dd0fc9-f07a-a9e6-d07c-8d823041d83b","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"714419b3-8bdc-8874-5e17-7cdaaa37cd0d","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"6877b60b-dac0-af16-f733-604568c0b87d","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your contact sync process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"bdfc0519-b2f5-e7f9-144f-92a40ef12ccf","name":"🛠 Customize me"}],"connections":{"New Contact Form Submission":{"main":[[{"node":"Keep Valid Contacts","type":"main","index":0}]]},"Keep Valid Contacts":{"main":[[{"node":"Segment Audience","type":"main","index":0}]]},"Segment Audience":{"main":[[{"node":"Step 1 — Welcome (Discord)","type":"main","index":0}],[{"node":"Tag for Slow Nurture","type":"main","index":0}]]},"Step 1 — Welcome (Discord)":{"main":[[{"node":"Wait Before Step 2","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Wait Before Step 2":{"main":[[{"node":"Converted Already?","type":"main","index":0}]]},"Converted Already?":{"main":[[{"node":"Step 2 — Value Nudge (Discord)","type":"main","index":0}],[{"node":"Mark Converted — Stop Drip","type":"main","index":0}]]},"Step 2 — Value Nudge (Discord)":{"main":[[{"node":"Update Drip Status","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Update Drip Status":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Sort Contacts Newest First","type":"main","index":0}]]},"Sort Contacts Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Discord","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Tag for Slow Nurture":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Mark Converted — Stop Drip":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Discord":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"ee943ee8-d0f9-455c-ba03-f4c2ad4d6dd1","id":"FDX08059"}