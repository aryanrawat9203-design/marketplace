{"name":"Replicate contacts across systems with HubSpot and Airtable automatically","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":1}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"6f5d8b0d-a8ce-43c2-8fae-e90e5bc5d956","name":"Hourly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"07d860df-e464-46ab-9a35-fc0533f6096e","name":"contactId","value":"={{ $json.body?.contactId || $json.body?.id }}","type":"string"},{"id":"261b3242-80d1-49a8-afb9-af197ad9b572","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"6fdf1912-26a8-49d1-85ee-615b2b3b63bb","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"97ea6fce-782f-4f72-b7cb-e0142fbf6b51","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fdfb271c-d646-4ad5-966c-0a82053decb0","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"3587155e-2fe2-4835-8181-fb40e1d37c89","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"105f804b-f8a0-4527-8e08-824720338499","leftValue":"={{ $json.kind }}","rightValue":"deleted","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"deleted"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-bas