{"name":"Qualify inbound leads with HubSpot and Telegram without manual work","nodes":[{"parameters":{"formTitle":"Qualify inbound leads with HubSpot and Telegram without manu","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Dealstage","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"ca0a6619-18d7-49ca-adf3-0b5e0af49a70","name":"New Contact Form Submission","webhookId":"c12946e2-0b1c-4800-bec1-bcd8e7f8ed0b"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b8fae9f4-b3ee-4949-a55b-446c4f8a2ca8","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"55a159d0-37ff-4bd7-8c07-3cee9407cc97","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'email' on incoming contact."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"5e7e31a6-d9ff-4988-8267-fc5087f40835","name":"Abort — Malformed Input"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b26b437a-8cd8-4a3e-9bf0-ae1b35d61921","leftValue":"={{ ($json.score ?? 50) >= 50 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"55a310ee-dca3-4feb-95bd-41aae1f6dc00","name":"Segment Audience"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=Hi {{ $json.name || 'there' }}, here's how to get started…","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"