"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3294,400],"id":"b100de54-e125-4ea7-b6a4-4eab1f1df8ab","name":"Score Enriched Records"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[3618,400],"id":"1ca10606-d3f3-466d-afef-afee0aaf7157","name":"Upsert into HubSpot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"5af19e1a-d040-4da8-91ed-d82b95577034","leftValue":"={{ $json.score >= 80 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[3942,400],"id":"25119cee-decb-4a5c-9025-84129a9f7e8d","name":"Hot Lead?"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🔥 Hot {{ $json.company || $json.email }} (score {{ $json.score }}) — reach out now","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[4266,160],"id":"d005dc38-7c7b-4664-92da-5934769cb410","name":"Ping Owner Immediately","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"323e7201-1964-486c-b03b-87564332e684","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"4ebc45ae-c307-4913-a041-23b861a1df84","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"5dd1e640-64ba-4632-b242-907c33b108d9","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"6b672b09-64c8-4494-b4eb-ca63ec166aeb","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[4914,400],"id":"931c972f-d34e-4854-a4ca-f92898691bb9","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Route demo requests with HubSpot and Twilio in real time — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5238,400],"id":"7800adcf-9d95-40c5-ac5e-bd03e1b010fd","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a665c26a-e284-4e6f-a5e1-2dd54b36085b","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ad6d812a-b59d-4b3d-9f5f-e0295cbe3fb4","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e5376ed8-ce9f-4227-b4a1-4691139ccfd3","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,1420],"id":"4dec4691-976d-4692-a58e-a1c34fa32b92","name":"Capture Failure Context"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[4914,1420],"id":"147953b7-85c1-476b-ae9c-ca84dfc2bb12","name":"Escalate Failure to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Contact Form Submission\n\nServes an n8n-hosted form (Email, Company, Dealstage). Each submission becomes one execution.\n\nNext: Stamp & Shape Contact","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"e23003ac-1071-0a22-a4f0-f3c7c741ee13","name":"Note: New Contact Form Submission"},{"parameters":{"content":"### Stamp & Shape Contact\n\nShapes the item: writes `contactId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"527d1bd9-0fe1-3b13-a7bb-79a4978132fa","name":"Note: Stamp & Shape Contact"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.contactId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Remove Duplicate Contacts · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"9bf257ad-89cc-ed5d-c61c-a3b35a9add19","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nhubspot — `contact` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"494600c3-ca6a-7c54-ebf9-ed9d31bb7cb5","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Remove Duplicate Contacts\n\nDrops duplicates within this run (compared on `contactId`).\n\nNext: Enrich — Primary Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"30c6f61c-3ea8-f01d-0da7-6dedf4d4fd75","name":"Note: Remove Duplicate Contacts"},{"parameters":{"content":"### Enrich — Primary Provider\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Primary Hit? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"6d03c1a5-53fd-d1ae-8e29-7afd954338a7","name":"Note: Enrich — Primary Provider"},{"parameters":{"content":"### Primary Hit?\n\nTwo-way gate on `={{ $json.company || $json.name }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Enrich — Fallback Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"0e7f415f-c1b2-8e78-935e-ab0c2661a68e","name":"Note: Primary Hit?"},{"parameters":{"content":"### Enrich — Fallback Provider\n\nGET https://fallback-enrich.example.com/v1/person — retries 3× with backoff on failure.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"644384f0-74d4-0c6b-8a75-001e97c85e90","name":"Note: Enrich — Fallback Provider"},{"parameters":{"content":"### Merge Enrichment Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Score Enriched Records","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"f5504602-97eb-78ff-34c9-e2119ec5359c","name":"Note: Merge Enrichment Paths"},{"parameters":{"content":"### Score Enriched Records\n\nCustom JavaScript: Score each contact 0-100 from simple heuristics\n\nNext: Upsert into HubSpot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"cbc94f32-9202-d52e-9de5-80db93e863bf","name":"Note: Score Enriched Records"},{"parameters":{"content":"### Upsert into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Hot Lead? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"b98814aa-7cd8-e39d-0f63-2c1a9590c4a5","name":"Note: Upsert into HubSpot"},{"parameters":{"content":"### Hot Lead?\n\nTwo-way gate on `={{ $json.score >= 80 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Ping Owner Immediately · ②→ Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"041e058c-d3a6-396e-88f6-d8c8f4c3b5d7","name":"Note: Hot Lead?"},{"parameters":{"content":"### Ping Owner Immediately\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,280],"id":"7e3ce506-e740-5ff7-acee-b6a537e763d5","name":"Note: Ping Owner Immediately"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"7d2884df-5481-570e-3e98-914147df4969","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"260fb8e7-3d12-6d70-eac6-b2c33a4ff106","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"69a033e5-291c-8f08-8cd6-44e28983761a","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Twilio","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"85f2587b-b3e3-43cb-e81b-002f919a8668","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Twilio SID + token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"ea0bd4d7-4b54-88ee-850e-f8fd5f1a04c8","name":"Note: Escalate Failure to Twilio"},{"parameters":{"content":"# Route demo requests with HubSpot and Twilio in real time\n\n**Pattern:** Lead Capture & Routing · **Level:** Advanced · **Trigger:** Form\n\n## What it does\nRoute demo requests with HubSpot and Twilio in real time. It starts from a hosted form submission.\n\n## Why it exists\nManual contact sync is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Contact Form Submission → Stamp & Shape Contact → Payload Valid? → Remove Duplicate Contacts → Enrich — Primary Provider → Primary Hit? → Merge Enrichment Paths → …\n\n## Use it for\n- Teams that want to lead capture & routing without manual effort\n- Anyone automating contact sync in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Responds in seconds\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; HubSpot private-app token; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"e0928b60-1f59-0e4c-f481-f0f83debcabb","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"8c054b3e-ccc1-46f2-aaf8-65de05b53c0a","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"0461cf2c-613e-e789-1efe-7e27ad1a9ed2","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your contact sync process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"4e1fc683-22c4-8b0c-621f-946ba86a07d8","name":"🛠 Customize me"}],"connections":{"New Contact Form Submission":{"main":[[{"node":"Stamp & Shape Contact","type":"main","index":0}]]},"Stamp & Shape Contact":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Vali