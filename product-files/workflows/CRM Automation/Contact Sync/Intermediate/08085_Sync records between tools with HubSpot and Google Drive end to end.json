{
  "name": "Sync records between tools with HubSpot and Google Drive end to end",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 15
            }
          ]
        }
      },
      "id": "6fd8b1b6-b661-4587-951c-1159e819623c",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "9e9e795e-10de-4bfe-8834-2abc7892f047",
              "name": "receivedAt",
