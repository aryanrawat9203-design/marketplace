      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO contacts (contactId, email, company, updated_at)\nVALUES ($1, $2, $3, NOW())\nON CONFLICT (contactId) DO UPDATE SET updated_at = NOW();",
        "options": {
          "queryReplacement": "={{ [ $json.contactId, $json.email, $json.company ] }}"
