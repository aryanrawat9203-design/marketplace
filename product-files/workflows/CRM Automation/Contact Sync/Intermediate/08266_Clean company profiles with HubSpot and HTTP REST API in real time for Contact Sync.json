":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7506,400],"id":"ce72d367-375b-4b4c-9fea-6cf7660bdb44","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"dealStage","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7830,400],"id":"6b5355cb-3482-47f6-9001-6e73876440d0","name":"Sort Contacts Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"a3a2ff30-0bcf-445d-a419-796fabe137ee","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"fc8f2af9-66b2-401b-862c-21613d643a42","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"67aee631-98a1-4b65-9b91-4f6f3b849114","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"a9c3a238-d78e-4469-b452-dfd51ec39d1b","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Contact Database"},"title":"={{ $json.email || $json.contactId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8478,400],"id":"ba99c282-6cdd-4e22-86b3-42ac765d9b74","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Clean company profiles with HubSpot and HTTP / REST API in real time f — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8802,400],"id":"78900273-885c-4538-9da0-d8150c78a71d","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b2e7f8a2