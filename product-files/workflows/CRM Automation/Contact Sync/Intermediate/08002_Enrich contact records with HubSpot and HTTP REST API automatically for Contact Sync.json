{"name":"Enrich contact records with HubSpot and HTTP / REST API automatically for Contact Sync","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":12}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"967c8f95-7398-47ca-a8fa-2174b7b3564b","name":"Hourly Schedule"},{"parameters":{"resource":"contact","operation":"search","filterGroupsUi":{"filterGroupsValues":[{"filtersUi":{"filterValues":[{"propertyName":"lastmodifieddate","operator":"GTE","value":"={{ $now.minus({days: 1}).toMillis() }}"}]}}]},"authentication":"appToken","additionalFields":{}},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[54,400],"id":"4b2f0e6e-9410-4463-b49b-df95aff816a6","name":"Read Pending Queue (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"8e996a12-b027-4c39-a120-f5ef19fb34c9","name":"contactId","value":"={{ $json.contactId || $json.id || $execution.id }}","type":"string"},{"id":"c41ecf7a-2b2d-4e76-9a5a-42ab781bb1d8","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"71e299ae-a089-4c43-b610-ebbd4acf624d","name":"Stamp & Shape Contact"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7c154788-9ec0-4e97-91dd-7681cbbade33","leftValue":"={{ $json.contactId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[702,400],"id":"85b2a8a9-252d-4d3a-b486-bc25f0ed2e91","name":"Payload Valid?"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[702,910],"id":"e3657fa8-1e4d-4a26-a