{"name":"Augment contact records with HubSpot and HTTP / REST API hands-free for Multi-Tool Agent (01842)","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":12}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"2ed34c78-a367-430c-b102-edac92338584","name":"Hourly Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a6d80b2a-d005-49d4-809e-3cec74f61fbe","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"c37961d4-8ed1-4d80-86ed-dc3e1635b222","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'query' on incoming request."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"614225aa-e610-448c-ab21-fd35547d87c5","name":"Abort — Malformed Input"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"requestId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"4ef71ce0-4d50-4221-974f-010fe2e47936","name":"Remove Duplicate Requests"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,400],"id":"adc047b5-bbbf-4c1d-9444-d25cf1ffec29","name":"Enrich — Primary Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6448e9d0-cebd-40b1-9a9b-065f1fbabf49","leftValue":"={{ $json.company || $json.name }}","rightValue":"