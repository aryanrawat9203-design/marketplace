workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4576,1420],"id":"a7cde515-be21-4c1c-b33d-c084e543a42b","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4900,1420],"id":"45ce744b-7d5a-4f11-8db8-461f85b17f9b","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5224,1420],"id":"b3489f2f-1faf-4193-9bc8-e319dadcec1e","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### When Chat Message Received\n\nOpens a hosted chat session; every user message starts an execution with `chatInput` + `sessionId`.\n\nNext: Stamp & Shape Request","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"cf5f2cf6-09b4-0858-ca8e-9bb7ee373929","name":"Note: When Chat Message Received"},{"parameters":{"content":"### Stamp & Shape Request\n\nShapes the item: writes `requestId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"a9cfa6c6-d2a0-f7c7-bb8b-a4aeed534215","name":"Note: Stamp & Shape Request"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.requestId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Answer from Knowledge Base · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"e6afcb77-3737-0834-eed1-5e165d959260","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"83706b74-2a43-8975-be27-427fe00a86fb","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Answer from Knowledge Base\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Grounded Answer Found? · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"bb375165-b876-8d11-c41c-0d04eeb8472a","name":"Note: Answer from Knowledge Base"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Answer from Knowledge Base** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"2aff2208-3d3d-92fd-2b24-781ea322651f","name":"Note: Groq Chat Model"},{"parameters":{"content":"### Knowledge Base Retriever\n\nExposes the vector index to the agent as a semantic-search tool.\n\nFeeds **Answer from Knowledge Base** as `tool`\n\n🔑 Supabase URL + service key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[939,1510],"id":"c08e8df4-e786-30a6-4387-97f4a84e5d6f","name":"Note: Knowledge Base Retriever"},{"parameters":{"content":"### Query Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Knowledge Base Retriever** as `embedding`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[993,2020],"id":"00c24955-077f-c5f0-fd0d-d80c751f958b","name":"Note: Query Embeddings"},{"parameters":{"content":"### Rerank Retrieved Chunks\n\nRe-scores retrieved chunks so only the most relevant reach the model.\n\nFeeds **Knowledge Base Retriever** as `reranker`\n\n🔑 Cohere API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1276,2020],"id":"3fa0586c-4867-4336-e934-46339f76722d","name":"Note: Rerank Retrieved Chunks"},{"parameters":{"content":"### Grounded Answer Found?\n\nTwo-way gate on `={{ !($json.output || '').includes('needsHuman') }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Deliver Answer via Slack · ②→ Log Knowledge Gap","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1600,520],"id":"9a632dc0-13ef-e089-880e-e63015734f68","name":"Note: Grounded Answer Found?"},{"parameters":{"content":"### Deliver Answer via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1924,280],"id":"9f010b21-1182-c5fe-6940-c74df4792c99","name":"Note: Deliver Answer via Slack"},{"parameters":{"content":"### Log Knowledge Gap\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Flag Gap to KB Owners · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2248,880],"id":"f6aabe44-7267-8614-e853-baf39c16fafa","name":"Note: Log Knowledge Gap"},{"parameters":{"content":"### Flag Gap to KB Owners\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2896,880],"id":"efdccd2c-7833-eda9-0da6-4d51bd64c0aa","name":"Note: Flag Gap to KB Owners"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per request (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3868,520],"id":"424cd27e-add3-823b-36c0-012542bb2847","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4192,520],"id":"3e392db6-b141-7cfe-34a4-009b2f368d4a","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4516,520],"id":"e693d145-9ba2-1cb9-a8f1-c30fdb8c8706","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4840,520],"id":"a0c35c86-6eb9-8f92-9902-6a991b740a89","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5164,520],"id":"964a7f1d-f740-57a0-0d04-cec3d501fb1d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4516,1540],"id":"712d64ca-ea53-617a-306e-f2b2d334aa9f","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4840,1540],"id":"418e76ec-f5ad-3e3a-d8b8-9462293e81ab","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5164,1540],"id":"a85b2e54-f493-7f01-fd05-41d798262244","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Handle chat messages automatically\n\n**Pattern:** Chatbot Responder · **Level:** Production · **Trigger:** Chat\n\n## What it does\nHandle chat messages automatically. It responds live to chat messages.\n\n## Why it exists\nManual multi-tool agent is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWhen Chat Message Received → Stamp & Shape Request → Payload Valid? → Answer from Knowledge Base → Grounded Answer Found? → Deliver Answer via Slack → Fingerprint for Idempotency → …\n\n## Use it for\n- Teams that want to chatbot responder without manual effort\n- Anyone automating multi-tool agent in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Keeps your systems in sync\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Cohere API key; Google OAuth2 / service account; Groq API key; OpenAI API key; Slack OAuth2; Supabase URL + service key.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"f5c16b35-25a1-e89d-dec6-a77ab7580c8f","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"931b2c35-b533-19ee-6685-71987a80bcc8","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"25776eef-e529-d71b-1cf5-ef64e299c050","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"371a4c30-fe72-a417-a604-16fe906a0175","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your multi-tool agent process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"3f2181ad-5f99-2d3f-cf80-14e75b07e4a4","name":"🛠 Customize me"}],"connections":{"When Chat Message Received":{"main":[[{"node":"Stamp & Shape Request","type":"main","index":0}]]},"Stamp & Shape Request":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Answer from Knowledge Base","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Answer from Knowledge Base","type":"ai_languageModel","index":0}]]},"Knowledge Base Retriever":{"ai_tool":[[{"node":"Answer from Knowledge Base","type":"ai_tool","index":0}]]},"Query Embeddings":{"ai_embedding":[[{"node":"Knowledge Base Retriever","type":"ai_embedding","index":0}]]},"Rerank Retrieved Chunks":{"ai_reranker":[[{"node":"Knowledge Base Retriever","type":"ai_reranker","index":0}]]},"Answer from Knowledge Base":{"main":[[{"node":"Grounded Answer Found?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Grounded Answer Found?":{"main":[[{"node":"Deliver Answer via Slack","type":"main","index":0}],[{"node":"Log Knowledge Gap","type":"main","index":0}]]},"Log Knowledge Gap":{"main":[[{"node":"Flag Gap to KB Owners","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Deliver Answer via Slack":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"d7758b1b-6d48-44be-b917-b4ad347121d5","id":"FDX00036"}