Data","typeVersion":1,"position":[6453,400],"id":"26094933-79a9-4ca9-bce0-7d811b0328f2","name":"Save Execution Metadata"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[6777,400],"id":"d39ae61a-68d2-4fd1-bd3b-a6788b00d9a8","name":"Cap Batch Volume"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"requestId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7101,400],"id":"171af67a-be6b-41ba-be45-393d8ac6965a","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"969b23ad-7731-4d65-8b0b-a4dbf78f6003","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7425,400],"id":"fa7e4bd2-7d67-4d9b-aad4-b20373715911","name":"Guard Non-Empty query"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"priority","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7749,400],"id":"657dfe27-c79f-4bd6-b359-08a0e88ed6c0","name":"Sort Requests Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"271fa7ef-a0c1-41a2-85f4-811722b6b075","name":"pipeline","value":"Multi-Tool Agent","type":"string"},{"id":"3eaeff7b-cf98-4144-a9da-03ae4beb4fc0","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8073,400],"id":"9548d75f-34fd-4501-a03d-27720e001bb4","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"79b0b6ee-225f-4d65-8b3d-729b808d91d7","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"3cc3a842-59fc-49f1-9e26-bccb1c6025ad","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"d3b0719f-c6f5-46d1-8108-4e3132e1752d","name":"status","value":"completed","type":"stri