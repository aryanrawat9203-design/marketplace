{"name":"Summarize long emails with MySQL and Outlook automatically","nodes":[{"parameters":{"httpMethod":"POST","path":"wf01739-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"18f6a4d9-eb0d-4697-b37c-22a1cae67c59","name":"Receive Inbound Webhook","webhookId":"8bcf55e2-fc71-407b-86e4-ff44a33d9fae"},{"parameters":{"assignments":{"assignments":[{"id":"cd897af3-0000-4600-9194-f7dcb089fc0a","name":"content","value":"={{ $json.body?.text || $json.content || JSON.stringify($json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"d281d39b-532d-4b97-84f4-5395ce7c9a57","name":"Collect Raw Text"},{"parameters":{"text":"={{ $json.text || $json.content }}","attributes":{"attributes":[{"name":"requestId","description":"The requestId of this request.","required":true},{"name":"query","description":"The query of this request.","required":true},{"name":"context","description":"The context of this request.","required":false}]},"options":{"systemPromptTemplate":"You are a precise extraction engine. Only extract values present in the text."}},"type":"@n8n/n8n-nodes-langchain.informationExtractor","typeVersion":1,"position":[378,400],"id":"fca4f319-8850-426a-811e-8f91bf1e3377","name":"Extract Structured Fields","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[621,970],"id":"67d579a3-fcf1-4a0f-8160-96b6c7eb3bcd","name":"OpenRouter Chat Model"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0e8788ad-a1ef-4783-ad76-b1001101cb81","leftValue":"={{ $json.output?.requestId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[945,400],"id":"204c0d0e-3e83-4fd3-8389-146ff0709