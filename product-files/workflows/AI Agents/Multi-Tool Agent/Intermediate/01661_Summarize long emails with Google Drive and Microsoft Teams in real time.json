ki"},{"parameters":{"toolDescription":"Fetch live request data from the internal REST API by id or query.","url":"https://api.example.com/v1/requests","options":{}},"type":"@n8n/n8n-nodes-langchain.toolHttpRequest","typeVersion":1.1,"position":[1309,1390],"id":"587b1ff3-953c-43fc-b2be-78517c1ab420","name":"Lookup API Data"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $json.sessionId || $execution.id }}","contextWindowLength":12},"type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.3,"position":[1066,970],"id":"3e692a07-f751-4fb1-86f9-d5aea58c9d01","name":"Conversation Memory"},{"parameters":{"assignments":{"assignments":[{"id":"824695e0-5984-426f-8ca5-1b658eb1432d","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"f478aa33-ae2e-4152-baa6-bcb1d9552d75","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1633,400],"id":"fa960e2b-a6e0-4220-ba92-39b93845817f","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"20e532cf-e16d-4247-803b-1947ef3bf43a","leftValue":"={{ $json.confidence }}","rightValue":"high","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1957,400],"id":"679e3ee3-d0ff-4826-9041-b6af53ea9f52","name":"Confident Enough?"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2281,160],"id":"6fc70c0b-95d5-4310-9783-de497b75c61a","name":"Deliver Answer + Log to Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":