{
  "name": "Clean contact records with HubSpot and HTTP / REST API on autopilot for Multi-Tool Agent",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 18
            }
          ]
        }
      },
      "id": "42fc657b-2944-486c-93c7-6e475c26fe3d",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a18456cb-6337-425a-8d85-ae4ab51c0dca",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "1b7285ca-79e5-4d5d-b670-6cdefe848c7b",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "b5f2f3ee-5d4e-40a2-af4d-f850e2fa903a",
