{
  "name": "Clean contact records with HubSpot and HTTP / REST API with instant alerts for Multi-Tool Agent",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 18
            }
          ]
        }
      },
      "id": "7910038b-0ec6-4245-9799-6cf1dfca4438",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "d3767009-3747-4cde-a659-6855d9651968",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "8775faca-b383-43d1-9a5a-68341a9424bc",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "1cafc6db-8c63-4468-8075-07d697c3bfd9",
      "name": "Validate Input",
