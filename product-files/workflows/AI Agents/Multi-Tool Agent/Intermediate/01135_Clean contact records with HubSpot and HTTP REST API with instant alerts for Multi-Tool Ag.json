          },
          "conditions": [
            {
              "id": "fdb3af28-14f6-43c9-9638-45b3f9e85723",
              "leftValue": "={{ $json.toolCallConfidence }}",
              "rightValue": "0.7",
              "operator": {
                "type": "number",
                "operation": "gte"
