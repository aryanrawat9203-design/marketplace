{"name":"Power an assistant workflow with Telegram","nodes":[{"parameters":{"updates":["message"],"additionalFields":{}},"type":"n8n-nodes-base.telegramTrigger","typeVersion":1.2,"position":[-270,400],"id":"f341031d-5afa-468d-a401-8e22e4e37a26","name":"On Telegram Event","webhookId":"88c6bafa-70c8-4106-b7ef-a366a7fe293b"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"34c45dac-c747-4272-b550-3cdb12f631b7","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"2e2b01f9-ca41-4ed2-8187-399834ee3434","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'query' on incoming request."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"daca9596-a15c-4d83-8df0-1cbdfa3bb24b","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"60bee229-e85e-4048-b6bf-f0732490e0ad","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"e39e16e9-c965-4304-9f4b-07bdcc0453ab","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"b7814d4b-12b7-4346-8806-c903b369098d","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a multi-tool agent pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"9e47c8bc-4432-40d6-94fd-1aaf2a3a59