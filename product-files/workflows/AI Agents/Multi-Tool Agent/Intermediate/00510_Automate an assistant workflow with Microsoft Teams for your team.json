{"name":"Automate an assistant workflow with Microsoft Teams for your team","nodes":[{"parameters":{"httpMethod":"POST","path":"wf00510-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"89729be8-2630-4616-9e97-6441e3edc829","name":"Receive Inbound Webhook","webhookId":"15debd7e-69fa-49e7-875a-d0eb4d9c8cc9"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b1c3722b-4aa7-42f0-ae76-ab8310d36b55","leftValue":"={{ $json.requestId || $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"a987ab75-21e8-4300-abd6-984d2d9ba5d1","name":"Keep Valid Requests"},{"parameters":{"assignments":{"assignments":[{"id":"30719806-7a86-446f-968c-8c2031c758d1","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"88b173d8-1c6b-483e-b170-f25e2548e255","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"f4c5669d-8d15-41f4-ae7d-9b09dcd8acb6","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a multi-tool agent pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"faf9ea23-f619-41c2-bad9-c2668ccaa855","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[9