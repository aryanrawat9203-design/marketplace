{"name":"Handle user questions and log the results for Multi-Tool Agent","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"13ddf1f6-9674-4865-878c-e93f79e74cfd","name":"When Chat Message Received","webhookId":"67ea26ef-e6a3-480a-b8f8-2a6c67729546"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b61e66e5-dcf2-4827-a6fb-9728b1438d80","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"1b6afc0a-c18c-4d39-a095-895be38de423","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'query' on incoming request."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"bca07f41-7fff-4b3f-8b90-702fb5fb830f","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"2de7ab0f-e258-49f0-82be-738d7a6aa467","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"8c41c900-3eb2-4ebe-9c6e-b9eb045156d1","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"d429d0e4-f703-471a-afc2-212379ff77d4","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a multi-tool agent pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"fe8bbe59-8351-4