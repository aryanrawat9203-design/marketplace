{"name":"Automate an assistant workflow with Microsoft Teams automatically","nodes":[{"parameters":{"httpMethod":"POST","path":"wf00013-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"fc564fd5-9309-4270-b941-98fe2136ebbf","name":"Receive Inbound Webhook","webhookId":"fa934599-d0c0-4e04-a8fc-145b75cc81c4"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"3a717b0b-f1ad-45ac-8bf8-9e8479adbaa0","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"837bafdd-a888-4003-951f-183e887c327b","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'query' on incoming request."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"14d449dd-71f0-4af9-9c3c-97c039b9d666","name":"Abort — Malformed Input"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.query || JSON.stringify($json) }}","options":{"systemMessage":"You are a multi-tool agent specialist for the ai agents team. Use the attached tools to look up real data before answering — never invent request details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"1fd9a2d2-0d85-4f88-9a68-2e08fcad8fc7","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[621,970],"id":"7af4f3ae-0bd7-4082-9142-a12abbbcd44b","name":"OpenAI Chat Model"},{"parameters":{"toolDescription":"Fetch live request data from the internal REST API by id or query.","url":"https://api.example.com/v1/requests","options":{}},"type":"@n8n/n8n-nodes-langchain.toolHttpRequest","typeVersion":1.1,"position":[621,1390],"id":"be293935-dc7f-4bb7-a1df-bab74676761e","name":"Lookup API Data"},{"parameters":{"name":"score_helper","description":"Compute a quality score for a request record.","jsCode":"const j = JSON.parse(query);\nreturn String((j.signals || []).length * 10);"},"type":"@n8n/n8n-nodes-langchain.toolCode","typeVersion":1.3,"position":[850,1390],"id":"43bd0464-7941-47b9-aa73-e116862e4b0f","name":"Custom Logic Tool"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[1309,1390],"id":"d27430e4-75cb-429e-8958-913208982530","name":"Run Calculations"},{"parameters":{"assignments":{"assignments":[{"id":"11c22c78-8a29-41b9-8f63-c1fe743a782b","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"307de3bd-ed05-4cf8-960d-7b0ffb8fb998","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1633,400],"id":"9fc60808-2173-4e41-886c-2bc458cf74da","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"09a6f55b-d4f3-4183-915e-a70731cfb60d","leftValue":"={{ $json.confidence }}","rightValue":"high","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1957,400],"id":"674a26bf-48ac-409d-96d8-662a7efd8270","name":"Confident Enough?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2281,160],"id":"0b955089-9a1d-4fb5-87c2-cb9eee4c91d1","name":"Deliver Answer + Log to Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🙋 Low-confidence answer needs review: {{ $json.answer }}","otherOptions":{}},"type":"n8n-nodes-base.microsoftTeams","typeVersion":2,"position":[2605,760],"id":"0dc94a9c-2cc7-45c1-a04b-009525663ba8","name":"Escalate to Human Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3253,400],"id":"44826c98-c1e4-4254-8d18-791a0055781a","name":"Join Outcomes"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4225,400],"id":"f179f572-8435-4ea6-8fd1-0162deaaf60c","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4549,400],"id":"a7699fa5-b958-4fc9-ad31-4e6c74a2b2bb","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4873,400],"id":"2aa3f622-095c-4bb7-91ff-5194875a38d5","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5197,400],"id":"9fa81128-39dd-4051-8765-e8b7a6769f43","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"93fe5175-9fc0-4e2b-9bd0-9d9e98db94f6","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f94fbf44-06f8-4eb1-bdb3-3c387e38cbdb","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"34fcbe56-a9c9-4d8f-82c2-1e5d24eb5a16","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5521,400],"id":"7a2daa2a-2cf7-4722-8274-6de0eb81e333","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5845,400],"id":"c6d65d10-b1af-4a4e-8262-aa926f25dbc5","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Automate an assistant workflow with Microsoft Teams automatically — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6169,400],"id":"3f3f5f8f-656e-4668-bed8-c95671674277","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6baef366-cfce-4fcf-9732-6801a6d6c4b8","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"1704326e-3509-4430-ac7c-a60febeaee64","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"d22b1ec4-acf4-432d-b17a-1a1298d884fd","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5521,1420],"id":"1dd512ac-b8e1-483b-8f79-357460d78f7a","name":"Capture Failure Context"},{"parameters":{"resource":"chatMessage","chatId":"OPS_TEAM_CHAT_ID","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.microsoftTeams","typeVersion":2,"position":[5845,1420],"id":"ba3496f2-2407-49de-b4df-64c17405c39d","name":"Escalate Failure to Microsoft Teams","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6169,1420],"id":"da58f946-582e-444e-b9ce-996ec6e1bad6","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf00013-request`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"5b232adc-dee1-ce22-28c3-c8bce53bba3c","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.query }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Reason & Act (AI Agent) · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"eec0a7b6-19b1-19d6-4f4b-0db0a4a1158a","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"97a88ff1-4e5f-fc30-dd95-33308f504d3a","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Reason & Act (AI Agent)\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Shape Agent Output · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"02275edb-e097-7a99-4bd9-4cd9b617506f","name":"Note: Reason & Act (AI Agent)"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Reason & Act (AI Agent)** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"885259e9-b7d1-86a9-0fe7-aba4c5d3cad1","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Lookup API Data\n\nTool the agent can call to hit the REST API with parameters it chooses at runtime.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1510],"id":"c4c60ed6-130e-0b3d-33c2-da2a20d2d697","name":"Note: Lookup API Data"},{"parameters":{"content":"### Custom Logic Tool\n\nDeterministic code helper the agent can invoke for exact computation.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[790,1750],"id":"8d015f63-472a-f14c-84ce-65b885118bca","name":"Note: Custom Logic Tool"},{"parameters":{"content":"### Run Calculations\n\nMath tool — keeps arithmetic exact instead of letting the LLM guess.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1249,1510],"id":"28232157-b5c0-b4b4-e6b6-c6adb2ee06ad","name":"Note: Run Calculations"},{"parameters":{"content":"### Shape Agent Output\n\nShapes the item: writes `answer`, `confidence`. Keeps the schema explicit between stages.\n\nNext: Confident Enough?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1573,520],"id":"66c13b38-80e1-540b-3921-4580fca9e525","name":"Note: Shape Agent Output"},{"parameters":{"content":"### Confident Enough?\n\nTwo-way gate on `={{ $json.confidence }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Deliver Answer + Log to Google Sheets · ②→ Escalate to Human Queue","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1897,520],"id":"a6b39bab-17bf-df93-38f1-40ab1cab23b7","name":"Note: Confident Enough?"},{"parameters":{"content":"### Deliver Answer + Log to Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2221,280],"id":"c2e61d00-82da-8ba6-e15a-1b2245fe6135","name":"Note: Deliver Answer + Log to Google Sheets"},{"parameters":{"content":"### Escalate to Human Queue\n\nmicrosoftTeams — `action` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2545,880],"id":"02245d44-85ea-d490-ccdc-02f764dd363d","name":"Note: Escalate to Human Queue"},{"parameters":{"content":"### Join Outcomes\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3193,520],"id":"f077bf1c-891a-9318-fe70-089ede7cc61e","name":"Note: Join Outcomes"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4165,520],"id":"caee9060-465b-7b7d-b101-31470c4fec6d","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4489,520],"id":"485aaff9-f73c-cc45-be55-afc7318de1bc","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4813,520],"id":"8645d54d-4c25-b681-152e-f54946a87163","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5137,520],"id":"fed28fa4-2f0f-7e4e-95c7-c354ee1b3e86","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5461,520],"id":"14513737-0d90-0d07-4f1b-50f24ca38cef","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5785,520],"id":"d8b75271-efa2-c101-0822-61cef5dac622","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6109,520],"id":"503f5d0c-9eec-0643-773d-ff088f29a209","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Microsoft Teams","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5461,1540],"id":"d4211c88-14c4-f1c6-b8a9-4d5d8d4830ff","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Microsoft Teams\n\nmicrosoftTeams — `chatMessage` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Microsoft OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5785,1540],"id":"7000f1a2-8970-398b-b8b6-9f7fd043b260","name":"Note: Escalate Failure to Microsoft Teams"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6109,1540],"id":"904fb8c4-eb42-71be-b113-cf93e7a67fe3","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Automate an assistant workflow with Microsoft Teams automatically\n\n**Pattern:** AI Agent · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nAutomate an assistant workflow with Microsoft Teams automatically. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual multi-tool agent is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Required Fields Present? → Reason & Act (AI Agent) → Shape Agent Output → Confident Enough? → Deliver Answer + Log to Google Sheets → Join Outcomes → …\n\n## Use it for\n- Teams that want to ai agent without manual effort\n- Anyone automating multi-tool agent in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Improves response time\n- Responds in seconds\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Microsoft OAuth2; OpenAI API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"242f48ac-6fef-f745-4a76-2c90c5a1ca3d","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"ae756789-a21a-d816-f7be-6b8a5898ed58","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"3690e4ea-cf56-27a7-3f1d-a6b27edfda78","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"7c1167db-cbe2-14b0-f7c7-7bd75b84fa9c","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your multi-tool agent process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"f80be37c-29c5-1dd3-08a7-ad482903a557","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Reason & Act (AI Agent)","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Reason & Act (AI Agent)","type":"ai_languageModel","index":0}]]},"Lookup API Data":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Custom Logic Tool":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Run Calculations":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Reason & Act (AI Agent)":{"main":[[{"node":"Shape Agent Output","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Shape Agent Output":{"main":[[{"node":"Confident Enough?","type":"main","index":0}]]},"Confident Enough?":{"main":[[{"node":"Deliver Answer + Log to Google Sheets","type":"main","index":0}],[{"node":"Escalate to Human Queue","type":"main","index":0}]]},"Deliver Answer + Log to Google Sheets":{"main":[[{"node":"Join Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Escalate to Human Queue":{"main":[[{"node":"Join Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Outcomes":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture