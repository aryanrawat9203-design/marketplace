s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6358,400],"id":"6df53441-fbf2-4425-b687-daa3b3a1cb05","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6682,400],"id":"547307e4-35b6-4349-ae8b-f291a8f4b6c6","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[7006,400],"id":"289a6640-c776-481c-b3ce-d84d0e0ce9bb","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"478175fd-9fb0-4176-a1a5-040c504bc044","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b6012e18-22e7-4924-a24b-f45e994885c5","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7330,400],"id":"2d13188f-630f-4192-ac60-0f9d28cf6308","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"7a375a63-8987-407a-bdf5-02f1f9a42548","name":"pipeline","value":"Multi-Tool Agent","type":"string"},{"id":"febccfc7-56af-4438-9da6-23083b83f0a5","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7654,400],"id":"63101bf8-854f-46ed-9d4b-6c5b9e0d8653","name":"Tag Pipeline Metadata"},{"