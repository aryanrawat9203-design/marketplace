      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "30490411-f631-4915-b12e-ee5ac6bf01fe",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "14cad23f-c42a-4934-a853-3d314159831b",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "57e392c2-7b45-4679-8148-1ed5bc971a0a",
      "name": "Validate Input",
