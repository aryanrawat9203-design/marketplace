{
  "name": "Clean company profiles with HubSpot and HTTP / REST API end to end for Multi-Tool Agent",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 9
            }
          ]
        }
      },
      "id": "e96d873a-0a1f-47cc-9e85-bab66fae6da0",
