{"name":"Clean contact records with HubSpot and HTTP / REST API at scale for Multi-Tool Agent","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":8,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"3a45505c-5f2f-4183-8b60-29ace641d055","name":"Daily Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"4edda494-946e-4afd-ba41-6a3273f54ad5","name":"page","value":"1","type":"number"},{"id":"046fdde4-fe55-4f40-a94f-17d05812a0fa","name":"hasMore","value":"true","type":"boolean"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"2a07566a-80b9-486a-ac2d-368137b52b19","name":"Init Cursor"},{"parameters":{"batchSize":1,"options":{"reset":false}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[378,400],"id":"12d86432-5ba6-4c04-9e88-e8209506ac63","name":"Page Loop"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/requests","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"page","value":"={{ $json.page }}"},{"name":"per_page","value":"50"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,880],"id":"6538ad35-da08-4b77-b4cc-582bdf7ef57f","name":"Fetch Page from API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"fieldToSplitOut":"data","options":{}},"type":"n8n-nodes-base.splitOut","typeVersion":1,"position":[1350,880],"id":"2f4e72ff-14a8-41a6-8c31-2f76ca8853cd","name":"Split Result Items"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming request records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    requestId: String(j.requestId ?? j.id ?? '').trim(),\n    query: typeof j.query === 'string' ? j.query.trim() : j.query ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2322,880],"id":"58743db9-55b5-4869-aca2-5b23351aaf35","name":"Normalize Page Items"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"requestId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2646,400],"id":"27b70548-6cde-4839-8867-f1458c69525c","name":"Remove Duplicate Requests"},{"parameters":{"operation":"upsert","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"AI Agents Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Requests"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["requestId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2970,400],"id":"7b847d61-7f01-4f85-9d99-4ecddd7368ef","name":"Upsert Harvest into Airtable","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"fieldsToSummarize":{"values":[{"aggregation":"count","field":"requestId"}]},"options":{}},"type":"n8n-nodes-base.summarize","typeVersion":1.1,"position":[3294,400],"id":"f252ad83-ddfb-4cc3-b2fe-d9ae3205b72f","name":"Tally Harvest Stats"},{"parameters":{"assignments":{"assignments":[{"id":"87fc321d-777c-4b75-8906-c776ace603bd","name":"pipeline","value":"Multi-Tool Agent","type":"string"},{"id":"30ac54bc-55ff-4e8b-9d3c-3ee6415fb265","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"9912409d-f8c6-4475-91cb-fc961956c2ee","name":"Tag Pipeline Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"3f6d4e69-5d34-436a-9ad8-0b5bc3dfafc3","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3942,400],"id":"8b97ae8d-3aa3-4b26-9758-ba38e713ee7d","name":"Guard Non-Empty query"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[4266,400],"id":"cd0a0779-5fb9-43f1-83cf-b4426ef5bcd2","name":"Cap Batch Volume"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"b1f9a41d-fb42-455b-9fd4-815deb60ef5a","name":"Stamp Processing Time"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"priority","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[4914,400],"id":"d966fe1a-c893-476e-af3f-69e58c66049e","name":"Sort Requests Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"2bef9237-8929-49d0-af00-452e8a9f8c0f","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e8b47e1f-df72-41ce-be06-d38b92d3a270","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"659df23b-8b66-4654-a5a1-18d10241f678","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"2ca307f5-d76d-47fb-b744-6e657f0cb630","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[5562,400],"id":"1bb2356f-43a2-4cd5-81da-e4d5261c5e66","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Clean contact records with HubSpot and HTTP / REST API at scale for Mu — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,400],"id":"c1f09a21-69c0-428b-870d-36510b58f3c2","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"40493a06-f706-4230-b5de-f5d720b09619","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"99d4ff7e-f2f8-4846-baf9-c679b11d3bcc","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"4913f70e-b5eb-46ff-b245-4e78920c9108","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,1420],"id":"cf600126-3be8-4591-96c3-a30636f12c76","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5562,1420],"id":"3cd095ea-8647-4d74-b78b-5a7f78d7c5ff","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 8:00. No input data; downstream nodes fetch what they need.\n\nNext: Init Cursor","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"e4073d0b-a3cd-76e2-3cf9-204c402f6b80","name":"Note: Daily Schedule"},{"parameters":{"content":"### Init Cursor\n\nShapes the item: writes `page`, `hasMore`. Keeps the schema explicit between stages.\n\nNext: Page Loop","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"98684984-f95f-0734-3608-9a8ae069b257","name":"Note: Init Cursor"},{"parameters":{"content":"### Page Loop\n\nLoop controller — releases 1 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Remove Duplicate Requests · ②→ Fetch Page from API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"1d5eda59-15f7-87ba-de70-701fbd1fed02","name":"Note: Page Loop"},{"parameters":{"content":"### Fetch Page from API\n\nGET https://api.example.com/v1/requests — retries 3× with backoff on failure.\n\nPorts: ①→ Split Result Items · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"2cef3f25-1e11-4592-1ed7-8c4f3599fef9","name":"Note: Fetch Page from API"},{"parameters":{"content":"### Split Result Items\n\nExplodes the `data` array into one item per element.\n\nNext: Normalize Page Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"eee5ce76-08c7-4fd4-c8c0-92824ad44e08","name":"Note: Split Result Items"},{"parameters":{"content":"### Normalize Page Items\n\nCustom JavaScript: Normalize incoming request records to a stable schema\n\nNext: Page Loop","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,1000],"id":"6ddb1687-8195-e215-0cde-a76df714748b","name":"Note: Normalize Page Items"},{"parameters":{"content":"### Remove Duplicate Requests\n\nDrops duplicates within this run (compared on `requestId`).\n\nNext: Upsert Harvest into Airtable","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"4a105900-ce73-f9a0-59e6-9e47399483d4","name":"Note: Remove Duplicate Requests"},{"parameters":{"content":"### Upsert Harvest into Airtable\n\nairtable — `upsert` operation against the connected account.\n\nPorts: ①→ Tally Harvest Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"bc4a8894-3c65-2bd9-4330-c954f1109de2","name":"Note: Upsert Harvest into Airtable"},{"parameters":{"content":"### Tally Harvest Stats\n\nGroup-by + aggregate (like a pivot table) — turns raw rows into KPI numbers.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"5c307598-8b59-1e7f-9b9b-bfc81eb07d68","name":"Note: Tally Harvest Stats"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Guard Non-Empty query","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"94b08237-126a-e6ea-06d3-9369cb441033","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Guard Non-Empty query\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"b111a713-e8c9-2850-5237-108b3f8bed40","name":"Note: Guard Non-Empty query"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"8ecd1475-300d-942b-976d-eb0d9735978e","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Sort Requests Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"5aa90a81-c461-654c-75e9-b1354cdcf904","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Sort Requests Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"70de4713-5ced-2d85-9d4a-a66204563602","name":"Note: Sort Requests Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"85b852c7-7eb4-c624-f969-edd7c807c4f8","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"c8f083d7-d339-f4b0-8335-0d53b2463fce","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"cc08ecfa-5ff7-0199-3cc3-ab1df037fff5","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"d8d6e43e-0a9d-f8b6-b624-bd2f5dcc186e","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"2a97b129-5241-3cc5-80f5-35de50e98858","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Clean contact records with HubSpot and HTTP / REST API at scale for Multi-Tool Agent\n\n**Pattern:** Data Enrichment · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nClean contact records with HubSpot and HTTP / REST API at scale for Multi-Tool Agent. It runs automatically on a schedule.\n\n## Why it exists\nManual multi-tool agent is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Init Cursor → Page Loop → Remove Duplicate Requests → Upsert Harvest into Airtable → Tally Harvest Stats → Tag Pipeline Metadata → …\n\n## Use it for\n- Teams that want to data enrichment without manual effort\n- Anyone automating multi-tool agent in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Responds in seconds\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; HubSpot private-app token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"84a9a2de-bdd8-32fe-f0e5-883cd551920a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"fdd6d36a-7631-6bde-e5d8-99532c69a00a","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"97fc8ebc-42fa-47a4-3eec-d9cdc7f89935","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"1f045757-cb4c-a21e-7737-7dba0b30885d","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your multi-tool agent process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"6a8bb777-70c1-03d7-73e3-8b9afd3c2af4","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Init Cursor","type":"main","index":0}]]},"Init Cursor":{"main":[[{"node":"Page Loop","type":"main","index":0}]]},"Page Loop":{"main":[[{"node":"Remove Duplicate Requests","type":"main","index":0}],[{"node":"Fetch Page from API","type":"main","index":0}]]},"Fetch Page from API":{"main":[[{"node":"Split Result Items","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Split Result Items":{"main":[[{"node":"Normalize Page Items","type":"main","index":0}]]},"Normalize Page Items":{"main":[[{"node":"Page Loop","type":"main","index":0}]]},"Remove Duplicate Requests":{"main":[[{"node":"Upsert Harvest into Airtable","type":"main","index":0}]]},"Upsert Harvest into Airtable":{"main":[[{"node":"Tally Harvest Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Tally Harvest Stats":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Guard Non-Empty query","type":"main","index":0}]]},"Guard Non-Empty query":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Sort Requests Newest First","type":"main","index":0}]]},"Sort Requests Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"f921702f-1710-4c84-bf70-faedbaa32854","id":"FDX00794"}