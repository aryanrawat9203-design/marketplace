{"name":"Power an AI agent task with Telegram 24/7","nodes":[{"parameters":{"updates":["message"],"additionalFields":{}},"type":"n8n-nodes-base.telegramTrigger","typeVersion":1.2,"position":[-270,400],"id":"2b58dc86-d7b6-4353-88d1-6823a7392998","name":"On Telegram Event","webhookId":"94669ff0-14b7-4a6e-bc92-bd5395f7a7bb"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4949eb51-91f2-4198-afd2-ff3a861d861c","leftValue":"={{ $json.requestId || $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"69f3ced5-68eb-49fc-85a8-c229376742e8","name":"Keep Valid Requests"},{"parameters":{"assignments":{"assignments":[{"id":"a5bb5d7f-6aec-4afa-ba79-fcc53a8dda62","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"fd2b4c94-aa6d-4ccc-b82b-d73ca2b4a063","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"673d2471-ea66-4fbc-ae53-528b290a5ba7","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a multi-tool agent pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"c30405bd-f6b7-4090-972e-f71eeb3a26b5","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[945,970],"id":"b1c8dbfc-7b82-4dbf-b