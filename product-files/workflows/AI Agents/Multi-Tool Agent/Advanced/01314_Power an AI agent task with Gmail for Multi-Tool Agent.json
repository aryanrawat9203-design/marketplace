{"name":"Power an AI agent task with Gmail for Multi-Tool Agent","nodes":[{"parameters":{"httpMethod":"POST","path":"wf01314-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"b71f0b8c-1606-4536-834b-3c280a958cb8","name":"Receive Inbound Webhook","webhookId":"03e63c6c-4c17-4fa6-ba63-ad88003f927c"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"33492245-05a2-4e2b-8928-38cd5b6a7fda","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"366615ed-5f9f-47ee-90a5-14cd21b63d93","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'query' on incoming request."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"468f3da2-9461-4549-bd27-7b7f3926a4ba","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"c6b1a47d-b3ab-4b8e-a0a4-bf6b22313e80","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"38dd2d29-0d38-475d-aec9-1e730f3ecab4","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"ce5f3903-692d-47ac-8790-8655502d3d89","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a multi-tool agent pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"d6093997-ab