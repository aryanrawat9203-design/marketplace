 for the research assistant team."},{"category":"Feedback","description":"Requests that are feedback for the research assistant team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[702,400],"id":"d290dea7-546b-4c48-9016-479ddae3e17e","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[945,970],"id":"d3d469b6-58d1-4b4d-a3ab-b696f8afec8a","name":"OpenAI Chat Model"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1269,-80],"id":"85e79e2d-7926-4434-84d1-2610d04e10db","name":"Store as Question","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1593,370],"id":"8a3f5c66-89c6-4cc8-91b5-d98851a1acf1","name":"Store as Complaint","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1917,820],"id":"647fb848-58de-4d26-a744-c3bd3e4346d1","name":"Store as Feedback","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=[Other] {{ $json.query }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2241,1270],"id":"237beef1-d82c-410b-9362-65b4d6be5f31","name":"Alert Slack — Other","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2889,400],"id":"426b0a1a-a30e-4e43-a4a5-c6e21709cd67","name":"Reunite Branches"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3861,400],"id":"ac6447d5-2dd6-4bca-b632-57c42a4f3a0f","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4185,400],"id":"415fcbec-b963-41cc-b1bd-498951ff20a2","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4509,400],"id":"183f9c64-2f97-41c4-90af-7865c317f245","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4833,400],"id":"d51c2a31-089d-44db-9a6f-5fedf89d8ee2","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"6a8255ea-7541-4c29-928d-80895a7076d5","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f2da9d27-3f4a-4729-bf37-66da6192dc4d","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"1d4f3746-3909-4c91-b02c-34cefb587fea","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,400],"id":"27c9427b-df49-4d05-9331-48eb04d63b3e","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5481,400],"id":"43bfe8ba-a244-46b6-9441-f4245f665e54","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Answer chat messages and log the results — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,400],"id":"ba363f60-13c3-4697-9b97-90895e6b0454","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"9387b5c4-5acc-4284-93a5-00941e3e3d8d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"61423dd5-e5be-4458-9101-feec8af5aa90","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"5279de74-d9de-4500-971c-a49e911a33e2","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,1420],"id":"6c73d52c-f329-4b45-8d3d-3b3f99024075","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5481,1420],"id":"e3428a9e-d772-4897-b266-2cd46d920c72","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5805,1420],"id":"ce54a7e8-fd92-4d8f-be75-05412b8147e3","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### When Chat Message Received\n\nOpens a hosted chat session; every user message starts an execution with `chatInput` + `sessionId`.\n\nNext: Stamp & Shape Request","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"60ba54b1-f470-73a5-b86d-055ef534ad8b","name":"Note: When Chat Message Received"},{"parameters":{"content":"### Stamp & Shape Request\n\nShapes the item: writes `requestId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"43a9d296-7196-5728-5fd2-c4a99a01c19e","name":"Note: Stamp & Shape Request"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.requestId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Classify with AI · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"2edd2ac7-f754-8ceb-4e8b-d6129b80383a","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"f13a37bf-1d44-f0ff-5d91-e0657e34f23c","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Classify with AI\n\nLLM classification into: Question, Complaint, Feedback (+fallback). Output port order matches this list.\n\nPorts: ①→ Store as Question · ②→ Store as Complaint, Capture Failure Context · ③→ Store as Feedback · ④→ Alert Slack — Other\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"22d46504-5a07-fadb-3f63-e236aac0f4cb","name":"Note: Classify with AI"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Classify with AI** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"431c4404-915d-aff3-2da1-e53bd463a6ae","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Store as Question\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,40],"id":"48abb19d-a2a6-f08e-249f-594402eb442a","name":"Note: Store as Question"},{"parameters":{"content":"### Store as Complaint\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,490],"id":"736d27fc-7201-e062-6667-bb3fb935dce2","name":"Note: Store as Complaint"},{"parameters":{"content":"### Store as Feedback\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,940],"id":"aedc3a86-9deb-8895-b37c-7bd8c4badf39","name":"Note: Store as Feedback"},{"parameters":{"content":"### Alert Slack — Other\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,1390],"id":"9d3c541d-429c-0916-7fef-102108a1dc0a","name":"Note: Alert Slack — Other"},{"parameters":{"content":"### Reunite Branches\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"635b2fd6-82ff-b8ba-71bc-4be6786220e2","name":"Note: Reunite Branches"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"e6c35081-a3a7-b684-9d33-5b0666a570da","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"5554fb51-e0fd-4cb5-165b-e53d8f398d71","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per request (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"17a07cd8-350a-62bc-ea0f-b2878b6de556","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"71b0af6c-9f93-f23c-f0d1-a7b8737f6179","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"668de368-2201-b531-349c-73ab8cd99a77","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"11260345-2673-e146-e520-cfcac44569a0","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"e8a0e1a9-57a2-022d-7cff-36aefec629e5","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"23b8dc87-32cf-8a27-f6f4-15e748484c22","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"f32ec357-8acc-e9f9-29a8-2c92c7e3da19","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,1540],"id":"20bbb91c-69f7-8d65-6507-b6e8b4a03d16","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Answer chat messages and log the results\n\n**Pattern:** Chatbot Responder · **Level:** Production · **Trigger:** Chat\n\n## What it does\nAnswer chat messages and log the results. It responds live to chat messages.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWhen Chat Message Received → Stamp & Shape Request → Payload Valid? → Classify with AI → Store as Question → Reunite Branches → Serialize Run Output (CSV) → …\n\n## Use it for\n- Teams that want to chatbot responder without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Removes copy-paste errors\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; OpenAI API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"40991297-76bc-5d46-dc75-7861e381a249","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"e012b3fe-91ee-b5ee-f1f6-8ae0f466bd82","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"45259753-a2c1-c534-510e-adcdf02196ce","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"525158fd-d0e4-f5a8-591b-983de50dd2b2","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-500],"id":"4c1f1350-b891-a820-dcbc-bdfd1655d3c5","name":"🛠 Customize me"}],"connections":{"When Chat Message Received":{"main":[[{"node":"Stamp & Shape Request","type":"main","index":0}]]},"Stamp & Shape Request":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Classify with AI","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Classify with AI","type":"ai_languageModel","index":0}]]},"Classify with AI":{"main":[[{"node":"Store as Question","type":"main","index":0}],[{"node":"Store as Complaint","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Store as Feedback","type":"main","index":0}],[{"node":"Alert Slack — Other","type":"main","index":0}]]},"Store as Question":{"main":[[{"node":"Reunite Branches","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Complaint":{"main":[[{"node":"Reunite Branches","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Feedback":{"main":[[{"node":"Reunite Branches","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Alert Slack — Other":{"main":[[{"node":"Reunite Branches","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Reunite Branches":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"ce25c6e8-7dd1-471f-b998-7be4b05e6566","id":"FDX00122"}