{"name":"Run an AI agent task with Gmail at scale","nodes":[{"parameters":{"httpMethod":"POST","path":"wf00914-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"ed075070-cd20-4782-b62f-62ffee68fd36","name":"Receive Inbound Webhook","webhookId":"eb484a38-a028-4f91-9628-d2801a9adf73"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4a265c3c-5fb9-4be7-b95d-2f14346344d9","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"4950e80b-db69-4192-a411-97e62c0eb115","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'query' on incoming request."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"343e85a7-345a-4c71-a013-c95bc2c6a06a","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"a275bc13-587f-4abf-a01f-b1cc1a87bb43","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"137415e5-928c-47f7-998d-be2414681667","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"d9ff7d09-43c0-4fd6-9d87-6fff898184f9","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a research assistant pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"d1610ed7-eac9-4283-b4a6-1f1314e6a287","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[945,970],"id":"451cf2b3-0e07-4950-852a-31c00fe1dc98","name":"Anthropic Chat Model"},{"parameters":{"description":"Delegate research sub-tasks for a request to the Research specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Research Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[864,1390],"id":"78f45e93-6da5-41a0-9cf0-80a0bb885d29","name":"Research Specialist (Sub-workflow)"},{"parameters":{"description":"Delegate draft sub-tasks for a request to the Draft specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Draft Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[1120,1390],"id":"cfdd0571-4db2-4bf4-a27a-74467a6abf26","name":"Draft Specialist (Sub-workflow)"},{"parameters":{"description":"Delegate review sub-tasks for a request to the Review specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Review Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[1552,1390],"id":"ec62b79c-1dc3-405d-b289-fb4d4aa05119","name":"Review Specialist (Sub-workflow)"},{"parameters":{"jsonSchemaExample":"{\n  \"summary\": \"string\",\n  \"sections\": [\"string\"],\n  \"status\": \"complete\"\n}"},"type":"@n8n/n8n-nodes-langchain.outputParserStructured","typeVersion":1.3,"position":[1714,970],"id":"aea11947-4695-40d3-b8ee-6fb58371e1cd","name":"Enforce Result Schema"},{"parameters":{"fieldToSplitOut":"output.sections","options":{}},"type":"n8n-nodes-base.splitOut","typeVersion":1,"position":[2038,400],"id":"d5759bb6-4909-4227-b6b9-3d388374feaf","name":"Unpack Sections"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2362,400],"id":"4c324504-71df-4cfc-bc05-882ccea54779","name":"Persist Deliverable to Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2686,400],"id":"5ac73376-29c4-4371-b7dd-df7202de8f74","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3010,400],"id":"cb0fe8ee-2a98-4608-8c79-ad126fae21d0","name":"Drop Already-Processed Items"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3334,400],"id":"70e8bea9-2a4b-47ed-bc32-e077d9a8d35c","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3658,400],"id":"eaef9ce1-05bb-411b-bb20-60320627b8a5","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3982,400],"id":"db97b2af-8580-40bf-94ef-107c0143c45c","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4306,400],"id":"bfc15670-bcc5-4a27-bada-2a7ee785d345","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Requests"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[4630,400],"id":"6bb2e4d2-8b8d-4dcc-afd9-de8ad892385c","name":"Offload to P