fore answering — never invent request details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"b0d9cde0-d6aa-411c-ae15-b6a7e0abed6d","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[945,970],"id":"6433ded6-3592-4556-9c02-dbc8aa771660","name":"OpenRouter Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[945,1390],"id":"b8275b89-dc5c-4ce4-afbb-9f24fcd28158","name":"Run Calculations"},{"parameters":{"name":"score_helper","description":"Compute a quality score for a request record.","jsCode":"const j = JSON.parse(query);\nreturn String((j.signals || []).length * 10);"},"type":"@n8n/n8n-nodes-langchain.toolCode","typeVersion":1.3,"position":[1174,1390],"id":"64006cc0-f84b-4d66-a2d2-14753252389b","name":"Custom Logic Tool"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolThink","typeVersion":1,"position":[1633,1390],"id":"112bc026-3d04-4376-8bb6-1ccbc0627b0a","name":"Think It Through"},{"parameters":{"assignments":{"assignments":[{"id":"693bcf91-8065-4576-924d-c1c9dfbbb8bc","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"b6767a2e-1767-433c-8f80-d36fca7152f9","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1957,400],"id":"139e4cbf-006f-4c21-8a19-cfbfa75165d3","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b4a03d60-5053-4e54-9b24-1707d6bfa991","leftValue":"={{ $json.confidence }}","rightValue":"high","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[2281,400],"id":"0fd9fd06-ea4e-441b-ab55-7921f8136c0f","name":"Confident Enough?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2605,160],"id":"e3ff3189-feca-4f6f-bd2d-19b4607c7bc9","name":"Deliver Answer + Log to Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🙋 Low-confidence answer needs review: {{ $json.answer }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2929,760],"id":"bb39f93a-7c8a-4a90-bbe5-9d173d2ccf1b","name":"Escalate to Human Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3577,400],"id":"7aadd26c-26ee-421f-8660-79921becf4cb","name":"Join Outcomes"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4549,400],"id":"aefff5e3-b510-4017-9b31-dde10a6e393e","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3cc258f4-eb96-4a2a-8d2f-18c0b5a2e9fd","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"07aa847d-0bcb-43a8-8325-02bee387e653","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4873,400],"id":"ae29b0a3-4243-4b4e-8b94-ae8fa1f482b8","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"c66cee29-3072-4074-9aee-4a8b4a6258e2","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c9c5bdb2-4413-4bb0-8c12-cc533aebd825","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"2ad588c9-0578-4d11-9c71-de8be73f57ae","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5197,400],"id":"1fcfea29-a767-468e-bf81-546d3ef5e742","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5521,400],"id":"1bf07c63-ed55-4ae1-b76b-962fc334ed58","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=✅ Automate an assistant workflow with Outlook 24/7 — run completed at {{ $now.t","bodyContent":"=✅ Automate an assistant workflow with Outlook 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[5845,400],"id":"f58669e7-564b-45e3-9b3e-154bbde1a5b8","name":"Send Summary to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"dd48d975-2c2f-4e98-89dd-bfc4d35ec740","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"d19e8038-577e-4133-9b7c-5ea11c85ff89","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e3e164d8-fc47-4104-a618-732b789dea02","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5197,1420],"id":"9e62a02c-1a22-418e-af06-3702f91dd9ab","name":"Capture Failure Context"},{"parameters":{"subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","bodyContent":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[5521,1420],"id":"6185b3a5-77e5-4f11-a27c-28bc80f26012","name":"Escalate Failure to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5845,1420],"id":"663e3a35-352c-4dee-87a3-d3d91b0eae16","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf01182-request`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Stamp & Shape Request","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d72aedbb-d4d2-8c1f-65f8-5ad0b0208d92","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Stamp & Shape Request\n\nShapes the item: writes `requestId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"4609c64c-8fe5-fc35-ac3c-238a28857da7","name":"Note: Stamp & Shape Request"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.requestId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Reason & Act (AI Agent) · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"83383482-4589-9765-c262-eca47558f3ed","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"9f110323-86f4-9047-d233-915bc1f92b21","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Reason & Act (AI Agent)\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Shape Agent Output · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"0d5702a0-565b-0da5-91b8-542b580367af","name":"Note: Reason & Act (AI Agent)"},{"parameters":{"content":"### OpenRouter Chat Model\n\nChat model powering the AI step (model: `anthropic/claude-sonnet-4.5`). Swap providers here without rewiring.\n\nFeeds **Reason & Act (AI Agent)** as `languageModel`\n\n🔑 OpenRouter API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"4e7bffdc-5fd6-1e1a-0c0b-ec0c6becee03","name":"Note: OpenRouter Chat Model"},{"parameters":{"content":"### Run Calculations\n\nMath tool — keeps arithmetic exact instead of letting the LLM guess.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1510],"id":"6b93da5d-686a-fccb-88fc-743de4279e66","name":"Note: Run Calculations"},{"parameters":{"content":"### Custom Logic Tool\n\nDeterministic code helper the agent can invoke for exact computation.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1114,1750],"id":"7ea88fb0-e929-f4dc-d8b8-89a04db94f5f","name":"Note: Custom Logic Tool"},{"parameters":{"content":"### Think It Through\n\nScratchpad tool: lets the agent reason step-by-step before acting.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1573,1510],"id":"e4894fb8-720c-7e56-b136-db53f0ff9f4f","name":"Note: Think It Through"},{"parameters":{"content":"### Shape Agent Output\n\nShapes the item: writes `answer`, `confidence`. Keeps the schema explicit between stages.\n\nNext: Confident Enough?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1897,520],"id":"360f9f0d-ebdd-1002-3155-2c4e70ed58ce","name":"Note: Shape Agent Output"},{"parameters":{"content":"### Confident Enough?\n\nTwo-way gate on `={{ $json.confidence }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Deliver Answer + Log to Google Sheets · ②→ Escalate to Human Queue","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2221,520],"id":"01b5ca4c-0d14-61fc-8e31-3d7c1a188fc6","name":"Note: Confident Enough?"},{"parameters":{"content":"### Deliver Answer + Log to Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2545,280],"id":"b6b059db-58d0-8d70-ab6b-78740f285523","name":"Note: Deliver Answer + Log to Google Sheets"},{"parameters":{"content":"### Escalate to Human Queue\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2869,880],"id":"00db03fb-31e3-5bb2-2fb1-f053fc4d72ea","name":"Note: Escalate to Human Queue"},{"parameters":{"content":"### Join Outcomes\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3517,520],"id":"b27fa720-d932-ee6c-9e64-29652510c6c5","name":"Note: Join Outcomes"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4489,520],"id":"ad27b055-7925-10a3-791a-fc7828be1f6a","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4813,520],"id":"98728ca5-62ba-db3e-3d17-f6c780de18f3","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5137,520],"id":"cbd0eb06-d800-1a05-dbb1-ba8b9cb5562f","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Outlook · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5461,520],"id":"0507256f-8ca4-e64b-d742-15738fdec589","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Outlook\n\nmicrosoftOutlook — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5785,520],"id":"009d4701-8d4a-1a86-9958-7dbadaa29d9f","name":"Note: Send Summary to Outlook"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Outlook","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5137,1540],"id":"a4d2b66c-c167-03b8-c2ba-7c79f6fe4723","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Outlook\n\nmicrosoftOutlook — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Microsoft OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5461,1540],"id":"fcccd5bc-c66d-3d9c-bb84-8cf0b0fdb9ab","name":"Note: Escalate Failure to Outlook"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5785,1540],"id":"5ba2d3a6-c749-9640-9575-70b096a9e635","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Automate an assistant workflow with Outlook 24/7\n\n**Pattern:** AI Agent · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nAutomate an assistant workflow with Outlook 24/7. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Stamp & Shape Request → Payload Valid? → Reason & Act (AI Agent) → Shape Agent Output → Confident Enough? → Deliver Answer + Log to Google Sheets → …\n\n## Use it for\n- Teams that want to ai agent without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Saves hours of manual work each week\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Microsoft OAuth2; OpenRouter API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"8bb2ad10-d475-b131-4227-bc43060bed5c","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"44832314-3a11-c81d-fde2-5d1424956888","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"dc8f6ac6-dac9-9afe-6aff-77b6f9770bee","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"61913ab0-05d1-99e9-0d5e-a28040784000","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"fa60c37c-72a3-8921-d892-8f581343c6f5","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Stamp & Shape Request","type":"main","index":0}]]},"Stamp & Shape Request":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Reason & Act (AI Agent)","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"OpenRouter Chat Model":{"ai_languageModel":[[{"node":"Reason & Act (AI Agent)","type":"ai_languageModel","index":0}]]},"Run Calculations":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Custom Logic Tool":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Think It Through":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Reason & Act (AI Agent)":{"main":[[{"node":"Shape Agent Output","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Shape Agent Output":{"main":[[{"node":"Confident Enough?","type":"main","index":0}]]},"Confident Enough?":{"main":[[{"node":"Deliver Answer + Log to Google Sheets","type":"main","index":0}],[{"node":"Escalate to Human Queue","type":"main","index":0}]]},"Deliver Answer + Log to Google Sheets":{"main":[[{"node":"Join Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Escalate to Human Queue":{"main":[[{"node":"Join Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Outcomes":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Outlook","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[