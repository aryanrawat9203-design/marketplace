      "name": "Load Previous Snapshot",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.example.com/v1/requests",
        "options": {
          "timeout": 20000
        },
        "sendQuery": true,
        "queryParameters": {
