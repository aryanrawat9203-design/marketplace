      "id": "678d7d61-fc5b-4fa1-8c50-676b5b7e4953",
      "name": "Enrich with AI",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.6,
      "position": [
        1500,
        300
