{"name":"Enrich contact records with HubSpot and HTTP / REST API in real time","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[2],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"38b85ad5-1c11-4d65-8a99-31a3ed3c6890","name":"Weekly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"dcf88071-52bd-427f-bb27-f78154ed6133","name":"page","value":"1","type":"number"},{"id":"8f856884-57a1-49fe-8a5b-db137e68f696","name":"hasMore","value":"true","type":"boolean"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"9f5e0818-b267-4910-92c5-1449c1311e8f","name":"Init Cursor"},{"parameters":{"batchSize":1,"options":{"reset":false}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[378,400],"id":"d565c4e7-51d4-46c0-848e-340e53a85bf3","name":"Page Loop"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/requests","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"page","value":"={{ $json.page }}"},{"name":"per_page","value":"50"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,880],"id":"2daa738f-2e3d-4aad-8f77-fc40eab9cf59","name":"Fetch Page from API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"fieldToSplitOut":"data","options":{}},"type":"n8n-nodes-base.splitOut","typeVersion":1,"position":[1350,880],"id":"8546c5cf-b3a7-4a18-aea8-276ddfc9891b","name":"Split Result Items"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming request records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    requestId: String(j.requestId ?? j.id ?? '').trim(),\n    query: typeof j.query === 'string' ? j.query.trim() : j.query ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2322,880],"id":"d205255e-cbfc-47cd-a5e4-068ed8f3b799","name":"Normalize Page Items"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"requestId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2646,400],"id":"5fa9d816-e414-47a0-a935-d0ad05041b9e","name":"Remove Duplicate Requests"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[2970,400],"id":"952cf0d4-c419-4251-ba77-2afeb120e7e1","name":"Upsert Harvest into HubSpot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"fieldsToSummarize":{"values":[{"aggregation":"count","field":"requestId"}]},"options":{}},"type":"n8n-nodes-base.summarize","typeVersion":1.1,"position":[3294,400],"id":"6016dbd0-0e4b-4b78-9eb0-55e3207fef3c","name":"Tally Harvest Stats"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3618,400],"id":"a8468c4d-c3d7-49e0-950b-af06ba1c6347","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3942,400],"id":"1b5e0e11-5b50-4f32-8e46-828ef5c427ff","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4266,400],"id":"045f2399-0e78-48a6-aedb-c4930154dc66","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[4590,400],"id":"b09cb2d1-bf11-49b6-a2c5-dbf220cf8a66","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"07d02cca-fb89-49de-8812-bd3389f864a2","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"b2322042-6f87-4e07-9830-531105daede5","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5562,400],"id":"53e964b0-a708-47a2-9921-0973ee8a41be","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"94426d11-7877-4e4d-ac26-13b321244fd7","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"7e41c4af-e771-4363-8a4a-fb0f6512a75c","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"47c5cc58-4746-451d-ba8c-89b81e4fdf3b","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"17123f22-83d8-4890-beaa-a50f900b75a7","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b861570c-b35d-4830-be3b-cbff2fb23abb","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9b9372a7-df1f-45c2-9bb8-94a4c0c2b25e","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"8554cfa3-42ed-4376-ad74-62425ff852fa","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6534,400],"id":"37a0944d-5d3a-4bd8-a471-b0cfe2ada9b9","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Enrich contact records with HubSpot and HTTP / REST API in real time — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6858,400],"id":"54eb1377-0641-4764-9768-7f3364e659a1","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"9740f407-d5de-4ef2-b4c4-e0994a371655","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"db98b271-8a59-4c40-87df-5aa3ffae4672","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"1c7ca4d4-253f-4ae1-86d8-3816a071e3a2","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,1420],"id":"8d456f2f-10a5-4e56-8d7f-e48017072a32","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,1420],"id":"d97006ac-181f-4d4a-985b-c7f7ac4285a9","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6858,1420],"id":"bf6a3fa9-f287-4c62-b3c6-fc5c9ce444bc","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Init Cursor","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"52b878ed-5810-75fb-708f-2b2a068dd07b","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Init Cursor\n\nShapes the item: writes `page`, `hasMore`. Keeps the schema explicit between stages.\n\nNext: Page Loop","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"d2aa23b1-6afb-edd9-c46f-5c57015534fd","name":"Note: Init Cursor"},{"parameters":{"content":"### Page Loop\n\nLoop controller — releases 1 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Remove Duplicate Requests · ②→ Fetch Page from API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"32b37d2b-e783-9ec6-d403-3cd9806bbe96","name":"Note: Page Loop"},{"parameters":{"content":"### Fetch Page from API\n\nGET https://api.example.com/v1/requests — retries 3× with backoff on failure.\n\nPorts: ①→ Split Result Items · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"3cd52e33-42d2-1337-2f33-dd423987e8ae","name":"Note: Fetch Page from API"},{"parameters":{"content":"### Split Result Items\n\nExplodes the `data` array into one item per element.\n\nNext: Normalize Page Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"1bfab468-4e9c-8353-4139-0fd5a7125225","name":"Note: Split Result Items"},{"parameters":{"content":"### Normalize Page Items\n\nCustom JavaScript: Normalize incoming request records to a stable schema\n\nNext: Page Loop","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,1000],"id":"7b214021-8293-45e6-1cea-be8c65b51676","name":"Note: Normalize Page Items"},{"parameters":{"content":"### Remove Duplicate Requests\n\nDrops duplicates within this run (compared on `requestId`).\n\nNext: Upsert Harvest into HubSpot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"cf33ba5e-cb1b-02aa-3b80-4f29c30bce02","name":"Note: Remove Duplicate Requests"},{"parameters":{"content":"### Upsert Harvest into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Tally Harvest Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"5a327f85-35fd-48fe-6fc5-50cb29fdf6f8","name":"Note: Upsert Harvest into HubSpot"},{"parameters":{"content":"### Tally Harvest Stats\n\nGroup-by + aggregate (like a pivot table) — turns raw rows into KPI numbers.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"56014b8e-233c-e5dc-5406-66b9732b7c36","name":"Note: Tally Harvest Stats"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per request (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"267f0015-0cab-fbc4-1332-50eb7ceb20b7","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"22d5c518-af98-abb0-84ce-da44deed0d01","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"7d3ddccf-daab-c14c-3d26-34c0ac0a877b","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"c4852d44-125c-8824-d000-260d95e75735","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"fc2979ad-ac77-687e-92f7-ebc5e430c22c","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"763c5d1b-edca-4492-1970-4865cbc972d1","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"e35de508-b168-497c-619c-389e8e8e3213","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"89fe5423-431c-0219-1366-df9ddf095e44","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"971ab7d2-d98c-36e4-db3d-5c1d6f68a65e","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"35b1c285-3361-b4ee-91e1-62fb8d14ac50","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"e7419d0a-0fa7-d287-7c0c-740a2156a641","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"56a8447f-373c-ae0c-f97e-3a235998dfd8","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"b374c5d2-f3d4-accc-518e-10817aa334da","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,1540],"id":"ac514738-0d27-9ac3-2957-ef2070ae1b66","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Enrich contact records with HubSpot and HTTP / REST API in real time\n\n**Pattern:** Data Enrichment · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nEnrich contact records with HubSpot and HTTP / REST API in real time. It runs automatically on a schedule.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Init Cursor → Page Loop → Remove Duplicate Requests → Upsert Harvest into HubSpot → Tally Harvest Stats → Fingerprint for Idempotency → …\n\n## Use it for\n- Teams that want to data enrichment without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Scales without extra headcount\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; HubSpot private-app token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a90a35d1-8f83-0db5-ee83-763d053b9232","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"557dc3cd-8383-fdb4-4c03-e2e4a60a79f0","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"b83455a4-c90e-6b39-59da-daf04a186a20","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"942bbc23-8e75-9711-8889-d39f6f058d1a","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"2646950c-6ffd-4a7d-e76c-ad65ca5e6962","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Init Cursor","type":"main","index":0}]]},"Init Cursor":{"main":[[{"node":"Page Loop","type":"main","index":0}]]},"Page Loop":{"main":[[{"node":"Remove Duplicate Requests","type":"main","index":0}],[{"node":"Fetch Page from API","type":"main","index":0}]]},"Fetch Page from API":{"main":[[{"node":"Split Result Items","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Split Result Items":{"main":[[{"node":"Normalize Page Items","type":"main","index":0}]]},"Normalize Page Items":{"main":[[{"node":"Page Loop","type":"main","index":0}]]},"Remove Duplicate Requests":{"main":[[{"node":"Upsert Harvest into HubSpot","type":"main","index":0}]]},"Upsert Harvest into HubSpot":{"main":[[{"node":"Tally Harvest Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Tally Harvest Stats":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupComple