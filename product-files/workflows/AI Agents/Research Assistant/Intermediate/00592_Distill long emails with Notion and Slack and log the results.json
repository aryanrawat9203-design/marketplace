{"name":"Distill long emails with Notion and Slack and log the results","nodes":[{"parameters":{"httpMethod":"POST","path":"wf00592-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"4db1952a-740c-4934-8b61-39a6d01d65fb","name":"Receive Inbound Webhook","webhookId":"e848be3d-a4d4-40e1-8c7f-fddcec4d8950"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/requests","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"488f3f5c-7dd3-471f-9a05-cfb3a46c5cd6","name":"Pull Fresh Items (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"priority","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[378,400],"id":"312b31cd-e086-4a51-9ac0-a4ba42a2c38c","name":"Newest First"},{"parameters":{"maxItems":15},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"04e38d8d-b04b-41fd-80b0-e1a022948b88","name":"Trim to Digest Size"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.chainSummarization","typeVersion":2,"position":[1026,400],"id":"878152e8-1f4f-41ae-9fad-2e283028bd98","name":"Summarize Content (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[1269,970],"id":"529aafd1-f901-4db6-885e-ca958232cc21","name":"Google Gemini Chat Model"},{"parameters":{"mode":"markdownToHtml","markdown":"={{ $json.response?.text || $json.text }}","options":{}},"type":"n8n-nodes-base.markdown","typeVersion":1,"position":[1593,400],"id":"5e7e3309-f1cf-4c88-a4d9-31c7be5b70c5","name":"Render as HTML"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"={{ $json.html || $json.response?.text || $json.text }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1917,400],"id":"e5186c2d-3bcd-4ca4-9e98-a5307c841a6d","name":"Post Digest to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2241,400],"id":"411d28af-6c7b-456d-bed8-f684588bb580","name":"Archive Digest in Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2565,400],"id":"65b8c00f-04ca-4e33-8f58-9e685b823919","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2889,400],"id":"398b4c90-3fb9-4581-9d91-c665551a9d68","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3213,400],"id":"1d15e8db-146f-40f1-be39-8a4136cc7c03","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3537,400],"id":"261d601a-2ace-4f6d-a17b-8254959294c5","name":"Drop Already-Processed Items"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Requests"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3861,400],"id":"41a47a5a-097f-46ef-b569-253f657dc9fe","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4185,400],"id":"e59513ee-269a-4ca4-9e18-961bd2e69bba","name":"Record Sub-workflow Result"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4509,400],"id":"996d27ed-be3a-4e99-9d35-511c3cf22904","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"9a7a8c5e-dc1c-42f6-96d0-ab021e17a4a4","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f2cf72e0-f2cd-487b-86a7-11cd9998583a","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4833,400],"id":"6d0e38bf-2929-4b62-8d15-e0928ee6dd3e","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5157,400],"id":"ca8c0e59-fd7e-4c76-9cb1-371d144b1d64","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5481,400],"id":"3f0dd447-28a9-4c5b-b475-3b46984d380f","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5805,400],"id":"ac74765f-d975-407b-8d42-74a1e257e22f","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6129,400],"id":"6dbeb695-fb24-4442-9e5e-a6ba3c69873a","name":"Compute Drift vs Snapshot"},{"parameters":{"dataToSave":{"values":[{"key":"requestId","value":"={{ $json.requestId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6453,400],"id":"449c7be7-be58-42e7-87ff-3f28be0f3c7e","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"e92e8389-1ec3-4ed5-b433-37b82b25b2d4","name":"pipeline","value":"Research Assistant","type":"string"},{"id":"be0f7ce2-7bea-4cad-866d-74a66a0913d8","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6777,400],"id":"307bd110-15f7-4aa0-9718-4899336a5e75","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"requestId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7101,400],"id":"b989a38e-2286-43d4-906f-60416df62ed7","name":"Align Field Names"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7425,400],"id":"a4bf74ea-0efe-45dd-84ba-fd7cb8f59f57","name":"Cap Batch Volume"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7749,400],"id":"8609f59b-0ada-4d0f-8f67-84602a79e729","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"24e9f0d0-5a0c-46b1-8da5-c7c336772c63","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8073,400],"id":"3503a5b7-f11b-4cac-9ad5-6c18fdaa9217","name":"Guard Non-Empty query"},{"parameters":{"assignments":{"assignments":[{"id":"5aac72a2-ce84-4f0c-9d76-5252800e2d03","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"a6c5caf9-8bd6-4224-bcba-e005f4db579d","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8339cd62-274f-4b1e-8597-b6d80b1c0e83","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8397,400],"id":"00639715-5f65-4ffa-87b4-72f8c2774463","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8721,400],"id":"02fe7fc8-8fce-4a50-9517-48403ca1d67e","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Distill long emails with Notion and Slack and log the results — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9045,400],"id":"702f4a0e-2895-4543-ab3c-dc2be6843585","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"986853e9-d1ec-485f-a73f-faf28608bcae","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"25f19259-fe4d-4478-8e2f-dd9804f8115c","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"39acd808-0f23-4d5f-9050-c9ed2573b521","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8397,1420],"id":"377b75a9-e545-435c-bf42-746e608c9095","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8721,1420],"id":"73103774-7d3c-41e0-ab66-5412f9f6f2fc","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9045,1420],"id":"90db3224-8e69-43f9-afce-5330a98c9d5d","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf00592-request`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Pull Fresh Items (API)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"afb5a200-e930-d1b4-f7bd-40b3bcec740d","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Pull Fresh Items (API)\n\nGET https://api.example.com/v1/requests — retries 3× with backoff on failure.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"7fecc588-644a-aa77-f57a-1933dc885556","name":"Note: Pull Fresh Items (API)"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"7713c62d-961d-6d10-a3c3-26f7e3865b0e","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"81186f28-bf47-1347-44cf-e885c31d7c4e","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Render as HTML · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"b7506f08-539c-1cec-9399-e9d535631029","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"d17f3702-169f-88e5-4291-513b43a69799","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Render as HTML\n\nConverts markdown to HTML for rich rendering in email/CMS.\n\nNext: Post Digest to Slack","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"bf1f3d72-6cc0-1421-4eb0-5ba03d5c07c4","name":"Note: Render as HTML"},{"parameters":{"content":"### Post Digest to Slack\n\nPosts a message to Slack (`#ai-ops`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nPorts: ①→ Archive Digest in Notion · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"4a502efa-b16d-8e6b-b0bb-c06739715e66","name":"Note: Post Digest to Slack"},{"parameters":{"content":"### Archive Digest in Notion\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"7da9d955-5ebd-35f8-21f4-1679738911b4","name":"Note: Archive Digest in Notion"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"56f5f03c-9a12-3dc6-bf2c-aa8781d900b1","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"2cf16dd9-cf33-b300-7886-e7a9981f68d4","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per request (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"35a733f6-4907-116f-7d72-3936823f1542","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"40845d79-2339-9003-4bf0-41e43b585277","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"33e93ae1-0b4b-2906-3dfd-e54a5a22f749","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"64e20226-544a-6f7d-d5cd-602438d7268f","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"4970cff3-6711-ff68-ef26-c1747d70ce08","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"f0164c89-9fa5-cb83-91d6-3ddc78831610","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"5d1811d2-102f-5458-af94-c15f02b8d4b2","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"4a13a078-972d-3d03-c626-c2cdc101b594","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Load Previous Snapshot\n\nPulls every page from the Notion database — fine for small datasets; add a filter if the database grows large.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"c8d39559-427c-56d6-0047-10bc4f64687d","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"2de8cbc3-fda3-1fcf-c015-3d6455fbeaa6","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"c69f8a63-cd33-32e2-5482-25f61ec9646e","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"a1ca8fc3-89f4-569c-88c5-97f32b74b824","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"2b5767fa-d0bf-a3b6-e7ff-2e3794eccc44","name":"Note: Align Field Names"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"25d689d4-8a2d-d20f-779c-45203cddba1e","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Guard Non-Empty query","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"2f15a57e-5d0f-ed72-5279-4cf4426aa442","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Guard Non-Empty query\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"47764443-39ed-d3cc-5064-9a994d2fb672","name":"Note: Guard Non-Empty query"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,520],"id":"b2f003a7-2bdd-f1ef-4e17-d767db6b40b4","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,520],"id":"93c227d0-e14e-83c1-76c7-1f882d9a46a9","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#ai-ops`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,520],"id":"1b3bb75d-81e9-6dd3-7484-0da5bba1e276","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,1540],"id":"98a82979-2796-ee58-f284-3ab2f9c67297","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#ai-ops`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,1540],"id":"5a7f26b3-37fe-f02e-79ef-939ef55237d5","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,1540],"id":"244fe742-263f-0510-b718-2af910192870","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Distill long emails with Notion and Slack and log the results\n\n**Pattern:** AI Summarize & Route · **Level:** Architect · **Trigger:** Webhook\n\n## What it does\nDistill long emails with Notion and Slack and log the results. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Pull Fresh Items (API) → Newest First → Trim to Digest Size → Summarize Content (AI) → Render as HTML → Post Digest to Slack → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Improves response time\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google AI API key; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a8805cce-309b-9cfc-248a-94a3625b6a68","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nSummarization uses a Chain, not an Agent, because the step is fixed — there's no decision about which tool to call, just 'summarize this text.' Posting to multiple channels runs as parallel branches, not sequential sends, so a slow API on one channel never delays the message that was already ready on another.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"8a17170d-fc43-ab69-3bfd-90c857c89ebb","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAbout as deep as this pattern goes — extend it:\n\n1. Add a third notification channel and watch the Merge node's input count update.\n2. Change 'Trim to Digest Size' from 15 to 5 and see how it narrows the summary's scope.\n3. Swap the Summarization Chain for a Q&A Chain to answer questions instead of just recapping.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"486d8c5c-16d6-2f45-182a-c7f950b2c20c","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"bd8b75f8-252d-d628-a1db-0ac44a1e4669","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"219bf1a7-ebd6-ac9f-911a-2233e72a3b8d","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"073d1bde-a906-3804-d2ac-7e9d6a3334ec","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"904ae509-1487-8b40-8d3a-cf3aca3ce3d7","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Pull Fresh Items (API)","type":"main","index":0}]]},"Pull Fresh Items (API)":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Render as HTML","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Render as HTML":{"main":[[{"node":"Post Digest to Slack","type":"main","index":0}]]},"Post Digest to Slack":{"main":[[{"node":"Archive Digest in Notion","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Digest in Notion":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Guard Non-Empty query","type":"main","index":0}]]},"Guard Non-Empty query":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Receive Inbound Webhook":[{"json":{"requestId":"REQ-10234","query":"What's our refund policy for orders over $500?","context":"customer asked via chat widget","priority":"normal"}},{"json":{"requestId":"REQ-10235","query":"Summarize this week's support tickets","context":"weekly ops review","priority":"low"}}]},"versionId":"0ebc2909-3c95-4a44-8c6e-605815ee1e6a","id":"FDX00592"}