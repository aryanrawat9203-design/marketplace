:"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1026,400],"id":"c8043ebc-0539-4765-b931-0e57557d6a6d","name":"Enrich — Primary Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"65bc0ed8-43ef-427b-bac3-09fd1a382f19","leftValue":"={{ $json.company || $json.name }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"9893b071-2fc1-4dc9-a104-f747072efe36","name":"Primary Hit?"},{"parameters":{"method":"GET","url":"https://fallback-enrich.example.com/v1/person","sendQuery":true,"queryParameters":{"parameters":[{"name":"email","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1674,880],"id":"22f6cad3-d209-4810-8ca0-ffde8707deda","name":"Enrich — Fallback Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"fa8e3f97-c094-4184-88cd-225d82d84927","name":"Merge Enrichment Paths"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each request 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.query) score += 20;\n  if (j.context) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3294,400],"id":"36972592-0b47-4ac7-9a6a-594c254343ba","name":"Score Enriched Records"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[3618,400],"id":"13ac7b72-8012-4149-a546-9fe9f1806958","name":"Upsert into HubSpot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6dde3ef8-65d9-4ee9-9e7e-f402951ae44e","leftValue":"={{ $json.score >= 80 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[3942,400],"id":"9de4e6c4-0bea-4a2e-9eba-5d88b6aad176","name":"Hot Lead?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🔥 Hot {{ $json.company || $json.email }} (score {{ $json.score }}) — reach out now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,160],"id":"96b8b054-a8bc-4200-88e2-5190b20759d2","name":"Ping Owner Immediately","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4590,400],"id":"95ae32b6-bbe0-4ab9-8ace-a93d87ee871a","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[4914,400],"id":"f984e970-de78-4f16-b5f4-397290fe3b5f","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5238,400],"id":"146abe3a-27f3-4405-bbbc-8a109752608f","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"0bfa834d-0632-44f3-b0ca-348e40c1e2da","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f4fe4d0b-1b3d-4836-815f-2a7c1f582024","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"617472c7-3428-43a2-85ea-0d848f2fd2dc","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"f8cd36f1-c76a-4b5c-b0f6-8c260977cbba","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"0c584732-4b13-4e10-bfc7-5ba8523b316c","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"7e50a2fa-d1f6-44d6-a3ac-18e8ffa9735b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"8b7fe63d-8fea-48e2-8179-62d8c0417881","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,400],"id":"718b0717-4b9e-47f2-a3c8-72a999d87370","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Augment contact records with HubSpot and HTTP / REST API at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,400],"id":"5eee919c-a3c5-4044-b2fd-ef7987e6fd65","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"f75080b5-54b7-4f40-b04c-d1d7e8f0d2ef","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"43879089-cd7d-44ed-9b7d-b21d073f1c99","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"fac24c69-f1c1-448b-8a02-d0cb67edf581","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"cc8772f6-1665-4328-90f2-a6c00b048f3a","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,1420],"id":"c2bb2c82-1f05-4978-a189-b02c19b96d0e","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[6534,1420],"id":"e11f6842-4362-4e0a-9a76-ff88f75ef478","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Request","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"f1f49b98-d43f-e6d5-51ae-291a6abcf8f5","name":"Note: Daily Schedule"},{"parameters":{"content":"### Stamp & Shape Request\n\nShapes the item: writes `requestId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"0fafb9e2-d3d9-7164-d66f-d77a29b327c8","name":"Note: Stamp & Shape Request"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.requestId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Remove Duplicate Requests · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"aabe49cf-8ae9-08a2-4ca4-f528782b20e7","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nhubspot — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"f8a1c584-9048-9299-d45a-e3f4ec305d2c","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Remove Duplicate Requests\n\nDrops duplicates within this run (compared on `requestId`).\n\nNext: Enrich — Primary Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"3aa4cf24-d236-8239-9de3-c90f626228c2","name":"Note: Remove Duplicate Requests"},{"parameters":{"content":"### Enrich — Primary Provider\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Primary Hit? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"b7feaa44-cc59-d4d1-c15a-eb13b7f34632","name":"Note: Enrich — Primary Provider"},{"parameters":{"content":"### Primary Hit?\n\nTwo-way gate on `={{ $json.company || $json.name }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Enrich — Fallback Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"e6b9456e-e65c-58e6-04d3-2cfefca785f6","name":"Note: Primary Hit?"},{"parameters":{"content":"### Enrich — Fallback Provider\n\nGET https://fallback-enrich.example.com/v1/person — retries 3× with backoff on failure.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"cd5ccb0f-fb7e-2da8-9a03-3f1b16e220cc","name":"Note: Enrich — Fallback Provider"},{"parameters":{"content":"### Merge Enrichment Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Score Enriched Records","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"ed11dd53-3b0e-311f-ccac-16e9ffca42da","name":"Note: Merge Enrichment Paths"},{"parameters":{"content":"### Score Enriched Records\n\nCustom JavaScript: Score each request 0-100 from simple heuristics\n\nNext: Upsert into HubSpot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"462a6141-bf78-0440-1e3f-963fb9634fa5","name":"Note: Score Enriched Records"},{"parameters":{"content":"### Upsert into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Hot Lead? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"91b82a31-28d0-6d61-4bac-be37cd66f85f","name":"Note: Upsert into HubSpot"},{"parameters":{"content":"### Hot Lead?\n\nTwo-way gate on `={{ $json.score >= 80 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Ping Owner Immediately · ②→ Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"76b759fc-8fd7-d6b3-bffe-a817bde9d288","name":"Note: Hot Lead?"},{"parameters":{"content":"### Ping Owner Immediately\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,280],"id":"96c1ae6f-e820-1499-6e5a-831da8833f52","name":"Note: Ping Owner Immediately"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"fcf1e4d8-fd5d-8e07-7c66-3ce5ebe1026a","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"35ad31d4-eb02-e455-5fae-5bf5a05c7fad","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"9ebb5565-c56b-ded3-e636-4f307267bdd7","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"c8c15b29-6982-2eec-10c3-9bf6f97e273a","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"7f4f154d-29c0-2209-5eba-2c7030babe4d","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"4d93702c-66ef-9886-fb17-1cc3dac5c76b","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"1e17b9e1-b36b-81e7-1dd9-e6bfb96e9f7d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"78c52143-72dc-cec2-706f-844d8155a226","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"07b15004-71ca-9ca8-fb7e-cd2958ef2957","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nhubspot — `contact` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 HubSpot private-app token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"5dabcd09-d7c9-8a72-39fa-bf6fb70fa2ae","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Augment contact records with HubSpot and HTTP / REST API at scale\n\n**Pattern:** Data Enrichment · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nAugment contact records with HubSpot and HTTP / REST API at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Stamp & Shape Request → Payload Valid? → Remove Duplicate Requests → Enrich — Primary Provider → Primary Hit? → Merge Enrichment Paths → …\n\n## Use it for\n- Teams that want to data enrichment without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Scales without extra headcount\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; HubSpot private-app token; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"6cec7e9e-c420-0b22-ab7d-214ba6d32d6a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"ffcfcacb-4315-34cd-93bb-f2ee92dd9b62","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"89098525-a6e6-c0f3-d3c7-ed18220894c3","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"c7bda4c0-0b63-7745-f2e0-98e99bf14860","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Stamp & Shape Request","type":"main","index":0}]]},"Stamp & Shape Request":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Remove Duplicate Requests","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Remove Duplicate Requests":{"main":[[{"node":"Enrich — Primary Provider","type":"main","index":0}]]},"Enrich — Primary Provider":{"main":[[{"node":"Primary Hit?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Primary Hit?":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":0}],[{"node":"Enrich — Fallback Provider","type":"main","index":0}]]},"Enrich — Fallback Provider":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Enrichment Paths":{"main":[[{"node":"Score Enriched Records","type":"main","index":0}]]},"Score Enriched Records":{"main":[[{"node":"Upsert into HubSpot","type":"main","index":0}]]},"Upsert into HubSpot":{"main":[[{"node":"Hot Lead?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hot Lead?":{"main":[[{"node":"Ping Owner Immediately","type":"main","index":0}],[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Ping Owner Immediately":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"17efab63-2ee1-4819-ab90-73006a92ecd2","id":"FDX00032"}