annelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=📚 Unanswered question logged: {{ $json.chatInput || $json.question }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2632,760],"id":"f6eb6713-8579-4de0-850e-e2b4a59bc350","name":"Flag Gap to KB Owners","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3604,400],"id":"0b4ea1c1-3278-4005-949f-2d77e3a3d889","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3928,400],"id":"5b4ee7d2-34f9-4148-b7af-faf57dfcb276","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4252,400],"id":"bec89cb0-dafc-4ab0-a5f6-63c199088dd2","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"7ae802a2-679a-4a2a-b979-9ac6443c36f1","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"a9b76d0a-0ea3-4ac3-8ca3-762ece247f8d","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4576,400],"id":"1eed9d2e-bae0-476e-a7eb-e676fed4a0bd","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"d4e66948-eef4-49e1-99a9-e8e913d30b92","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"11bd083d-002b-46da-8d15-b8058da55f47","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9204adac-6b50-4c21-8ef7-00953b069616","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4900,400],"id":"f98e5006-0ef8-427d-894e-d67f31fa485a","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5224,400],"id":"2de28818-f2c0-4dd4-908e-b7cde3581153","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Handle user questions for Research Assistant (01009) — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5548,400],"id":"99a78d15-2ab6-4ecc-a3e8-c56a94c94893","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b418f302-df18-4658-a544-f0a1b1a2d0d3","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ecf6dd00-c395-4eec-a8f5-71108d983dcc","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"22950be0-6b9a-42b2-a1de-43b747d91123","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4900,1420],"id":"25f0a2a9-9bb5-4114-8a28-fddd9579c930","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5224,1420],"id":"ced51f82-6925-484a-ba63-fee91cef62bd","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5548,1420],"id":"bfeb1ea7-ff8c-4467-b6bd-15aeb7def580","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### When Chat Message Received\n\nOpens a hosted chat session; every user message starts an execution with `chatInput` + `sessionId`.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"b553e499-a6b6-6f65-6da2-7c400a727269","name":"Note: When Chat Message Received"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.query }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Answer from Knowledge Base · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"ac9d2b47-4a1f-dcc6-0fb8-c101de3edb06","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"e73e696a-1657-cf5b-1084-36298bf2ad22","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Answer from Knowledge Base\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Grounded Answer Found? · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"78aef49d-2841-7341-0a12-7f5835832b25","name":"Note: Answer from Knowledge Base"},{"parameters":{"content":"### OpenRouter Chat Model\n\nChat model powering the AI step (model: `anthropic/claude-sonnet-4.5`). Swap providers here without rewiring.\n\nFeeds **Answer from Knowledge Base** as `languageModel`\n\n🔑 OpenRouter API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"c6d3f93a-77a6-2116-bba5-a5265bf06eb3","name":"Note: OpenRouter Chat Model"},{"parameters":{"content":"### Knowledge Base Retriever\n\nExposes the vector index to the agent as a semantic-search tool.\n\nFeeds **Answer from Knowledge Base** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[615,1510],"id":"5fb4f40e-7162-9a88-d6d1-e1eb5800c7c1","name":"Note: Knowledge Base Retriever"},{"parameters":{"content":"### Query Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Knowledge Base Retriever** as `embedding`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[669,2020],"id":"691e921c-6cf5-e145-fab8-79ffbc98a872","name":"Note: Query Embeddings"},{"parameters":{"content":"### Rerank Retrieved Chunks\n\nRe-scores retrieved chunks so only the most relevant reach the model.\n\nFeeds **Knowledge Base Retriever** as `reranker`\n\n🔑 Cohere API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[952,2020],"id":"239b8bd9-de69-ef81-17c5-ad0ef86469c4","name":"Note: Rerank Retrieved Chunks"},{"parameters":{"content":"### Grounded Answer Found?\n\nTwo-way gate on `={{ !($json.output || '').includes('needsHuman') }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Deliver Answer via Slack · ②→ Log Knowledge Gap","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1276,520],"id":"ddd373c7-ebee-30f2-b437-d6bfe7c3acf1","name":"Note: Grounded Answer Found?"},{"parameters":{"content":"### Deliver Answer via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Serialize Run Output (CSV) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1600,280],"id":"414ed419-d34f-16e6-f4ea-e8112eb6ec8c","name":"Note: Deliver Answer via Slack"},{"parameters":{"content":"### Log Knowledge Gap\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Flag Gap to KB Owners · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1924,880],"id":"228885fd-c6bb-a948-94fd-d3839af6ef62","name":"Note: Log Knowledge Gap"},{"parameters":{"content":"### Flag Gap to KB Owners\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2572,880],"id":"59ca888e-0d9f-be24-f7e9-b9a3f27a509a","name":"Note: Flag Gap to KB Owners"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3544,520],"id":"7cb006b2-0b03-44fb-23b4-83bfaeb49aec","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3868,520],"id":"61145687-c0d6-9f48-f600-8c055b6c9c2b","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4192,520],"id":"12a3dc1d-5d43-edc0-78f3-07e7b5091876","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4516,520],"id":"2fe37a86-cd1b-72b7-b1f1-df0c42af0bca","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4840,520],"id":"47665de7-736a-c605-c3cc-1133264df24e","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5164,520],"id":"f88f731d-b84f-f9ce-5ad3-2e925f33f5ca","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5488,520],"id":"f389cbb8-f75e-7b57-37f4-b0655eb29a16","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4840,1540],"id":"77bd2101-9335-cb4a-ef94-c28dd76a27fd","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5164,1540],"id":"765bd67a-78fb-48c8-337e-d8a7af120b27","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5488,1540],"id":"d8577e45-aa70-4674-ff5c-a39cc24d91f3","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Handle user questions for Research Assistant (01009)\n\n**Pattern:** Chatbot Responder · **Level:** Production · **Trigger:** Chat\n\n## What it does\nHandle user questions for Research Assistant (01009). It responds live to chat messages.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWhen Chat Message Received → Required Fields Present? → Answer from Knowledge Base → Grounded Answer Found? → Deliver Answer via Slack → Serialize Run Output (CSV) → Archive Row Snapshot → …\n\n## Use it for\n- Teams that want to chatbot responder without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Responds in seconds\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Cohere API key; Google OAuth2 / service account; OpenAI API key; OpenRouter API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a21eb5ef-30d7-1952-36f1-5384bfc56589","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"6414ba2e-b88a-00cc-d342-980504119c62","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"84402519-fee4-dab5-2fc6-c8d8f3e38caa","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"0089c4fe-6b21-9fee-44a5-1a4a1c409e5b","name":"🛠 Customize me"}],"connections":{"When Chat Message Received":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Answer from Knowledge Base","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"OpenRouter Chat Model":{"ai_languageModel":[[{"node":"Answer from Knowledge Base","type":"ai_languageModel","index":0}]]},"Knowledge Base Retriever":{"ai_tool":[[{"node":"Answer from Knowledge Base","type":"ai_tool","index":0}]]},"Query Embeddings":{"ai_embedding":[[{"node":"Knowledge Base Retriever","type":"ai_embedding","index":0}]]},"Rerank Retrieved Chunks":{"ai_reranker":[[{"node":"Knowledge Base Retriever","type":"ai_reranker","index":0}]]},"Answer from Knowledge Base":{"main":[[{"node":"Grounded Answer Found?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Grounded Answer Found?":{"main":[[{"node":"Deliver Answer via Slack","type":"main","index":0}],[{"node":"Log Knowledge Gap","type":"main","index":0}]]},"Log Knowledge Gap":{"main":[[{"node":"Flag Gap to KB Owners","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Deliver Answer via Slack":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"31039044-4e6b-468b-8dae-95099bf07543","id":"FDX01009"}