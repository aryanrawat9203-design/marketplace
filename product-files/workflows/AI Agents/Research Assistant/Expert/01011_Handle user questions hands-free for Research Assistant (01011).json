 before answering — never invent request details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"f8e585bb-233b-41f1-a4bb-1309611bd198","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[945,970],"id":"bcc48126-b815-4167-b422-165fd008dd38","name":"Groq Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[945,1390],"id":"52378d3c-1d35-4cef-bd6d-b2fa23090525","name":"Run Calculations"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[1174,1390],"id":"2b2d1744-8969-4233-a968-c447f05b76d5","name":"Search Reference Wiki"},{"parameters":{"toolDescription":"Fetch live request data from the internal REST API by id or query.","url":"https://api.example.com/v1/requests","options":{}},"type":"@n8n/n8n-nodes-langchain.toolHttpRequest","typeVersion":1.1,"position":[1633,1390],"id":"f294040e-ecf1-44bd-a8d8-8458861e01cd","name":"Lookup API Data"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolThink","typeVersion":1,"position":[2322,1390],"id":"5753acf4-6cb1-4740-8287-b55294a01dd5","name":"Think It Through"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $json.sessionId || $execution.id }}","contextWindowLength":12},"type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.3,"position":[2079,970],"id":"bf8c27c0-d9ab-4b7a-a1e4-1525582c4cec","name":"Conversation Memory"},{"parameters":{"assignments":{"assignments":[{"id":"b5d317b3-154c-4c87-8004-a10fb419b708","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"591c1c04-32e4-4d68-8c68-8eea08e167d1","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2646,400],"id":"fffede58-8adc-46df-b30f-170c1769c989","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c6abade9-84fb-42e2-b3d0-12b09d80b9fd","leftValue":"={{ $json.confidence }}","rightValue":"high","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[2970,400],"id":"c40d01d3-7320-4666-9934-cf9cf8c05f46","name":"Confident Enough?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3294,160],"id":"8ecbc11c-8b19-4373-b913-b3b6ea8fb7ef","name":"Deliver Answer + Log to Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🙋 Low-confidence answer needs review: {{ $json.answer }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3618,760],"id":"5fc49e44-6e19-4d34-bfe8-3358d098ddd2","name":"Escalate to Human Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[4266,400],"id":"36b35673-8a06-480e-9a44-d9c005c9d426","name":"Join Outcomes"},{"parameters":{"assignments":{"assignments":[{"id":"63061bdf-808c-4c87-b214-6c33ebad210d","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5feae86d-9412-470d-8260-a1c3dbb9d236","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"7eaae6c6-5b67-48a2-a111-a2431a5b5090","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"41a0c308-d41a-41c2-8fc3-fce97d7c67bf","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"15decf57-5150-4ef0-b2a7-27efd9f9575a","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Handle user questions hands-free for Research Assistant (01011) — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,400],"id":"d246f176-8ee5-40a5-856b-12edfcdd6340","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"bbc75359-7b8e-44e9-835e-0b2019e46235","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"111a5818-9e9b-4f85-8d6a-565d29ace93e","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"7443948d-1f51-4db6-9102-6dd43ad3c971","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,1420],"id":"074cd12a-1c3b-4503-b59d-5c002412ffd1","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5562,1420],"id":"4248b5be-d495-4a56-b389-4077db5b97c7","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,1420],"id":"3845b778-efa5-4d59-9007-c36eadfae01f","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### When Chat Message Received\n\nOpens a hosted chat session; every user message starts an execution with `chatInput` + `sessionId`.\n\nNext: Stamp & Shape Request","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"36bb7cce-507e-fb04-bfff-e0ced8a3192b","name":"Note: When Chat Message Received"},{"parameters":{"content":"### Stamp & Shape Request\n\nShapes the item: writes `requestId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"759ae4d3-c6f3-bea0-94f9-04ea21c9da3b","name":"Note: Stamp & Shape Request"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.requestId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Reason & Act (AI Agent) · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"be924faa-c1c6-7f67-6d1d-32fa2498d326","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"ef23698a-cc0d-28b1-61fe-e9a1323d54b9","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Reason & Act (AI Agent)\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Shape Agent Output · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"d7f36240-b533-50b0-1894-5276ba216abd","name":"Note: Reason & Act (AI Agent)"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Reason & Act (AI Agent)** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"1a04c4ab-de01-cb93-c9f5-5116de7b142c","name":"Note: Groq Chat Model"},{"parameters":{"content":"### Run Calculations\n\nMath tool — keeps arithmetic exact instead of letting the LLM guess.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1510],"id":"4c2b1881-9268-b2fc-e67e-08f6b76b7f61","name":"Note: Run Calculations"},{"parameters":{"content":"### Search Reference Wiki\n\nReference lookup tool for general-knowledge questions.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1114,1750],"id":"34ba379c-edb3-bfa2-666c-9855ced06f8d","name":"Note: Search Reference Wiki"},{"parameters":{"content":"### Lookup API Data\n\nTool the agent can call to hit the REST API with parameters it chooses at runtime.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1573,1510],"id":"b07c1403-2f4a-84df-dbe5-5a085ecf9e34","name":"Note: Lookup API Data"},{"parameters":{"content":"### Think It Through\n\nScratchpad tool: lets the agent reason step-by-step before acting.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,1510],"id":"e1247d64-466e-1497-88ba-bff453e278f1","name":"Note: Think It Through"},{"parameters":{"content":"### Conversation Memory\n\nConversation memory keyed by session — the bot remembers earlier turns for each user separately.\n\nFeeds **Reason & Act (AI Agent)** as `memory`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2019,1090],"id":"c1b2f8f6-bbdc-52dd-d932-51e998338e60","name":"Note: Conversation Memory"},{"parameters":{"content":"### Shape Agent Output\n\nShapes the item: writes `answer`, `confidence`. Keeps the schema explicit between stages.\n\nNext: Confident Enough?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"4dde1a50-7799-c7c9-9c96-d08dfbc1a55b","name":"Note: Shape Agent Output"},{"parameters":{"content":"### Confident Enough?\n\nTwo-way gate on `={{ $json.confidence }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Deliver Answer + Log to Google Sheets · ②→ Escalate to Human Queue","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"5d3079c2-1202-b845-d89f-c3cb0d87b52b","name":"Note: Confident Enough?"},{"parameters":{"content":"### Deliver Answer + Log to Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,280],"id":"7eb4462f-576f-63d2-e584-d77064cbaa1f","name":"Note: Deliver Answer + Log to Google Sheets"},{"parameters":{"content":"### Escalate to Human Queue\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,880],"id":"d4eb02b6-d40a-3a87-6826-990355358ee0","name":"Note: Escalate to Human Queue"},{"parameters":{"content":"### Join Outcomes\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"c3191101-3d3b-2da1-ac01-94837ab74005","name":"Note: Join Outcomes"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"711f7cf1-1cbf-291d-d159-dfc2eaec9dda","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"20609985-bfce-6210-2af6-c6678792a603","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"e8b78da5-4d8a-5c1e-4586-cda0f2f32947","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"00e4e374-35b9-d788-331e-8c5302e46c2a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"d4d5f0fc-7aac-7d0a-d900-3376e7f1e7d6","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"7b4e055d-86e1-e335-8288-5d70b760f168","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Handle user questions hands-free for Research Assistant (01011)\n\n**Pattern:** Chatbot Responder · **Level:** Production · **Trigger:** Chat\n\n## What it does\nHandle user questions hands-free for Research Assistant (01011). It responds live to chat messages.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWhen Chat Message Received → Stamp & Shape Request → Payload Valid? → Reason & Act (AI Agent) → Shape Agent Output → Confident Enough? → Deliver Answer + Log to Google Sheets → …\n\n## Use it for\n- Teams that want to chatbot responder without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Standardizes the process every time\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Groq API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"3d041a9f-3be0-e38a-c4a9-7c2501914a4e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"1f89707c-5e0b-8326-b925-dd3750dd12d6","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"69370352-98d2-ac94-ebd7-e562d695c7d1","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"1ebdaadb-95b3-20a3-bb42-99c678e91c96","name":"🛠 Customize me"}],"connections":{"When Chat Message Received":{"main":[[{"node":"Stamp & Shape Request","type":"main","index":0}]]},"Stamp & Shape Request":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Reason & Act (AI Agent)","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Reason & Act (AI Agent)","type":"ai_languageModel","index":0}]]},"Run Calculations":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Search Reference Wiki":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Lookup API Data":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Think It Through":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Conversation Memory":{"ai_memory":[[{"node":"Reason & Act (AI Agent)","type":"ai_memory","index":0}]]},"Reason & Act (AI Agent)":{"main":[[{"node":"Shape Agent Output","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Shape Agent Output":{"main":[[{"node":"Confident Enough?","type":"main","index":0}]]},"Confident Enough?":{"main":[[{"node":"Deliver Answer + Log to Google Sheets","type":"main","index":0}],[{"node":"Escalate to Human Queue","type":"main","index":0}]]},"Deliver Answer + Log to Google Sheets":{"main":[[{"node":"Join Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Escalate to Human Queue":{"main":[[{"node":"Join Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Outcomes":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"b1b6f904-1ab8-4f9f-b77e-5d498b35aa66","id":"FDX01011"}