| $json.text }}","bodyContent":"={{ $json.html || $json.response?.text || $json.text }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[1917,100],"id":"ae9b6957-9b78-41cb-a5d7-abd7b80ec04f","name":"Post Digest to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"={{ $json.html || $json.response?.text || $json.text }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2241,610],"id":"9c66940d-34bf-4e45-ae1c-e74c4e671ce7","name":"Post Digest to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2889,400],"id":"a5dee315-a1f8-4d93-80d1-2c21d96e08c4","name":"Confirm All Sends"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[3861,400],"id":"c95c6c84-eb70-43c6-9a42-7202822120cf","name":"Archive Digest in Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4185,400],"id":"d7f9c39e-80f2-49a1-aea8-bca650f40950","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4509,400],"id":"ffe85843-ec70-438e-9e8c-9c464ca14096","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4833,400],"id":"69ad8771-effc-41c7-8efe-51734ac4efd1","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5157,400],"id":"cf87d836-b896-443d-b279-31e6443ca71a","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5481,400],"id":"fd637a7c-6778-42a9-8360-046906bce88e","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"978291d6-95c0-4fcd-b2cd-e6863488e30d","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6abc5a27-7c88-4248-8efb-d448e12ae7f5","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5805,400],"id":"9b0a3376-437c-40aa-9115-40650a64dd19","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"3933b3c6-14ed-43f7-866e-a5d1362c8a5c","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c5d38db6-8bca-4fc6-8257-1c37500f9447","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"3b92be88-7942-4300-aed3-befa863b7203","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6129,400],"id":"93401e35-73d6-4dee-9f23-ffbf38c21270","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6453,400],"id":"a30880a5-a1bf-47fe-aa33-cc19125c48e9","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Digest documents with Notion and Outlook — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6777,400],"id":"eb963713-ca7d-4e6d-aa9a-926318bf4bf8","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d726494c-7f76-47b4-82b3-384fea8698f3","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"b3dc4ec4-f4e7-47f2-af29-d3f55deb2bd6","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ef1260b3-cfc5-406f-8f7f-a323b99b4d7e","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6129,1420],"id":"77d45902-2a2a-4a35-ad11-844d93287dca","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6453,1420],"id":"a5edc5a5-75f8-42ab-ad45-ea05d9b17014","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6777,1420],"id":"c601bf18-5f79-4a77-b6c6-a070ea53e4b1","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf01499-request`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Pull Fresh Items (API)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ef23e06d-acb7-1ab8-e753-1c645dc2afb7","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Pull Fresh Items (API)\n\nGET https://api.example.com/v1/requests — retries 3× with backoff on failure.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"91238e60-9d12-6a18-6abc-05f7a9a519de","name":"Note: Pull Fresh Items (API)"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"0bf69bf1-8044-ca12-73f7-ec05f6ed8500","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"217fd40c-8b5c-a688-810e-d4404ac0ffb6","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Render as HTML · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"497c9298-3b42-50fe-c561-286269126e7f","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"e3e0fd31-70f7-5104-12ac-802c08df6e1f","name":"Note: Groq Chat Model"},{"parameters":{"content":"### Render as HTML\n\nConverts markdown to HTML for rich rendering in email/CMS.\n\nNext: Post Digest to Outlook","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"9c9e1fea-fb90-86fe-8fdd-639ebb97b101","name":"Note: Render as HTML"},{"parameters":{"content":"### Post Digest to Outlook\n\nmicrosoftOutlook — `action` operation against the connected account.\n\nPorts: ①→ Confirm All Sends · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,220],"id":"1794eded-09d8-9caa-855f-f531f4d24b81","name":"Note: Post Digest to Outlook"},{"parameters":{"content":"### Post Digest to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Confirm All Sends · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,730],"id":"1e8cc026-57c1-5458-18a3-321641f9d3d6","name":"Note: Post Digest to Slack"},{"parameters":{"content":"### Confirm All Sends\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Archive Digest in Notion","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"d4f1c4ad-a276-fd58-d70f-3711966257bc","name":"Note: Confirm All Sends"},{"parameters":{"content":"### Archive Digest in Notion\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"23534a80-0476-c8e6-6b89-d334ad0a3f20","name":"Note: Archive Digest in Notion"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"f0ae4ebd-75a2-77dd-2644-266b81ead21a","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"60ddee5c-201f-d950-7e4e-551365834cd5","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"168883ed-aea7-6bcf-0ab1-a8b55c796aea","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"c3fdac58-fb9a-8ac9-c5a8-e53776a7017f","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"a4e14155-f351-8921-4b43-2fedfd0b06f6","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"35db0495-d616-05d9-f55d-49030468f97d","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"805d7ad1-04b8-a94c-3fd1-a80ebf15bbdb","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"ba5c836d-f747-4d9b-6b2a-ffb63c11ee23","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"a439c6a3-2262-6f30-0827-938443576862","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,1540],"id":"1335e8e0-834e-d9ae-2c3d-33dcd687073e","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,1540],"id":"c4c8caf7-8377-60ed-1b02-ea93414d22b1","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,1540],"id":"d39f8d70-b7fb-cf1a-3ed8-47f3c471155e","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Digest documents with Notion and Outlook\n\n**Pattern:** AI Summarize & Route · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nDigest documents with Notion and Outlook. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Pull Fresh Items (API) → Newest First → Trim to Digest Size → Summarize Content (AI) → Render as HTML → Post Digest to Outlook → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Standardizes the process every time\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Groq API key; Microsoft OAuth2; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"ab18d979-73a7-08a6-a433-91da5e5744c3","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-320],"id":"15db053e-6142-c0a0-7d9b-1f5fd42eaf72","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-320],"id":"fa11beb2-d661-6bc5-2458-e74764b714f6","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-320],"id":"2d835471-42e0-cee9-30e7-bb1ac7dde99b","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-320],"id":"80657b86-07d1-2660-c470-bb7587d8ff5e","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Pull Fresh Items (API)","type":"main","index":0}]]},"Pull Fresh Items (API)":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Render as HTML","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Render as HTML":{"main":[[{"node":"Post Digest to Outlook","type":"main","index":0},{"node":"Post Digest to Slack","type":"main","index":0}]]},"Post Digest to Outlook":{"main":[[{"node":"Confirm All Sends","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Post Digest to Slack":{"main":[[{"node":"Confirm All Sends","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Confirm All Sends":{"main":[[{"node":"Archive Digest in Notion","type":"main","index":0}]]},"Archive Digest in Notion":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"bef0f5d6-cf52-4858-85c6-90695073b38e","id":"FDX01499"}