      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "bdefa727-95ed-4ae3-8242-335b141a75ad",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "2bf172cb-7cb0-4792-b5b4-b893b7574bfb",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "0bad0feb-e62b-4e75-bcfe-3daba9b8166b",
