 Found?"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["requestId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1269,160],"id":"d0d48fdb-5808-47c4-aa5a-9d18f5f894ab","name":"Upsert into Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✍️ Extraction incomplete for {{ $json.fileName || 'document' }} — please review.","otherOptions":{}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[1593,760],"id":"4afe4b46-c7d1-4201-b8af-024eab61d3d1","name":"Queue for Manual Review","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2241,400],"id":"41f0b7cb-7f2e-4c0f-804a-2b8107aaa890","name":"Merge Review Paths"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3213,400],"id":"0b1b63b5-bc9e-4207-aff2-0af363a6804a","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"86940206-5b86-4fb2-95bc-e8b891c91210","name":"pipeline","value":"Research Assistant","type":"string"},{"id":"7adb2d1a-a50d-4d63-b8e1-be70b68720b6","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3537,400],"id":"8d9bf4ed-0721-4cb5-91e3-9e446da2fbe3","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"requestId","value":"={{ $json.requestId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3861,400],"id":"18b2eb5e-ae0c-47ac-b102-efff78aa3ef6","name":"Save Execution Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"priority","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[4185,400],"id":"ae8a3f36-8720-4e99-8cc7-172990829162","name":"Sort Requests Newest First"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ab03e20c-87f7-41e2-a498-138da230bdd4","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[4509,400],"id":"85dc1a80-bb2f-4069-a6ef-7327f8b0d1d2","name":"Guard Non-Empty query"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"requestId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[4833,400],"id":"98ae8ed6-f8ab-4bdc-a483-c2d13b319b23","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"4dc26594-fe6d-424f-ae4e-79ecf6d1dacb","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"eb6c1413-50c9-4257-be64-1f154d68a637","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"026b767b-ee8c-4808-9768-32ef27283cfb","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,400],"id":"387fb951-38b3-4362-a0a3-90ec49dbbff0","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5481,400],"id":"f25b1319-454c-44f5-9520-802b60723fca","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Power an AI agent task with Telegram — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,400],"id":"f3fd820b-e493-45c6-864a-9c899554569b","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"736b24c4-7a2b-4093-bd53-2dea7d81bcf1","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a29ad899-64f4-47d3-b036-ed5db7ae37b9","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"3f20443b-97ec-4267-bc43-9c14b8fcdee6","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,1420],"id":"7ac25cb9-b4ba-4dce-aedb-01dfb56e6d4e","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5481,1420],"id":"2b920a6e-2a1d-4860-99c8-d446365dfbb3","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### On Telegram Event\n\nNative push trigger — telegram calls this workflow the moment the event happens (no polling).\n\nNext: Collect Raw Text\n\n🔑 Telegram bot token","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"cb233bd3-d773-8043-bae1-8c1d40787597","name":"Note: On Telegram Event"},{"parameters":{"content":"### Collect Raw Text\n\nShapes the item: writes `content`. Keeps the schema explicit between stages.\n\nNext: Extract Structured Fields","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"31dfc20e-0ee0-8875-0d2a-7feb58ef4cae","name":"Note: Collect Raw Text"},{"parameters":{"content":"### Extract Structured Fields\n\nPulls structured fields (requestId, query, context) out of free text using a strict extraction prompt.\n\nPorts: ①→ All Required Fields Found? · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"9d447e65-5444-e3d2-4a0e-4dec15f0a44e","name":"Note: Extract Structured Fields"},{"parameters":{"content":"### OpenRouter Chat Model\n\nChat model powering the AI step (model: `anthropic/claude-sonnet-4.5`). Swap providers here without rewiring.\n\nFeeds **Extract Structured Fields** as `languageModel`\n\n🔑 OpenRouter API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"33d0a4a1-96d1-1a01-cc56-93e92a0c8194","name":"Note: OpenRouter Chat Model"},{"parameters":{"content":"### All Required Fields Found?\n\nTwo-way gate on `={{ $json.output?.requestId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Upsert into Google Sheets · ②→ Queue for Manual Review","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,520],"id":"f553a6cc-7cff-e02b-adca-d6f1805c3de0","name":"Note: All Required Fields Found?"},{"parameters":{"content":"### Upsert into Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Review Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,280],"id":"80effab5-6c53-a7a2-f167-2c4b60a8d5e4","name":"Note: Upsert into Google Sheets"},{"parameters":{"content":"### Queue for Manual Review\n\ntelegram — `action` operation against the connected account.\n\nPorts: ①→ Merge Review Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,880],"id":"8cb157eb-f97c-3d05-188c-e58564584a18","name":"Note: Queue for Manual Review"},{"parameters":{"content":"### Merge Review Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"63f83465-d288-6533-6064-499a108b1969","name":"Note: Merge Review Paths"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"cc72a81f-b830-a0e1-2665-f5e8f14b6487","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"59e0fd18-c5a1-ecda-dd24-8f399a37c760","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Sort Requests Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"8c2030e0-c04a-5e80-a27d-6febf5a50b12","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Sort Requests Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Guard Non-Empty query","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"1d416f9b-a1ec-7b29-900b-1f51090b1989","name":"Note: Sort Requests Newest First"},{"parameters":{"content":"### Guard Non-Empty query\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"3714e1ec-102c-cb05-4644-dd7870fce5a6","name":"Note: Guard Non-Empty query"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"9e282d68-6ca7-2d4c-b2a9-c02619ca6cec","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"1ecf531e-c5ee-0e7f-a9fa-7c9444dca9d1","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"85b66220-c441-5d73-ab58-a33964b951bc","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"d16706a8-9008-7aff-0c3e-4147f1b7ff80","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"b8ea8890-e7f6-df2b-54b9-4249f8247630","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"ec5db7c0-cd2a-8e3d-443c-3f889c2b23e8","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Power an AI agent task with Telegram\n\n**Pattern:** AI Agent · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nPower an AI agent task with Telegram. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual research assistant is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nOn Telegram Event → Collect Raw Text → Extract Structured Fields → All Required Fields Found? → Upsert into Google Sheets → Merge Review Paths → Stamp Processing Time → …\n\n## Use it for\n- Teams that want to ai agent without manual effort\n- Anyone automating research assistant in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Removes copy-paste errors\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; OpenRouter API key; Slack OAuth2; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a8378484-9840-5fbc-f810-21d270b9d222","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"b2f0d1e1-a13e-c188-9879-6dc10048e76e","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"2946692c-a0a3-2509-ca4a-05382c0e3b08","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research assistant process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"ba810db3-d920-ac4c-f440-28f5883e4856","name":"🛠 Customize me"}],"connections":{"On Telegram Event":{"main":[[{"node":"Collect Raw Text","type":"main","index":0}]]},"Collect Raw Text":{"main":[[{"node":"Extract Structured Fields","type":"main","index":0}]]},"OpenRouter Chat Model":{"ai_languageModel":[[{"node":"Extract Structured Fields","type":"ai_languageModel","index":0}]]},"Extract Structured Fields":{"main":[[{"node":"All Required Fields Found?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"All Required Fields Found?":{"main":[[{"node":"Upsert into Google Sheets","type":"main","index":0}],[{"node":"Queue for Manual Review","type":"main","index":0}]]},"Upsert into Google Sheets":{"main":[[{"node":"Merge Review Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Queue for Manual Review":{"main":[[{"node":"Merge Review Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Review Paths":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Sort Requests Newest First","type":"main","index":0}]]},"Sort Requests Newest First":{"main":[[{"node":"Guard Non-Empty query","type":"main","index":0}]]},"Guard Non-Empty query":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"1922e7d9-33a6-4596-ad99-7ae15fb04c2a","id":"FDX00683"}