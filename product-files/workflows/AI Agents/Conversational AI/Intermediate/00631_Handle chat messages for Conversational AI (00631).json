tring"},{"id":"d08fcedc-7491-4ef2-9154-35b954cefe24","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5170,400],"id":"c4601cdb-afb1-4e24-af94-356fabe3a4e5","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5494,400],"id":"2703170f-e34d-44d4-ac86-00dfb7610c9c","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5818,400],"id":"e3082a3d-5f46-450a-af4d-cecace506dee","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6142,400],"id":"1ff62bd5-f2f3-4ddf-8946-d155dd6883b6","name":"Stamp Processing Time"},{"parameters":{"dataToSave":{"values":[{"key":"requestId","value":"={{ $json.requestId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6466,400],"id":"4eb2a61b-3cf4-4bb2-b994-a98c6d08abbe","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"1b2830fb-292b-4952-bd10-a3b9d89e10ed","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"12e05533-3ba9-4c55-8a35-9c162f1bc61f","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"f3e52015-85b6-410b-9bbc-34d4018a7a71","name":"status"