      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "2623956c-46b5-4b1f-9c62-13e1a789c772",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "ce2d250d-97be-4290-bcb4-571dd484e7da",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "7bf448ae-0dc8-4874-87af-02bfaed7d944",
      "name": "Validate Input",
