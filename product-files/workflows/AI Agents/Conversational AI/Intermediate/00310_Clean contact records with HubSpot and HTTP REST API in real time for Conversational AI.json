{
  "name": "Clean contact records with HubSpot and HTTP / REST API in real time for Conversational AI",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 6
            }
          ]
        }
      },
      "id": "6867da1a-2598-404b-99f6-eb1e46722a36",
      "name": "Schedule Trigger",
