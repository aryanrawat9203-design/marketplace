{"name":"Distill documents with Notion and Discord 24/7","nodes":[{"parameters":{"httpMethod":"POST","path":"wf01212-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"bc20b43d-5416-4d3a-b694-47d849446aa5","name":"Receive Inbound Webhook","webhookId":"ad71d18b-dced-4037-9f3f-97e1ae3f5184"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"62c4a97b-f26e-4711-91dd-a7acff98e0dd","leftValue":"={{ $json.requestId || $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"32426eb2-3132-48aa-b3bd-2c5c83459a86","name":"Keep Valid Requests"},{"parameters":{"inputText":"={{ $json.query || JSON.stringify($json) }}","categories":{"categories":[{"category":"Action Needed","description":"Requests that are action needed for the conversational ai team."},{"category":"Reference","description":"Requests that are reference for the conversational ai team."},{"category":"Ignore","description":"Requests that are ignore for the conversational ai team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"a6722cb0-9c0f-4cbf-b0bd-265503953fa8","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[621,970],"id":"fdbaf4ae-cf63-46fb-9923-72f5f25561fa","name":"Groq Chat Model"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[945,-80],"id":"10509274-1492-4069-8447-876fad938ceb","name":"Store as Action Needed","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1269,370],"id":"b0de8b1d-dcf4-4b56-9a07-5934db09d21c","name":"Store as Reference","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1593,820],"id":"005d141e-c7c5-46fd-8227-497f8a180f60","name":"Store as Ignore","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=[Other] {{ $json.query }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1917,1270],"id":"b39f60b0-a53b-4401-8120-69d7694f092e","name":"Alert Slack — Other","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2565,400],"id":"fda51f16-51a5-4a8d-845c-d09418016823","name":"Reunite Branches"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3537,400],"id":"1d0aac39-c9fa-4abe-b60b-3de114a9c2e6","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3861,400],"id":"814a7bb6-ee75-4ad5-a83a-6b0fc7a118f7","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4185,400],"id":"7f4ef7fa-180d-4add-90d3-65b36ad9df04","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4509,400],"id":"8e9915e4-1fb5-4b5a-8077-b57804524a9b","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4833,400],"id":"95669aca-5ae7-4fcc-a82a-d111f64926e7","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5157,400],"id":"2021889d-d323-407c-a449-4da172526538","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5481,400],"id":"903610d1-c1ed-4dbc-aed7-24b449c62bb3","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"5a3655ba-5940-4abe-91bb-f27bd4897f76","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"667f50ee-e6d7-4d2a-8ef2-f6458dcd2231","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5805,400],"id":"c32c02ee-fbca-4722-894b-10ef22a40adf","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"4399d1a3-3fb1-4c6b-a131-9ff9b6db4e8b","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e8d38ad4-7fd5-496f-be46-91b100c86030","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"37e2b226-6bee-4014-bb5f-580f0e589f0b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6129,400],"id":"ea1590b3-93b9-4a61-bfc9-c7f5bd3444a3","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6453,400],"id":"323cca5a-75d8-4ac7-b533-a3a172460bdb","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Distill documents with Notion and Discord 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6777,400],"id":"9a4bf5ba-a241-4d12-a11b-ff34dcb5465d","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d676aaca-e23f-40b8-ae26-a223f9c670b0","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"fa28d703-16f3-41e6-b957-caa14312b609","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"1a2e7f63-9051-49de-8adc-64eed663cdae","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6129,1420],"id":"76b596a7-63a8-4fd9-886e-1d2e36645970","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6453,1420],"id":"b80de871-3cb0-4028-a841-fe17f8cca605","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6777,1420],"id":"43893c28-b148-47e3-aa3a-198efb491ecd","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf01212-request`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Keep Valid Requests","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"bf9c67f6-d9a2-f874-3ceb-779e1b109faf","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Keep Valid Requests\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Classify with AI","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"1c204f98-7110-ede6-7aee-e086f277dbc9","name":"Note: Keep Valid Requests"},{"parameters":{"content":"### Classify with AI\n\nLLM classification into: Action Needed, Reference, Ignore (+fallback). Output port order matches this list.\n\nPorts: ①→ Store as Action Needed · ②→ Store as Reference, Capture Failure Context · ③→ Store as Ignore · ④→ Alert Slack — Other\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"68b0ab95-5961-3bc6-3be6-448d38c4fb59","name":"Note: Classify with AI"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Classify with AI** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"1784d1cd-8ab5-ed8e-1db8-9459dbbc16ce","name":"Note: Groq Chat Model"},{"parameters":{"content":"### Store as Action Needed\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,40],"id":"9bd6f1a5-ae23-364a-f0ab-f859baa57f36","name":"Note: Store as Action Needed"},{"parameters":{"content":"### Store as Reference\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,490],"id":"817175e7-0aa4-a573-8acb-2a9f5dea08ee","name":"Note: Store as Reference"},{"parameters":{"content":"### Store as Ignore\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,940],"id":"0d9fc2f5-d8e3-ab4a-35bc-5ee49da72f6a","name":"Note: Store as Ignore"},{"parameters":{"content":"### Alert Slack — Other\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,1390],"id":"b483dbc6-15cb-3267-56d2-8dba966e4a3b","name":"Note: Alert Slack — Other"},{"parameters":{"content":"### Reunite Branches\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"448c83f3-3ca2-9dab-e533-60cdc4b16335","name":"Note: Reunite Branches"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per request (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"003721b8-3cbd-2907-eca9-2603394a76d1","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"cc12d3e9-152c-60b2-9f75-8e9286659f13","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"8f633682-1e1c-5922-a0bd-13d84cd3d97c","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"def9773c-e23f-9ff9-b73c-b59219f4411e","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"634feaa8-5c6c-84dc-3a2c-45ddcf781a60","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"b0b47faa-634e-f00f-5b10-81ec92535e87","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"ffade75c-ab04-fc0b-dcc4-c8d5901d9084","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"3ce94876-8681-a458-5bbe-0b62ad2b05c7","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"cf4627d3-17e2-97b1-5f00-3d54391ed14f","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"0d48391f-b639-a52c-2ea9-2227e45dbfcb","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"dadb2c98-f17e-66ba-4e4b-0e2d2319b70a","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,1540],"id":"802ffcbe-f496-d2e6-9b7e-3207f18d03e5","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,1540],"id":"2c656880-1b5b-16a5-e244-a1d1c3100734","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,1540],"id":"19ad492e-2c71-bd1f-7b3e-e6e131e984bc","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Distill documents with Notion and Discord 24/7\n\n**Pattern:** AI Summarize & Route · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nDistill documents with Notion and Discord 24/7. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual conversational ai is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Keep Valid Requests → Classify with AI → Store as Action Needed → Reunite Branches → Fingerprint for Idempotency → Drop Already-Processed Items → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating conversational ai in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Removes copy-paste errors\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Groq API key; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"038896ba-f7b5-8af3-2cce-eef48d9e54d4","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"7c4f7c23-a128-69cb-43a8-02d593de284e","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"cf08b5e7-e185-7e91-6e9d-b0d6c0de2e9f","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"1abcaeff-2b69-2029-38fa-a18916d57ac2","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your conversational ai process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-500],"id":"ced60884-6d69-6e98-decd-4d8de864f41e","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Keep Valid Requests","type":"main","index":0}]]},"Keep Valid Requests":{"main":[[{"node":"Classify with AI","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Classify with AI","type":"ai_languageModel","index":0}]]},"Classify with AI":{"main":[[{"node":"Store as Action Needed","type":"main","index":0}],[{"node":"Store as Reference","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Store as Ignore","type":"main","index":0}],[{"node":"Alert Slack — Other","type":"main","index":0}]]},"Store as Action Needed":{"main":[[{"node":"Reunite Branches","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Reference":{"main":[[{"node":"Reunite Branches","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Ignore":{"main":[[{"node":"Reunite Branches","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Alert Slack — Other":{"main":[[{"node":"Reunite Branches","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Reunite Branches":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"44dfe6fc-aed7-4f6f-a7bb-2e77f16ebeaf","id":"FDX01212"}