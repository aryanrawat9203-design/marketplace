{"name":"Reply to chat messages without manual work","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"00935e47-e01a-4990-848b-ca955c0a32a6","name":"When Chat Message Received","webhookId":"cacbb8ca-4d8f-42b2-83fe-0ea73252aa50"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"11d2760a-f9ad-4495-9a0f-84b35cb122f1","leftValue":"={{ $json.requestId || $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"1e23c107-d77e-4093-8bbf-536216f11999","name":"Keep Valid Requests"},{"parameters":{"assignments":{"assignments":[{"id":"f9b5b1b2-41c8-4956-81e7-58a7e352da83","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"49e9a5a4-04ba-4c7a-8415-d04525ac2ee5","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"f2a02a9e-60fa-4f31-aabb-fdee87676537","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a conversational ai pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"a36f9eb9-e02b-45de-ba21-c2a17e175c6d","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[945,970],"id":"f9736b6e-c09d-4c21-b