{
  "name": "Augment contact records with HubSpot and HTTP / REST API on autopilot for Conversational AI",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "triggerAtHour": 17,
              "triggerAtMinute": 0
