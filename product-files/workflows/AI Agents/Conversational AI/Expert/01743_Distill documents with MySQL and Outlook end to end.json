d":"c5f6ecc6-972f-4879-84b9-64b527de087a","name":"Log Neutral Feedback","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=💚 Positive feedback received: {{ $json.query }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,880],"id":"a2625405-ca17-4088-83be-bb5130717c22","name":"Thank the Sender","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2565,400],"id":"c85ded30-335e-42bd-8fcf-a08e0c2b3992","name":"Collect All Outcomes"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"priority","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3861,400],"id":"d55e23b9-ba77-45e1-8ad3-6c88dca0047f","name":"Sort Requests Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"e119c13d-ffd4-4ad4-98c8-c14f1908b22a","name":"pipeline","value":"Conversational AI","type":"string"},{"id":"cae2767a-4211-4955-a23c-0684bfa96f3e","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4185,400],"id":"73b2301a-7a07-43bb-8d57-204ec1ece20f","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"requestId","value":"={{ $json.requestId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4509,400],"id":"4492f3b1-0a67-4497-950a-12c0893c4367","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4833,400],"id":"8caf0f35-9e94-41c6-b1f8-1758fa5785f4","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1b4b4ce4-e2de-4ba5-9b46-b973ac8333b8","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[5157,400],"id":"63705ab8-f81c-4a84-bce9-c245d826c8d7","name":"Guard Non-Empty query"},{"parameters":{"assignments":{"assignments":[{"id":"a8df5101-e223-44e5-89a6-9beffa96b73d","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"162f3841-9c5f-41d5-934f-c51a637d148a","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"b3c5aa2e-c16b-4b60-a482-93f3e0015c4b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,400],"id":"fa949f66-6c72-4c9f-a399-a77c78b46959","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"requests","cachedResultName":"requests"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[5805,400],"id":"cc05e95d-6903-44f7-8ddf-0aac6e4b2fe8","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Distill documents with MySQL and Outlook end to end — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6129,400],"id":"99bf76b8-ec0e-4a45-952c-65b90c4d4bfb","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"07aa42d6-9636-41cf-b777-f6d85c556196","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"05eb4931-ee6f-4e06-81c2-2698546f2e9d","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"95db7c86-940a-4c47-85c2-8f3922e19e37","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,1420],"id":"7a64e432-429d-4bf4-85bc-8ec1ffa7ec33","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,1420],"id":"68ce3e68-7db0-4a99-8093-d6b9eacfb302","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf01743-request`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Keep Valid Requests","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"6eec17a5-bb8b-ea3c-fc0e-b2a4f777590d","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Keep Valid Requests\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Detect Sentiment","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"17575b92-f3ce-ffed-a833-098a57bf827e","name":"Note: Keep Valid Requests"},{"parameters":{"content":"### Detect Sentiment\n\nScores the text's sentiment; ports fire positive / neutral / negative.\n\nPorts: ①→ Escalate Negative — Outlook · ②→ Log Neutral Feedback, Capture Failure Context · ③→ Thank the Sender\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"4e7908b6-0754-b101-a638-2d5b0727470a","name":"Note: Detect Sentiment"},{"parameters":{"content":"### OpenRouter Chat Model\n\nChat model powering the AI step (model: `anthropic/claude-sonnet-4.5`). Swap providers here without rewiring.\n\nFeeds **Detect Sentiment** as `languageModel`\n\n🔑 OpenRouter API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"ea99b1fc-56af-4001-38e8-58bb934212a5","name":"Note: OpenRouter Chat Model"},{"parameters":{"content":"### Escalate Negative — Outlook\n\nmicrosoftOutlook — `action` operation against the connected account.\n\nPorts: ①→ Collect All Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,40],"id":"e728b4c5-3ffa-3a2f-627a-ec8304872010","name":"Note: Escalate Negative — Outlook"},{"parameters":{"content":"### Log Neutral Feedback\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Collect All Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,520],"id":"39311269-c685-cfdd-4593-7403ede73efd","name":"Note: Log Neutral Feedback"},{"parameters":{"content":"### Thank the Sender\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Collect All Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,1000],"id":"17f0f416-86f3-3914-2982-55ef00e09299","name":"Note: Thank the Sender"},{"parameters":{"content":"### Collect All Outcomes\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Sort Requests Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"015c0789-acb7-86e3-8838-3600d5dc2c17","name":"Note: Collect All Outcomes"},{"parameters":{"content":"### Sort Requests Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"34e334bf-eaae-d581-b096-74bc289aee56","name":"Note: Sort Requests Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"ca228a59-b623-dafb-c1f3-d7af5c88c5e6","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"005bac23-60c1-8cac-81a2-b91754fcc47d","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Guard Non-Empty query","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"1b54bf1f-ea02-7d12-3424-279fd4d50500","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Guard Non-Empty query\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"e6682885-ce59-f56f-d21b-404fbd742156","name":"Note: Guard Non-Empty query"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"282dabab-f55d-7be3-f56b-31d80509a41f","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"a8ecacf6-053b-7108-2346-482328e4ff5f","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"d8f44072-10ef-8388-3451-593f897de155","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"8e3e1ed2-9974-45b4-0fe0-e937fc451d74","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,1540],"id":"5f3b1e72-56d1-0e83-697a-d2d8d1c75223","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Distill documents with MySQL and Outlook end to end\n\n**Pattern:** AI Summarize & Route · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nDistill documents with MySQL and Outlook end to end. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual conversational ai is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Keep Valid Requests → Detect Sentiment → Escalate Negative — Outlook → Collect All Outcomes → Sort Requests Newest First → Tag Pipeline Metadata → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating conversational ai in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Removes copy-paste errors\n- Improves response time\n\n## Before first run\nConnect credentials: Microsoft OAuth2; MySQL connection; OpenRouter API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"aa670072-17da-a422-013c-5fa18344f737","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"46d6f3f6-0ad2-6c4a-9266-77feccf30c28","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"a8baa3b0-4c82-df48-5ea8-7eba7a71e90a","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"5ca5afa0-63f4-5991-6496-864314d1d340","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your conversational ai process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-500],"id":"016b24b0-b812-742e-6c1f-4ead596ee81d","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Keep Valid Requests","type":"main","index":0}]]},"Keep Valid Requests":{"main":[[{"node":"Detect Sentiment","type":"main","index":0}]]},"OpenRouter Chat Model":{"ai_languageModel":[[{"node":"Detect Sentiment","type":"ai_languageModel","index":0}]]},"Detect Sentiment":{"main":[[{"node":"Escalate Negative — Outlook","type":"main","index":0}],[{"node":"Log Neutral Feedback","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Thank the Sender","type":"main","index":0}]]},"Escalate Negative — Outlook":{"main":[[{"node":"Collect All Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Neutral Feedback":{"main":[[{"node":"Collect All Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Thank the Sender":{"main":[[{"node":"Collect All Outcomes","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Collect All Outcomes":{"main":[[{"node":"Sort Requests Newest First","type":"main","index":0}]]},"Sort Requests Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Guard Non-Empty query","type":"main","index":0}]]},"Guard Non-Empty query":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"a3d80fde-0306-46ae-83e0-7fc639ddffa1","id":"FDX01743"}