{
  "name": "Clean company profiles with HubSpot and HTTP / REST API hands-free",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
