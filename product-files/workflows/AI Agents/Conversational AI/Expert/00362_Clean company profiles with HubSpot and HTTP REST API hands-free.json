              "id": "3b2d2e89-31e0-494b-bb45-7adde98898e4",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "15c4e8d1-cfd5-4fea-b5f7-f8d4f3146eb9",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "7503015b-17b8-40e3-8b93-3499fc563e18",
