{"name":"Enrich contact records with HubSpot and HTTP / REST API for your team","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":12}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"9a29e1cb-14b6-4148-825b-bb6739937258","name":"Hourly Schedule"},{"parameters":{"resource":"contact","operation":"search","filterGroupsUi":{"filterGroupsValues":[{"filtersUi":{"filterValues":[{"propertyName":"lastmodifieddate","operator":"GTE","value":"={{ $now.minus({days: 1}).toMillis() }}"}]}}]},"authentication":"appToken","additionalFields":{}},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[54,130],"id":"555784c9-6e78-465f-bbb0-42c3db3b8139","name":"Pull Side A (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"executeQuery","query":"SELECT * FROM requests WHERE updated_at > NOW() - INTERVAL '1 day' ORDER BY updated_at DESC;","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[378,670],"id":"6cf2d26c-0ec7-47e7-86a1-1e231dc14ffe","name":"Pull Side B (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mergeByFields":{"values":[{"field1":"requestId","field2":"requestId"}]},"options":{}},"type":"n8n-nodes-base.compareDatasets","typeVersion":2.3,"position":[1026,400],"id":"f9bd2fa8-899e-4639-97aa-0ef0b75097a8","name":"Diff the Two Systems"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO request_log (requestId, query, context, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.requestId, $json.query, $json.context ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1998,-200],"id":"ca36e8b9-77f9-499c-8723-457073d6021b","name":"Create Missing in PostgreSQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"aggregate":"aggrega