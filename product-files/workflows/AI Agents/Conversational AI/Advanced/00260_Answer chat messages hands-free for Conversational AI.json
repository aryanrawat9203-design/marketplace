{"name":"Answer chat messages hands-free for Conversational AI","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"92bec745-4b48-41ae-a036-00d64dbf1c1d","name":"When Chat Message Received","webhookId":"6dd59f38-fb88-4dac-900d-12440dd4a6ba"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4dc6c69f-6aa8-4b18-8489-bd753c5b60f4","leftValue":"={{ $json.requestId || $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"d9661e21-6ca7-4cf3-a395-6237ee0e9a66","name":"Keep Valid Requests"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.question || JSON.stringify($json) }}","options":{"systemMessage":"You answer request questions using only the retrieved knowledge-base context. If the context does not contain the answer, say so and set needsHuman=true.","maxIterations":6}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"8e381462-9bdc-405b-8ebb-10769840ba8b","name":"Answer from Knowledge Base","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[621,970],"id":"2f9bf9f2-2173-4c96-a454-756628d88f05","name":"Groq Chat Model"},{"parameters":{"pineconeIndex":{"__rl":true,"mode":"list","value":"","cachedResultName":"kb-main"},"mode":"retrieve-as-tool","topK":5,"toolDescription":"Semantic search over the conversational ai knowledge base. Always call this before answering factual request questions."},"type":"@n8n/n8n-nodes-langchain.vectorStorePinecone","typeVersion":1.3,"position":[675,1390],"id":"8a91e561-d0b7-41d7-9c83-906fa170ec21","name":"Knowledge Base Retriever"},{"parameters":{"options":{}},"type":