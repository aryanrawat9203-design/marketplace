ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9126,1420],"id":"056b8f52-3874-49c8-b821-69ada7e0eaa0","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[9450,1420],"id":"5ee7ce84-d644-4d89-b209-ba9ca6e56b4e","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 12 h. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Requests","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"e07b5d74-32cc-22d6-368a-27a5d28e4b55","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Keep Valid Requests\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Remove Duplicate Requests","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"b2140200-df32-98cc-d352-61a0e7a371ba","name":"Note: Keep Valid Requests"},{"parameters":{"content":"### Remove Duplicate Requests\n\nDrops duplicates within this run (compared on `requestId`).\n\nNext: Enrich — Primary Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"c4777fcc-747c-505a-d439-2eb6a654ff13","name":"Note: Remove Duplicate Requests"},{"parameters":{"content":"### Enrich — Primary Provider\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Primary Hit? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"c380f2ee-437a-f54a-f382-b8bc9641cec5","name":"Note: Enrich — Primary Provider"},{"parameters":{"content":"### Primary Hit?\n\nTwo-way gate on `={{ $json.company || $json.name }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Enrich — Fallback Provider","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"99675dee-e379-e953-16b1-a27a46090e3a","name":"Note: Primary Hit?"},{"parameters":{"content":"### Enrich — Fallback Provider\n\nGET https://fallback-enrich.example.com/v1/person — retries 3× with backoff on failure.\n\nPorts: ①→ Merge Enrichment Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"6b93fa45-9b13-bc9d-0a61-e72c99a9873e","name":"Note: Enrich — Fallback Provider"},{"parameters":{"content":"### Merge Enrichment Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Score Enriched Records","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"6592d8a4-8bec-f365-79b6-f22ea8361626","name":"Note: Merge Enrichment Paths"},{"parameters":{"content":"### Score Enriched Records\n\nCustom JavaScript: Score each request 0-100 from simple heuristics\n\nNext: Upsert into HubSpot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"4ab80c61-4690-1013-735a-7311d6efca49","name":"Note: Score Enriched Records"},{"parameters":{"content":"### Upsert into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Hot Lead? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"721a7473-fce5-628c-594a-01871e6d6556","name":"Note: Upsert into HubSpot"},{"parameters":{"content":"### Hot Lead?\n\nTwo-way gate on `={{ $json.score >= 80 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Ping Owner Immediately · ②→ Fingerprint for Idempotency","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"53c542b0-b935-7bc3-5051-22cffbc3c6f3","name":"Note: Hot Lead?"},{"parameters":{"content":"### Ping Owner Immediately\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,280],"id":"e92e125d-ac2a-722a-34a2-77bdf2e8cb43","name":"Note: Ping Owner Immediately"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per request (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"f7e63230-78e9-ee31-7d4b-5df6426d8c9a","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"bf2ae0c1-914c-7e27-1cfb-663414c95b52","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"d282d5dc-f479-42c9-63c4-bad6fe5e2af2","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"80cfec4e-e814-c2e9-efc9-c22f84b052b9","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"c40ffc85-5dc9-d016-a880-20beeeec9a28","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"0a28a5fc-c583-2dac-1164-bd99e1263ccc","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"e3be8b4b-7b65-ffdd-d932-c023b987199f","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"6f2ad4c7-5f67-a72f-f9a4-97220e45d88c","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"f44add5d-b1db-1c00-facf-05780bbbcff1","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"7e92c891-cdb7-01f5-e424-57f24eb7c0d6","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"e378f11b-43c6-980d-1949-28e169c232d1","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"f362692c-1f5a-cf8f-78f8-f7cfff9f40ef","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"b0485ce7-8402-982d-22ee-52fe44992660","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"9bc2aee5-371f-7d1a-6a1c-419e33d178cd","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"38038e1f-e484-9abd-b787-21469ff9bfd3","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,520],"id":"f88c478b-c82f-9915-4d94-8ecae8d88518","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,520],"id":"d91a6fcb-b554-7289-370e-3c0ddbc16e5c","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,1540],"id":"c2b018cd-2995-dfd1-2bec-624ebbb436d6","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,1540],"id":"7df0f570-d082-b1cd-ba18-5529146a2448","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nhubspot — `contact` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 HubSpot private-app token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,1540],"id":"164837c0-5a37-5e49-36b4-5ad3706ab411","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Enrich company profiles with HubSpot and HTTP / REST API on autopilot for Conversational AI\n\n**Pattern:** Data Enrichment · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nEnrich company profiles with HubSpot and HTTP / REST API on autopilot for Conversational AI. It runs automatically on a schedule.\n\n## Why it exists\nManual conversational ai is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Keep Valid Requests → Remove Duplicate Requests → Enrich — Primary Provider → Primary Hit? → Merge Enrichment Paths → Score Enriched Records → …\n\n## Use it for\n- Teams that want to data enrichment without manual effort\n- Anyone automating conversational ai in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Saves hours of manual work each week\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; HubSpot private-app token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"40f11ea5-0ea7-0074-adb5-89d681a3cd31","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"9c073414-6681-6304-c689-030c627aa69c","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"3c391299-91a7-4fad-f9e0-eeaaddba4646","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your conversational ai process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"64df6ddd-5b11-97f5-040b-ffb0ba32e682","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Keep Valid Requests","type":"main","index":0}]]},"Keep Valid Requests":{"main":[[{"node":"Remove Duplicate Requests","type":"main","index":0}]]},"Remove Duplicate Requests":{"main":[[{"node":"Enrich — Primary Provider","type":"main","index":0}]]},"Enrich — Primary Provider":{"main":[[{"node":"Primary Hit?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Primary Hit?":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":0}],[{"node":"Enrich — Fallback Provider","type":"main","index":0}]]},"Enrich — Fallback Provider":{"main":[[{"node":"Merge Enrichment Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Enrichment Paths":{"main":[[{"node":"Score Enriched Records","type":"main","index":0}]]},"Score Enriched Records":{"main":[[{"node":"Upsert into HubSpot","type":"main","index":0}]]},"Upsert into HubSpot":{"main":[[{"node":"Hot Lead?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hot Lead?":{"main":[[{"node":"Ping Owner Immediately","type":"main","index":0}],[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Ping Owner Immediately":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"6bf31346-0184-4bc5-8105-c8a463714559","id":"FDX00398"}