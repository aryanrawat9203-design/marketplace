{"name":"Answer user questions with instant alerts for Conversational AI","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"f44c67c4-ce71-4082-b0ed-3b036e7d8b93","name":"When Chat Message Received","webhookId":"bcc153e8-2b5a-4ae3-a264-bae809784109"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"91e0c9a1-03ea-4a6e-a3c0-bb7ac7a22dfd","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"8748a035-a319-454e-a126-1ce9e6847c10","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'query' on incoming request."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"ba7c0406-e897-46d9-9862-2d0af88343f6","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"f5190fd3-21fa-4198-b4b2-40602eb9a6ad","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"fd63b136-7674-4646-8f96-ebe43f0551a2","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"66e1c108-99a7-4e98-8f96-e22f1895f0e0","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a conversational ai pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"03142dfa-8949