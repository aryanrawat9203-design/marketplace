ontain the answer, say so and set needsHuman=true.","maxIterations":6}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"3d474929-1814-4a87-8cf0-82bcc9a325a1","name":"Answer from Knowledge Base","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[945,970],"id":"20566e30-71ba-41e9-a1fc-6e8d658103b8","name":"Google Gemini Chat Model"},{"parameters":{"pineconeIndex":{"__rl":true,"mode":"list","value":"","cachedResultName":"kb-main"},"mode":"retrieve-as-tool","topK":5,"toolDescription":"Semantic search over the task automation knowledge base. Always call this before answering factual request questions."},"type":"@n8n/n8n-nodes-langchain.vectorStorePinecone","typeVersion":1.3,"position":[999,1390],"id":"dd7ed0d1-efb1-4e23-8ed1-a467a60a593b","name":"Knowledge Base Retriever"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.embeddingsGoogleGemini","typeVersion":1,"position":[1053,1900],"id":"0e4813fb-d2a7-4cb2-a466-357d9b2dfc98","name":"Query Embeddings"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c0587c17-1a16-43c0-afcb-0a503634122d","leftValue":"={{ !($json.output || '').includes('needsHuman') }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1377,400],"id":"820b2b70-c508-4c2a-8176-9f9ff531a161","name":"Grounded Answer Found?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"answer\": $json.output } }}","options":{}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[1701,160],"id":"abe2cc5b-b19c-4f10-970a-baf6b9007979","name":"Return Answer (HTTP 200)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2025,760],"id":"1ff31f84-e41e-41f8-b131-fa7fc20f3674","name":"Log Knowledge Gap","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=📚 Unanswered question logged: {{ $json.chatInput || $json.question }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[2673,760],"id":"fe3e23f3-bd8a-408e-bacb-e9004446426c","name":"Flag Gap to KB Owners","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3645,400],"id":"72678e93-30c0-4d84-9bae-895277855b13","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d0d494af-2c2b-4c5d-9a88-d44164c1ea64","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"be30e3f8-bf23-4620-b42c-72385216a05f","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3969,400],"id":"1367c8fb-161a-4565-af1c-18c9c8386251","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4293,400],"id":"3a114ed2-f880-4a8b-bb6b-3da8adfa4dbd","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4617,400],"id":"f871f90d-50c2-4824-bc68-bfb09f42d4f9","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Requests"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[4941,400],"id":"3a0e881b-61cc-43d1-beaa-47cee326ba81","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5265,400],"id":"6d228ad8-7fbb-4931-ba9d-37426888a75d","name":"Record Sub-workflow Result"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5589,400],"id":"acace23f-a75a-4633-8e2f-37ded80bf68a","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5913,400],"id":"53cace1f-f83e-4dec-874e-6ab08ef5ccb1","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6237,400],"id":"38c23096-9907-49d7-a735-dea0beb20837","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6561,400],"id":"a75942af-da57-4f15-8528-a6fb1b4a1d0b","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[6885,400],"id":"c92ba6da-9b1c-4d2d-8e92-0907eb1773f2","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Request Database"},"title":"={{ $json.query || $json.requestId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[7209,400],"id":"3e4ca97e-fe89-476a-b1e6-1ca294223300","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"53d9fa54-2187-4cfe-b44b-ceac5ceeb8e6","leftValue":"={{ $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7533,400],"id":"85b97079-3c9b-48b7-bc32-ce1385ad54b0","name":"Guard Non-Empty query"},{