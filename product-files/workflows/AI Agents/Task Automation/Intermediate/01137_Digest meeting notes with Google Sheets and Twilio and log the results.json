{"name":"Digest meeting notes with Google Sheets and Twilio and log the results","nodes":[{"parameters":{"httpMethod":"POST","path":"wf01137-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"d781f3a5-cb1b-4867-8ef2-7107ec1155c4","name":"Receive Inbound Webhook","webhookId":"9fba5c9a-fcdb-4855-bdaa-65075a21b1cc"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"9f5020a1-c049-401a-8310-4642ec3c4475","leftValue":"={{ $json.requestId || $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"30b75508-fb6c-4183-bda0-3f9f6bea80db","name":"Keep Valid Requests"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.query || JSON.stringify($json) }}","options":{"systemMessage":"You are a task automation specialist for the ai agents team. Use the attached tools to look up real data before answering — never invent request details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"75ca8b4b-6ed7-4a84-b400-91ca29c5fa89","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[621,970],"id":"6e453472-6225-464d-aad3-5133771a1c13","name":"Groq Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[621,1390],"id":"cf496a6a-0b74-4059-b708-212a25093214","name":"Search Reference Wiki"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[850,1390],"id":"fe90bb44-8d04-4b26-a6fc-398dce8f70db","name":"Run Calculations"},{"paramete