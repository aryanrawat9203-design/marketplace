{"name":"Clean contact records with HubSpot and HTTP / REST API with instant alerts","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":12}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"eb3a4b0c-2a78-481c-8bcf-58e94b3672ab","name":"Hourly Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fd9aca1e-217d-49b9-84e7-7e0a6675255d","leftValue":"={{ $json.requestId || $json.query }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"a78cb77e-0262-4a5e-bfc5-9da5e5a30462","name":"Keep Valid Requests"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"requestId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"cd90c609-403c-4197-8c33-dc460af84549","name":"Remove Duplicate Requests"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,400],"id":"abe87706-a46f-4553-911a-15efa6ff6247","name":"Enrich — Primary Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"93d8a61d-d489-4573-b313-0296ad99df43","leftValue":"={{ $json.company || $json.name }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1026,400],"id":"d88fe3cc-8897-4266-ad74-09442e00f779","name":"Primary Hit?"},{"parameters":{"method":"GET","url":"https://fallback-enrich.example.com/v1/person","sendQuery":true,"queryParameters":{"parameters":[{"name":"email","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1350,880],"id":"28bdfa1b-4291-4ec6-9989-da7d7276bf9c","name":"Enrich — Fallback Provider","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1998,400],"id":"4492a907-7ae4-4f2d-bdff-1b6a19b1e8c6","name":"Merge Enrichment Paths"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each request 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.query) score += 20;\n  if (j.context) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2970,400],"id":"97c2742a-8de4-4ef2-b781-d3a684724c2d","name":"Score Enriched Records"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[3294,400],"id":"b53ce7de-a560-43de-b228-ee57cda5c7f0","name":"Upsert into HubSpot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"53e73082-2374-40e5-b19b-326f295514a7","leftValue":"={{ $json.score >= 80 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[3618,400],"id":"f7edeaee-204c-4d2c-99a8-bb0942435356","name":"Hot Lead?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🔥 Hot {{ $json.company || $json.email }} (score {{ $json.score }}) — reach out now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3942,160],"id":"e8141acb-9ab6-4277-8657-44538951dab5","name":"Ping Owner Immediately","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"contact","operation":"search","filterGroupsUi":{"filterGroupsValues":[{"filtersUi":{"filterValues":[{"propertyName":"lastmodifieddate","operator":"GTE","value":"={{ $now.minus({days: 1}).toMillis() }}"}]}}]},"authentication":"appToken","additionalFields":{}},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[4266,400],"id":"f6f4fca5-6616-4c23-b6d3-3d1ad5eb0501","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4590,400],"id":"6e9dbfa9-a47c-4c7b-aee6-7ec3008d75bf","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"4efe3025-5cce-4ee8-b140-52dc7c0f9e87","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"4c8e63b5-9e0c-42c4-91bd-bcc7e7bc1098","name":"Persist Run Metadata"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Requests"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5562,400],"id":"f81b1335-f34b-41d1-8e69-fb9f859fce02","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5886,400],"id":"6f7102d4-f038-4d5b-b817-7e2ba86a9786","name":"Record Sub-workflow Result"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per request (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.requestId, j.query].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6210,400],"id":"0c6427b9-a355-4d17-abb4-f7fcc331875b","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6534,400],"id":"66ead8c5-4737-473c-97e0-0bb243ff83f5","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,