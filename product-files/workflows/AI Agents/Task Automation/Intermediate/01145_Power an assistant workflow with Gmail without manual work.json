[{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6520,400],"id":"9a8c97bc-bd6a-49f2-818a-ed425d0ae82b","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.query }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6844,400],"id":"563ae737-c6c1-4deb-88dc-ee49e7d2c0b5","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"f16c8fed-ef2b-4f9e-890a-3061e9bfbe2b","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"2be157e6-3a99-429d-b5c5-8e99f7baf143","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7168,400],"id":"2e7b7dfe-f5c3-4822-a995-356a2d7f061e","name":"Fold In Enrichment Fields"},{"parameters":{"dataToSave":{"values":[{"key":"requestId","value":"={{ $json.requestId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7492,400],"id":"2a976ecd-8602-458b-a10e-622118c9f44f","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"4f122c09-e852-4b00-90fc-15773a93e571","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"43313e0e-5599-4010-be70-905e5023cab5","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"20ad9fdc-0a48-4337-a947-2acb5acffa57","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7816,400],"id":"c4235189-fee2-4734-a7dd-1373855bf4ba","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","