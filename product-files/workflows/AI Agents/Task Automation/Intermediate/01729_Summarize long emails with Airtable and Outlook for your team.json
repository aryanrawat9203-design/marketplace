{"name":"Summarize long emails with Airtable and Outlook for your team","nodes":[{"parameters":{"httpMethod":"POST","path":"wf01729-request","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"719044f0-0ed2-4fe8-aa38-fdff8b38aef4","name":"Receive Inbound Webhook","webhookId":"8851488d-b5d2-46fb-a130-58c13fee5a35"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming request records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    requestId: String(j.requestId ?? j.id ?? '').trim(),\n    query: typeof j.query === 'string' ? j.query.trim() : j.query ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"c01288e9-9738-4a74-9c39-1184c40f94e9","name":"Normalize Request Payload"},{"parameters":{"inputText":"={{ $json.query || JSON.stringify($json) }}","options":{}},"type":"@n8n/n8n-nodes-langchain.sentimentAnalysis","typeVersion":1,"position":[378,400],"id":"5b334af6-140f-4e79-9fff-dd375c9cdf9c","name":"Detect Sentiment","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[621,970],"id":"e7fa9717-86f2-4f14-a01d-205e8732e7fa","name":"OpenRouter Chat Model"},{"parameters":{"subject":"=😠 Negative request: {{ $json.query }}","bodyContent":"=😠 Negative request: {{ $json.query }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[945,-80],"id":"10ecaea7-de1f-4a77-a27d-d38a6d59de58","name":"Escalate Negative — Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultNam