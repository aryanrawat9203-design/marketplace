gleSheets","typeVersion":4.7,"position":[2902,400],"id":"41a802b5-541f-4cff-a9cb-c673e81813c8","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Run an assistant workflow with Slack end to end — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3226,400],"id":"2bd04174-1835-4789-a954-d870c8ccff61","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6010eafe-3f84-4936-9dc3-c384bc3f9871","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"52d40ba6-8490-4a1e-b798-69a207c3a21e","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"17326069-3f80-4889-b14b-a410aa1ffcdd","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2578,1420],"id":"2158d989-1bc4-4347-b670-b1b55f513e00","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2902,1420],"id":"dc5b775d-fb74-42fc-82b4-12c69c919820","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf01684-request`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Stamp & Shape Request","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ef39ac47-0e26-63f4-a294-061494de353e","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Stamp & Shape Request\n\nShapes the item: writes `requestId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"c094ecd0-126c-76b0-438c-2635aeca885c","name":"Note: Stamp & Shape Request"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.requestId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Frame the Assignment · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"a94294aa-bc7d-6a4f-16ae-96a46c5b6cbc","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"3322d08d-14fe-3666-a5ef-0050ad57b0c3","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Frame the Assignment\n\nShapes the item: writes `assignment`, `deadline`. Keeps the schema explicit between stages.\n\nNext: Coordinator Agent","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"df676c7b-204f-c8d8-dff9-609dc8350cc5","name":"Note: Frame the Assignment"},{"parameters":{"content":"### Coordinator Agent\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Unpack Sections · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"3076276a-253a-b007-1fd4-fdf50dc37114","name":"Note: Coordinator Agent"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Coordinator Agent** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"a0286bf0-c994-5c73-43cf-50474ac49154","name":"Note: Groq Chat Model"},{"parameters":{"content":"### Research Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1128,1510],"id":"e9e120a0-ca4c-19f9-3107-9913b6c8a7ce","name":"Note: Research Specialist (Sub-workflow)"},{"parameters":{"content":"### Draft Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1384,1750],"id":"ed7fa532-a2c7-ef2f-ae1c-0b079712cd66","name":"Note: Draft Specialist (Sub-workflow)"},{"parameters":{"content":"### Enforce Result Schema\n\nForces the agent's answer into the JSON schema below — downstream nodes rely on this exact shape.\n\nFeeds **Coordinator Agent** as `outputParser`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1546,1090],"id":"aee23bf6-2f73-07cb-217b-c3e2559e9aea","name":"Note: Enforce Result Schema"},{"parameters":{"content":"### Unpack Sections\n\nExplodes the `output.sections` array into one item per element.\n\nNext: Persist Deliverable to Google Sheets","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1870,520],"id":"78f2d082-6a8e-5dfe-b4d2-c01b1a4b56ed","name":"Note: Unpack Sections"},{"parameters":{"content":"### Persist Deliverable to Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2194,520],"id":"f730cd93-d70c-a2f3-717e-6f6e24838dff","name":"Note: Persist Deliverable to Google Sheets"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2518,520],"id":"0a86c361-2124-7c70-e280-43e433d2a759","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2842,520],"id":"a111d1a7-5394-caef-1b90-29af9b082de4","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3166,520],"id":"e3d57b8a-b4af-ffc3-c164-606365783115","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2518,1540],"id":"9f1fcfff-a721-2430-c93a-6d4f7b80467f","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2842,1540],"id":"c8cfb3db-6ae3-b43d-ae55-4d1422e21b1c","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Run an assistant workflow with Slack end to end\n\n**Pattern:** AI Agent · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nRun an assistant workflow with Slack end to end. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual task automation is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Stamp & Shape Request → Payload Valid? → Frame the Assignment → Coordinator Agent → Unpack Sections → Persist Deliverable to Google Sheets → …\n\n## Use it for\n- Teams that want to ai agent without manual effort\n- Anyone automating task automation in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Runs 24/7 in the background\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Groq API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"2ca922be-bfeb-3f76-2a92-3bcf0098d45b","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"9cd7de0e-e9c7-904b-af48-2da0b725f84a","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"90a7fd57-9393-065b-f719-beeac55340d3","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"3f47130c-a890-fa97-240c-1c3783b5c69c","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your task automation process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"85532f31-9707-3b74-fe37-7fb157062df3","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Stamp & Shape Request","type":"main","index":0}]]},"Stamp & Shape Request":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Frame the Assignment","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Frame the Assignment":{"main":[[{"node":"Coordinator Agent","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Coordinator Agent","type":"ai_languageModel","index":0}]]},"Research Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Draft Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Enforce Result Schema":{"ai_outputParser":[[{"node":"Coordinator Agent","type":"ai_outputParser","index":0}]]},"Coordinator Agent":{"main":[[{"node":"Unpack Sections","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Unpack Sections":{"main":[[{"node":"Persist Deliverable to Google Sheets","type":"main","index":0}]]},"Persist Deliverable to Google Sheets":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"3064b687-6ccf-4472-8c1d-e4e9fd18719e","id":"FDX01684"}