          "conditions": [
            {
              "id": "c5da3d6c-86de-483f-be75-9846ed064876",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
