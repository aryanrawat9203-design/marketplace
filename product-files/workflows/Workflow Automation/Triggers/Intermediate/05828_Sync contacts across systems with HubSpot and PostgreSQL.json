{
  "name": "Sync contacts across systems with HubSpot and PostgreSQL",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 2
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -200,
        400
      ],
      "id": "cb4d4c9c-7535-43c1-af8e-d31180adf25c",
      "name": "Hourly Schedule"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM jobs WHERE updated_at > NOW() - INTERVAL '1 day' ORDER BY updated_at DESC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        40,
        400
      ],
      "id": "db8abc9f-de18-47b0-ac3f-cb5bf486e1de",
      "name": "Load Previous Snapshot",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "resource": "contact",
        "operation": "search",
        "filterGroupsUi": {
          "filterGroupsValues": [
            {
              "filtersUi": {
                "filterValues": [
                  {
                    "propertyName": "lastmodifieddate",
                    "operator": "GTE",
                    "value": "={{ $now.minus({days: 1}).toMillis() }}"
                  }
                ]
              }
            }
          ]
        },
        "authentication": "appToken",
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [
        280,
        400
      ],
      "id": "053abef3-7b5d-4a31-8b28-3a6f7c058dee",
      "name": "Fetch Changes (HubSpot)",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming job records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    jobId: String(j.jobId ?? j.id ?? '').trim(),\n    type: typeof j.type === 'string' ? j.type.trim() : j.type ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        400
      ],
      "id": "dda253d6-9789-421a-b4b9-3b1a6831d2f2",
      "name": "Normalize Records"
    },
    {
      "parameters": {
        "resource": "contact",
        "email": "={{ $json.email }}",
        "additionalFields": {
          "companyName": "={{ $json.company }}"
        },
        "authentication": "appToken"
      },
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [
        760,
        400
      ],
      "id": "46361ee0-c988-4f13-ae55-cbdd40d366dd",
      "name": "Upsert into HubSpot",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Advance the incremental watermark to the newest record seen\nconst items = $input.all().map(i => i.json);\nconst newest = items.reduce((m, j) => {\n  const ts = new Date(j.updatedAt || j.receivedAt || 0).getTime();\n  return ts > m ? ts : m;\n}, 0);\nreturn [{ json: { watermark: new Date(newest || Date.now()).toISOString(), processed: items.length } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        400
      ],
      "id": "cdf2d97b-2415-4cea-90f2-8ce72f9cf1d2",
      "name": "Advance Watermark"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO jobs (jobId, type, payload, updated_at)\nVALUES ($1, $2, $3, NOW())\nON CONFLICT (jobId) DO UPDATE SET updated_at = NOW();",
        "options": {
          "queryReplacement": "={{ [ $json.jobId, $json.type, $json.payload ] }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1240,
        400
      ],
      "id": "c5dee5ea-9622-4c03-8dce-98927c1fb414",
      "name": "Persist Watermark (PostgreSQL)",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "operation": "getCurrentDate",
        "outputFieldName": "processedAt",
        "options": {}
      },
      "type": "n8n-nodes-base.dateTime",
      "typeVersion": 2,
      "position": [
        1480,
        400
      ],
      "id": "2463b85d-0065-48f4-b439-b141321c0557",
      "name": "Stamp Processing Time"
    },
