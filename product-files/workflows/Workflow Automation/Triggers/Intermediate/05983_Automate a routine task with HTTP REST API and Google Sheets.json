{"name":"Automate a routine task with HTTP / REST API and Google Sheets","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":9,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"73bf275a-9a5d-4340-93ad-277a06b1d92b","name":"Daily Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"352a02fa-033c-4670-b542-d75260b9c1d0","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"8eb15a88-e780-446e-a610-6eaaafa9a729","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"d4527010-98fc-42be-8b84-dd7c31e77bcd","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"e5c903b5-0257-4e15-8ca8-f98ccbd05c57","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0dd97686-4c90-4c24-8a65-0cf488f302a8","leftValue":"={{ $json.kind }}","rightValue":"job.start","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"job.start"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2a5ea140-29ee-494e-9123-0ef642c07586","leftValue":"={{ $json.kind }}","rightValue":"job.done","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"job.done"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"2ef6cf65-d8e1-4afe-81f2-282135ae1430","name":"Route by Event Kind"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":