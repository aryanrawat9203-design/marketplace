pshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6534,400],"id":"22a35f50-32e7-435a-ac70-5748dfd164d4","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e185ec9e-7f28-4ca4-9096-9bd5dbb6a682","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"34452435-23e2-4a2e-acdb-61d40a0b709a","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"bfa3bfd8-e18f-4ef9-b0ef-54a3f2990b04","name":"Fold In Enrichment Fields"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a8c2414e-7d5a-4ba2-8ceb-0bad5764e39c","leftValue":"={{ $json.type }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7182,400],"id":"cb1bbfe4-963c-4e31-91b7-b2a769a6c335","name":"Guard Non-Empty type"},{"parameters":{"dataToSave":{"values":[{"key":"jobId","value":"={{ $json.jobId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7506,400],"id":"a8041148-59dc-471b-ba7b-d0ac9994c1fa","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"7849983a-52ea-41b3-8e4c-d93cffce541b","name":"pipeline","value":"Triggers","type":"string"},{"id":"46feb83c-ba0a-445d-8554-a6db1e6c977b","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7830,400],"id":"06ac3063-2ff5-4ed0-a489-701f1a259d79","name":"Tag Pipeline Metadata"},{"pa