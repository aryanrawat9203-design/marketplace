Teams","typeVersion":2,"position":[10098,400],"id":"847c72ab-328d-428c-b99d-511525b0b1e6","name":"Send Summary to Microsoft Teams","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"2af3564d-fb88-484f-931a-8eb377b73207","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"0ec32731-94cd-41bb-9b37-56931f9f2be5","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"89d7655b-0e2f-497b-ba05-1bd170113963","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9450,1420],"id":"3914f4df-fe87-49a8-be97-a37aab3429fd","name":"Capture Failure Context"},{"parameters":{"resource":"chatMessage","chatId":"OPS_TEAM_CHAT_ID","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.microsoftTeams","typeVersion":2,"position":[9774,1420],"id":"ab2dc57f-64bc-4366-a3a0-24b3bd3f430c","name":"Escalate Failure to Microsoft Teams","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[10098,1420],"id":"01778ea2-b573-44b3-8543-2a66841c68a4","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 6 h. No input data; downstream nodes fetch what they need.\n\nNext: Normalize Job Payload","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d8300254-89e2-9461-fd8c-2117e0a53fc2","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Normalize Job Payload\n\nCustom JavaScript: Normalize incoming job records to a stable schema\n\nNext: Route by Work Type","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"4a5d2f01-d862-1854-0003-6df4ddfcfd73","name":"Note: Normalize Job Payload"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 4 lanes: standard, priority, batch + fallback.\n\nPorts: ①→ Delegate 'standard' to Sub-workflow · ②→ Fast-Track 'priority' + Alert · ③→ Fast-Track 'batch' + Alert · ④→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"ff5a349a-3911-7725-a5d5-76ca9fcc59c5","name":"Note: Route by Work Type"},{"parameters":{"content":"### Delegate 'standard' to Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"f40b9796-9f59-c448-8134-2bcbc7f2844c","name":"Note: Delegate 'standard' to Sub-workflow"},{"parameters":{"content":"### Fast-Track 'priority' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"6bd8f8b8-8c92-3723-19e5-ca868279e6a3","name":"Note: Fast-Track 'priority' + Alert"},{"parameters":{"content":"### Fast-Track 'batch' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"ab8c9be0-d93c-e878-8518-e67ecf76ea4e","name":"Note: Fast-Track 'batch' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1780],"id":"fa08dd86-c2d1-6355-16bb-6701cf826663","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"e076ccf2-9d45-631c-8406-c2b89124e398","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"34edd852-a9f3-5c5f-ab1b-e1b611c9849e","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"a443fcf7-10be-fd34-f64c-cfb012af685d","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Load Previous Snapshot\n\nmySql — `select` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"66577c5f-1df6-0ce0-94d4-fe0ddc911dcd","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"2790f728-d5da-95af-16d5-0b49803b85f2","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"9c7a9313-eba3-2e16-8cd6-036bacf1ad26","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"2739a2e9-9bab-a880-a0ac-da10b5899dc0","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"fd2856ef-8b5e-8c5b-4bcd-30746a7dfdb8","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"eb33aea7-8c70-b785-550e-28ea78906c54","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per job (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"7428a607-ba11-1c25-3410-2af3a2c05660","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"b3a19fc0-b33f-2e38-6f96-cd7ec131c767","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"dbbe7c89-bf0d-798f-18bc-3750bf061d1d","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"d1e41a1c-8ea7-5c03-1d61-564f967ea56b","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Guard Non-Empty type","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"bb770332-545c-c919-c36f-269ec785b5ba","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Guard Non-Empty type\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"bd36f6ce-dadf-ccc5-7fdd-298ccf5423ad","name":"Note: Guard Non-Empty type"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Sort Jobs Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"b025868e-ddc8-b876-4b15-ae351133073c","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Sort Jobs Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"160062e4-76f8-12d6-cb7e-6d8bb2a4f246","name":"Note: Sort Jobs Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"df82c842-e693-d833-ae89-d16515e31e1d","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"cd024b0f-9ed0-8554-be89-bf642f602667","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,520],"id":"2f295d33-0e29-23ba-573c-1a125dc9e416","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,520],"id":"9303caad-c426-bd86-9f03-35eaae883102","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Microsoft Teams · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9714,520],"id":"ffdeace3-f16e-dee6-78bd-fab1404a8859","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Microsoft Teams\n\nmicrosoftTeams — `chatMessage` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10038,520],"id":"88915dd4-9fe2-285b-73e1-5628d5045d22","name":"Note: Send Summary to Microsoft Teams"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Microsoft Teams","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,1540],"id":"1e6378d7-7a35-277f-d852-da0114cdf2c3","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Microsoft Teams\n\nmicrosoftTeams — `chatMessage` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Microsoft OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9714,1540],"id":"50b31cf1-6479-22f4-5c5a-e25238ded656","name":"Note: Escalate Failure to Microsoft Teams"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10038,1540],"id":"8359e079-d249-49bb-da66-d95c463e7b5b","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Orchestrate a routine task with HTTP / REST API and MySQL with instant alerts\n\n**Pattern:** Workflow Automation · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nOrchestrate a routine task with HTTP / REST API and MySQL with instant alerts. It runs automatically on a schedule.\n\n## Why it exists\nManual triggers is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Normalize Job Payload → Route by Work Type → Delegate 'standard' to Sub-workflow → Merge Routed Work → Serialize Run Output (CSV) → Archive Row Snapshot → …\n\n## Use it for\n- Teams that want to workflow automation without manual effort\n- Anyone automating triggers in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Scales without extra headcount\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Microsoft OAuth2; MySQL connection; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"e1b070c2-c641-2599-5cb7-221726ab6815","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"8ee6b270-4c1c-6d48-6893-d72561a4a83f","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"b5d99ab0-53f5-8bfd-b8dc-56419930eea7","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your triggers process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"35f75528-d53d-3af9-5990-f60638eed2da","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Normalize Job Payload","type":"main","index":0}]]},"Normalize Job Payload":{"main":[[{"node":"Route by Work Type","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Delegate 'standard' to Sub-workflow","type":"main","index":0}],[{"node":"Fast-Track 'priority' + Alert","type":"main","index":0}],[{"node":"Fast-Track 'batch' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Delegate 'standard' to Sub-workflow":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'priority' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'batch' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Guard Non-Empty type","type":"main","index":0}]]},"Guard Non-Empty type":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Sort Jobs Newest First","type":"main","index":0}]]},"Sort Jobs Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Microsoft Teams","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Microsoft Teams","type":"main","index":0}]]},"Escalate Failure to Microsoft Teams":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Microsoft Teams":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"1ee0bce1-5272-425a-bc5b-3ca2dafe1fe4","id":"FDX06215"}