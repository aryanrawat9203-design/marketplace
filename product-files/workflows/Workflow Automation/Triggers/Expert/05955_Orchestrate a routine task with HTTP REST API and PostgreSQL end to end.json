acement":"={{ [ $json.jobId, $json.type, $json.payload ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[702,130],"id":"7677bce1-6497-4c93-829d-7064514e2c3b","name":"Handle 'job.start' → PostgreSQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/jobs","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1026,640],"id":"3af63aff-3c72-4c71-b41a-4251935bb6b0","name":"Handle 'job.done' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO job_log (jobId, type, payload, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.jobId, $json.type, $json.payload ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1350,1150],"id":"73cc77ab-b641-4284-9547-db4c10ab9375","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1998,400],"id":"e1ef60a5-115f-470b-8b4b-ca20893956a3","name":"Consolidate Handling"},{"parameters":{"assignments":{"assignments":[{"id":"02e68342-ae48-41d4-910a-e9f8d84533f7","name":"pipeline","value":"Triggers","type":"string"},{"id":"4d2f5f1e-30aa-46a8-a93b-030dd4eddf81","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2970,400],"id":"8b9314a3-395c-44f9-b7b9-3177b29345ae","name":"Tag Pipeline Metadata"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[3294,400],"id":"cdd3073a-6da2-480a-b246-f223542a76c6","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3618,400],"id":"43b6eeba-0341-4e83-a488-6f03141ca07e","name":"Sort Jobs Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"jobId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3942,400],"id":"a200cb1b-ab8b-4e72-8637-730f352f71a2","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"5ba1bebf-2e95-4484-8ea6-53f6ca325beb","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"306b3ed7-9bca-4683-bba4-c3dd13f5b292","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"754bd5dc-896c-477b-a4a4-d073092b501b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"9a9cad98-0588-4222-a045-a3ac2e724ac2","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO job_log (jobId, type, payload, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.jobId, $json.type, $json.payload ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4590,400],"id":"38e5ef72-5564-4a3e-9433-645f342bbcfb","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=✅ Orchestrate a routine task with HTTP / REST API and PostgreSQL end to  — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,400],"id":"fcb39d36-26fb-48dc-8432-51230cfb66ec","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b46a2d69-1094-4de4-b575-50b87fd7a10b","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"1b30d4af-6fef-49cc-8383-9dc861d2883f","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e3c5c191-84a7-428b-9143-8d62efc710f2","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,1420],"id":"cbf5b26e-0ecb-42a6-95e3-93077fa0c562","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4590,1420],"id":"eb0c3450-52ac-483c-b9b1-66e9809ee003","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 12 h. No input data; downstream nodes fetch what they need.\n\nNext: Map to Canonical Schema","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"5d0b236b-5cde-9994-b962-4bc02b7ee644","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `jobId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Route by Event Kind","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"9f9cfa04-276e-01b1-b6f0-a07c71e20435","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 3 lanes: job.start, job.done + fallback.\n\nPorts: ①→ Handle 'job.start' → PostgreSQL · ②→ Handle 'job.done' → Forward API · ③→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"970941d7-b96f-1e3e-ae91-fc727b778c44","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'job.start' → PostgreSQL\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"e9842bec-acb1-0bfe-03e1-e83d3274f5e6","name":"Note: Handle 'job.start' → PostgreSQL"},{"parameters":{"content":"### Handle 'job.done' → Forward API\n\nPOST https://api.example.com/v1/jobs — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"4598da83-c733-5582-28e7-3b970692aaf2","name":"Note: Handle 'job.done' → Forward API"},{"parameters":{"content":"### Log Unrecognized Kind\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"4222176f-ccb1-0637-a0a4-584e36c672f8","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"c11ab345-3c5c-67ed-f874-7853c9bda5bf","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"0a0840e2-edb0-04e0-17f5-0e597924cdaa","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Sort Jobs Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"c5b9573c-17ba-1d51-17e4-40dc753dbd0b","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Sort Jobs Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"eaabb8b9-bc91-73d2-ea43-625e1cd43c87","name":"Note: Sort Jobs Newest First"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"8219193d-ba80-9a9d-297c-afd6c6239a54","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"a49241ec-5b78-3c1d-bc52-5129e40c73e3","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"a111d889-d731-fb2f-9475-5bcafa88e8c1","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"498381b5-e3f0-9856-a347-d63804f822d4","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,1540],"id":"e10c806e-247e-3bda-34a7-a70740e933f4","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"08d896df-7bbb-5bb2-3c9d-a8ae971b2ae8","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Orchestrate a routine task with HTTP / REST API and PostgreSQL end to end\n\n**Pattern:** Workflow Automation · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nOrchestrate a routine task with HTTP / REST API and PostgreSQL end to end. It runs automatically on a schedule.\n\n## Why it exists\nManual triggers is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Map to Canonical Schema → Route by Event Kind → Handle 'job.start' → PostgreSQL → Consolidate Handling → Tag Pipeline Metadata → Cap Batch Volume → …\n\n## Use it for\n- Teams that want to workflow automation without manual effort\n- Anyone automating triggers in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Has retries and error handling built in\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9bdaada3-5784-9ba6-432b-e0732bd7fe4b","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"ebe582f8-0132-addd-6e0c-906da4d12e72","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your triggers process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"3e2cbf97-32a4-ad73-fb7c-2210efbd73d1","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'job.start' → PostgreSQL","type":"main","index":0}],[{"node":"Handle 'job.done' → Forward API","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'job.start' → PostgreSQL":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'job.done' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Sort Jobs Newest First","type":"main","index":0}]]},"Sort Jobs Newest First":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"be98cba0-ba57-439f-b931-4120249a1ed8","id":"FDX05955"}