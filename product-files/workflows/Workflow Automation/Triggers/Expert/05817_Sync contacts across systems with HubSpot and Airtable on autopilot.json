aysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6858,400],"id":"10d0062f-4f66-49f2-bc3f-918432c502d6","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"d96ff16f-abb3-4edc-8d34-80174ba541a6","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b4285b91-0224-43ae-8cb4-c12c0323e007","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"7a54ccbb-abd9-4d9d-abb5-029693ba3122","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"78b2e842-ba21-4948-8307-5fa00e04e4a1","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Workflow Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Jobs"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[7506,400],"id":"b4cac4c0-5f44-45ea-bed2-3a3178ab88a6","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=✅ Sync contacts across systems with HubSpot and Airtable on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[7830,400],"id":"3987b77d-00aa-47f9-9a5e-b148af8f46ac","name":"Send Summary to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"840138c4-c5fb-45fa-8d6e-8e320a5f9cff","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"f9483110-3fe4-4aee-bf5f-57d6acd49eab","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"32a749a8-1636-437a-af9e-5040d5394459","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,1420],"id":"515099ed-94c7-474c-84b4-16ec188315bd","name":"Capture Failure Context"},{"parameters":{"authentication":"webhook","content":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[7506,1420],"id":"6f68c04b-b6ab-4d3b-aa6d-e73daaad690d","name":"Escalate Failure to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7830,1420],"id":"f5bcd1ea-eca1-411a-9e43-9cec4e100831","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 6 h. No input data; downstream nodes fetch what they need.\n\nNext: Pull Side A (HubSpot)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"e51d2cd0-f1df-5639-7859-be39c055e2a0","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Pull Side A (HubSpot)\n\nhubspot — `search` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"afe72d3d-82f4-3156-03f0-97d793ba07fd","name":"Note: Pull Side A (HubSpot)"},{"parameters":{"content":"### Pull Side B (Airtable)\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,790],"id":"44c51f0c-c690-4fcf-5a69-78e8370f1102","name":"Note: Pull Side B (Airtable)"},{"parameters":{"content":"### Diff the Two Systems\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Create Missing in Airtable · ②→ Count In-Sync Rows · ③→ Apply Updates to Airtable · ④→ Backfill into HubSpot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"81af20ff-8de7-f977-82de-31b8d76a9bbb","name":"Note: Diff the Two Systems"},{"parameters":{"content":"### Create Missing in Airtable\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,-80],"id":"2cc78ec8-11d9-5c44-0a45-0dd5aa93aed6","name":"Note: Create Missing in Airtable"},{"parameters":{"content":"### Count In-Sync Rows\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Gather Sync Results","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,340],"id":"861459db-e3f9-56dc-9b26-3efa605b1468","name":"Note: Count In-Sync Rows"},{"parameters":{"content":"### Apply Updates to Airtable\n\nairtable — `upsert` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,760],"id":"509a5e1f-02dc-3f25-41f7-459cc5812483","name":"Note: Apply Updates to Airtable"},{"parameters":{"content":"### Backfill into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,1180],"id":"b49a7f1b-ca06-d213-21a6-5a7e2c6d2a78","name":"Note: Backfill into HubSpot"},{"parameters":{"content":"### Gather Sync Results\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"eecac5de-ef84-ecae-4895-2a8dc27fe418","name":"Note: Gather Sync Results"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"18841810-d58f-60ea-25da-acdec9f04132","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"034d122c-9026-e75b-d4a0-6d9fe3f8502d","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"9eff753f-e47c-cf3b-c7a2-8c5964b31578","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"92299f76-9f5e-c3bc-7c79-104f17005280","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"ea6b2b19-142e-a9b7-41a5-c5381cc07d9b","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"4ebc9aad-72e8-3e41-7fa6-eb5eaa46df86","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Load Previous Snapshot\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"6aa7912c-63ff-ed6f-5734-1d2406aa5f13","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"46bbcb94-f5c4-cd01-418d-dfe57a6f683b","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"2b87c899-b26b-c2eb-b5c6-f50f46c78bde","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Discord · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"657f16d8-3ef9-c6ff-dcba-cb626238928c","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Discord\n\ndiscord — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"83d20744-dcfc-9938-23fc-ead797a4b2f1","name":"Note: Send Summary to Discord"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Discord","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"b4f440e7-062d-b3fe-2b9f-02b0c82ad0f5","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Discord\n\ndiscord — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Discord webhook URL","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"bc7dd36c-b6f2-684e-a1de-86a051020497","name":"Note: Escalate Failure to Discord"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,1540],"id":"158247d1-7034-995b-b51a-87057fe32480","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Sync contacts across systems with HubSpot and Airtable on autopilot\n\n**Pattern:** Two-System Sync · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nSync contacts across systems with HubSpot and Airtable on autopilot. It runs automatically on a schedule.\n\n## Why it exists\nManual triggers is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Pull Side A (HubSpot) → Diff the Two Systems → Create Missing in Airtable → Gather Sync Results → Enrich with Reference Data → Fold In Enrichment Fields → …\n\n## Use it for\n- Teams that want to two-system sync without manual effort\n- Anyone automating triggers in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Removes copy-paste errors\n- Improves response time\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Discord webhook URL; Google OAuth2 / service account; HubSpot private-app token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"b77d26de-9e55-f411-0ac5-469496f7069d","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-620],"id":"1d6da792-d187-d6d3-a147-ac27b47b4624","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-620],"id":"a698072b-5863-7bc6-4fc6-afe0ea9fb357","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your triggers process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-620],"id":"14523d5e-328c-f87b-9271-17e045533498","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Pull Side A (HubSpot)","type":"main","index":0},{"node":"Pull Side B (Airtable)","type":"main","index":0}]]},"Pull Side A (HubSpot)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Pull Side B (Airtable)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff the Two Systems":{"main":[[{"node":"Create Missing in Airtable","type":"main","index":0}],[{"node":"Count In-Sync Rows","type":"main","index":0}],[{"node":"Apply Updates to Airtable","type":"main","index":0}],[{"node":"Backfill into HubSpot","type":"main","index":0}]]},"Create Missing in Airtable":{"main":[[{"node":"Gather Sync Results","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count In-Sync Rows":{"main":[[{"node":"Gather Sync Results","type":"main","index":1}]]},"Apply Updates to Airtable":{"main":[[{"node":"Gather Sync Results","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backfill into HubSpot":{"main":[[{"node":"Gather Sync Results","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Gather Sync Results":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion 