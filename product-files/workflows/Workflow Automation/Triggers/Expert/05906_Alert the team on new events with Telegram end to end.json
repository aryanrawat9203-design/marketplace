{"name":"Alert the team on new events with Telegram end to end","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05906-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"90d770d2-3a48-433f-a296-3c2e7ea924af","name":"Receive Inbound Webhook","webhookId":"06745d8b-5614-4675-aee7-10a6b0badcb5"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"231807b2-1703-4f25-adb4-27694b569977","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7778aefd-8959-44fd-896e-348a2e04d0c5","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"c66ca62d-724a-4399-b86c-d8ca52fb891f","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"e28b6299-8102-4e39-b494-077a38109a1e","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"027e57bf-cd27-4999-bba1-1e0e529553a3","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"3af2cdcb-d5f7-4dc0-a832-269e63dfb581","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"0f0785af-a709-4e89-8399-31a8307c8c15","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"68294bec-4891-4420-8810-f