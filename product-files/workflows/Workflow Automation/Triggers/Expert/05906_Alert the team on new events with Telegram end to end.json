","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2322,1150],"id":"de4399e8-fb44-45d9-9f82-038e1e3aa45a","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2970,400],"id":"a287bf57-b96d-41ce-9815-4d0cfbc23076","name":"Consolidate Handling"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"ok\": true } }}","options":{}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[3942,400],"id":"75b50aa7-b9df-40d3-acf3-a68f9c37780b","name":"Respond with Outcome"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"057bffa1-7e8e-41e2-a6f6-2191640fb2b5","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"f1c5d338-4600-40bf-85e4-4aff5183d4ed","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"0260a620-1bae-46eb-98a0-de626fb60af0","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"a8574909-793f-4ed0-ab8e-9592d1a3f5eb","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"ad0da74f-5550-4d55-9100-5ff2f57cd024","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"368a1259-4b7d-4fbd-9