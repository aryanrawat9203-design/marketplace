maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5238,400],"id":"79b930d1-b0d5-4811-b49c-9bffeb7faf2f","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6fdeb002-d94b-48d5-8eb1-571a153577e4","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f454a025-c9b1-403d-b8d3-1cfe0033b582","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"3b90a0ee-cb72-4144-ae87-15e21a1fc8df","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5886,400],"id":"7e65d789-6b65-4627-abdb-46246ec4d5ba","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6210,400],"id":"e6f4ec5b-4ac1-4169-854d-2e7529a425e9","name":"Persist Run Metadata"},{"parameters":{"resource":"contact","operation":"search","filterGroupsUi":{"filterGroupsValues":[{"filtersUi":{"filterValues":[{"propertyName":"lastmodifieddate","operator":"GTE","value":"={{ $now.minus({days: 1}).toMillis() }}"}]}}]},"authentication":"appToken","additionalFields":{}},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[6534,400],"id":"34c048d5-088d-464b-b1d6-8a8377484894","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6858,400],"id":"fcae277b-97a2-403b-bf00-ec2a19ce8eef","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"ab25bf16-d6f8-4360-aeba-cad99810e485","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9de3e5e6-9fa2-401e-81ba-6a212b9c20d3","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"d45461ea-ef9b-40ef-a90d-8f957afde167","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"c8d2c4d5-9702-4106-aa0c-98e310ffef2d","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[7506,400],"id":"6ddc98b4-5abc-4956-ac71-3192726d97ce","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=✅ Sync contacts across systems with HubSpot and Google Sheets for your t — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7830,400],"id":"e9985b8d-dbcd-4776-a31e-3494d68a5a9c","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d4b79be9-14e0-4cb9-b453-1534606c05ee","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ea30182a-0ad3-4e4e-971d-068f76aa133f","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"628503e2-a4f2-430f-baa8-cf6ba45e4cea","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,1420],"id":"92751bd3-64db-44f7-92b8-55a87f2cc906","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7506,1420],"id":"39e49e9f-6b2e-4670-a4e8-c6ed6803963f","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7830,1420],"id":"fe93e1d1-312b-4793-b6eb-628cafa6cfe6","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 7:00. No input data; downstream nodes fetch what they need.\n\nNext: Pull Side A (HubSpot)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ee3f41bd-fcd1-cc07-20eb-78963a518bd0","name":"Note: Daily Schedule"},{"parameters":{"content":"### Pull Side A (HubSpot)\n\nhubspot — `search` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"07f59178-1251-df81-b2fd-508a1a72551e","name":"Note: Pull Side A (HubSpot)"},{"parameters":{"content":"### Pull Side B (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,790],"id":"21d21122-e06c-e6ce-c35b-4a232d5a9ddb","name":"Note: Pull Side B (Google Sheets)"},{"parameters":{"content":"### Diff the Two Systems\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Create Missing in Google Sheets · ②→ Count In-Sync Rows · ③→ Apply Updates to Google Sheets · ④→ Backfill into HubSpot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"09c86fb0-3a65-330e-5a7e-622f8dd741e4","name":"Note: Diff the Two Systems"},{"parameters":{"content":"### Create Missing in Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,-80],"id":"ddc4af59-35a1-3e60-cc81-1a7cdca94186","name":"Note: Create Missing in Google Sheets"},{"parameters":{"content":"### Count In-Sync Rows\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Gather Sync Results","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,340],"id":"262e82c8-4580-fb96-3f8a-4eaaa8ed5f2d","name":"Note: Count In-Sync Rows"},{"parameters":{"content":"### Apply Updates to Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,760],"id":"7695ae1d-d83d-fac8-65f1-2e261662f6b6","name":"Note: Apply Updates to Google Sheets"},{"parameters":{"content":"### Backfill into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,1180],"id":"d0cc8184-6a99-8ea5-09da-c21e5c1e34c1","name":"Note: Backfill into HubSpot"},{"parameters":{"content":"### Gather Sync Results\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"93d0bfc5-7945-1c1f-883b-b723359b1c3a","name":"Note: Gather Sync Results"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"f8b89979-a849-d31c-6355-1dc39daa7f07","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"ebb1b5f2-f75d-c4ae-2168-8f780a90469c","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"8d2e369d-020c-797a-1a28-c21b32deb9e6","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"ba595abf-7071-87fc-e336-7f73c97d9698","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"3f28aa6c-2f93-b025-01d0-897f5f52d1ea","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"52727635-03eb-6245-bbf7-e22684f5cf9c","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Load Previous Snapshot\n\nhubspot — `search` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"068129be-3326-ca12-6c50-c434b05e9543","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"76e4225c-9520-f833-102e-a43b4e0565d7","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"e00c569a-16d8-3e12-9a7c-6484b07834a8","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"a67f0066-f4af-dfac-0777-b686750d50f6","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"9b078650-e7fe-1459-7bce-2741dee8e23b","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"92032a16-2f0e-b25d-81bf-3ffbe21c936d","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"4d439320-0799-dd03-95b6-c0a9a861aceb","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,1540],"id":"583a74c3-3064-ec84-c389-8d3d3da88a9b","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Sync contacts across systems with HubSpot and Google Sheets for your team\n\n**Pattern:** Two-System Sync · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nSync contacts across systems with HubSpot and Google Sheets for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual triggers is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Pull Side A (HubSpot) → Diff the Two Systems → Create Missing in Google Sheets → Gather Sync Results → Serialize Run Output (CSV) → Archive Row Snapshot → …\n\n## Use it for\n- Teams that want to two-system sync without manual effort\n- Anyone automating triggers in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Removes copy-paste errors\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; HubSpot private-app token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"38e8a943-fbd4-8e1a-57db-cd8cadadb70f","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-620],"id":"9b93db31-f21c-cb3c-9631-0928f9eb4167","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-620],"id":"8d699679-2324-212c-65c9-f30ad91ff4aa","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your triggers process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-620],"id":"f4644ec4-c509-9b6d-f0e7-875ee827b851","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Pull Side A (HubSpot)","type":"main","index":0},{"node":"Pull Side B (Google Sheets)","type":"main","index":0}]]},"Pull Side A (HubSpot)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Pull Side B (Google Sheets)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff the Two Systems":{"main":[[{"node":"Create Missing in Google Sheets","type":"main","index":0}],[{"node":"Count In-Sync Rows","type":"main","index":0}],[{"node":"Apply Updates to Google Sheets","type":"main","index":0}],[{"node":"Backfill into HubSpot","type":"main","index":0}]]},"Create Missing in Google Sheets":{"main":[[{"node":"Gather Sync Results","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count In-Sync Rows":{"main":[[{"node":"Gather Sync Results","type":"main","index":1}]]},"Apply Updates to Google Sheets":{"main":[[{"node":"Gather Sync Results","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backfill into HubSpot":{"main":[[{"node":"Gather Sync Results","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Gather Sync Results":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"m