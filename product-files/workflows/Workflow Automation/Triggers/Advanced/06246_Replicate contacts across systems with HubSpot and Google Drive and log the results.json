      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "sendTo": "={{ $json.email }}",
        "subject": "Automated update",
        "message": "={{ $json.summary }}",
        "options": {}
      },
      "id": "c6aed91c-e618-4e21-abbc-b7c09e8c3a7f",
      "name": "Send Gmail Message",
