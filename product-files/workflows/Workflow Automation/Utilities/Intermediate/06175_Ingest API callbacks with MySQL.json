{"name":"Ingest API callbacks with MySQL","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06175-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"3853b4fb-ec61-4d53-b549-09eb8384ff76","name":"Receive Inbound Webhook","webhookId":"99de7c49-33eb-4c87-b194-6f45c603aee4"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"117e01ed-1d78-40ac-8166-b48f5da206c0","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"35bb4b2b-2066-4632-b504-fb0a41e0fdfc","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"d3f49e1d-de93-459c-905a-2ffc2ea2aa7f","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"e3fd6855-5753-47ab-bed3-499899d81667","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"0ddff5a4-3c01-4878-a6f1-9fa005a468c0","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"2cc05901-d4e4-4089-9215-3de4fcd5b915","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"4136ef10-4936-4f2a-a695-d8930475f5d2","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"ac4383f1-56ea-4ce8-896a-d365c1465d6c","name":"Map to Canonical Schema"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"accepted\": true, \"id\": $json.jobId } }}","options":{"responseCode":202}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[1350,400],"id":"93924afd-08b8-4e3f-91fc-8d615df538ea","name":"Acknowledge Fast (HTTP 202)"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2d2f30c1-8bdd-4169-97c2-971421f98e53","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b81fa47f-4170-4adb-97af-edfcb692b820","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1674,400],"id":"ce64a118-64ba-4e2d-99c4-749a9c2f305e","name":"Route by Event Kind"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[1998,130],"id":"a1dd32b3-1e4f-40ea-8daf-c17a7b73e1d2","name":"Handle 'created' → MySQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/jobs","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2322,640],"id":"3842dbc1-638d-406a-af3b-c7610c04a16a","name":"Handle 'updated' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[2646,1150],"id":"06ee65d5-5748-408b-a3f0-5d462255c260","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3294,400],"id":"c4bf5651-6f62-4d50-b45e-702e0d1ef53f","name":"Consolidate Handling"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per job (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.jobId, j.type].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"f301bf51-10c1-4a43-bf66-1e8e433679cd","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4590,400],"id":"4e49b38e-f9d4-4816-97d4-767773f968ea","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"de733a60-bf07-42dd-a700-fcfdbceb2e78","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"89b86063-98ec-4858-90f6-03d4ac7624bb","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5562,400],"id":"71f8a447-8b63-451e-a566-2c29d587ca34","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d85ca7bd-84e2-41f7-8e8f-fea06a47e2ae","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"8dcf37ae-8a1d-465c-af3c-2d5208e3a9b4","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"0e4fd799-b54a-4e88-9ef4-a44d20c4f87f","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"87b758b6-95f7-4b8d-a853-3527235ddfad","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"8cbc43f0-5270-4b32-96fd-9c57048e6da8","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"12b719b1-ea50-4c79-964b-173b43a4b532","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"c9669d79-3940-4f76-afaf-bd3d42ea6819","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[6534,400],"id":"673b19a4-946a-4331-a18c-1c4aa320af78","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=✅ Ingest API callbacks with MySQL — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6858,400],"id":"8574d048-f2ba-42d3-ac73-b23feb3eee9e","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"5b4b4390-2a68-46b8-a49e-1d32e94e4432","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"943ebb45-8d1f-44e6-a895-322ef1217ac2","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"c1002fcf-bb23-42e6-99ec-a6d16f8285b0","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,1420],"id":"c0ff3019-9328-48d3-be34-7a4d44ec667e","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,1420],"id":"8d99574a-106d-4f9a-a1ec-3e2d247684d8","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[6858,1420],"id":"23172017-5e2b-4eca-82a0-dc61e8ca879f","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf06175-job`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Compute HMAC Signature","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"0ddc5a77-9e06-cd10-60cd-802eb4dd0fc7","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Compute HMAC Signature\n\nComputes the HMAC-SHA256 of the raw payload to verify the sender's signature before trusting the data.\n\nNext: Signature Valid?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"df765686-31e8-4471-b1d2-c6426e06896a","name":"Note: Compute HMAC Signature"},{"parameters":{"content":"### Signature Valid?\n\nTwo-way gate on `={{ $json.computedSignature === $json.headers['x-signature']`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Map to Canonical Schema · ②→ Reject (HTTP 401)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"8ff07b43-106f-e3db-11d0-6b82fabd7035","name":"Note: Signature Valid?"},{"parameters":{"content":"### Reject (HTTP 401)\n\nSends the HTTP 401 response back to the caller — keep this fast; heavy work happens after/async.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"b954eaae-472a-46ee-90d7-e5263eb0f70c","name":"Note: Reject (HTTP 401)"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `jobId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Acknowledge Fast (HTTP 202)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"49a3408a-8a78-5e4f-fbcd-5606df8fcee2","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Acknowledge Fast (HTTP 202)\n\nSends the HTTP 202 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Route by Event Kind","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"95172adb-be30-91ef-2010-7b9a7d1e2b8d","name":"Note: Acknowledge Fast (HTTP 202)"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 3 lanes: created, updated + fallback.\n\nPorts: ①→ Handle 'created' → MySQL · ②→ Handle 'updated' → Forward API · ③→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"413aa12a-3e41-b792-963c-4e96c71a1e5e","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'created' → MySQL\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,250],"id":"aed85535-8aa7-8715-ff56-b57170d2a508","name":"Note: Handle 'created' → MySQL"},{"parameters":{"content":"### Handle 'updated' → Forward API\n\nPOST https://api.example.com/v1/jobs — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,760],"id":"bb89e03a-8cc3-f94a-1ede-1b6a23743e00","name":"Note: Handle 'updated' → Forward API"},{"parameters":{"content":"### Log Unrecognized Kind\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1270],"id":"c08aa291-4170-84e9-8a66-4cd830a8f6f5","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"f0782519-2215-94a1-3523-c2cd5f4b08ae","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per job (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"4310e4bb-bc43-b91b-8282-542f9f660b51","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"15c8bc7d-a3ee-85f0-4176-fac378c43305","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"b582e23d-f392-a586-4283-5ecb559fc051","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"9eeac837-ab2c-0be3-9451-bdb39c5dd11b","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"15c6db30-09cf-b512-05c1-11c26aaa48dc","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"cb9ba479-daaf-49d6-2f74-6d57cfbfd822","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"910e2555-fe2c-6094-0ccb-61bb8f990cc3","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"9c948dcb-ec7a-ca0c-c3b2-7eecaf1f91e7","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"1355fcde-b1ae-e12c-5906-6129339195fd","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"c4ac9719-3578-0982-01b4-ab67a442fb7f","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"531395e2-ee8f-be1c-165c-c454d45b86a8","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nmySql — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,1540],"id":"1bb0a1b5-4914-173e-0275-d8edee660e8c","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Ingest API callbacks with MySQL\n\n**Pattern:** Webhook Pipeline · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nIngest API callbacks with MySQL. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual utilities is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Compute HMAC Signature → Signature Valid? → Map to Canonical Schema → Acknowledge Fast (HTTP 202) → Route by Event Kind → Handle 'created' → MySQL → …\n\n## Use it for\n- Teams that want to webhook pipeline without manual effort\n- Anyone automating utilities in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Standardizes the process every time\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; MySQL connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"806665ee-0239-a5de-97e9-de8db41ee01a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"37bdf687-4964-d416-66cc-4d67265cdbc7","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable, and the HMAC signature is verified before any processing. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"0d2bd7a3-7548-fd8d-d66f-43edad001adc","name":"🔐 Security"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"ddc1ff44-1f5f-0000-b3f6-b215cdd7d6aa","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your utilities process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-290],"id":"9bfb404d-9c9c-60c7-453e-14b173799cb7","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Compute HMAC Signature","type":"main","index":0}]]},"Compute HMAC Signature":{"main":[[{"node":"Signature Valid?","type":"main","index":0}]]},"Signature Valid?":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}],[{"node":"Reject (HTTP 401)","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Acknowledge Fast (HTTP 202)","type":"main","index":0}]]},"Acknowledge Fast (HTTP 202)":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'created' → MySQL","type":"main","index":0}],[{"node":"Handle 'updated' → Forward API","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'created' → MySQL":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'updated' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"2c7f8e7c-221d-43e8-a481-e90a539026e0","id":"FDX06175"}