Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"dda70dd3-5d0f-48ad-88e5-7ed539c328e1","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5886,400],"id":"e2f66db3-0e46-4e2b-b4b2-647a949babeb","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"0f588dd2-477f-4bf3-a942-2a60580f9081","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"026f23c1-6992-44b9-ab7b-00e122840cec","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"2081f91a-278a-4ee0-8c74-51f747149535","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6534,400],"id":"16682379-6a1a-4511-b210-18e20a3cfc2b","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"9fba9603-c8b0-41b7-b390-a4d7df91cf72","leftValue":"={{ $json.type }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[6858,400],"id":"483ae04e-5d5e-40be-8025-5c7904a565e0","name":"Guard Non-Empty type"},{"parameters":{"dataToSave":{"values":[{"key":"jobId","value":"={{ $json.jobId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7182,400],"id":"b5df17f4-6f03-4d59-ab2f-82c0d7d0e769","n