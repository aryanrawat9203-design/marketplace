-nodes-base.dateTime","typeVersion":2,"position":[5562,400],"id":"757a9ee9-223f-4665-b4f8-0ec6bdab9d1c","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"5b6092c9-9627-437c-add9-8efb3e65b61c","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"32e40640-b518-45f8-a0c5-b588da182e89","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"fd943025-ab0b-4c7c-9cc0-7f17434cff97","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"c4192fe8-028c-47ae-826e-264817ea26dd","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[6210,400],"id":"697eb309-e244-4c56-861a-d95cf0bf5373","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Sync contacts across systems with HubSpot and MySQL — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[6534,400],"id":"d14f5a7a-9690-4a3d-8e15-9f5afb0f2474","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"ffe231d5-9def-48aa-ada1-fb7560f4c97d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"d81824f9-7705-4bf1-b9cb-e007620fe00d","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"db0f120c-f174-4d00-92cb-75453df4517f","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"3e1d294e-3354-4090-96c6-a6d148d6bdb8","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,1420],"id":"45bebf6a-099f-4050-9a63-e5d639eea29d","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 2 h. No input data; downstream nodes fetch what they need.\n\nNext: Pull Side A (HubSpot)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"5b52c746-a396-4e07-8e6c-b730741cb873","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Pull Side A (HubSpot)\n\nhubspot — `search` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"314964f1-9615-a51b-308e-3a828db99a94","name":"Note: Pull Side A (HubSpot)"},{"parameters":{"content":"### Pull Side B (MySQL)\n\nmySql — `select` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,790],"id":"c531daea-946d-3d06-00ee-973a70ae82e6","name":"Note: Pull Side B (MySQL)"},{"parameters":{"content":"### Diff the Two Systems\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Create Missing in MySQL · ②→ Count In-Sync Rows · ③→ Apply Updates to MySQL · ④→ Backfill into HubSpot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"0d6053de-de3e-0798-28f8-7e607d25a666","name":"Note: Diff the Two Systems"},{"parameters":{"content":"### Create Missing in MySQL\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,-80],"id":"3f08e080-0135-3e41-be63-ffc94a70639b","name":"Note: Create Missing in MySQL"},{"parameters":{"content":"### Count In-Sync Rows\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Gather Sync Results","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,340],"id":"5ffc9083-ad74-b470-ebb1-4ae7c0e25d14","name":"Note: Count In-Sync Rows"},{"parameters":{"content":"### Apply Updates to MySQL\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,760],"id":"493eb46d-dbb0-6883-f78a-895746bc005e","name":"Note: Apply Updates to MySQL"},{"parameters":{"content":"### Backfill into HubSpot\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,1180],"id":"772d3307-56ee-d828-b560-5201dd25716f","name":"Note: Backfill into HubSpot"},{"parameters":{"content":"### Gather Sync Results\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"f9e03dea-b383-c97a-9d23-f86a13ae2c78","name":"Note: Gather Sync Results"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"f351c23e-48c7-c4a1-9af4-2519ccf642e4","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Jobs Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"5390b9bc-6fc2-73bb-5fa0-7391d7961005","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Jobs Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"a948b27f-ff77-34f8-59b4-a8d5a842399b","name":"Note: Sort Jobs Newest First"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"243e8a3b-cbaa-9614-cb9e-76b02bdf444a","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"f282a8ed-3f06-e899-518f-f653a9847e3d","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"05399288-cbe0-896b-b0bb-93cef77171f3","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"c450f5d4-8368-7a2c-8703-1bcab34f2c33","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"dcbe6fc1-717c-d89f-775b-c8cfb654100c","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"7d682420-8394-0886-f9b6-5b02ac3cb158","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Sync contacts across systems with HubSpot and MySQL\n\n**Pattern:** Two-System Sync · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nSync contacts across systems with HubSpot and MySQL. It runs automatically on a schedule.\n\n## Why it exists\nManual utilities is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Pull Side A (HubSpot) → Diff the Two Systems → Create Missing in MySQL → Gather Sync Results → Save Execution Metadata → Tag Pipeline Metadata → …\n\n## Use it for\n- Teams that want to two-system sync without manual effort\n- Anyone automating utilities in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Removes copy-paste errors\n- Responds in seconds\n\n## Before first run\nConnect credentials: HubSpot private-app token; MySQL connection; Slack OAuth2; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"916559c8-0d8c-9f7b-cdde-f8dce866d5a5","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-620],"id":"4d47cfe0-24d4-31ae-b4fd-e75390dcb9a8","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-620],"id":"fc0aa0c6-e91b-ef62-9b75-dbf1c94c2690","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your utilities process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-620],"id":"86ff18d1-3ad2-a29c-ccac-17e8f6af2f2b","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Pull Side A (HubSpot)","type":"main","index":0},{"node":"Pull Side B (MySQL)","type":"main","index":0}]]},"Pull Side A (HubSpot)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Pull Side B (MySQL)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff the Two Systems":{"main":[[{"node":"Create Missing in MySQL","type":"main","index":0}],[{"node":"Count In-Sync Rows","type":"main","index":0}],[{"node":"Apply Updates to MySQL","type":"main","index":0}],[{"node":"Backfill into HubSpot","type":"main","index":0}]]},"Create Missing in MySQL":{"main":[[{"node":"Gather Sync Results","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count In-Sync Rows":{"main":[[{"node":"Gather Sync Results","type":"main","index":1}]]},"Apply Updates to MySQL":{"main":[[{"node":"Gather Sync Results","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backfill into HubSpot":{"main":[[{"node":"Gather Sync Results","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Gather Sync Results":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Jobs Newest First","type":"main","index":0}]]},"Sort Jobs Newest First":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Twilio","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Twilio":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"14c194b3-f05a-4553-ac5e-e10bc7f7a67c","id":"FDX06014"}