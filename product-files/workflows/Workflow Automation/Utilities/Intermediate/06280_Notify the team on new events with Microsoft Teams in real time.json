{"name":"Notify the team on new events with Microsoft Teams in real time","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06280-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"e4506590-c307-4815-a79f-2f9ddf50a082","name":"Receive Inbound Webhook","webhookId":"4ab6817f-8302-4510-a005-99edfe2f492f"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"25bb68a7-02e5-4907-832e-5b3b8634c142","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"9983ef63-1cc4-4428-b195-8dd7f754ef1a","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"def83300-0a4c-4328-b5d5-55e8c5b49a90","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"3faee25e-c0ab-49ab-8d44-8fec9cb00de6","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"bee42834-f2a3-483b-9346-e8c2916abbc9","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"3567d3f1-5ace-47a4-9736-5973dfcbfaa1","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"f45ad6a1-cfbc-41e8-90e7-463f3883942e","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"69f76976-4c1d-4