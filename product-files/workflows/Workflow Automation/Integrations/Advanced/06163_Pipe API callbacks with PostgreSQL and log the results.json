{"name":"Pipe API callbacks with PostgreSQL and log the results","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06163-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"a82492cd-ac8c-4170-9a41-68e4961b9379","name":"Receive Inbound Webhook","webhookId":"4f20001b-7b9f-4f2f-afff-72d0dc59e094"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"6fb78a26-4ed3-4821-8988-feff9732c14c","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d883f3fc-1b8a-4322-905a-63ba2cbd6d36","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"2abcf81a-909b-4d7e-9879-dd30e9cbd104","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"9b290f91-d898-451b-a87f-87e08d951687","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"ea5e88dd-2abc-436b-b60e-55a52b0988cd","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"f04987fb-ea61-43dc-8bff-e371d39fab73","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"18ceee18-17c4-4e07-a4b8-be215c74532a","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"ac43af55-5339-45d5-854f-