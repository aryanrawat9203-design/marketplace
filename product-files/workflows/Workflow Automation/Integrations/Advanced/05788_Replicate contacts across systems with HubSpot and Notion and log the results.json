+ s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.jobId, j.type].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5238,400],"id":"92873c39-e688-45a9-be8a-2d83572d5b80","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5562,400],"id":"b4e7d15f-6f32-45a5-b218-3462be2d27a4","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5886,400],"id":"26cfcebf-618b-4525-a4fd-1dad309bc00a","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"fc499bdc-e287-4ae0-8695-f340f1141259","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"ba0cfa21-9465-453d-a3e9-9ad4e28a47de","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"236903dd-bb18-430e-9a50-cf4f3666b584","name":"Fold In Enrichment Fields"},{"parameters":{"resource":"contact","operation":"search","filterGroupsUi":{"filterGroupsValues":[{"filtersUi":{"filterValues":[{"propertyName":"lastmodifieddate","operator":"GTE","value":"={{ $now.minus({days: 1}).toMillis() }}"}]}}]},"authentication":"appToken","additionalFields":{}},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[6534,400],"id":"7957c61d-4638-4b17-81ed-fa59dbca92aa","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6858,400],"id":"20eb4cad-dc3b-4763-826e-4c6981bd7b20","name":"Compute Drift vs Snapshot"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"jobId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7182,400],"id":"00ae8fd2-d7dc-43ce-ad17-44386294c176","name":"Align Field Names"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7506,400],"id":"ab0cd08c-3af8-416c-ade9-7e94d243bc2b","name":"Stamp Processing Time"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7830,400],"id":"4a407e32-31c8-44a6-8be7-dabe092fd067","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8154,400],"id":"c30ee519-94ff-4273-b02b-a65d6538122a","name":"Sort Jobs Newest First"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0edef25c-89ac-447a-93c3-90dc882fa4f0","leftValue":"={{ $json.type }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"