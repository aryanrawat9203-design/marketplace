{"name":"Automate a routine task with HTTP / REST API and Notion","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":1}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"fe7a5dd8-55d1-4d93-9ecb-4a6aa2536a2c","name":"Hourly Schedule"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[54,400],"id":"59f187f7-b430-4377-9d5e-d2b8d110a010","name":"Read Pending Queue (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"979c21e0-26ae-433b-b368-bc04b4894474","name":"jobId","value":"={{ $json.jobId || $json.id || $execution.id }}","type":"string"},{"id":"bc0cd16e-23dd-4cdf-9906-e6617c1ac2fa","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"17c959ad-1cc4-4c4e-a3cf-6e31ea0848c7","name":"Stamp & Shape Job"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a1da7af4-acd4-49a3-ba67-ef11306f149f","leftValue":"={{ $json.jobId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[702,400],"id":"7d556e88-36b0-417f-8670-a714f6e9a9c6","name":"Payload Valid?"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Database"},"title":"={{ $json.type || $json.jobId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[702,910],"id":"b04977fb-e827-4604-bd6b-5ab682e3ba5d","name":"Record Rejected Input","retr