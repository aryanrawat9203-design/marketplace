potency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6210,400],"id":"8dc6afca-e9da-428d-91dc-5ae57e59d268","name":"Drop Already-Processed Items"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Jobs"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[6534,400],"id":"96b1b9bb-c362-4100-8696-d8d59661aaf8","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"d192bb4c-ab9f-4047-af86-961eade95035","name":"Record Sub-workflow Result"},{"parameters":{"assignments":{"assignments":[{"id":"1302a551-ea7d-4d2c-b375-a9a2d314a176","name":"pipeline","value":"Integrations","type":"string"},{"id":"1339a5d4-f61e-4c8a-8467-da77907f7498","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"dbeb36c2-9c4d-4f0c-9239-aa783a67c5c5","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7506,400],"id":"5b09317c-a9cb-405b-83e9-924d4c7209c1","name":"Sort Jobs Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"jobId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7830,400],"id":"b72c286c-64c4-4233-bd0d-1399fd34e093","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"daee2e2d-6af6-4f4a-844a-74426079ff63","leftValue":"={{ $json.type }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8154,400],"id":"be56c454-fd83-41f0-872c-1efb48219869","name":"Guard Non-Empty type"},{"parameters":{"dataToSave":{"values":[{"key":"jobId","value":"={{ $json.jobId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8478,400],"id":"67ab8290-4a71-4918-a2d2-b4f3d549faf4","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"b54b781e-502b-4bb6-9dae-ccfcede90bf9","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"45d7fd33-07f6-409a-876b-c9c7ca85638a","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"df4835ae-c951-43e5-bf1d-125695bed3b5","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8802,400],"id":"cd668562-2e59-4922-bfae-88ba9833e9b4","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Database"},"title":"={{ $json.type || $json.jobId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9126,400],"id":"18c1223c-7882-4bba-94a0-970101e40949","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=✅ Replicate contacts across systems with HubSpot and Notion automaticall — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9450,400],"id":"8ce9fdb4-47a4-478c-ba7a-2b4748ba5674","name":"Send Summary to Slack","retryOnFail":true,"ma