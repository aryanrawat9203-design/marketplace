ResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["jobId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[702,130],"id":"583c54cc-1337-40ee-a7a6-e86a32261111","name":"Handle 'created' → Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/jobs","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1026,640],"id":"f60906ca-3215-4289-a2dd-4fd86e6fde80","name":"Handle 'updated' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1350,1150],"id":"d54f7e13-0699-4e85-a06e-8d0d5c45ad68","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1998,400],"id":"6ff65960-c93f-450f-9f78-f4343dc0d03d","name":"Consolidate Handling"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"ok\": true } }}","options":{}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[2970,400],"id":"1a87fb04-1f96-4c96-b363-18d14f845b0b","name":"Respond with Outcome"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3294,400],"id":"a00e8209-0a79-4bd4-b6e6-47