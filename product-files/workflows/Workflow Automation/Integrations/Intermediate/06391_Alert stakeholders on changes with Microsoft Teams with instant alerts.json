{"name":"Alert stakeholders on changes with Microsoft Teams with instant alerts","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06391-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"38754a15-8553-429c-9270-11ec99f9ee59","name":"Receive Inbound Webhook","webhookId":"75865965-e3f4-45c4-902e-d017ed7ad1f7"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"56fbf2e8-8995-4690-8869-f5cb7dee7446","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d0ffa594-bfd8-4ab8-9787-eca27c965040","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"58b4fc08-8ea6-4fc9-8f8c-889b770722e0","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"1a0da992-122d-48de-a6b5-3f9d0fa8f427","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"dcbde17f-fdb6-4a81-9668-607c67961eb0","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"edb7eb15-e0d2-4c2c-926b-9fccf160395d","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"da922d8e-ae93-48bd-a7eb-952c9cded96e","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"11f5c565