s":["jobId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[702,130],"id":"89dd16dc-4cbf-4bdb-beb1-c3bb04b17bef","name":"Process 'standard' → Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚀 Priority job handled: {{ $json.jobId }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1026,640],"id":"745749ef-3e06-4daf-b1c6-1b179b321643","name":"Fast-Track 'priority' + Alert","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1350,1150],"id":"cc2b4250-3e60-444d-8f37-446126830e06","name":"Hold Unknown Types (DLQ)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1998,400],"id":"fabd7499-c91f-4d01-8796-971deceae015","name":"Merge Routed Work"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[2970,400],"id":"5fd93417-2244-4c51-b13c-5c68f4e010a7","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3294,400],"id":"8936d5d7-0e73-4ce2-96f0-26898ec248e0","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per job (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.jobId, j.type].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3618,400],"id":"edfbece1-c69e-44da-9734-3ef8772b811c","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3942,400],"id":"585cce7d-3299-435c-be0c-8625bc2984d1","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"358b9077-74a5-4874-86f5-3cbd8200dad2","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a6bfbc6c-17d1-41a9-87fb-1aed1e067f71","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"06e38e98-b876-44bf-9f09-dd64d39da9ae","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"f9073dfd-a82c-45c5-b82a-71a11572c1c4","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"400f34ca-6657-4996-81f2-9de41aad4bfd","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"2498a32b-f7ed-433d-b9ea-e721bd5d9a6e","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"36dc6e82-8baf-49b5-bde3-98af0e4fff82","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6927cbbf-d4d7-4ddd-9616-bdedfca769f7","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"4e5485c7-a664-4b34-b145-fb877a9a4223","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"7382377c-9e4b-4307-b632-2fd29fda513a","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"f163be94-d845-41f8-a580-03a6fad15167","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=✅ Capture webhook payloads with Google Sheets — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,400],"id":"787f3108-74b8-469c-9fe6-508424f0b5dc","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"219ac475-7fd8-4ed8-a8d8-821ee280b08c","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"b383b633-0c0b-4f64-ab7f-038a9ba533d6","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"3d0d30c0-90d7-4dee-a420-ab8ce61ef9ef","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"d8bde6d2-3de1-41c8-8012-160a931ca857","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,1420],"id":"39c4cbe9-ebae-47a7-bbdd-be612e52a987","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"5b8beed4-d1f6-448b-8e5f-1c5d98166254","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf06199-job`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Keep Valid Jobs","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"63ad8f7b-4e93-0d99-7e4c-67c55cc1a2bd","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Keep Valid Jobs\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Route by Work Type","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"f649b824-2da3-1850-1331-3598dffd1245","name":"Note: Keep Valid Jobs"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: standard, priority + fallback.\n\nPorts: ①→ Process 'standard' → Google Sheets · ②→ Fast-Track 'priority' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"43116c10-7b15-6098-86a0-4a7c34c2d67b","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'standard' → Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"c766295d-3e1d-39f3-cc52-c3530046e165","name":"Note: Process 'standard' → Google Sheets"},{"parameters":{"content":"### Fast-Track 'priority' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"69e101f5-ef3d-ab85-b2dc-2a474c6b728a","name":"Note: Fast-Track 'priority' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"4dd4a53c-9d58-8ee2-f488-1d80eefc0d9f","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"b9d3d383-934c-048c-2a56-ed4ebd74adec","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"f0314ebf-6f8d-b602-1039-6d83e67f2c51","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"e6e8eef2-5b3e-8f06-f197-6b971763b0c7","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per job (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"4a4e81fe-993f-3186-19ad-3020efa24339","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"56c7acdc-e78a-5e2b-00c6-8334d56882d9","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"6b8c5a56-1bbd-49ce-b327-4749dd397bcc","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"2659aa2d-681c-d0f7-d5dc-0cc2a2bee6da","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"c9a042b4-69d0-0fbf-421f-d660be5fbe4e","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"e777bd0e-2214-b71f-1601-ba3b6e277c84","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"986c6457-c251-3724-fb32-06f5507a7688","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"fb681356-a86e-41cd-7fec-19273f9140dc","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"2e763935-5490-83c0-d4bb-e3a611da8b3e","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"c0163fbd-d9fb-61c1-9b81-9f87765061d2","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"38ccbca6-afc1-be9b-54ee-e57640b12753","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"8a045b9a-da93-ba31-e9a2-03d15540450c","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Capture webhook payloads with Google Sheets\n\n**Pattern:** Webhook Pipeline · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nCapture webhook payloads with Google Sheets. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual integrations is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Keep Valid Jobs → Route by Work Type → Process 'standard' → Google Sheets → Merge Routed Work → Serialize Run Output (CSV) → Archive Row Snapshot → …\n\n## Use it for\n- Teams that want to webhook pipeline without manual effort\n- Anyone automating integrations in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Responds in seconds\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"fd0ae27e-50c9-e523-2832-d6032c30fa21","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"5b553a8c-3cb5-34dc-6059-acb68e8d366b","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"d5ebe8ac-352b-a166-69c1-5fe24ada4ac9","name":"🔐 Security"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"2204e13c-5973-1ca7-fffb-c89711e532ed","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your integrations process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-290],"id":"f9e2d156-93fd-de65-4474-0ca9c26a4b20","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Keep Valid Jobs","type":"main","index":0}]]},"Keep Valid Jobs":{"main":[[{"node":"Route by Work Type","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'standard' → Google Sheets","type":"main","index":0}],[{"node":"Fast-Track 'priority' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'standard' → Google Sheets":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'priority' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},