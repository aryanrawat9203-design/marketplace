axTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"88fdf47c-a26c-4110-b457-4a67c5eec525","name":"Merge Routed Work"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3294,400],"id":"f8311ad8-f31f-4186-861c-753896701e92","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"97380559-624a-4a15-8196-5a0f157b3feb","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c1264bb6-cf48-4867-b3a1-37650ea82080","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"35c17298-9c9c-448c-90e4-f49f5ade39c2","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per job (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.jobId, j.type].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"86fc275b-2f59-4134-baca-7710b54c1570","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4266,400],"id":"8d376c88-0002-45e8-8395-685a479208e0","name":"Drop Already-Processed Items"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4590,400],"id":"c92d8689-f25e-40ad-a02b-9e5c7b5dad49","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"dcc9af62-0636-466b-bf35-5ff44634b8e7","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5238,400],"id":"299e7cd9-4132-4030-9942-1febdfcd052f","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"5b8f43aa-35b9-46e1-ae67-f2043864566a","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"09794dcc-648d-4eff-8afd-330e1a9a2af6","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"af6ad6ca-3cb7-4519-8467-24971f6e878d","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"34d8317c-4585-4df9-982e-fe90cca4d968","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"03da5a70-b42e-45bf-a462-51baac1343b4","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Database"},"title":"={{ $json.type || $json.jobId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6210,400],"id":"67069269-cd36-4030-8839-42d5d0d19987","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=✅ Streamline a multi-step process with HTTP / REST API and Notion automa — run ","bodyContent":"=✅ Streamline a multi-step process with HTTP / REST API and Notion automa — run completed at {{ $now.toFormat('HH:mm') }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[6534,400],"id":"eaec39cb-45be-4166-81c7-d9c28f47f9c4","name":"Send Summary to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"ebd05335-cebd-4b64-b700-29f0f39615d3","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"0a6372a5-3b2a-43c6-a572-433641fd99e2","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"2ac6d958-adb2-4847-9411-84a8cba3d29d","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"4743a320-1d8b-4e60-9cd1-5eb171f3c759","name":"Capture Failure Context"},{"parameters":{"subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","bodyContent":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[6210,1420],"id":"ca692cfa-b47b-48d0-8f8f-0275e00308f8","name":"Escalate Failure to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Database"},"title":"={{ $json.type || $json.jobId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6534,1420],"id":"d2e0885b-e88a-423b-b54b-3f759bb0310d","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 1 h. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Jobs","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"2c6d549d-b9f7-ab2c-5de2-9a3af417271b","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Keep Valid Jobs\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Route by Work Type","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"9f140bd1-3538-cf71-f58a-53eb584a7bc7","name":"Note: Keep Valid Jobs"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 4 lanes: standard, priority, batch + fallback.\n\nPorts: ①→ Process 'standard' → Google Sheets · ②→ Fast-Track 'priority' + Alert · ③→ Fast-Track 'batch' + Alert · ④→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"9548f785-8889-78a7-3089-6b590f3d161c","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'standard' → Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"893f36b1-24e3-6280-29de-3da8e59e1353","name":"Note: Process 'standard' → Google Sheets"},{"parameters":{"content":"### Fast-Track 'priority' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"d00fb990-31f7-5c4d-2a63-11861ac6395e","name":"Note: Fast-Track 'priority' + Alert"},{"parameters":{"content":"### Fast-Track 'batch' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"cef9fdda-97e2-f305-3b39-1789b77ef97d","name":"Note: Fast-Track 'batch' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1780],"id":"a542f35b-ad80-b4a9-4e12-6cfe54186ea9","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"3edfca83-28ae-fd4a-50e4-11e0b7f60535","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"e0d4f576-e22b-2d0c-86db-af03a7c8def0","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"6dacf81d-7b81-cd3d-027c-5c37e0b7fd29","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per job (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"974143a1-20c7-dd35-61c0-2f4f458ced0a","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"a33207f7-b6cf-1b39-b525-883f00373e75","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"676e911f-66cc-fc7d-9b46-6df02ad50dfd","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"8bef5f03-0154-3c1a-4d7f-cf6d1937167c","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"9446a1da-10f0-0ff1-6df2-6da274c48df6","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"5e654d64-070b-a470-7a68-e688d02f185c","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"4389828d-211b-10ca-76ec-eecdc1b5a171","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Outlook · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"66b445e0-9176-9638-92dc-0758d1ba5dc1","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Outlook\n\nmicrosoftOutlook — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"c61042bb-c5c9-4472-c6df-8ce25a3fe71e","name":"Note: Send Summary to Outlook"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Outlook","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"dfe65550-c7d0-6d7c-0059-f3c6a4587392","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Outlook\n\nmicrosoftOutlook — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Microsoft OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"0d4d0ae3-4d45-7791-73a6-1a6ce07bdedf","name":"Note: Escalate Failure to Outlook"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"6add8233-49c5-25d1-321e-f3a13687f7dd","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Streamline a multi-step process with HTTP / REST API and Notion automatically\n\n**Pattern:** Workflow Automation · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nStreamline a multi-step process with HTTP / REST API and Notion automatically. It runs automatically on a schedule.\n\n## Why it exists\nManual integrations is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Keep Valid Jobs → Route by Work Type → Process 'standard' → Google Sheets → Merge Routed Work → Enrich with Reference Data → Fold In Enrichment Fields → …\n\n## Use it for\n- Teams that want to workflow automation without manual effort\n- Anyone automating integrations in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Has retries and error handling built in\n- Standardizes the process every time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Microsoft OAuth2; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"25cf1ba9-ad74-866b-c749-55437dffe8ad","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"900644f3-5f4d-ca7f-0e6b-f208cfe744a4","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"69dcec1b-a258-2acb-6518-e4071f1bebd5","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your integrations process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"6b92568c-5d25-6f7a-308e-7c52214ba7e3","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Keep Valid Jobs","type":"main","index":0}]]},"Keep Valid Jobs":{"main":[[{"node":"Route by Work Type","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'standard' → Google Sheets","type":"main","index":0}],[{"node":"Fast-Track 'priority' + Alert","type":"main","index":0}],[{"node":"Fast-Track 'batch' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'standard' → Google Sheets":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'priority' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'batch' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Outlook","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Outlook","type":"main","index":0}]]},"Escalate Failure to Outlook":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Outlook":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"dcc11c10-0774-4358-9a6d-71f416badb84","id":"FDX06369"}