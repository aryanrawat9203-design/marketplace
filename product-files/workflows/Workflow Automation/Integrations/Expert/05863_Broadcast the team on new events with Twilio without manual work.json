{"name":"Broadcast the team on new events with Twilio without manual work","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05863-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"29c5ecd0-99a7-49ef-b7d4-4a799b1d2fb2","name":"Receive Inbound Webhook","webhookId":"183d8506-ccaf-463e-bb92-5ff4d626902c"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"7448f6e0-c405-444a-a770-cbe086ac08ae","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"71b3ea63-cf4f-4d66-a40e-d3c4cce8e6f0","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"11daa821-49aa-4bc0-bda7-a183148b9015","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"f35e4413-cbfc-48f8-8f68-216607a31731","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"6555ae22-0094-4044-936f-1f3fefd79359","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"5fb36ecc-1bc6-40bf-a7c5-29aa6193a795","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"ccdbf28e-5211-467a-b0a6-1534330ae53d","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"617fcff3-ce66-