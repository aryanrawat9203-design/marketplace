{"name":"Broadcast the team on new events with Twilio without manual work","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05863-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"10f57d43-2856-4c2d-bd6e-ba892299ab1b","name":"Receive Inbound Webhook","webhookId":"48a36167-c9c7-46ea-8c41-7abb3b92dffb"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"a8407f6c-09ba-45f9-a5c5-0c3cf811e09e","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d5f73d20-61ef-4446-8172-0aeb6d26bb7b","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"82212077-42ee-4cbc-ae9a-20e0dfbe1a69","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"10532652-6744-40aa-a5f0-33600e013078","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"cc0ba962-4ff8-4fb9-8997-5e3c03c27109","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"704f5fe0-4ca0-4381-a353-fb874b02c7b5","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"7962f5ff-398d-4cc9-8a4d-b2e03fbb351a","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"592b629f-ff34-