00) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4590,400],"id":"5d37363a-5ab4-44cc-834a-7374bdf2112f","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Jobs"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[4914,400],"id":"e7e45b06-7fce-4e51-8b43-e1990f967c07","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"62ece61b-2961-4249-a117-7cbe4f867ec8","name":"Record Sub-workflow Result"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5562,400],"id":"c9687185-e373-432b-bb03-e6d75405caac","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Database"},"title":"={{ $json.type || $json.jobId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5886,400],"id":"9ebed6d1-64c6-4ee3-96fa-bcc93dfebd3d","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6210,400],"id":"015ceee5-d1fd-4cb5-9085-51711665ecaa","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetwe