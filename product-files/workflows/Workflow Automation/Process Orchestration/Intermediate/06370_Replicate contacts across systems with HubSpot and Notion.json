{"name":"Replicate contacts across systems with HubSpot and Notion","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":4}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"50682b29-d609-4993-91af-dd52fd28eae4","name":"Hourly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"1f8a2f3b-51dc-41ab-b9eb-e9124f779eca","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"363c6dbd-981c-4302-986b-23e37f80ed51","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"149412de-6a91-4da7-a391-a1b4cf77c078","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"06d19573-e33b-44b2-8a1a-8a4935ab0a4a","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fdeec6d0-df63-4294-8980-7c86a71b1bed","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"56e598d0-97b7-482b-ae19-b22c5b421930","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"231ce4b4-4bfc-4afe-904c-f116e96d7686","leftValue":"={{ $json.kind }}","rightValue":"deleted","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"deleted"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":