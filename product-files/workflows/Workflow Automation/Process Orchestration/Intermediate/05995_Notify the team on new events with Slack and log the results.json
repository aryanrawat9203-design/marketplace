{"name":"Notify the team on new events with Slack and log the results","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05995-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"25f91c55-4f1a-4ad8-ad01-4d5c53f1432a","name":"Receive Inbound Webhook","webhookId":"181c3ba1-df76-4f12-933c-7acf480778a8"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"899a0547-2961-43b5-b9fe-4ae8edbed574","leftValue":"={{ $json.type }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"63cc9131-8033-4967-986a-86490252eb46","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'type' on incoming job."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"9f15147b-c190-44aa-bd88-84e2a3eac97e","name":"Abort — Malformed Input"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"3426367b-9b7d-4d72-b60d-1de66cdd094d","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"standard","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"standard"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7c29a89a-7adc-4f4c-af6e-bf5eb20cb86a","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"priority","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"priority"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"57abfaeb-904c-4aed-86b0-9215cef179db","name":"Route by Work Type"},{"parameters":{