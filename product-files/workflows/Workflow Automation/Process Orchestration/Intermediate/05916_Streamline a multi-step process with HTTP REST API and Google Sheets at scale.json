{"name":"Streamline a multi-step process with HTTP / REST API and Google Sheets at scale","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":7,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"d01eefe4-601f-4611-853e-9f6875c12d60","name":"Daily Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"58e47892-fbdb-4dfb-8c6e-ca39911ab295","leftValue":"={{ $json.type }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"d1bbe1c2-9c2b-4c39-9c5c-210fa48d8e36","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'type' on incoming job."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"b8dc7c32-eb94-4eec-b47d-b3a38ce96f37","name":"Abort — Malformed Input"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"cde7a364-18e9-4e40-95f6-33fa5d0c50ee","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"sync","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"sync"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b8db9c86-b558-4e20-810b-0f32fbc44fc0","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"async","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"async"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"12884680-7014-4819-b111-ad087b699f23","name":"Route by Work Type"},{"parameters":{"operation":"appendOrU