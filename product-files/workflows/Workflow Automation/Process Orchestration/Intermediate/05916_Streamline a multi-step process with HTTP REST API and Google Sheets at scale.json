831c73d-47e9-4676-9f16-c61b2d8a6ae2","name":"Cap Batch Volume"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8de735cb-898e-4a06-aa36-a58f8b744365","leftValue":"={{ $json.type }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3618,400],"id":"304ced22-7248-426d-a543-8a8603a564e7","name":"Guard Non-Empty type"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3942,400],"id":"1edcd025-187b-412e-9ad9-3c84ab2bd40d","name":"Sort Jobs Newest First"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4266,400],"id":"948b8325-25df-4697-a5b7-548a5898cb1f","name":"Stamp Processing Time"},{"parameters":{"dataToSave":{"values":[{"key":"jobId","value":"={{ $json.jobId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4590,400],"id":"4f269b5d-1a87-4d50-a1df-594a23b3c49e","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"edd85bd8-efca-477e-8964-65713b1a65f5","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"ffc3813f-e2b2-416a-8339-1ab481d61df0","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"7d5a24fe-07b0-42c0-b9f2-da4324bb71a8","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"f1ac07e8-35a0-4a28-b6c7-2a6d0795b8ad","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"448940fc-550f-44be-8c93-d8ae49303d38","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=✅ Streamline a multi-step process with HTTP / REST API and Google Sheets — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5562,400],"id":"4cf98929-ccbe-4ed7-8b00-f3b3f4547ea3","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d69d449b-9604-43d2-b8d8-2e2ff3ac5f1b","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"e1c6f154-93cf-4719-8ed9-1042c7fdfa65","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"1e621b64-459c-48cf-bee9-6a2c34b24fee","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,1420],"id":"60937c02-1479-4fd2-819b-f25b5e6db76f","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5238,1420],"id":"9ba6dc64-1a93-43f4-a011-fdeec83b09c5","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 7:00. No input data; downstream nodes fetch what they need.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"7365a088-31d1-3545-bf5a-00186528ea89","name":"Note: Daily Schedule"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.type }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Route by Work Type · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"1b38a7d2-fed5-7f19-931a-1f9de52e5bcc","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"f06619dc-1c66-0a3c-970e-fab93115a103","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: sync, async + fallback.\n\nPorts: ①→ Process 'sync' → Google Sheets · ②→ Fast-Track 'async' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"ba94cea8-9273-52d1-35e9-a3b5d0af4abb","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'sync' → Google Sheets\n\nUpserts a row into 'Job Tracker', matched on `jobId` — re-running with the same key updates the row instead of duplicating it.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"90bc9e1f-a863-a697-5ec9-b66537be3f66","name":"Note: Process 'sync' → Google Sheets"},{"parameters":{"content":"### Fast-Track 'async' + Alert\n\nPosts a chat message into a Microsoft Teams channel — same role as a Slack notify, for teams standardized on Teams.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"074bbd41-6abc-e513-cc6b-9cc886912ea0","name":"Note: Fast-Track 'async' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\nAppends a new row to 'Job Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"6cbce9c2-8c26-2a19-e8e6-a3dec4fe1ee3","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"d1856d44-6b45-f2d8-6465-18f7be14a8ac","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"24354de4-8013-af6b-56f7-8da09ad5c4a6","name":"Note: Align Field Names"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Guard Non-Empty type","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"4e21904d-768e-a6fd-9b42-8e9f3f64bc3e","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Guard Non-Empty type\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Sort Jobs Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"b4cd2ad6-ccc3-c49c-776c-797c0ef74291","name":"Note: Guard Non-Empty type"},{"parameters":{"content":"### Sort Jobs Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"dcfe62f1-0200-9f12-b67e-255079bd7e3f","name":"Note: Sort Jobs Newest First"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"41c9365a-c5b0-dffe-40f7-3866c047a389","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"d8911e38-436f-8d05-ea5c-624420d512da","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"04918497-8c95-23be-1570-3377916dd093","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\nAppends a new row to 'Job Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"08eff9e2-ccac-2638-6d7a-4f2adb836088","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#automation`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"14a493bc-5b93-289e-9a8d-19c5e675e803","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"33754a35-8f94-bd64-74f7-6cfa4758adff","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#automation`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"2be3d91d-df90-e8f9-71b6-99fea8434e53","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Streamline a multi-step process with HTTP / REST API and Google Sheets at scale\n\n**Pattern:** Workflow Automation · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nStreamline a multi-step process with HTTP / REST API and Google Sheets at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual process orchestration is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Required Fields Present? → Route by Work Type → Process 'sync' → Google Sheets → Merge Routed Work → Align Field Names → Cap Batch Volume → …\n\n## Use it for\n- Teams that want to workflow automation without manual effort\n- Anyone automating process orchestration in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Removes copy-paste errors\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Microsoft OAuth2; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"1fe893f2-6dcb-8bf6-8c00-a9963bbe85a4","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nUnrecognized work types are parked in a dead-letter lane instead of erroring the whole run or silently dropping the item — new event kinds will show up eventually, and this is where you'd notice one without losing it. One kind is deliberately routed through a sub-workflow to show how heavier per-type logic can be extracted without touching this router at all.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"9c2b72f0-e5e2-0240-8191-682cbcb9fce3","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nYou've got the basics covered — push further:\n\n1. Send a work-type value that matches no switch rule and confirm it lands in the dead-letter branch.\n2. Add a new work type and its own handling branch.\n3. Replace the direct-write branch with a sub-workflow call, matching the pattern already used for the first kind.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"e1e38ec3-3e24-b00c-9a46-5197fcac4dd6","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"4ef61f2a-93e4-89b8-f1bf-633263ee7474","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your process orchestration process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"e86e1fdf-eaae-a538-5cd7-e300fa64e9e6","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Route by Work Type","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'sync' → Google Sheets","type":"main","index":0}],[{"node":"Fast-Track 'async' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'sync' → Google Sheets":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'async' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Guard Non-Empty type","type":"main","index":0}]]},"Guard Non-Empty type":{"main":[[{"node":"Sort Jobs Newest First","type":"main","index":0}]]},"Sort Jobs Newest First":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Daily Schedule":[{"json":{"jobId":"JOB-4401","type":"export","payload":"customer-list-2026-07","status":"queued"}},{"json":{"jobId":"JOB-4402","type":"sync","payload":"inventory-delta","status":"running"}}]},"versionId":"e57342cf-13a5-4cc0-a6e6-2a6e102b7f7c","id":"FDX05916"}