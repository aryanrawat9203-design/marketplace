{"name":"Broadcast stakeholders on changes with Discord end to end","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05872-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"5b168cac-3573-4d96-90cb-1917b6113261","name":"Receive Inbound Webhook","webhookId":"2a696431-f6fc-44fb-af6d-fd4ac043f6ff"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"681bc7d9-cf1b-4859-a1e1-cc907dd11d02","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"34ca305e-41d5-4fd5-8227-1f23ec13cf67","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"1bb14d81-5c52-4717-bae4-4622fbaff5e4","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"dc045bbd-115c-4dfb-b948-ec56dbebecd2","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"c49eb0c5-6bea-4f6d-97d2-6e25d294fe84","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"afeaabc7-8fed-46b0-8a41-9fbccebf3ce5","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"8360c5e8-d341-4e17-b315-d23f23f0e440","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"e7daebee-7262-4d48-87