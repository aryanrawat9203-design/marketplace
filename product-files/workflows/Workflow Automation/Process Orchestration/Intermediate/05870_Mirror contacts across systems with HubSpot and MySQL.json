{"name":"Mirror contacts across systems with HubSpot and MySQL","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":1}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"ad50e86a-c60d-496f-add2-29a45ac3f93d","name":"Hourly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"4dd4665e-6216-4914-9b89-939b82550749","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"cfb9f5f6-5fb1-43ed-bb29-210485c94583","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"0f47325a-8b72-4063-9bfd-6849b4e15a9c","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"04b83f00-bc5e-470c-96a4-2d9d563f4fa8","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"46bac3d6-9ad1-49b4-9c0d-02de5ed75a89","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0b129c11-5a4e-4edf-8c41-6ce608b1c7cd","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"47770ab3-54e1-4305-a932-ec98460e4646","leftValue":"={{ $json.kind }}","rightValue":"deleted","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"deleted"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,