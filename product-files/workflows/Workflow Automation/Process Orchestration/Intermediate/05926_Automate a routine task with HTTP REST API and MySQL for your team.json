{"name":"Automate a routine task with HTTP / REST API and MySQL for your team","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":12}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"99b318d7-8a10-4b58-ab96-150211228f89","name":"Hourly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"b46b3922-9995-4078-ae2d-e09a0bb93cf0","name":"jobId","value":"={{ $json.jobId || $json.id || $execution.id }}","type":"string"},{"id":"fd018177-e100-4a64-b6d5-560ece8b39f0","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"83aacffc-c947-4ef1-8e7c-2c65bb82a713","name":"Stamp & Shape Job"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c3b49cad-73be-4d5e-8744-2a9e15f735c6","leftValue":"={{ $json.jobId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"1540b7ac-f04d-46c3-b97e-89a13f4b4974","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[378,910],"id":"7f09341a-8be9-4470-827e-39ca8962bda7","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"84aa01a0-05d9-47f4-a128-412e67e003dd","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"sync","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"sync"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"37203115-7dac-4b3b-8448-7025ca3f4fab","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"async","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"async"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"a10a2663-f862-4f76-93a2-d444789100dd","name":"Route by Work Type"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[1026,130],"id":"eb52d534-8a01-442b-9a65-004abcb421bb","name":"Process 'sync' → MySQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚀 Priority job handled: {{ $json.jobId }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[1350,640],"id":"c7eb15b7-6182-45fb-a411-ba27d5a67fe5","name":"Fast-Track 'async' + Alert","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[1674,1150],"id":"b48b7c3d-0a3e-42a7-a33d-856571f35243","name":"Hold Unknown Types (DLQ)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"75222f33-4342-4bb1-af85-2e83e0431ec6","name":"Merge Routed Work"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.type }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3294,400],"id":"2c1471e1-268d-4cd3-9829-69464ec9e9a3","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e7b2bfd6-ace3-4ae7-b22d-797242054b3f","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"70fd567c-ab5d-4782-bbe7-db0eceb4fcca","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"035aabb7-72eb-4fc3-b1db-2d2566ac9b18","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3942,400],"id":"079cc10b-a661-47cb-b992-d516c3e6841c","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4266,400],"id":"5017dfd5-782e-4e6c-80aa-3ee938bd96b6","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"7c2e81fb-e627-4808-ad63-7fb7565119be","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"c0ba9e4e-1c93-4cd4-9071-0f9f5a47dc98","name":"Persist Run Metadata"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"644c3d67-af72-4350-bebc-ff1a35ad8e3f","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"d6826c24-fe37-49b2-9d74-39bf6ea9aa5b","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"a5a2450a-3a10-421e-80ea-0807f3b73e16","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"d0c4b8da-628d-46b9-81e5-adcd4e2df9fb","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"76088004-1eec-4515-b2f4-e71e157d1817","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"2d0667a3-d346-47e0-863f-90cbaaf42824","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[6210,400],"id":"893af685-e0bf-424c-8cf3-d05d3341558f","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=✅ Automate a routine task with HTTP / REST API and MySQL for your team — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,400],"id":"d62bdde8-495b-4442-a48a-83b293ea7d59","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"7e13290f-edda-4b3c-8303-68a1237436dd","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ef521435-a675-4f9c-a1a6-c3d065d3e067","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"3d0652d1-9bbd-4900-bbcc-290e1861ef99","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"adf04fb1-8e62-4b58-acbd-41db3722b220","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#automation","cachedResultName":"#automation"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,1420],"id":"6eeb7f15-80ed-456c-87e3-ba3db78d152c","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"jobs","cachedResultName":"jobs"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[6534,1420],"id":"f774a486-904c-4521-a335-e64f99a7f8c2","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 12 h. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Job","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"8684ffd5-dcd3-5ae0-ada6-62d0f1a8ef70","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Stamp & Shape Job\n\nShapes the item: writes `jobId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"854f0248-fc7d-96fd-7258-9d466da1bd83","name":"Note: Stamp & Shape Job"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.jobId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Route by Work Type · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"b87011c6-9a21-beda-ab01-9624894472c3","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nInserts a row into the MySQL table using fields auto-mapped from the incoming item.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"786b60ef-0b76-12f6-8ce8-2a33b42e16bf","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: sync, async + fallback.\n\nPorts: ①→ Process 'sync' → MySQL · ②→ Fast-Track 'async' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"60669544-f903-6825-308f-1571e2760078","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'sync' → MySQL\n\nInserts a row into the MySQL table using fields auto-mapped from the incoming item.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,250],"id":"51d5e2de-2695-8df7-e792-298b6a3cb863","name":"Note: Process 'sync' → MySQL"},{"parameters":{"content":"### Fast-Track 'async' + Alert\n\nSends an SMS via Twilio — reserved for urgent alerts since SMS costs money per message, unlike chat notifications.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,760],"id":"1f3c9b0e-686d-376d-a9e6-e26ae28f52d6","name":"Note: Fast-Track 'async' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\nInserts a row into the MySQL table using fields auto-mapped from the incoming item.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1270],"id":"ee20bbae-ceb0-dd0b-36e4-73ae8e1854f7","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"197c4a37-2ebe-ad56-b929-fe26e646636d","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"ad624b48-365b-9493-bff2-797bda30f24e","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"e6b521f5-7cb3-98ff-5825-04e94087671b","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"aa35d9da-7fa2-6cc6-37f4-8d56cb4f8089","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nAppends a new row to 'Job Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"b481a75b-d5eb-8f3f-aa1e-63b7b58d094b","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"38b0bdcb-4927-2f1b-a78e-273fcf45fc72","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"102b52c7-f604-5d27-4fc6-c2d83337d5f4","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Load Previous Snapshot\n\nReads every row from 'Job Tracker' — the read side of the store, e.g. for a digest or a downstream sync.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"9216a916-7cf8-61ab-398e-c4cc7613b3c4","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"4611dda6-f9aa-c77e-4417-f65095f59c9b","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"cdd8b16a-6740-7842-a4c8-d680a12bfca1","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nInserts a row into the MySQL table using fields auto-mapped from the incoming item.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"2d64041b-3bd5-5ca1-754a-ad140988748c","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#automation`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"2a9b73a8-0d6d-e087-cad7-16cbf95ffad2","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"cd6e47ef-6b42-4cc4-f89d-5d9904cfb8bf","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#automation`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"5d79c598-dc07-e01a-fcc4-d9bb80721a0f","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nInserts a row into the MySQL table using fields auto-mapped from the incoming item.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"dbb8074b-2d8c-07bd-bfc6-865a499fa4e9","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Automate a routine task with HTTP / REST API and MySQL for your team\n\n**Pattern:** Workflow Automation · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nAutomate a routine task with HTTP / REST API and MySQL for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual process orchestration is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Stamp & Shape Job → Payload Valid? → Route by Work Type → Process 'sync' → MySQL → Merge Routed Work → Enrich with Reference Data → …\n\n## Use it for\n- Teams that want to workflow automation without manual effort\n- Anyone automating process orchestration in productivity\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Saves hours of manual work each week\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; MySQL connection; Slack OAuth2; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"cb8c2314-191f-e48d-d8fd-437b2cf4ff6c","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nUnrecognized work types are parked in a dead-letter lane instead of erroring the whole run or silently dropping the item — new event kinds will show up eventually, and this is where you'd notice one without losing it. One kind is deliberately routed through a sub-workflow to show how heavier per-type logic can be extracted without touching this router at all.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"24696d68-793f-8fac-94fa-0431727ef85e","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAlready production-grade — deepen your understanding:\n\n1. Send a work-type value that matches no switch rule and confirm it lands in the dead-letter branch.\n2. Add a new work type and its own handling branch.\n3. Replace the direct-write branch with a sub-workflow call, matching the pattern already used for the first kind.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"6dbfd5ed-d47f-e711-14c1-c95b1388e18c","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"440f9ddc-6d49-4a6b-5022-8707f368ef21","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your process orchestration process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"c6d6e6be-e85c-99a4-e077-87d67cd6b832","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Stamp & Shape Job","type":"main","index":0}]]},"Stamp & Shape Job":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Route by Work Type","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'sync' → MySQL","type":"main","index":0}],[{"node":"Fast-Track 'async' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'sync' → MySQL":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'async' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Hourly Schedule":[{"json":{"jobId":"JOB-4401","type":"export","payload":"customer-list-2026-07","status":"queued"}},{"json":{"jobId":"JOB-4402","type":"sync","payload":"inventory-delta","status":"running"}}]},"versionId":"adf135d8-5d8a-44ef-b526-7f592929e6be","id":"FDX05926"}