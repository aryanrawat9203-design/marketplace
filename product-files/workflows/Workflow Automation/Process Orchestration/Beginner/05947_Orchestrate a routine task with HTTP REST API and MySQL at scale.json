{"name":"Orchestrate a routine task with HTTP / REST API and MySQL at scale","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":7,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"9aab751d-215e-4e92-86e9-55b6b0e3c18a","name":"Daily Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"1cbb00ae-b47a-4732-99b4-77dcf717b41a","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"1be269f3-f77f-4687-b8b8-d38866e4f5f7","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"a8b06700-3b40-46ca-b7cd-5b894808d8b6","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"5b08055d-c23f-4c72-8974-729a171da9a2","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c1d9ca26-b618-487f-9c92-73c6a5a35820","leftValue":"={{ $json.kind }}","rightValue":"job.start","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"job.start"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"82551c80-5fd0-409a-a4cb-6c6b9ca0ffbd","leftValue":"={{ $json.kind }}","rightValue":"job.done","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"job.done"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"5307c311-1233-4a9d-81a1-f7c449d57ca9","name":"Route by Event Kind"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultNa