{"name":"Orchestrate a routine task with HTTP / REST API and MySQL at scale","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":7,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"17286930-ce2f-4b41-b1bd-20d271fa6297","name":"Daily Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"a00ae80a-7e42-4b13-9b61-91ed877969e5","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"3229dcb5-dc68-4af7-b010-93f5773476f4","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"cee252b5-b89a-46f0-8d3a-2868733727f8","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"367e1283-beac-4dcb-b1da-023e558538e8","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"008b8aed-dcae-4775-8b4f-000f08057259","leftValue":"={{ $json.kind }}","rightValue":"job.start","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"job.start"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"368d00bd-d87a-4b68-bd75-2e7fbad1f947","leftValue":"={{ $json.kind }}","rightValue":"job.done","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"job.done"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"6284aa2d-5b55-4df8-bcb1-46ee13e5353c","name":"Route by Event Kind"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Job Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultNa