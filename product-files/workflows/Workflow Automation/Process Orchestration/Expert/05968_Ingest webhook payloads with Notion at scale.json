{"name":"Ingest webhook payloads with Notion at scale","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05968-job","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"e134ec25-64be-41fd-97d4-0373e6fd398e","name":"Receive Inbound Webhook","webhookId":"8d099576-d5ac-4738-a8ee-ef4746c2f5b8"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"a2c70115-2e41-466e-b13c-ec7316c77fd1","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"410b6786-fe27-4a89-90c5-2ae110e25a0f","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"20d0a428-2dab-4945-8195-78c560f1187a","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"0b34f01f-b838-4183-a64c-22a651c50ceb","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"12cd8c7b-95f6-4902-bd9a-4fc78560ce58","name":"jobId","value":"={{ $json.body?.jobId || $json.body?.id }}","type":"string"},{"id":"d8a8d81d-d4f4-4ea6-b64c-5652cc0cdb00","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"8540e40f-a588-45d1-b23a-bed7558bebb4","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"23b22141-76d9-43f9-ab26-01bbf203b3