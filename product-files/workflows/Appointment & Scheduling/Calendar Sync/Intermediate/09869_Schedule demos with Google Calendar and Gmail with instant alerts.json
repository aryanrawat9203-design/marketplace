{"name":"Schedule demos with Google Calendar and Gmail with instant alerts","nodes":[{"parameters":{"formTitle":"Schedule demos with Google Calendar and Gmail with instant a","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Starttime","requiredField":false},{"fieldLabel":"Service","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"5ec17384-34aa-463f-acc3-ebc27e538d14","name":"New Booking Form Submission","webhookId":"58cedaa0-bf72-4388-9923-0b113a0616aa"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"70e1ba00-8661-4f31-b91b-d05db966a337","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"d24cfd11-a378-48bc-9857-3d0f2799d8ae","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'email' on incoming booking."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"472ba9bd-1d32-44de-add9-707af5ff7890","name":"Abort — Malformed Input"},{"parameters":{"resource":"event","operation":"getAll","calendar":{"__rl":true,"mode":"list","value":"","cachedResultName":"Team Calendar"},"options":{"timeMin":"={{ $json.startTime || $now.toISO() }}","timeMax":"={{ $now.plus({days: 1}).toISO() }}","singleEvents":true},"returnAll":true},"type":"n8n-nodes-base.googleCalendar","typeVersion":1.3,"position":[378,400],"id":"3349e7f1-d233-4a08-9bbd-16a7b83772db","name":"Check Calendar Availability","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b6bc9731-