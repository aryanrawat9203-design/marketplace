- prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4590,400],"id":"fd1a8cbf-c889-49e1-b3f0-d0cb2175b673","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"643a5ef2-d152-435e-9ce5-f28f7975aeee","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"326e289e-4ccf-42f5-9967-ee986f6d1cf1","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5562,400],"id":"bf1850d9-b453-411a-9f90-6f9221ff3d40","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Booking Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"611f20b3-8357-4107-92e9-a9524c6952ac","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"94617842-f901-47dc-af95-54ea01494212","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"7aa633e0-f186-4603-88fa-15590a000574","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"78c9e304-cb63-4100-a228-781052079222","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.se