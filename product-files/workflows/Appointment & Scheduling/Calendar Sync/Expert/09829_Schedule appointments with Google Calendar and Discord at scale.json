 = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.bookingId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4590,400],"id":"fa1152d7-5345-41b3-8e37-e9a5c4f4d584","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4914,400],"id":"e57ea5e4-0559-4ae2-ad52-68f5101aee2a","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"87615eb8-1fd9-49b4-bd4e-2bc7a38f32fe","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"158b65dd-5657-40db-8b9b-3ef32c0c50a5","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"74c858d2-ca71-4fff-a101-698ce089872a","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"bc0d18b6-ee29-4682-af99-073ab398f3b2","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Booking Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"fcc86b3b-d9d9-47b0-bd34-2a35a8b5735c","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#bookings","cachedResultName":"#bookings"},"text":"=✅ Schedule appointments with Google Calendar and Discord at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position"