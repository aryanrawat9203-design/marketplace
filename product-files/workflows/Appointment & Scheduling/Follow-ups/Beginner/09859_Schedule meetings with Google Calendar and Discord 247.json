st Approval via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resume":"webhook","httpMethod":"POST","options":{}},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1026,400],"id":"14896eb2-3e7f-40f7-916a-29cd3d40caba","name":"Hold for Decision","webhookId":"8dc3086e-cc7f-4583-8821-2df39329db44"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"80893880-158d-41f8-8325-a313377abc02","leftValue":"={{ $json.body?.decision || $json.decision }}","rightValue":"approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"d69b5f99-a29f-455c-951c-ade34c27a96b","name":"Approved?"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Booking Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["bookingId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1674,160],"id":"7e609372-26e4-41aa-b789-9da743b020e0","name":"Apply Approved Change (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#bookings","cachedResultName":"#bookings"},"text":"=❌ Request {{ $json.requestId }} was declined.","otherOptions":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[1998,760],"id":"c067ac0c-4fe0-4c3e-bdaa-8f0d3f71e2b9","name":"Record Decline + Notify Requester","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"4a73291e-f5a4-462b-8c76-cebf1c9b7ccc","name":"Join Decision Paths"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[3618,400],"id":"6adfabcb-7fc0-4af0-a26c-b73285103911","name":"Cap Batch Volume"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"bookingId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3942,400],"id":"a3e9a04b-e9c4-4e02-ade1-c9f5b82ffa83","name":"Align Field Names"},{"parameters":{"authentication":"webhook","content":"=✅ Schedule meetings with Google Calendar and Discord 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[4266,400],"id":"68f72b21-9528-491c-8758-ec95c141984e","name":"Send Summary to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"79c1adcc-b6ce-4aad-8342-caff95185381","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"596c5f10-f77e-4289-9ced-a19064361689","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"6bacfed4-765d-4a5d-a501-91fbf708f3c0","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,1420],"id":"3add9b84-8cf7-4357-90c4-d626b5204463","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#bookings","cachedResultName":"#bookings"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3942,1420],"id":"619f32aa-9631-4294-bcbc-4752934caa61","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Booking Form Submission\n\nServes an n8n-hosted form (Email, Starttime, Service). Each submission becomes one execution.\n\nNext: Keep Valid Bookings","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"5d065903-6a3e-ee43-f4d5-fd2595cac665","name":"Note: New Booking Form Submission"},{"parameters":{"content":"### Keep Valid Bookings\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Prepare Approval Packet","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"17327b94-347c-1de4-831b-eeac03f99f2f","name":"Note: Keep Valid Bookings"},{"parameters":{"content":"### Prepare Approval Packet\n\nShapes the item: writes `requestId`, `summary`, `requestedBy`. Keeps the schema explicit between stages.\n\nNext: Request Approval via Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"126d5711-b4b7-dff9-b11e-2b8960edb60f","name":"Note: Prepare Approval Packet"},{"parameters":{"content":"### Request Approval via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Hold for Decision · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"6a801175-9b69-1c2e-866e-f79afa9b5467","name":"Note: Request Approval via Slack"},{"parameters":{"content":"### Hold for Decision\n\nPauses the execution until the resume webhook is called — this is the approval/HITL gate.\n\nNext: Approved?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"2cf06031-0acd-45e2-558c-f2b1654235ad","name":"Note: Hold for Decision"},{"parameters":{"content":"### Approved?\n\nTwo-way gate on `={{ $json.body?.decision || $json.decision }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Apply Approved Change (Google Sheets) · ②→ Record Decline + Notify Requester","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"7d080c15-260f-bf72-c2e0-53bb1abf61c5","name":"Note: Approved?"},{"parameters":{"content":"### Apply Approved Change (Google Sheets)\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"f348ca27-9705-22e3-2c42-c29a410b9942","name":"Note: Apply Approved Change (Google Sheets)"},{"parameters":{"content":"### Record Decline + Notify Requester\n\ndiscord — `action` operation against the connected account.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"0fde6ed3-d906-2aac-7df0-34fbbddbead6","name":"Note: Record Decline + Notify Requester"},{"parameters":{"content":"### Join Decision Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"d7925313-56d8-6683-3343-a9b6c0fcf269","name":"Note: Join Decision Paths"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"0f8d3c78-7cb8-796d-6412-b8ee472b4da5","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Send Summary to Discord","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"0f1041a8-6a0e-347b-1687-9e9a583f1774","name":"Note: Align Field Names"},{"parameters":{"content":"### Send Summary to Discord\n\ndiscord — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"13b3a5d7-f5ea-bce9-22ef-6cc145a38ef0","name":"Note: Send Summary to Discord"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,1540],"id":"c8e50137-619b-900f-1433-bb1fdef58d09","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"e45a78b6-f065-25a1-8bd1-32c74f28b3c1","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Schedule meetings with Google Calendar and Discord 24/7\n\n**Pattern:** Meeting Scheduling · **Level:** Core · **Trigger:** Form\n\n## What it does\nSchedule meetings with Google Calendar and Discord 24/7. It starts from a hosted form submission.\n\n## Why it exists\nManual follow-ups is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Booking Form Submission → Keep Valid Bookings → Prepare Approval Packet → Request Approval via Slack → Hold for Decision → Approved? → Apply Approved Change (Google Sheets) → …\n\n## Use it for\n- Teams that want to meeting scheduling without manual effort\n- Anyone automating follow-ups in healthcare\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Removes copy-paste errors\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: Discord webhook URL; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"7576012a-9c2b-a4ae-fb7b-244aff323cbb","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"b6595ef5-4644-e531-5d40-522f5b14177e","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"5641684a-e492-2348-eb70-c6ac3cf559c0","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🙋 Human in the loop\n\nThe workflow pauses at the Wait node until a human posts a decision to the resume URL (included in the approval message). Approve → the action executes; anything else → recorded as declined. No timeout is set by default — add one under the Wait node's options if approvals go stale.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"cdac0c63-d1c2-037f-da55-3bd6bfba55d3","name":"🙋 Human in the loop"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your follow-ups process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"685ec8be-e21a-1082-568d-0807dd607ee7","name":"🛠 Customize me"}],"connections":{"New Booking Form Submission":{"main":[[{"node":"Keep Valid Bookings","type":"main","index":0}]]},"Keep Valid Bookings":{"main":[[{"node":"Prepare Approval Packet","type":"main","index":0}]]},"Prepare Approval Packet":{"main":[[{"node":"Request Approval via Slack","type":"main","index":0}]]},"Request Approval via Slack":{"main":[[{"node":"Hold for Decision","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold for Decision":{"main":[[{"node":"Approved?","type":"main","index":0}]]},"Approved?":{"main":[[{"node":"Apply Approved Change (Google Sheets)","type":"main","index":0}],[{"node":"Record Decline + Notify Requester","type":"main","index":0}]]},"Apply Approved Change (Google Sheets)":{"main":[[{"node":"Join Decision Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Decline + Notify Requester":{"main":[[{"node":"Join Decision Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Decision Paths":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Send Summary to Discord","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Discord":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"8ded0e57-8b53-4923-ba80-c72f5a53faf2","id":"FDX09859"}