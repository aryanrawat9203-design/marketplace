0) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"1fed68c6-9460-4a9d-94be-9cffc6d29744","name":"Compute Drift vs Snapshot"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e01ce0bb-d2b0-4393-8f4f-c3927bc5a592","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7506,400],"id":"fbd89a54-8b29-4834-9643-7a59795bbbe6","name":"Guard Non-Empty email"},{"parameters":{"dataToSave":{"values":[{"key":"bookingId","value":"={{ $json.bookingId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7830,400],"id":"b0fa92e2-04f4-4351-8f5e-5e1c54794f1f","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"3d45bae6-b23a-4787-b15f-ad450e0499da","name":"pipeline","value":"Follow-ups","type":"string"},{"id":"52c086ec-bf91-4caa-b8ed-5a5a5a03f6e5","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"797e8dec-3b4f-42ce-a5af-8c2e78d4eb94","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"65c09201-f7c0-4e55-83eb-45a04243412c","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6f09fd2a-d238-4d69-a92e-b50db55f3168","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"68bf4e78-1859-48ff-a44d-8a453a41013f","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,400],"id":"a165b543-d918-4c49-9521-83f740c8d9da","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Booking Database"},"title":"={{ $json.email || $json.bookingId }}","options":{}},"type":"n