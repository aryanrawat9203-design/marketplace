0) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"e51f3479-1e5e-43e9-8473-61286db7b83a","name":"Compute Drift vs Snapshot"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ccadc674-3f68-451b-b512-7b94788bc86c","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7506,400],"id":"137700a4-d13e-4c3f-b95f-fa5d46a6e84a","name":"Guard Non-Empty email"},{"parameters":{"dataToSave":{"values":[{"key":"bookingId","value":"={{ $json.bookingId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7830,400],"id":"ed4ddfa6-c68a-4313-a3af-544339cc83bf","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"df467938-f4c1-4f3c-9a82-63591dfacefa","name":"pipeline","value":"Follow-ups","type":"string"},{"id":"384133eb-953f-4b73-bbe3-23d96b56def0","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"3b2008b5-41c8-45e1-a8ab-7a9b4b600fa7","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"9d804323-9e5c-4659-acd7-f93d22e09994","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f66326dc-b5fa-4515-ad5b-4ada76fe7fb8","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"dfa67d91-e2aa-41f6-8dd9-7b8532904352","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,400],"id":"e1d5b5e9-18bf-4f12-ae8e-94bcaeadb000","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Booking Database"},"title":"={{ $json.email || $json.bookingId }}","options":{}},"type":"n