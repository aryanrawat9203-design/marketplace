e":"list","value":"","cachedResultName":"Booking Database"},"title":"={{ $json.email || $json.bookingId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5886,400],"id":"b1b03f85-bed4-4517-9eee-c9f9d1e74e35","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Booking Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6210,400],"id":"7ae8c222-995e-4bc8-833f-0d3cb6937f24","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6534,400],"id":"39956200-9470-45eb-94ad-7afc202e3a1d","name":"Compute Drift vs Snapshot"},{"parameters":{"dataToSave":{"values":[{"key":"bookingId","value":"={{ $json.bookingId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"faeb025b-46a8-422b-8c9f-38d78b8966a9","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"9032f512-b7f2-4674-8612-b75e275800d6","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"297ac66b-8052-4ac9-aac8-875f52ac41bc","name":"itemCount","value":"={{ $input.all().length }