-2938-4968-b098-bc2c49f814a3","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"7799be95-101b-407d-8479-4e76b278af73","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b66ad3d1-69f0-4866-8374-244c3487fa0a","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"85623116-eb28-4f03-adb5-7ad1fa3d9dfd","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"63846196-56b0-4391-ae4c-fcac38c83a92","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Booking Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,400],"id":"d17f82d5-147b-489a-9658-c6bacdcf9299","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=✅ Schedule demos with Google Calendar and Outlook — run completed at {{ $now.to","bodyContent":"=✅ Schedule demos with Google Calendar and Outlook — run completed at {{ $now.toFormat('HH:mm') }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[6534,400],"id":"cb2ba623-0cb6-41d2-a671-ebc99ec30406","name":"Send Summary to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"61c311b8-674c-4d01-aa53-21293590925b","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"8e874c03-b779-4087-a287-a0f1de58f726","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify