{"name":"Collect listings with HTTP / REST API and Google Drive in real time","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":4}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"a3cf74fb-b624-47e0-8370-27601cfdf677","name":"Hourly Schedule"},{"parameters":{"url":"https://news.example.com/feed.xml","options":{}},"type":"n8n-nodes-base.rssFeedRead","typeVersion":1.2,"position":[54,400],"id":"39572868-13f6-4a04-acae-22b1161617bf","name":"Read Source Feed","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.link }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"d2cd6bfb-5758-4211-a80b-310f7c283c88","name":"Skip Already-Seen Posts"},{"parameters":{"maxItems":5},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"31c72472-270c-4db8-900b-0a2652c3095a","name":"Keep Top Stories"},{"parameters":{"promptType":"define","text":"=Rewrite this story as a punchy 3-sentence post for our audience:\n\n{{ $json.title }}\n{{ $json.contentSnippet || $json.content }}","options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"bfca23c1-6735-4a2d-a1e2-83c302ce9ab8","name":"Rewrite for Our Audience (AI)","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[1269,970],"id":"72183258-620e-4b6e-b946-25c60b5a7b14","name":"OpenAI Chat Model"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"={{ $json.text || $json.title }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,160],"id":"265815cd-1c06-4507-8300-b21b71a1d814","name":"Publish to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1917,400],"id":"a615fb8d-a8c0-4ca6-b292-5f2ee0b0f3c2","name":"Log Published Posts (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Listings"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[2241,400],"id":"f1862265-77fa-402a-ae40-76c4bf4456e4","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2565,400],"id":"4c5ba5b7-2256-4198-8be9-ce1fa3fdd8e9","name":"Record Sub-workflow Result"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2889,400],"id":"dfc59e83-7fb8-4e98-9e80-c8985f37b784","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3213,400],"id":"f6492177-babc-4a7e-82ba-69d785bda840","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3537,400],"id":"b3d63d02-644b-47d1-9c7a-bacded9a05c5","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3861,400],"id":"9842b85b-2e5f-4fa9-acf0-f27fd8749e46","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.url }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4185,400],"id":"36ce0cff-1705-43e1-a469-2a2472f1d57b","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6bfb513c-0b9b-4068-bd6d-75899477fd10","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"8dac48d3-a913-4bcf-827c-8d56f30cde81","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4509,400],"id":"c7c57071-a712-4793-a384-54c50c63d0b6","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4833,400],"id":"929f835c-b206-4716-b9db-9a1e63c24e5f","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[5157,400],"id":"147e78ee-be8a-4307-9e71-850b3479f140","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per listing (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.listingId, j.url].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5481,400],"id":"e1761f7c-9607-465f-bc5a-7d3e1288b9f3","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5805,400],"id":"6b0981b7-8ed5-43b1-946e-550361165ff0","name":"Drop Already-Processed Items"},{"parameters":{"dataToSave":{"values":[{"key":"listingId","value":"={{ $json.listingId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6129,400],"id":"3fedd538-6a89-49cc-a05f-2497b5cacf1a","name":"Save Execution Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"listingId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[6453,400],"id":"b555c098-b946-4d74-94f9-647d7da8b30f","name":"Align Field Names"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"price","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[6777,400],"id":"e1740af3-f5cb-470a-a987-04321d574817","name":"Sort Listings Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"4c7483b7-d665-45da-9ae1-e223f4304b3d","name":"pipeline","value":"Lead Lists","type":"string"},{"id":"7be4a1b6-386d-441c-baf1-020624c92a38","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7101,400],"id":"c136463e-fffc-4aa5-a295-c113215f81fa","name":"Tag Pipeline Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c8fb5779-40b8-4b2b-ab47-e3c8558841d9","leftValue":"={{ $json.url }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7425,400],"id":"58fb6ee7-a549-4e41-b7e2-89353068bdcb","name":"Guard Non-Empty url"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7749,400],"id":"45c2b22d-ac1d-486a-8e73-9b13881166c6","name":"Stamp Processing Time"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8073,400],"id":"40c0c447-5083-4c7c-a4fc-e2bec8c93fce","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"68be5939-f1ca-4a6a-a0cd-3b4f9b69afde","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"d5ca7be7-ce0b-41e9-91f2-e411f9c76709","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8ef85511-91b3-4ee6-85d4-ee175ea72b3b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8397,400],"id":"65265d0c-ae0b-4310-81fb-f288b4f2245c","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[8721,400],"id":"30b5ca97-b7f2-420b-93f3-a30faff987be","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=✅ Collect listings with HTTP / REST API and Google Drive in real time — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9045,400],"id":"54043836-5893-4840-a773-32c89b68c9b6","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"064ef8e4-0ba1-410c-baa9-f5a4383bfe5d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"5b64f64e-86db-4aee-8c2c-da340b2ff5ec","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"af11e670-c7d5-4f2b-9b17-fdef91a1f74b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8397,1420],"id":"3bbada57-bc1b-4f83-8e73-bfcb40e00ec8","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8721,1420],"id":"21ae5458-ca23-4f30-9be3-ee272208e619","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Database"},"title":"={{ $json.url || $json.listingId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9045,1420],"id":"be071387-72b7-42d4-89b9-91fa75dfe13c","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 4 h. No input data; downstream nodes fetch what they need.\n\nNext: Read Source Feed","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"09efdf2f-e2b6-88f8-d2ee-ed27254aae74","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Read Source Feed\n\nPulls the RSS feed and emits one item per entry (title, link, content).\n\nPorts: ①→ Skip Already-Seen Posts · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"be9f6a29-d46c-e2f4-4a5a-72bb533d1166","name":"Note: Read Source Feed"},{"parameters":{"content":"### Skip Already-Seen Posts\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Keep Top Stories","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"2e726b6d-d6b7-35ed-59a8-84fceb6dacae","name":"Note: Skip Already-Seen Posts"},{"parameters":{"content":"### Keep Top Stories\n\nCaps the stream at 5 items to protect downstream quotas.\n\nNext: Rewrite for Our Audience (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"089e8ab5-2796-0348-15dc-60ebe4d52946","name":"Note: Keep Top Stories"},{"parameters":{"content":"### Rewrite for Our Audience (AI)\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish to Slack · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"a6ec6686-ab35-d5c7-c50f-fcaf5e9b06cf","name":"Note: Rewrite for Our Audience (AI)"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Rewrite for Our Audience (AI)** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"dad9cc91-0a13-b160-5493-8f8d8d93cf8f","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Publish to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Log Published Posts (Google Sheets) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,280],"id":"65f45218-95d3-d1fb-e87c-17a23d142bcd","name":"Note: Publish to Slack"},{"parameters":{"content":"### Log Published Posts (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Offload to Post-Process Sub-workflow · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"a86cda76-aaeb-09f2-fe02-de0e7b08ce2c","name":"Note: Log Published Posts (Google Sheets)"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"315316ef-dd7a-40d9-1f32-6ffd9c86aa1c","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"d4a19da4-911a-6200-2862-56bc209fba53","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"8ca4530e-2c5a-b311-0a5c-88bb7b666bbb","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"d5c26336-fc53-3236-3436-0cbe0e57f5cf","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"2537c7af-380a-d38f-f75f-019a8924d8da","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"3b646a3f-cd94-defc-3cf1-2d4afafd2cde","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"2a421017-59fb-6cce-12dc-d0b4edca8210","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"58b03c86-2433-8be9-f851-d484090b08d4","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"5f67c488-444d-d96e-ee76-4565589af270","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"91228ec7-4025-b959-034c-2b1e0fa75eca","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per listing (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"8c20bb8e-9d2a-897e-f8d0-da0d4ae1a5ac","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"177409fd-217b-7eb5-fb14-53799eab9444","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"e3022a1e-1e13-0b1e-8bf4-42ef7893fac6","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Sort Listings Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"0d9f603d-df94-66be-e299-f2a316f0c8a8","name":"Note: Align Field Names"},{"parameters":{"content":"### Sort Listings Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"da003e6d-d0aa-8db1-f98a-f2a3b045f123","name":"Note: Sort Listings Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Guard Non-Empty url","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"fb46a7bb-a5de-f61f-0bfb-82e0f1c27c62","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Guard Non-Empty url\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"d5246d0f-1105-bf70-f204-66447177f6f0","name":"Note: Guard Non-Empty url"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"9132afda-17d7-fcaf-687e-f02fe5279f26","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"9906ab73-24a9-c377-c3fe-e01ca4615d27","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,520],"id":"ca8e3f62-8679-2183-e51b-8187d84c1e34","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,520],"id":"c3941390-a31e-4850-88d3-ead814655776","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,520],"id":"2147841d-d9eb-3b08-9d3a-ec7852db6543","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,1540],"id":"c64213ad-9ddd-46cc-6642-5b9f91f9955b","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,1540],"id":"d3b5e122-5935-1546-27cd-31200e7b1109","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,1540],"id":"b926e6e7-9b1b-c3ef-dc70-16b94cc05276","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Collect listings with HTTP / REST API and Google Drive in real time\n\n**Pattern:** Web Scraping · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nCollect listings with HTTP / REST API and Google Drive in real time. It runs automatically on a schedule.\n\n## Why it exists\nManual lead lists is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Read Source Feed → Skip Already-Seen Posts → Keep Top Stories → Rewrite for Our Audience (AI) → Publish to Slack → Log Published Posts (Google Sheets) → …\n\n## Use it for\n- Teams that want to web scraping without manual effort\n- Anyone automating lead lists in data\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Responds in seconds\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Notion integration token; OpenAI API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"191ccbd4-91a9-f367-49d7-c720b6cfe360","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"20966fc7-55ce-7b55-7a7f-cd121694f9ff","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"db3f7e3c-bafe-d146-3480-53043bba4e57","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"08ae7004-0f96-acb1-a31a-3e7e3c1ac286","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your lead lists process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"1d3071b9-7dec-dd8f-500d-dcbf2eada526","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Read Source Feed","type":"main","index":0}]]},"Read Source Feed":{"main":[[{"node":"Skip Already-Seen Posts","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Skip Already-Seen Posts":{"main":[[{"node":"Keep Top Stories","type":"main","index":0}]]},"Keep Top Stories":{"main":[[{"node":"Rewrite for Our Audience (AI)","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Rewrite for Our Audience (AI)","type":"ai_languageModel","index":0}]]},"Rewrite for Our Audience (AI)":{"main":[[{"node":"Publish to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Slack":{"main":[[{"node":"Log Published Posts (Google Sheets)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Published Posts (Google Sheets)":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Sort Listings Newest First","type":"main","index":0}]]},"Sort Listings Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Guard Non-Empty url","type":"main","index":0}]]},"Guard Non-Empty url":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"f4b4dd7a-1da2-432a-86fe-422f94946fbf","id":"FDX09776"}