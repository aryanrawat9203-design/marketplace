{"name":"Scrape listings with HTTP / REST API and Airtable for your team","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":6}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"c624e743-b7ec-4100-9c61-771a86d98d37","name":"Hourly Schedule"},{"parameters":{"method":"GET","url":"https://example-market.com/listings","options":{"timeout":20000,"response":{"response":{"responseFormat":"text"}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"af3589af-0c79-4350-8e17-7f3f9ac00e9f","name":"Fetch Target Page","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"extractHtmlContent","extractionValues":{"values":[{"key":"title","cssSelector":".listing h2","returnValue":"text","returnArray":true},{"key":"price","cssSelector":".listing .price","returnValue":"text","returnArray":true},{"key":"url","cssSelector":".listing a","returnValue":"attribute","attribute":"href","returnArray":true}]},"options":{}},"type":"n8n-nodes-base.html","typeVersion":1.2,"position":[378,400],"id":"316abe85-0bc3-471c-8dfd-d05cf8f95685","name":"Extract Listings (CSS)"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Zip parallel arrays into one item per listing\nconst j = $input.first().json;\nconst n = (j.title || []).length;\nconst out = [];\nfor (let i = 0; i < n; i++) {\n  out.push({ json: { title: j.title[i], price: j.price?.[i], url: j.url?.[i] } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"7e50f448-d0bd-4a6e-9d25-8ad5fc274006","name":"Rows from Arrays"},{"parameters":{"operation":"search","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Web Scraping & Data Extraction Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listings"},"filterByFormula":"={LastModified} > DATEADD(NOW(), -1, 'days')","options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[1026,910],"id":"9a913ce4-8cf9-4ac2-9ca5-5df1ca12dfa4","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mergeByFields":{"values":[{"field1":"url","field2":"url"}]},"options":{}},"type":"n8n-nodes-base.compareDatasets","typeVersion":2.3,"position":[1674,400],"id":"c2e92212-d43b-4ae5-83d3-694f45caedb5","name":"Diff vs Last Run"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=🆕 {{ $json.title }} — {{ $json.price }} ({{ $json.url }})","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2646,-80],"id":"0d769947-8d41-4147-afe1-38a449a477e0","name":"Alert New Findings","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"upsert","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Web Scraping & Data Extraction Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listings"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["listingId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2970,460],"id":"a2cf1428-5d15-4eb1-9576-4226b0565a91","name":"Update Changed Rows","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Web Scraping & Data Extraction Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listings"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3294,970],"id":"94f53ab9-3bae-4924-93fb-20dafe521178","name":"Write Fresh Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3942,400],"id":"036b4198-bec6-4c0d-80d9-0ca9ef22f59a","name":"Merge Diff Outcomes"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per listing (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.listingId, j.url].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"2779f88e-3d39-4e5e-a5f6-dce0dfbe74c4","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5238,400],"id":"b4b1c1fc-de56-4981-9b18-800f54a73b55","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5562,400],"id":"a965dbeb-5043-4120-9758-623780155084","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"f907ca11-c764-42e6-8a91-d332277cf1cf","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6210,400],"id":"e15370b9-b89c-4758-8aa5-bf76513bef13","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6534,400],"id":"4faaa970-6392-43c6-ab6d-67347ab598bb","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"70b497fa-7441-4033-956f-3d91f429c83e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"599e235b-5afa-43f7-b37e-b57cdab6d3e8","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9740a69e-d105-4f92-83f2-040b03cb0132","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"32ee6b1e-78c7-4d83-9897-1356f6954875","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7182,400],"id":"3479450d-d4fa-45c1-b49d-b49189cfd417","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=✅ Scrape listings with HTTP / REST API and Airtable for your team — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7506,400],"id":"ded53914-ac0c-44ba-914d-6aea50c44557","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"606f0928-1a90-4d51-a248-2f41898c2d18","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"684fd1f8-ed04-4fe8-8522-f3dde8090034","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"54a6c90b-0dc7-45d5-aae0-7d50bbf39736","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,1420],"id":"b2dbc63e-aa9f-422d-bea4-19404101891c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7182,1420],"id":"052fe236-5943-4076-a4b3-ef980e0ec81c","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7506,1420],"id":"33cdd1de-1d89-4a33-8ce4-1dcb0eaecfe3","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 6 h. No input data; downstream nodes fetch what they need.\n\nNext: Fetch Target Page","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"a91e569d-64c9-228c-185e-a199f53d280b","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Fetch Target Page\n\nGET https://example-market.com/listings — retries 3× with backoff on failure.\n\nPorts: ①→ Extract Listings (CSS) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"9d5b5b1f-39fe-666b-c57c-e2e8509266cd","name":"Note: Fetch Target Page"},{"parameters":{"content":"### Extract Listings (CSS)\n\nExtracts structured values from raw HTML via CSS selectors.\n\nNext: Rows from Arrays","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"fbf5563f-64be-dd0c-4064-2004a838578a","name":"Note: Extract Listings (CSS)"},{"parameters":{"content":"### Rows from Arrays\n\nCustom JavaScript: Zip parallel arrays into one item per listing\n\nNext: Diff vs Last Run","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"f5846f0b-042b-08a3-7bf5-42ee5afa51d1","name":"Note: Rows from Arrays"},{"parameters":{"content":"### Load Previous Snapshot\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Diff vs Last Run · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1030],"id":"94f1dad8-2a2b-5672-c676-e6838896a30f","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Diff vs Last Run\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Alert New Findings · ③→ Update Changed Rows · ④→ Write Fresh Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"c7d6ad4b-8bc3-bbaf-bc5f-13c833adb3a9","name":"Note: Diff vs Last Run"},{"parameters":{"content":"### Alert New Findings\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,40],"id":"26bc3d40-b425-f6c6-dc75-97e54f725c50","name":"Note: Alert New Findings"},{"parameters":{"content":"### Update Changed Rows\n\nairtable — `upsert` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,580],"id":"20236b11-89da-dff7-3dc6-b30f1eff8ba9","name":"Note: Update Changed Rows"},{"parameters":{"content":"### Write Fresh Snapshot\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,1090],"id":"66ed43f4-2902-dbaf-75d3-4fde8996eb2f","name":"Note: Write Fresh Snapshot"},{"parameters":{"content":"### Merge Diff Outcomes\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"2d4b598f-235a-f880-11f4-296aadd9298a","name":"Note: Merge Diff Outcomes"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per listing (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"6b6a4e59-d9c2-d2b5-57e6-06f52b4b984b","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"66486c20-4727-49db-be10-2914a9b1f5ff","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"856584d2-24f2-ac09-799f-da26cd3d5c93","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"6ad00e76-b1f1-96fb-4fe6-91f1999c38b8","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"292b5ffa-3592-66e8-bf04-d75ce0f6c29e","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"c4c5697f-1b32-73f9-fcf3-9272fea95d40","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"cf9614e1-7f58-0133-efd3-0065117a2ba7","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"28e33cf1-c5c1-9f74-a0fe-1e1ef7bc3543","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"7c045a5a-e9b8-f26a-1b17-c38e1346f3f8","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,1540],"id":"d01b263c-6304-2dd2-dee5-abe47ac24008","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"d0988944-46f0-6d5d-1a29-7b24bb56b4d6","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"a387a4a2-c252-3ce4-ea46-f943d2c234ab","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Scrape listings with HTTP / REST API and Airtable for your team\n\n**Pattern:** Web Scraping · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nScrape listings with HTTP / REST API and Airtable for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual lead lists is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Fetch Target Page → Extract Listings (CSS) → Rows from Arrays → Diff vs Last Run → Alert New Findings → Merge Diff Outcomes → …\n\n## Use it for\n- Teams that want to web scraping without manual effort\n- Anyone automating lead lists in data\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Improves response time\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"25d93db7-5006-d317-ef12-fe84334b290a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"6d091eb1-c800-96ab-54e7-2f1d80e34edc","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"8eea884d-91d2-583d-c082-48cfc7751099","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your lead lists process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"a37c253c-186d-1b60-2531-6aa102651537","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Fetch Target Page","type":"main","index":0},{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Fetch Target Page":{"main":[[{"node":"Extract Listings (CSS)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Extract Listings (CSS)":{"main":[[{"node":"Rows from Arrays","type":"main","index":0}]]},"Rows from Arrays":{"main":[[{"node":"Diff vs Last Run","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Diff vs Last Run","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff vs Last Run":{"main":[[{"node":"Alert New Findings","type":"main","index":0}],[],[{"node":"Update Changed Rows","type":"main","index":0}],[{"node":"Write Fresh Snapshot","type":"main","index":0}]]},"Alert New Findings":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Update Changed Rows":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Write Fresh Snapshot":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Diff Outcomes":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"405b6114-06b4-48d6-99b6-a469b1ef936f","id":"FDX09688"}