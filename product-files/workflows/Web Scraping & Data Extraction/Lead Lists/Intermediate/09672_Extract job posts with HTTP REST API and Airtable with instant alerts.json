          "mode": "list",
          "value": "",
          "cachedResultName": "Web Scraping & Data Extraction Base"
        },
        "table": {
          "__rl": true,
          "mode": "list",
          "value": "",
          "cachedResultName": "Listings"
        },
        "filterByFormula": "={LastModified} > DATEADD(NOW(), -1, 'days')",
        "options": {}
