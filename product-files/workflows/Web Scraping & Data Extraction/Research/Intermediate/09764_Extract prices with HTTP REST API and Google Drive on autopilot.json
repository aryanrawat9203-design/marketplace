{"name":"Extract prices with HTTP / REST API and Google Drive on autopilot","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":6,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"aa702f20-be14-4f76-baa3-1822960a0f73","name":"Daily Schedule"},{"parameters":{"method":"GET","url":"https://example-market.com/listings","options":{"timeout":20000,"response":{"response":{"responseFormat":"text"}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"9165898d-f750-4073-b50b-d516ac66817b","name":"Fetch Target Page","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"extractHtmlContent","extractionValues":{"values":[{"key":"title","cssSelector":".listing h2","returnValue":"text","returnArray":true},{"key":"price","cssSelector":".listing .price","returnValue":"text","returnArray":true},{"key":"url","cssSelector":".listing a","returnValue":"attribute","attribute":"href","returnArray":true}]},"options":{}},"type":"n8n-nodes-base.html","typeVersion":1.2,"position":[378,400],"id":"cc7a08d2-9033-45a1-9f8c-3770e141421d","name":"Extract Listings (CSS)"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Zip parallel arrays into one item per listing\nconst j = $input.first().json;\nconst n = (j.title || []).length;\nconst out = [];\nfor (let i = 0; i < n; i++) {\n  out.push({ json: { title: j.title[i], price: j.price?.[i], url: j.url?.[i] } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"2de92f50-abb6-4c10-ad99-2a91267d814d","name":"Rows from Arrays"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,910],"id":"115bcddc-bcf5