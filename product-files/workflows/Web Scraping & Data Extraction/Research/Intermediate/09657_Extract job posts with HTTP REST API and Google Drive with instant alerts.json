":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3942,400],"id":"ac6f5828-ce01-4a8d-8e09-c2992cfdfdee","name":"Merge Diff Outcomes"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4914,400],"id":"c8a0c9cd-b15b-4189-90fb-f93c8b68b3d1","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[5238,400],"id":"58ce4c91-3a9d-4d2c-9982-e27a81b72f11","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5562,400],"id":"53f62136-692f-410c-b0c7-1d2f23867e85","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5886,400],"id":"1ba9143f-0b7d-4661-87ea-018567e3c33a","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per listing (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.listingId, j.url].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6210,400],"id":"d334f09c-c9f3-4e6a-8cfe-8531f57c5ade","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6534,400],"id":"0e053068-16ed-417b-b1cf-a10501616d83","name":"Drop Already-Processed Items"},{"parameters":{"dataToSave":{"values":[{"key":"listingId","value":"={{ $json.listingId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"a2f73039-4595-4b1a-804f-41bd9612d674","name":"Save Execution Metadata"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=✅ Extract job posts with HTTP / REST API and Google Drive with instant a — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7182,400],"id":"ef284bbf-350a-4369-8da1-deacfa270857","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"923f2f88-1875-4ce9-adbd-37e1d897f233","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"63117f92-cfe6-4585-bedd-2a55bf544fda","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"78f97d08-8dc5-4965-a3b5-d8d90b77b9af","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6534,1420],"id":"38dcb6e4-9cb9-4a9e-b460-2e19b7335185","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6858,1420],"id":"f9cc9c81-0363-4c11-9674-bcda069cbbea","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7182,1420],"id":"fa7caa19-cae7-4581-b694-6ed3dc3a2018","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 7:00. No input data; downstream nodes fetch what they need.\n\nNext: Fetch Target Page","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"2a6beb73-2a36-ea26-72a0-891b287604d7","name":"Note: Daily Schedule"},{"parameters":{"content":"### Fetch Target Page\n\nGET https://example-market.com/listings — retries 3× with backoff on failure.\n\nPorts: ①→ Extract Listings (CSS) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"0e011543-4329-2635-6f3b-fa301965766b","name":"Note: Fetch Target Page"},{"parameters":{"content":"### Extract Listings (CSS)\n\nExtracts structured values from raw HTML via CSS selectors.\n\nNext: Rows from Arrays","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"5ac2602b-35b2-1e12-8350-c1a939a0b3ff","name":"Note: Extract Listings (CSS)"},{"parameters":{"content":"### Rows from Arrays\n\nCustom JavaScript: Zip parallel arrays into one item per listing\n\nNext: Diff vs Last Run","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"6c8e60b3-5167-d0e9-d1b0-fa83dcb3585d","name":"Note: Rows from Arrays"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Diff vs Last Run · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1030],"id":"70d0b9aa-5dd6-9919-b9e4-438cfe9f9e2d","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Diff vs Last Run\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Alert New Findings · ③→ Update Changed Rows · ④→ Write Fresh Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"e5e7e374-b741-6e10-b167-3d9e230d6e96","name":"Note: Diff vs Last Run"},{"parameters":{"content":"### Alert New Findings\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,40],"id":"0d9b4388-9b88-c026-fda4-8d8c2ba8204c","name":"Note: Alert New Findings"},{"parameters":{"content":"### Update Changed Rows\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,580],"id":"909e91e1-f505-a03f-e328-0dc2777bdc83","name":"Note: Update Changed Rows"},{"parameters":{"content":"### Write Fresh Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,1090],"id":"4190c5a8-24e3-399f-515b-72f04d45692c","name":"Note: Write Fresh Snapshot"},{"parameters":{"content":"### Merge Diff Outcomes\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"f11ca889-cce9-1149-0fff-96b26bb4b14a","name":"Note: Merge Diff Outcomes"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"dc747fdf-c823-2d15-9639-b4d6bbeb19db","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"db46a7fa-2383-a447-e2b4-47856b120518","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"3de71d71-ac0b-c64a-42a7-2ccfcc1fd6c1","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"c4074166-1c48-27fe-d8ff-e6b5c9c8a149","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per listing (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"c73accf1-ab44-05eb-34e6-7da34c1139f3","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"3d1f05b0-2efa-76a1-c076-5d59243078fa","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Send Summary to Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"5407d12b-9512-9557-b337-91a3cee921eb","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"7e7719df-ffd6-e0ce-f680-2dfff34d8e2f","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"bf45b0b2-ab34-7c50-fba7-b5a18e25e2df","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,1540],"id":"c6640954-fc53-26a0-71a0-7df139ea6386","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"92fd6a5b-e1fd-8fe8-37f6-9e02800a555e","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Extract job posts with HTTP / REST API and Google Drive with instant alerts\n\n**Pattern:** Web Scraping · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nExtract job posts with HTTP / REST API and Google Drive with instant alerts. It runs automatically on a schedule.\n\n## Why it exists\nManual research is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Fetch Target Page → Extract Listings (CSS) → Rows from Arrays → Diff vs Last Run → Alert New Findings → Merge Diff Outcomes → …\n\n## Use it for\n- Teams that want to web scraping without manual effort\n- Anyone automating research in data\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Responds in seconds\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"1f4f8010-8bc7-d25e-069e-457b6da575a1","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"afb2da4b-114a-e23b-0ea5-d3e8fc952d92","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"dbe5c3d0-3881-d915-dc91-55bc038286e5","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"90f6d035-ae75-0013-b438-2c618e3cd862","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Fetch Target Page","type":"main","index":0},{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Fetch Target Page":{"main":[[{"node":"Extract Listings (CSS)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Extract Listings (CSS)":{"main":[[{"node":"Rows from Arrays","type":"main","index":0}]]},"Rows from Arrays":{"main":[[{"node":"Diff vs Last Run","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Diff vs Last Run","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff vs Last Run":{"main":[[{"node":"Alert New Findings","type":"main","index":0}],[],[{"node":"Update Changed Rows","type":"main","index":0}],[{"node":"Write Fresh Snapshot","type":"main","index":0}]]},"Alert New Findings":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Update Changed Rows":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Write Fresh Snapshot":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Diff Outcomes":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"de62530c-93e7-4f3a-9a3e-1ef6072706ce","id":"FDX09657"}