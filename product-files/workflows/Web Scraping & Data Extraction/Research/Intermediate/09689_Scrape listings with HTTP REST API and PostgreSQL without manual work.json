{"name":"Scrape listings with HTTP / REST API and PostgreSQL without manual work","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[2],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"b87ed062-a8ac-4e59-ac94-8a139a05eeaf","name":"Weekly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"fc5be963-3ed9-43af-b3fc-ed51396f3daf","name":"page","value":"1","type":"number"},{"id":"02265e9b-6365-4b4e-9f42-b3d0fc1c6b81","name":"hasMore","value":"true","type":"boolean"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"c27b0f3b-76db-49ff-bed0-a482a1eee1e5","name":"Init Cursor"},{"parameters":{"batchSize":1,"options":{"reset":false}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[378,400],"id":"21c88d2f-0acc-4ce2-8b69-7ad6211caf37","name":"Page Loop"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/listings","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"page","value":"={{ $json.page }}"},{"name":"per_page","value":"50"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,880],"id":"0c19f712-08b9-486a-95f6-a93300bd6b4c","name":"Fetch Page from API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"fieldToSplitOut":"data","options":{}},"type":"n8n-nodes-base.splitOut","typeVersion":1,"position":[1350,880],"id":"cff4fa28-7bae-4283-b96c-2059e1d7c730","name":"Split Result Items"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming listing records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    listingId: String(j.listingId ?? j.id ?? '').trim(),\n    url: typeof j.url === 'string' ? j.url.trim() : j.url ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2322,880],"id":"189ccf3a-344c-495d-b87c-d428cabe903b","name":"Normalize Page Items"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"listingId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2646,400],"id":"66273edf-ac2e-47c2-a39b-a26f26b56ce3","name":"Remove Duplicate Listings"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO listings (listingId, url, title, updated_at)\nVALUES ($1, $2, $3, NOW())\nON CONFLICT (listingId) DO UPDATE SET updated_at = NOW();","options":{"queryReplacement":"={{ [ $json.listingId, $json.url, $json.title ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2970,400],"id":"14dc83ea-10a6-48ba-9117-c46f979821f9","name":"Upsert Harvest into PostgreSQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"fieldsToSummarize":{"values":[{"aggregation":"count","field":"listingId"}]},"options":{}},"type":"n8n-nodes-base.summarize","typeVersion":1.1,"position":[3294,400],"id":"ffcef41b-0c9f-471d-9803-daab87de28d8","name":"Tally Harvest Stats"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3618,400],"id":"52eea9e5-d20f-499d-b1e7-4f256b7d954e","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3942,400],"id":"9faa2faa-014d-428c-aa97-76f6cd9a4bf2","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per listing (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.listingId, j.url].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"33d2482e-753b-4d17-b1c5-b8e1fd4e40dd","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4590,400],"id":"dc7033f3-26e2-491f-b56c-de8b18cce1da","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"5f082036-15bb-4312-9864-5184dadf8c4b","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"db4cb586-2eeb-47ae-a5b9-106c0600f4f8","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.url }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5562,400],"id":"f33111e7-444d-41ef-a04e-96f367770248","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"91876207-6bcb-41eb-af69-b11dd816c873","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"70e8f892-a10e-44a9-b292-a074f675b935","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"a259d9c0-ea5d-498f-a262-9d88c599c1c5","name":"Fold In Enrichment Fields"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Listings"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[6210,400],"id":"508cbb41-7a22-47c4-a17b-78302a645f37","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6534,400],"id":"67a88959-ddf8-44c6-8411-f64621a184fd","name":"Record Sub-workflow Result"},{"parameters":{"operation":"executeQuery","query":"SELECT * FROM listings WHERE updated_at > NOW() - INTERVAL '1 day' ORDER BY updated_at DESC;","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[6858,400],"id":"f5c3035d-a178-4406-8b05-00bd4cc427ed","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"c89acc07-1d82-4f13-8196-4aef3c407e98","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"00969226-16b3-4261-8f33-5c8f51c2c112","name":"pipeline","value":"Research","type":"string"},{"id":"9eb901e5-5a85-40b8-92ac-83bae676ef10","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7506,400],"id":"cd20c530-3a67-4e85-ad76-3df1cefde264","name":"Tag Pipeline Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fd26e70d-3bde-41a2-843b-d2392cb688d5","leftValue":"={{ $json.url }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7830,400],"id":"dd6e4a28-19b4-49e7-9c85-4c324cce3041","name":"Guard Non-Empty url"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8154,400],"id":"0d782e94-1fd8-4552-a4a0-cac9217dc9c0","name":"Cap Batch Volume"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[8478,400],"id":"fe72b9f1-14ec-4edb-8566-9431ad88bf86","name":"Stamp Processing Time"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"listingId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8802,400],"id":"5cc52835-894f-425a-b28f-caefa4b5e1ce","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"b1a94ff3-2993-42d1-b7f0-7f18e05098f7","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"ae5ec9a5-72f9-444c-9131-9ffc82842625","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8d089e4f-9ff1-435f-8228-9c85dba0b42b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9126,400],"id":"c20c611d-a561-4a9b-a890-bea15cca5698","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[9450,400],"id":"65dcbce3-25d8-4cf6-8aeb-eb5093234303","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=✅ Scrape listings with HTTP / REST API and PostgreSQL without manual wor — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9774,400],"id":"983dc620-d859-4ebc-b321-02f94eb88739","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"fac61ab0-03d1-4916-891b-b287d7886815","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ffc4a05b-c8e5-4d3e-998e-beeb75fa9dd7","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"f477a93a-4c68-41b4-a9c2-012ec7c0181b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9126,1420],"id":"97e4ed4c-b1be-4831-b600-0f56e6b6ed5c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#scraping","cachedResultName":"#scraping"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9450,1420],"id":"2010ce32-53a4-4b34-aa9b-3ff0cf7783fb","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Listing Database"},"title":"={{ $json.url || $json.listingId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9774,1420],"id":"53f5cd15-cac8-4cc0-bf41-bad85cd1aca2","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Init Cursor","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"e7adbe57-4c5e-7fb5-c9b2-36fc50ffa10d","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Init Cursor\n\nShapes the item: writes `page`, `hasMore`. Keeps the schema explicit between stages.\n\nNext: Page Loop","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"ed4dae44-0cee-d00c-b766-ba3ec2fec3cc","name":"Note: Init Cursor"},{"parameters":{"content":"### Page Loop\n\nLoop controller — releases 1 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Remove Duplicate Listings · ②→ Fetch Page from API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"e4b017d5-dfde-47e3-350c-de702cc834db","name":"Note: Page Loop"},{"parameters":{"content":"### Fetch Page from API\n\nGET https://api.example.com/v1/listings — retries 3× with backoff on failure.\n\nPorts: ①→ Split Result Items · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"21b328e2-a9c0-2013-150b-13cee85a99ca","name":"Note: Fetch Page from API"},{"parameters":{"content":"### Split Result Items\n\nExplodes the `data` array into one item per element.\n\nNext: Normalize Page Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"1d4f4a57-d7aa-56b3-83f9-e6c0f586dce4","name":"Note: Split Result Items"},{"parameters":{"content":"### Normalize Page Items\n\nCustom JavaScript: Normalize incoming listing records to a stable schema\n\nNext: Page Loop","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,1000],"id":"cc3b1f55-9d7b-cb0e-345b-97bfab6c36fe","name":"Note: Normalize Page Items"},{"parameters":{"content":"### Remove Duplicate Listings\n\nDrops duplicates within this run (compared on `listingId`).\n\nNext: Upsert Harvest into PostgreSQL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"1b33f93a-7621-68da-3cda-0ba07bc7b2d6","name":"Note: Remove Duplicate Listings"},{"parameters":{"content":"### Upsert Harvest into PostgreSQL\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Tally Harvest Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"03b6df90-8996-feb5-8df3-c6eecf9f60cb","name":"Note: Upsert Harvest into PostgreSQL"},{"parameters":{"content":"### Tally Harvest Stats\n\nGroup-by + aggregate (like a pivot table) — turns raw rows into KPI numbers.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"a19d4e2d-5bee-6141-1f75-c468a5b9b446","name":"Note: Tally Harvest Stats"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"70ce76cd-afa7-cafd-8d04-9c9d9d61465b","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"970680b2-5aee-7ab0-e602-c26bb4e1c96f","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per listing (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"fb5f40c9-6e8a-451e-99fb-05bd63d63fbc","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"b02301f7-72d3-3879-16e1-d6aea6b0a8e6","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"45b753e9-5c4e-37b5-a075-faee5f1114cf","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"6fad3b1d-d555-8d39-7e97-20e139a0bd06","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"35b83b04-fa2c-6bcd-8cbb-cc21adbcd636","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"3502fa9d-b20a-52df-044f-377dbd1b7860","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"d3c019c6-18be-276d-780b-ec1d733a0c73","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"ba5cbd7e-06c0-5b5d-9db4-78d4a1997b6d","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Load Previous Snapshot\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"735f8235-c3dd-055f-0e1e-05beb148a2a4","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"f625746a-fcbd-7ba4-5fa3-c6b97df79a32","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Guard Non-Empty url","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"2107a73b-edf8-a099-6f49-df77bdc0c84e","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Guard Non-Empty url\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"d8fff006-81ac-7ddc-762b-151e32a8b771","name":"Note: Guard Non-Empty url"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"ee0dda4f-f117-d39e-7fe2-47ace7ee93c4","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"627db1ff-2f9b-fecd-a277-24f9bbb1b5dc","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"812bbea6-a15e-361e-eae1-accfd78d0cbb","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,520],"id":"92443102-b4e9-1708-bebc-4bc6fa73f761","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,520],"id":"0876be69-df7b-cc99-73d8-a405055ed6e3","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9714,520],"id":"396dfe48-ddf5-7a14-11c8-a76629edc852","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,1540],"id":"ab64aba3-9f6c-e4b9-c92a-339ba49375f8","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,1540],"id":"7c4cf6c8-76a9-3ccc-7368-f89e713aaf2c","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9714,1540],"id":"544e8b53-9b25-8758-b642-85aa89647e9d","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Scrape listings with HTTP / REST API and PostgreSQL without manual work\n\n**Pattern:** Web Scraping · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nScrape listings with HTTP / REST API and PostgreSQL without manual work. It runs automatically on a schedule.\n\n## Why it exists\nManual research is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Init Cursor → Page Loop → Remove Duplicate Listings → Upsert Harvest into PostgreSQL → Tally Harvest Stats → Serialize Run Output (CSV) → …\n\n## Use it for\n- Teams that want to web scraping without manual effort\n- Anyone automating research in data\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Saves hours of manual work each week\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Notion integration token; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"34204ed3-2dad-b047-0b03-dc02d4d4386f","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"6da54b65-bf12-980b-7ac5-b7c3ae9f8d95","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"979821d1-b265-54de-0361-e867674557a7","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"681b5cac-24c1-05e4-a3e8-0532b7cf8bd8","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your research process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"19f9505b-2e2c-8d48-72b7-7640c4aa17d2","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Init Cursor","type":"main","index":0}]]},"Init Cursor":{"main":[[{"node":"Page Loop","type":"main","index":0}]]},"Page Loop":{"main":[[{"node":"Remove Duplicate Listings","type":"main","index":0}],[{"node":"Fetch Page from API","type":"main","index":0}]]},"Fetch Page from API":{"main":[[{"node":"Split Result Items","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Split Result Items":{"main":[[{"node":"Normalize Page Items","type":"main","index":0}]]},"Normalize Page Items":{"main":[[{"node":"Page Loop","type":"main","index":0}]]},"Remove Duplicate Listings":{"main":[[{"node":"Upsert Harvest into PostgreSQL","type":"main","index":0}]]},"Upsert Harvest into PostgreSQL":{"main":[[{"node":"Tally Harvest Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Tally Harvest Stats":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Guard Non-Empty url","type":"main","index":0}]]},"Guard Non-Empty url":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"ff9814cc-3852-49ca-af41-74f1a4ece7c0","id":"FDX09689"}