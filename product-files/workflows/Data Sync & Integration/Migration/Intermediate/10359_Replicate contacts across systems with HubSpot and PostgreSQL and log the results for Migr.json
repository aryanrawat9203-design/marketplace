      ],
      "id": "96cad45e-6b7f-43f5-b275-d13345ac1692",
      "name": "Persist Watermark (HubSpot)",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "operation": "getCurrentDate",
        "outputFieldName": "processedAt",
