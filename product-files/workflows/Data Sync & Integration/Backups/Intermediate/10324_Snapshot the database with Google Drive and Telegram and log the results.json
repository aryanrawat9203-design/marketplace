              "type": "string"
            },
            {
              "id": "e336eef1-eebb-4662-bff5-0d0b7e402519",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "6448e943-4048-4c10-82ef-b65eee19455f",
      "name": "Validate Input",
