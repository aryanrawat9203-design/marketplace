{"name":"Ingest webhook payloads with Notion 24/7","nodes":[{"parameters":{"httpMethod":"POST","path":"wf10349-record","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"6a43423f-65cd-46b0-953e-88ecba004c24","name":"Receive Inbound Webhook","webhookId":"ffcea298-4dd9-4aec-8f14-0b4f8df8a5de"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming record records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    recordId: String(j.recordId ?? j.id ?? '').trim(),\n    sourceId: typeof j.sourceId === 'string' ? j.sourceId.trim() : j.sourceId ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"d8162bf3-c6fe-42cb-a897-74453010303a","name":"Normalize Record Payload"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c3530481-71d4-400f-b9a4-a16f88720adf","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"standard","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"standard"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"194ce195-1ae5-40b0-b3ac-8085390b91d8","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"priority","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"priority"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"01c09c56-7a11-4d1a-bf84-ff671ca9317f","name":"Route by Work Type"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"