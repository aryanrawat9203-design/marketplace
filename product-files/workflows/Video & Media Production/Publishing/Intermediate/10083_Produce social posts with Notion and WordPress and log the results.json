s":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#media","cachedResultName":"#media"},"text":"={{ $json.html || $json.response?.text || $json.text }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1917,400],"id":"d1ec24a3-6a44-4685-b1b1-2fb496de776a","name":"Post Digest to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Database"},"title":"={{ $json.title || $json.assetId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2241,400],"id":"45cca5f4-9ef2-48b3-a7d9-0e16232dd983","name":"Archive Digest in Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per asset (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.assetId, j.title].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2565,400],"id":"792a26d1-37de-424e-a402-0c2999044512","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2889,400],"id":"c4f2b4fc-e4dd-4eaf-b6ce-07586294751a","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3213,400],"id":"f013db26-859a-4b08-bbff-27c111c7a295","name":"Serialize Run Output (CSV)"},{"parameters":{"resource"