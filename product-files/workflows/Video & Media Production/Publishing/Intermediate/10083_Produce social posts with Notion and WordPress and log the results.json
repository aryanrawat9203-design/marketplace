":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5157,400],"id":"cfdab6ba-3dad-43e7-98b9-d8daa13316a7","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5481,400],"id":"0d6d914f-532d-47ee-ba81-f6b4692b8ea8","name":"Record Sub-workflow Result"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5805,400],"id":"3586f0ac-17a8-4e99-a163-4ee89c2d961a","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6129,400],"id":"8312171f-233e-488d-bc4a-e96f35cc9a62","name":"Compute Drift vs Snapshot"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"assetId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[6453,400],"id":"549181d2-eeae-448e-84d5-be1d3b81c666","name":"Align Field Names"},{"parameters":{"operation":"getCurrentDate","