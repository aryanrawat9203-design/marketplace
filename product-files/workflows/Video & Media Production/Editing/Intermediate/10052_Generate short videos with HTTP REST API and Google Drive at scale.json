        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming asset records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    assetId: String(j.assetId ?? j.id ?? '').trim(),\n    title: typeof j.title === 'string' ? j.title.trim() : j.title ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40,
        400
      ],
      "id": "72f92c2f-9a17-440b-879a-5910f4824114",
