      "id": "de502ec0-aa1c-45fe-99a6-80d3d62471bc",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality shorts content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        520,
