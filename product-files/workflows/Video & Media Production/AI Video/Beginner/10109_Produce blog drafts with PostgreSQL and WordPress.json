{"name":"Produce blog drafts with PostgreSQL and WordPress","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":6,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"e03b28d0-f20e-4265-b547-12fbcd643c12","name":"Daily Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"823a04c7-8614-4024-aca1-74110568afad","name":"assetId","value":"={{ $json.assetId || $json.id || $execution.id }}","type":"string"},{"id":"38a480cc-3a63-4ffb-afce-a7ceac38e081","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"908fccf2-024d-4666-8a10-4ce35abdcb53","name":"Stamp & Shape Asset"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ac46dca3-6300-4188-aefe-d6199b982726","leftValue":"={{ $json.assetId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"14d69cbb-53b3-47ba-8838-4c0ebcd65361","name":"Payload Valid?"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO asset_log (assetId, title, duration, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.assetId, $json.title, $json.duration ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[378,910],"id":"ef654a1b-12be-45b5-8a80-c2c5aa9e491f","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"assignments":{"assignments":[{"id":"e2ddb0fa-8ed8-4133-80cf-f1039415d3e4","name":"brief","value":"={{ $json.topic || $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"97c3cda0-17bb-4866-880a-1493490a2e05","name":"tone","value":"={{ $json.tone || 'professional' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[702,400],"id":"e805c243-e45a-44a3-8410-aa19d105501f","name":"Build the Brief"},{"parameters":{"promptType":"define","text":"=Write {{ $json.tone }} content for: {{ $json.brief }}","messages":{"messageValues":[{"message":"You write production-quality ai video content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"3809f9a2-cde6-4f68-90b8-edea316feab2","name":"Draft with AI Writer","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[1269,970],"id":"199b1ea5-abd0-410f-89d7-89e109b3a687","name":"OpenAI Writer Model"},{"parameters":{"promptType":"define","text":"=Improve this draft without changing facts:\n\n{{ $json.text }}","messages":{"messageValues":[{"message":"You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1593,400],"id":"de8eec4e-a3f1-4a57-b9fb-a8d1da87914a","name":"Refine with AI Editor","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[1836,970],"id":"62de2cf9-1378-40de-a38f-babb6ca1fbc4","name":"OpenAI Editor Model"},{"parameters":{"mode":"markdownToHtml","markdown":"={{ $json.text }}","options":{}},"type":"n8n-nodes-base.markdown","typeVersion":1,"position":[2160,400],"id":"c5f4a3af-b4d5-42b3-81c1-4949af0f1355","name":"Convert to HTML"},{"parameters":{"title":"={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}","additionalFields":{"content":"={{ $json.html || $json.text }}","status":"draft"}},"type":"n8n-nodes-base.wordpress","typeVersion":1,"position":[2484,400],"id":"7fa0cade-ed13-4ed1-b482-1e64809752b8","name":"Publish Draft to WordPress","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"assetId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[2808,400],"id":"0d0db92c-510f-43fe-b791-a8d4c34197ec","name":"Align Field Names"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3132,400],"id":"6b8f54a6-3ac6-4551-b008-2d36a6762b4e","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"6314dc88-2f5b-4e08-a043-e828126ca85d","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e7725083-8fd4-4542-95c5-96e8a3a6178c","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9d575f63-c8f2-4656-b5d7-a081460b5f6a","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3456,400],"id":"f936748f-ab99-45e6-b9ec-ea646e352b1c","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO asset_log (assetId, title, duration, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.assetId, $json.title, $json.duration ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[3780,400],"id":"7fa7e8a0-48f9-4cab-aac6-72b68e71b3e9","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#media","cachedResultName":"#media"},"text":"=✅ Produce blog drafts with PostgreSQL and WordPress — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4104,400],"id":"5babb03e-961d-451a-8e7b-8f96a61d6bc6","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6c463744-4afe-44ff-a9cb-03d5e24a78b0","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"e0e4e714-72c7-4bc4-8c55-8a3565ec82ac","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"6427a006-1f4d-4b09-9604-7dd4c9a710bd","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3456,1420],"id":"c1030901-ef23-40db-a2a9-9fc2fedb9e9d","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#media","cachedResultName":"#media"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3780,1420],"id":"f925d4e7-c00b-4f34-8058-e9115438be87","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 6:00. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Asset","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"45b91335-61e5-27b4-7360-8da1dc62b021","name":"Note: Daily Schedule"},{"parameters":{"content":"### Stamp & Shape Asset\n\nShapes the item: writes `assetId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"ce2e84e8-c264-db84-e709-b7b75772de67","name":"Note: Stamp & Shape Asset"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.assetId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Build the Brief · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"6780aadf-c1fa-3869-4ba6-6b99171e5a67","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\npostgres — `executeQuery` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"0f165071-1fa8-6348-fed6-c94ff2352e53","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Build the Brief\n\nShapes the item: writes `brief`, `tone`. Keeps the schema explicit between stages.\n\nNext: Draft with AI Writer","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"0cfadf3c-4d5b-a9fe-0e0f-31ebec9566c2","name":"Note: Build the Brief"},{"parameters":{"content":"### Draft with AI Writer\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Refine with AI Editor · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"addbd0a2-5f04-b9d2-df2a-5ad1be5bedf7","name":"Note: Draft with AI Writer"},{"parameters":{"content":"### OpenAI Writer Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Draft with AI Writer** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"3074c4cd-6a00-9b87-d441-90880ed23825","name":"Note: OpenAI Writer Model"},{"parameters":{"content":"### Refine with AI Editor\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Convert to HTML · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"01988f9b-f2ec-b4a9-94c8-d85e8aed4ff4","name":"Note: Refine with AI Editor"},{"parameters":{"content":"### OpenAI Editor Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Refine with AI Editor** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,1090],"id":"6f34c0d9-6c87-1446-9a7c-dc76825301d9","name":"Note: OpenAI Editor Model"},{"parameters":{"content":"### Convert to HTML\n\nConverts markdown to HTML for rich rendering in email/CMS.\n\nNext: Publish Draft to WordPress","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2100,520],"id":"bc82523a-e102-0975-c61e-79499a461653","name":"Note: Convert to HTML"},{"parameters":{"content":"### Publish Draft to WordPress\n\nwordpress — `action` operation against the connected account.\n\nPorts: ①→ Align Field Names · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 WordPress credentials","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2424,520],"id":"9868b1e3-1c4c-5d68-7845-8a7efa6a0cc6","name":"Note: Publish Draft to WordPress"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2748,520],"id":"97d3b432-374d-20ae-e58c-fd29dcbac6d3","name":"Note: Align Field Names"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3072,520],"id":"1de175bd-2b4c-a207-5ad4-3b735e548ffb","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,520],"id":"fda6a727-2cfb-6475-be7b-ce7e08a48b6d","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,520],"id":"92d70bc3-50a3-e324-1efe-99f5113098d5","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4044,520],"id":"4f687b93-818e-33f2-0a78-c38f5479c47d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,1540],"id":"f41f345c-e5c4-ce94-7456-c86f2ef5c2cc","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,1540],"id":"16b6304a-848e-7d97-9fc8-981352df030b","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Produce blog drafts with PostgreSQL and WordPress\n\n**Pattern:** Content Generation · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nProduce blog drafts with PostgreSQL and WordPress. It runs automatically on a schedule.\n\n## Why it exists\nManual ai video is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Stamp & Shape Asset → Payload Valid? → Build the Brief → Draft with AI Writer → Refine with AI Editor → Convert to HTML → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating ai video in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Keeps your systems in sync\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: OpenAI API key; Postgres connection; Slack OAuth2; WordPress credentials.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"88f90ef8-3a82-361c-82f0-30f484898ba7","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"b61adccc-b4a3-e34c-eff4-3e9611a61615","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"7e603ef2-c424-796f-8f58-6f65711e68b3","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your ai video process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"8335611a-953b-fb23-4268-139d19317581","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Stamp & Shape Asset","type":"main","index":0}]]},"Stamp & Shape Asset":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Build the Brief","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Build the Brief":{"main":[[{"node":"Draft with AI Writer","type":"main","index":0}]]},"OpenAI Writer Model":{"ai_languageModel":[[{"node":"Draft with AI Writer","type":"ai_languageModel","index":0}]]},"Draft with AI Writer":{"main":[[{"node":"Refine with AI Editor","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"OpenAI Editor Model":{"ai_languageModel":[[{"node":"Refine with AI Editor","type":"ai_languageModel","index":0}]]},"Refine with AI Editor":{"main":[[{"node":"Convert to HTML","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Convert to HTML":{"main":[[{"node":"Publish Draft to WordPress","type":"main","index":0}]]},"Publish Draft to WordPress":{"main":[[{"node":"Align Field Names","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"1d9c567c-93f1-4a20-90cd-490eb5e47578","id":"FDX10109"}