              "id": "011e24c6-a99f-4fe9-9dfc-9f9f59fa82c0",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "7b700d17-ec69-4ad6-b264-7d12c090c646",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
