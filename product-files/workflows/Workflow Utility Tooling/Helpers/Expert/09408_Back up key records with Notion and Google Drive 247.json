{"name":"Back up key records with Notion and Google Drive 24/7","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":1}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"5d083d26-616f-4fb0-a460-a1cee6370dad","name":"Hourly Schedule"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[54,400],"id":"2fe35640-f8aa-4b62-835d-4164e3759886","name":"Export All Rows (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[378,400],"id":"7b229b76-86f6-4631-93de-74ecc1ae3d0c","name":"Serialize to CSV"},{"parameters":{"operation":"compress","fileName":"=backup-{{ $now.toFormat('yyyyLLdd') }}.zip","binaryPropertyName":"data","options":{}},"type":"n8n-nodes-base.compression","typeVersion":1.1,"position":[702,400],"id":"107a1943-3e02-443b-82f4-4bc0a082a1b4","name":"Compress Archive"},{"parameters":{"operation":"upload","name":"=backup-{{ $now.toFormat('yyyyLLdd-HHmm') }}.zip","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Backups"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[1026,400],"id":"4f0b028e-03ed-46e6-a2bf-6e92464edad7","name":"Upload Backup to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"902177cb-84e6-4e71-aee8-c1ad8f9a4887","leftValue":"={{ ($binary.data?.fileSize ?? 1) > 0 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"9388f26b-384f-4d69-bb02-6e6444df00ac","name":"Backup Size Sane?"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🛑 Tonight's backup came out EMPTY — investigate immediately.","options":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"25235806-c114-40f9-93a5-a99f0ca47071","name":"Alarm — Empty Backup","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[1998,400],"id":"03e086fb-1f32-4d8a-969c-cd7c505b640d","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[2322,400],"id":"02a409b7-a0a5-4575-a2e9-46d419a67752","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,400],"id":"b786aa49-f14e-45bf-bfea-bb2cfb0e9a46","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2970,400],"id":"b9302bd4-adb3-4f9c-b754-0aec4acece4e","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.source }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3294,400],"id":"f44deb6d-a941-4299-af6d-9069097f378e","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"1f39109b-4ce4-4718-bfbe-0476e19ba9ee","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"11f78571-6827-433c-bd8f-8351a2e3e5a5","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"8a707dc6-4bff-4a39-9ec9-35d8d11affde","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per payload (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.itemId, j.source].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"aa3dfe79-7f73-4eba-af5f-9f21a79f0696","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4266,400],"id":"b5e7dd6a-8f1e-42e0-8e7d-e5c9d37a62df","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"ac34cc21-0352-4f22-837e-e1bc4a4b5f68","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"982b22de-096f-47c1-8cd3-bfc517774987","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"ac83d22e-afa6-4f00-b10d-012baa4015d4","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"3ef83883-0340-43d5-ac34-b4f4b23fe9e6","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8398b549-eb1a-4daf-bffc-8d53251c7246","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"8fdc4f43-9bc2-4ab6-b299-a45f099107f9","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"d430a801-c821-4e53-9804-1d9f35b59519","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Back up key records with Notion and Google Drive 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5886,400],"id":"997d74cf-6b0f-4d26-b721-e4cb514da489","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"afc7c772-0d52-4a54-b297-146f9db69989","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"647c62b0-4567-499d-a628-461439a43790","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ded6cd1c-9c95-4f37-a2dc-f090f07828e3","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,1420],"id":"7e851bef-3cc7-46da-9c14-a4ce5a71641d","name":"Capture Failure Context"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5562,1420],"id":"be6d2f8f-4400-4386-a3f1-a81f57f4d16d","name":"Escalate Failure to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,1420],"id":"c5021a1e-809c-4eaf-af34-78042479f5d7","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 1 h. No input data; downstream nodes fetch what they need.\n\nNext: Export All Rows (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"10ae98f2-6078-970f-6b21-ead1190a9254","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Export All Rows (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Serialize to CSV · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"59b3664d-c150-9017-0e08-6f0b47748d8a","name":"Note: Export All Rows (Google Sheets)"},{"parameters":{"content":"### Serialize to CSV\n\nSerializes items to a CSV binary file.\n\nNext: Compress Archive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"5a03457f-f4c3-c693-af82-0d89b685def0","name":"Note: Serialize to CSV"},{"parameters":{"content":"### Compress Archive\n\nZips the binary to cut storage/transfer size before upload.\n\nNext: Upload Backup to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"d26c2d0c-ce03-a813-4197-ef072e3fd0b2","name":"Note: Compress Archive"},{"parameters":{"content":"### Upload Backup to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Backup Size Sane? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"14c79b73-faf6-ea95-6f67-d4cdd68079b7","name":"Note: Upload Backup to Google Drive"},{"parameters":{"content":"### Backup Size Sane?\n\nTwo-way gate on `={{ ($binary.data?.fileSize ?? 1) > 0 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Serialize Run Output (CSV) · ②→ Alarm — Empty Backup","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"44f4069e-0011-6d64-407f-f32598bb03fa","name":"Note: Backup Size Sane?"},{"parameters":{"content":"### Alarm — Empty Backup\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"b66416d4-4071-b289-0d35-f52a085a3c2d","name":"Note: Alarm — Empty Backup"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"1051a734-aa4a-1815-d900-e0c5b44b6a83","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"1cced1f2-2866-8817-8fb4-4668fe9e7c83","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"196e8b0f-b037-b6b9-9cd4-17e1e30f3b62","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"1afe5ef6-ebce-5736-210b-0125caa078e3","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"d21022e5-c736-b0b3-5b1f-ac2f75b43869","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"c028cf7d-7470-5ef4-ebe6-6a4059a2dffc","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per payload (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"d1cfe1f2-c2aa-fdba-c0c6-24826fc54d9a","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"afe5be54-cbef-a9f6-ce01-8259b51b247a","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"a9b78bf8-1f3a-d721-58aa-49b983a9b7c0","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"4508772b-d558-4310-ae39-e7a60fa44fac","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"6fb6e672-2c34-e4d4-452b-d39224e5532a","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"1a08f9f9-7091-a311-c174-a33948a5f55e","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"31129054-ccf1-37f6-084d-b0fdaf3b528e","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Twilio","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"603e55b7-d2f9-588f-fe74-572b331c04fc","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Twilio\n\ntwilio — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Twilio SID + token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"f3d0bb71-70ea-13c5-758c-49e1f23c1739","name":"Note: Escalate Failure to Twilio"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"0d3d7914-0bec-5c3b-2f9c-05d107f551d6","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Back up key records with Notion and Google Drive 24/7\n\n**Pattern:** Backup & Archive · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nBack up key records with Notion and Google Drive 24/7. It runs automatically on a schedule.\n\n## Why it exists\nManual helpers is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Export All Rows (Google Sheets) → Serialize to CSV → Compress Archive → Upload Backup to Google Drive → Backup Size Sane? → Serialize Run Output (CSV) → …\n\n## Use it for\n- Teams that want to backup & archive without manual effort\n- Anyone automating helpers in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Removes copy-paste errors\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Slack OAuth2; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"2757fc0d-f171-e22c-5bc9-4054445e820e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"8726f9c6-1f58-5f24-b1e1-195af29c95ac","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"eb16a763-4efa-985b-975e-0d289eca2405","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your helpers process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"feded2ad-80c8-8bad-2d75-ef2021c106b6","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Export All Rows (Google Sheets)","type":"main","index":0}]]},"Export All Rows (Google Sheets)":{"main":[[{"node":"Serialize to CSV","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize to CSV":{"main":[[{"node":"Compress Archive","type":"main","index":0}]]},"Compress Archive":{"main":[[{"node":"Upload Backup to Google Drive","type":"main","index":0}]]},"Upload Backup to Google Drive":{"main":[[{"node":"Backup Size Sane?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backup Size Sane?":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}],[{"node":"Alarm — Empty Backup","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Twilio","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Twilio","type":"main","index":0}]]},"Escalate Failure to Twilio":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Alarm — Empty Backup":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Twilio":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"8671252c-ffc8-46ad-a957-fb7d99e155bc","id":"FDX09408"}