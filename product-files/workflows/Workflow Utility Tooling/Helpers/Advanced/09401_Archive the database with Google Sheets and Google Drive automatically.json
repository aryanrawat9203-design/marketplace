            {
              "id": "5c624b55-b3bd-4158-9afe-966a90a51522",
              "leftValue": "={{ $json.itemId }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.if",
