encyKey: hash([j.itemId, j.source].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6534,400],"id":"0bccd93f-c09c-4068-8466-9978cf2b540d","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6858,400],"id":"b88d02a9-8568-4e7d-a42f-6ec76cc09abb","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.source }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[7182,400],"id":"865d88bc-dc21-40a7-a109-aaa88810336c","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"ee5ed99f-3330-42fd-87cc-aa073ad10588","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"508c6f4c-7d16-47f8-ab79-59f7abd1c8fa","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7506,400],"id":"bddf917d-5013-47b8-9c4f-868447b2fe3b","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7830,400],"id":"56815618-b09d-403d-86ec-3456a5dd596f","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[8154,400],"id":"9f406347-1c17-4d4c-b7ee-5514d97e78e5","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"d4035820-457e-4c34-8295-a3e632524627","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"cb9cd650-dc97-4188-b89d-69b455677ca2","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"35b8ed10-1303-4b7a-b7ab-e5c83017bc30","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,400],"id":"e4b66cdb-cdc3-4a82-8c40-0da9bd5e52d2","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Database"},"title":"={{ $json.source || $json.itemId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8802,400],"id":"c315602e-0d2c-4969-baae-a9da82cf0fce","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ops","cachedResultName":"#ops"},"text":"=✅ Pipe API callbacks with Airtable automatically — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9126,400],"id":"f8fc9968-15b7-4d2c-9539-fb3bfc2d56f5","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4af25be4-f568-496e-be96-2b6d55dd92aa","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"fda43773-69b6-4ec9-a288-3805f490713d","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"52d8e873-8c47-4725-b402-6645ac25f013","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,1420],"id":"f4ea9d3d-809d-4d95-9f04-e7a11f56ba0c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ops","cachedResultName":"#ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8802,1420],"id":"0b3dc58e-7a0c-4065-9ad8-4dd9bad8dedf","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[9126,1420],"id":"dc221d74-d751-4f3e-a46e-0b93a9d0dccc","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf09277-payload`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Compute HMAC Signature","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"69d0ddab-ae65-64e7-dc63-17bef5b0cff2","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Compute HMAC Signature\n\nComputes the HMAC-SHA256 of the raw payload to verify the sender's signature before trusting the data.\n\nNext: Signature Valid?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"b3974891-8c49-98fe-87e1-f783dc2700c2","name":"Note: Compute HMAC Signature"},{"parameters":{"content":"### Signature Valid?\n\nTwo-way gate on `={{ $json.computedSignature === $json.headers['x-signature']`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Map to Canonical Schema · ②→ Reject (HTTP 401)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"08fe7d1f-ae1d-8eed-14bb-ed2bfcec5fa8","name":"Note: Signature Valid?"},{"parameters":{"content":"### Reject (HTTP 401)\n\nSends the HTTP 401 response back to the caller — keep this fast; heavy work happens after/async.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"dab94741-51f7-e62e-19f3-6f1596025d91","name":"Note: Reject (HTTP 401)"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `itemId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Route by Event Kind","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"0d2dcacf-35e2-72e4-bb8c-88653200f3e7","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 4 lanes: payment, refund, dispute + fallback.\n\nPorts: ①→ Handle 'payment' → Airtable · ②→ Handle 'refund' → Forward API · ③→ Handle 'dispute' → Forward API · ④→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"577e5601-a6b2-5b5b-2830-2c4e2faab734","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'payment' → Airtable\n\nairtable — `upsert` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,250],"id":"cdc936b3-c9de-5ae6-9b26-02d6378ffbda","name":"Note: Handle 'payment' → Airtable"},{"parameters":{"content":"### Handle 'refund' → Forward API\n\nPOST https://api.example.com/v1/payloads — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,760],"id":"92c7b36f-5d68-4573-2660-87117301f023","name":"Note: Handle 'refund' → Forward API"},{"parameters":{"content":"### Handle 'dispute' → Forward API\n\nPOST https://api.example.com/v1/payloads — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,1270],"id":"c05f669f-0a88-d3ef-d352-990c5a3e0293","name":"Note: Handle 'dispute' → Forward API"},{"parameters":{"content":"### Log Unrecognized Kind\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1780],"id":"ce471b63-1843-b279-dfae-9bbdfbf8c1e4","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Respond with Outcome","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"0161822e-9647-20f5-8bb8-03dcf569bd89","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Respond with Outcome\n\nSends the HTTP 200 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"f4ce15ab-f614-d5f6-ce10-c134195d1bb2","name":"Note: Respond with Outcome"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"a0d6a711-b179-9af3-6d32-41cf99a83b79","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"40088540-d115-2d7b-bd19-e29e5987d6cd","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"429449e7-b8ab-8da2-4e01-3efc2a1f8d52","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Offload to Post-Process Sub-workflow · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"81dc3c48-95d2-9535-df78-48b838ac009d","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"6d6abab9-4cd6-8c32-8586-b5290e1fcb01","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"229dbec2-5493-09e5-c33e-3986ce439dc7","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per payload (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"97d60e19-c0ff-08f7-b377-535d02a3cc9a","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"2b9c83b3-6cb7-4418-bc51-fce221d786ef","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"cf56b2f9-bbfa-5567-7414-bbc59672fcd1","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"14b39a56-9a26-a1f1-b1cb-94a0985e89d8","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"7debf625-cb80-1aa0-d809-de9ce6d21226","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"37a5e34b-cd17-18f3-4dfe-6bab58a87271","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"50061e61-ebbf-0d7a-b174-3765b011c80d","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"883275f5-49b3-8b36-f3c5-854b0e72c95d","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,520],"id":"e2ac16ff-e994-69fd-ed81-3cbf56e75988","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,1540],"id":"1abcfe82-f0fa-cdb8-8d19-856e6ef18724","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,1540],"id":"aadb6d8e-09cd-2653-f286-b4936b119300","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,1540],"id":"d8ef86ba-0f83-64b8-78fb-e3592abb919b","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Pipe API callbacks with Airtable automatically\n\n**Pattern:** Webhook Pipeline · **Level:** Architect · **Trigger:** Webhook\n\n## What it does\nPipe API callbacks with Airtable automatically. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual data transforms is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Compute HMAC Signature → Signature Valid? → Map to Canonical Schema → Route by Event Kind → Handle 'payment' → Airtable → Consolidate Handling → …\n\n## Use it for\n- Teams that want to webhook pipeline without manual effort\n- Anyone automating data transforms in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Responds in seconds\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2 / service account; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"826cb29e-feb5-8335-c177-73e1981ae720","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"78c32085-cb8f-8bb2-2a9e-f6bfa86c301d","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable, and the HMAC signature is verified before any processing. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"5bb36097-5cd0-cb0b-fbef-e567a73e2484","name":"🔐 Security"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"9864e8aa-f9d9-4a8a-daed-737799e299cf","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your data transforms process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-290],"id":"b33a22a5-9092-24f5-9e47-42242a66b783","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Compute HMAC Signature","type":"main","index":0}]]},"Compute HMAC Signature":{"main":[[{"node":"Signature Valid?","type":"main","index":0}]]},"Signature Valid?":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}],[{"node":"Reject (HTTP 401)","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'payment' → Airtable","type":"main","index":0}],[{"node":"Handle 'refund' → Forward API","type":"main","index":0}],[{"node":"Handle 'dispute' → Forward API","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'payment' → Airtable":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'refund' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'dispute' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Respond with Outcome","type":"main","index":0}]]},"Respond with Outcome":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"6269c401-2feb-4914-af12-c06b626bde39","id":"FDX09277"}