}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"7cc688a2-f6f4-473e-be6a-f5f1e7216bc9","name":"Route by Event Kind"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Database"},"title":"={{ $json.source || $json.itemId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[702,130],"id":"abbf2d45-37c2-4e25-9fad-e32973e51972","name":"Handle 'payment' → Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/payloads","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1026,640],"id":"21969cb1-65c0-435d-bd5a-7aa9143f3238","name":"Handle 'refund' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/payloads","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1350,1150],"id":"16ab4274-5785-4125-9478-2be833cd957c","name":"Handle 'dispute' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Database"},"title":"={{ $json.source || $json.itemId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1674,1660],"id":"99535856-2df8-40de-b3a5-8f3b23af8a59","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"63aa9323-7b04-42b5-9f11-0f7a74580fb5","name":"Consolidate Handling"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"ok\": true } }}","options":{}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[3294,400],"id":"853a2b9b-034d-44ea-88f6-e2ea6b613018","name":"Respond with Outcome"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"itemId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3618,400],"id":"a024e5bb-40f6-40b0-9fca-1fe5f23b43a3","name":"Align Field Names"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ops","cachedResultName":"#ops"},"text":"=✅ Capture webhook payloads with Notion without manual work — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3942,400],"id":"e78596e1-e7c4-462e-acc6-b15bcbfc26d9","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e4264c26-594c-4e67-a6ed-4be51a437f57","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"84654209-a729-48fc-bfde-e96639316a83","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"0b896c87-fa9b-4793-a77e-15c7b875cee0","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3294,1420],"id":"59ca620d-d6b3-43b0-b7c2-c722afc05846","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ops","cachedResultName":"#ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3618,1420],"id":"ceaa9562-bc2d-48c2-9ce7-fcfa89e2a55c","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf09369-payload`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Map to Canonical Schema","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"3306aec2-189b-58a4-64c4-2dcc98a11a03","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `itemId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Route by Event Kind","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"7c838288-c7fd-0ee8-c0dd-918e7f27402f","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 4 lanes: payment, refund, dispute + fallback.\n\nPorts: ①→ Handle 'payment' → Notion · ②→ Handle 'refund' → Forward API · ③→ Handle 'dispute' → Forward API · ④→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"c8f2d4ca-6b81-f2b9-4615-4e18196b5b35","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'payment' → Notion\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"2eb6ae02-a028-801e-95c3-5e7e9970f10d","name":"Note: Handle 'payment' → Notion"},{"parameters":{"content":"### Handle 'refund' → Forward API\n\nPOST https://api.example.com/v1/payloads — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"22c6dc9a-cccd-a514-8287-320976588ded","name":"Note: Handle 'refund' → Forward API"},{"parameters":{"content":"### Handle 'dispute' → Forward API\n\nPOST https://api.example.com/v1/payloads — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"8154ed16-4778-52cc-65c9-3c9480212d3e","name":"Note: Handle 'dispute' → Forward API"},{"parameters":{"content":"### Log Unrecognized Kind\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1780],"id":"14df33cd-4c43-2982-0e92-82674a7d9e14","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Respond with Outcome","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"4aa0e130-02c5-9b68-92dd-c9c4f3ed2bf0","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Respond with Outcome\n\nSends the HTTP 200 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Align Field Names","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"dfa7e238-981f-65af-d1f7-33339d48ef16","name":"Note: Respond with Outcome"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Send Summary to Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"313632f9-105c-69bd-0f62-8ecc74c95e7d","name":"Note: Align Field Names"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"1589d4ce-172d-d6d3-a870-c9d9fc6f57ac","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,1540],"id":"8cb3ec75-f4de-e873-c103-949275d8d214","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,1540],"id":"edbdf6ec-8c25-ba9b-0a98-ca0ffb4a3cac","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Capture webhook payloads with Notion without manual work\n\n**Pattern:** Webhook Pipeline · **Level:** Core · **Trigger:** Webhook\n\n## What it does\nCapture webhook payloads with Notion without manual work. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual data transforms is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Map to Canonical Schema → Route by Event Kind → Handle 'payment' → Notion → Consolidate Handling → Respond with Outcome → Align Field Names → …\n\n## Use it for\n- Teams that want to webhook pipeline without manual effort\n- Anyone automating data transforms in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Has retries and error handling built in\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"c847979d-430e-58ec-3989-c3e0c7b3a85a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"e453f176-7e88-a58f-d65b-a88ed365be3c","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"79d6c9f7-c4e8-fd56-2db5-1e8a1660ef6c","name":"🔐 Security"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your data transforms process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"fba3ac52-99da-e975-42af-bf354f67e790","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'payment' → Notion","type":"main","index":0}],[{"node":"Handle 'refund' → Forward API","type":"main","index":0}],[{"node":"Handle 'dispute' → Forward API","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'payment' → Notion":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'refund' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'dispute' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Respond with Outcome","type":"main","index":0}]]},"Respond with Outcome":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"45ee9499-5cab-4a10-9e2c-87e84552f712","id":"FDX09369"}