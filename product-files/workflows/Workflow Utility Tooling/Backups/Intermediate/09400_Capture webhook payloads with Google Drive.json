{"name":"Capture webhook payloads with Google Drive","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09400-payload","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"5bdb85b0-7625-4142-b173-847ea06f76a9","name":"Receive Inbound Webhook","webhookId":"bda1e9df-b3d4-404b-960f-a41534814e58"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b830765c-804d-4365-a992-90209c874e41","leftValue":"={{ $json.source }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"d73565b2-ef9e-41fa-82c2-ffcd87570e0a","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'source' on incoming payload."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"8c3c164b-9428-40de-9dac-14f77889503b","name":"Abort — Malformed Input"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"dd5eb893-32db-487b-8705-527b511f1852","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"standard","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"standard"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1d18f022-7d58-4ed4-b364-e60cc35cff43","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"priority","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"priority"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"546253dd-c8dc-4d0b-b086-128a60ef3434","name":"Route by Work Type"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["itemId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[702,130],"id":"f96b05a7-8cf1-4c79-ad04-db4127ebd41d","name":"Process 'standard' → Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ops","cachedResultName":"#ops"},"text":"=🚀 Priority payload handled: {{ $json.itemId }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1026,640],"id":"ab818d58-092d-4ca2-943d-06144ce67bee","name":"Fast-Track 'priority' + Alert","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1350,1150],"id":"f8862337-7666-416e-aa7f-e1391358ad53","name":"Hold Unknown Types (DLQ)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1998,400],"id":"b5fcde3e-1162-4c3a-bb7c-32c03cfd354a","name":"Merge Routed Work"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2970,400],"id":"0fa4b345-74b2-4fc8-b303-7958f550298f","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3294,400],"id":"b5a7fac7-ec3b-4a73-9ff5-95b1424e352a","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per payload (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.itemId, j.source].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3618,400],"id":"853f2645-cdc6-4422-9204-d9b527c55b2a","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3942,400],"id":"f654e027-8624-4af5-975b-9f722ccf4858","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.source }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"f7eb440d-0e28-4e73-86cb-3247b6c9ccf7","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"135539f7-c7ba-455c-89d8-0248644a3822","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"76b7e92e-d0c5-45a1-9eab-85a69e085205","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"6063f2d2-83bd-480a-a547-038107a0b2aa","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4914,400],"id":"ec7eda28-cfab-48e1-966c-5306361006d7","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[5238,400],"id":"14668a46-e36a-4794-bb53-c08a0e7483c8","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4dfca89c-751f-4380-b08d-0d6f4b1a485b","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9cb1b276-e262-42be-b674-df8732278de7","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"c632f67b-0bc7-4c12-915a-db7a4e13b3c1","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"1c8dd6a0-8183-46d7-a269-3200877ed856","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"f4f8fd3e-abf5-4a99-9343-f2ae8e8eef69","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ops","cachedResultName":"#ops"},"text":"=✅ Capture webhook payloads with Google Drive — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,400],"id":"a1be2330-526a-4119-85ac-d009627b484c","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d136946b-13a2-4942-b016-0bbfa5914158","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"79824b9a-f3c5-43c7-8076-e0b3050a9240","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"bc021cff-e580-4164-8426-84a957799df6","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"685b0a0f-5695-475a-978b-54904be6a951","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ops","cachedResultName":"#ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,1420],"id":"80ef1329-3e92-44b9-8286-aaa838064666","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Payload Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"28e9187a-e4ee-4e0d-b4c3-b21eedfeccb6","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf09400-payload`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ce4e995f-389c-720e-753e-99eea6d5a78c","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.source }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Route by Work Type · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"2203d68e-7cda-1473-e463-8b496aa74b11","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"59b58b11-1382-54e5-9f39-97f57a5dd861","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: standard, priority + fallback.\n\nPorts: ①→ Process 'standard' → Google Sheets · ②→ Fast-Track 'priority' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"b1f150f8-dd21-1ec6-a485-59d396b43cc6","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'standard' → Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"589f2015-5ad2-2afd-7c9e-de6a32cdb1d0","name":"Note: Process 'standard' → Google Sheets"},{"parameters":{"content":"### Fast-Track 'priority' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"422e7a97-04f0-5613-2fd8-8e6ee9f60008","name":"Note: Fast-Track 'priority' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"78636d34-1c3d-fdf7-1940-30e2d123bf38","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"a9c1b7d2-9057-028a-3878-531b3d56f46b","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"577a0611-10ab-30c2-6251-625fbc9459a0","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"1ee496c1-8524-1dda-4408-d202a187b1ba","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per payload (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"b35a518b-55a6-ce43-68e2-8f7b3eed126b","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"d424c2c6-74cb-2ba3-f6e5-4f8b1b440006","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"48ba834c-0ccc-5bbe-510a-223e6d695b7e","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"cbd21d2d-6dbb-c750-5e03-67a085eec919","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"31380679-1115-e532-12b3-7f796e056dca","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"287b1991-070f-ef07-735a-d75605525316","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"591f3cfb-5488-1290-b5db-0e91ad1cecfa","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"1e20e037-a161-922f-2b8e-0706913dd7d0","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"ce2c19be-3f04-2087-7ceb-a26a8b8b152e","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"67dc578a-2281-d301-ec26-64dd0ad442e7","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"203c6b41-0b8d-8e63-9157-f4b246592721","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"85f86cfb-6724-e3d4-a1c1-ca7524ffdb4d","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Capture webhook payloads with Google Drive\n\n**Pattern:** Webhook Pipeline · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nCapture webhook payloads with Google Drive. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual backups is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Required Fields Present? → Route by Work Type → Process 'standard' → Google Sheets → Merge Routed Work → Stamp Completion Time → Persist Run Metadata → …\n\n## Use it for\n- Teams that want to webhook pipeline without manual effort\n- Anyone automating backups in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Has retries and error handling built in\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"18922e93-d88a-ed5c-19bf-f79591e78889","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"e07fbac3-0a8d-c451-a6d2-d1d943dc08f3","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"e41d80d3-6a05-026e-838e-a3606e3f8a8d","name":"🔐 Security"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"b79a496b-8792-3313-83dc-226f03284eda","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your backups process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-290],"id":"fdc38069-2fa5-a277-140d-7c1bf3d541e3","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Route by Work Type","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'standard' → Google Sheets","type":"main","index":0}],[{"node":"Fast-Track 'priority' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'standard' → Google Sheets":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'priority' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"e41e8e81-9b07-4ad7-b675-1311dbbe354e","id":"FDX09400"}