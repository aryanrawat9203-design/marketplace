:4.2,"position":[2970,400],"id":"34af056c-5245-4017-9f18-f3670f21cd86","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a45fbe25-2102-48ea-a574-6f636b213678","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"aa8f44ec-780c-4558-923c-91e6a2cdd22e","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3294,400],"id":"33b66ff1-fe18-462b-a65c-58575c0e54ef","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3618,400],"id":"5bb1353a-7d15-4b92-892d-00f6b66c4d67","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"3a066846-ab2e-4f4b-8cd3-c9e7367c0883","name":"Compute Drift vs Snapshot"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per task (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.taskId, j.title].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"cc99846c-587a-4340-b9d9-0088c220e750","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4590,400],"id":"746e7002-ccd0-4815-9696-972f7fb924a9","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"fc2cbd90-8960-495b-924c-000441a53383","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"4df36ed9-2c77-471b-9330-6852254fcc91","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"64c31411-9e10-4123-a838-5e2b0749d383","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"37744906-7df8-43e1-bf67-ab1415b66174","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"e30a46b2-89f7-454c-98db-6d7c3dc805ff","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"e2a68b9f-5439-42f4-ba36-18edb1cdd193","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"383119c6-8fab-4c9a-921d-579f2ccea95f","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Onboard new hires with Trello and Twilio on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[6210,400],"id":"a99b38ec-a495-4e4c-a911-a9557e754a00","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"c65766ac-c62f-43dc-83c5-a6e5cd896380","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"afad67ee-4ff1-4e84-b865-d01daf9d6fdb","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"eb9d979a-93ff-4016-b342-1623c353a40a","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"fe55764f-1c02-4e86-be03-60d16dfc1469","name":"Capture Failure Context"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5886,1420],"id":"2bc88911-d02b-4512-8a90-e24a81f2fcba","name":"Escalate Failure to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"1e4f2769-9ac9-409c-8967-572cae7c8c38","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf08464-task`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"91964671-a318-a029-3565-fba38a5fe46c","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.title }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Route by Work Type · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"ec0ec1cc-64b1-8cef-4ad5-dad681c0c9a3","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"5b8bd2fe-bec5-bbe8-9cc8-54d3f52c722e","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: employee, contractor + fallback.\n\nPorts: ①→ Process 'employee' → Google Sheets · ②→ Fast-Track 'contractor' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"91b83201-69c2-4926-8db0-243c6f8e2ca1","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'employee' → Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"0d952303-4405-b028-62f2-97df2fc2f0b2","name":"Note: Process 'employee' → Google Sheets"},{"parameters":{"content":"### Fast-Track 'contractor' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"e6c2cbe5-2ad0-8af9-fb6b-8f7ba72ed97f","name":"Note: Fast-Track 'contractor' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"376cd973-d1ad-21d5-0ac7-dce3cc415c0d","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"0348e2be-f0d4-21ce-90f0-6e09226753e0","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"9c3aeb08-960f-761c-5007-4105b8f7d4cc","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"ea5b1c15-077a-7062-0064-c1bf67e6ce3b","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"c670c2a4-7fb9-9b2d-7891-703b2d3e1bad","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"0b838d81-5638-f906-839b-6974b532f0aa","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per task (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"6a4d9b5e-a0f0-b031-197a-22c0cc74984d","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"83528c63-a167-9cad-7c12-1265a3d4098b","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"e56724e2-912d-3262-b820-53cc045751e9","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"252325e4-08a3-c5f0-e681-6763f32afc9b","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"e2c6281b-3585-8f5a-c7cd-0d1df39db80f","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"34266ab3-5b0e-ee31-0e7f-6de8537888d1","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"3d0229a9-0db9-17c5-71bc-152f9939ed77","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Twilio","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"c93f2574-4a83-edb6-1ca5-12cba7039357","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Twilio\n\ntwilio — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Twilio SID + token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"be817390-004b-3716-be35-1d8c56261ac8","name":"Note: Escalate Failure to Twilio"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"c2720732-cf88-f5af-679c-26f21879a281","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Onboard new hires with Trello and Twilio on autopilot\n\n**Pattern:** Onboarding Sequence · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nOnboard new hires with Trello and Twilio on autopilot. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual onboarding is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Required Fields Present? → Route by Work Type → Process 'employee' → Google Sheets → Merge Routed Work → Enrich with Reference Data → Fold In Enrichment Fields → …\n\n## Use it for\n- Teams that want to onboarding sequence without manual effort\n- Anyone automating onboarding in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Removes copy-paste errors\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Slack OAuth2; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9ef8b007-6302-fbde-3379-7dae8bd196c5","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"fdb2a9f4-441b-bc72-c2d3-d83835b8a687","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"5bb80fbc-0806-004b-b6bd-9a5b869fdba4","name":"🔐 Security"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"90d4efca-2bc2-9445-710a-f549857f96a2","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your onboarding process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-290],"id":"f941861f-67e1-f2af-9405-d755f7dfeb9a","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Route by Work Type","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'employee' → Google Sheets","type":"main","index":0}],[{"node":"Fast-Track 'contractor' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'employee' → Google Sheets":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'contractor' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Twilio","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Twilio","type":"main","index":0}]]},"Escalate Failure to Twilio":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Twilio":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"921bd6f9-c888-445f-af15-421978174d55","id":"FDX08464"}