{"name":"Onboard new hires with Trello and Twilio on autopilot","nodes":[{"parameters":{"httpMethod":"POST","path":"wf08464-task","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"66488ece-a161-4c6c-afc6-65106eb7027c","name":"Receive Inbound Webhook","webhookId":"0141a4df-3820-4196-a241-a14822163a12"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4a17c65c-39ac-447b-bf0f-c0aa97c93e3a","leftValue":"={{ $json.title }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"ca7f5629-16f4-4c57-817f-c68fe24fa09b","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'title' on incoming task."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"b19598f9-b6c3-43a6-9a4c-ed941594b7f6","name":"Abort — Malformed Input"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1a7f7a56-34bf-4469-a71b-11efa913611c","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"employee","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"employee"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ad39e240-c4b2-433c-813e-638817db4278","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"contractor","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"contractor"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"f3bc1183-8509-493b-896b-0db4ea5547c5","name":"Route by Work Type"},{"parameters":