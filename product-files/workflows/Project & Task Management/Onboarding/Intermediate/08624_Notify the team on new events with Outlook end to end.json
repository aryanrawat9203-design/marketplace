{"name":"Notify the team on new events with Outlook end to end","nodes":[{"parameters":{"httpMethod":"POST","path":"wf08624-task","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"34c3b2fb-4927-4a4f-afde-2245d832dc50","name":"Receive Inbound Webhook","webhookId":"b4c3edfd-80a3-4c59-b49b-a0f3944dd327"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"48158c61-6ad1-415c-b6e9-2a663db0b844","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"943bd707-5e07-4d1c-8924-9dae768f3b5e","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"0a42981c-c8e5-465b-b5a9-c6dfb0674761","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"98e9930e-a451-4371-83cf-15fd539367d4","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"30fb26f5-68cb-4658-9baa-d2a1b4395246","name":"taskId","value":"={{ $json.body?.taskId || $json.body?.id }}","type":"string"},{"id":"301411e5-2f0c-495a-8a20-05cec2967134","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"7180e616-ff10-465b-85ae-39fc79218543","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"3f87f436-e42d-44eb-b2ee-d532f925e244","name":"Map to Canonical Schema"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"accepted\": true, \"id\": $json.taskId } }}","options":{"responseCode":202}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[1350,400],"id":"14b487bb-3810-42ac-a721-024e64e89595","name":"Acknowledge Fast (HTTP 202)"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e3533022-cee2-4b0c-b01e-b19956185281","leftValue":"={{ $json.kind }}","rightValue":"opened","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"opened"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"93c9fe20-417f-4e09-913c-4011853e634a","leftValue":"={{ $json.kind }}","rightValue":"closed","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"closed"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"675cae09-0793-4754-addb-090b5d9778eb","leftValue":"={{ $json.kind }}","rightValue":"reopened","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"reopened"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1674,400],"id":"d3cfa529-c35d-4a4c-8469-8f7c436d6d04","name":"Route by Event Kind"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["taskId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1998,130],"id":"6d5c86d6-98fd-4293-8dcb-aad8615bc3f5","name":"Handle 'opened' → Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/tasks","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2322,640],"id":"aa4f8242-9d05-4616-a46d-6e7c6dd280fd","name":"Handle 'closed' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/tasks","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2646,1150],"id":"3fa88a4d-b75b-452a-9a8f-36f26085bcdc","name":"Handle 'reopened' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2970,1660],"id":"66468203-98b6-4c16-b269-cf3456eefcdd","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3618,400],"id":"a00fedfa-a5ac-45e6-8dbc-c857bfd66e81","name":"Consolidate Handling"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"7b4404ed-c080-4db3-94c6-223ff214cabb","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"1273b8b4-fd93-4290-b733-0e097c88bb40","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5238,400],"id":"8fc248c6-641f-4529-ba63-b6246d028285","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"233e04d6-862c-4e09-a58b-a7a2f4771e1f","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"9f46acd8-8581-4fca-9638-aa722c1d616f","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"290625e3-e89d-4765-b9ae-0e0613a7e367","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"0ecaeae9-ab26-4d09-9471-4d427d2d7d9b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"876edcab-25b5-4bc5-8184-24b77a6db608","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,400],"id":"5a08769e-8d7a-4b14-a608-dd7013af7b02","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=✅ Notify the team on new events with Outlook end to end — run completed at {{ $","bodyContent":"=✅ Notify the team on new events with Outlook end to end — run completed at {{ $now.toFormat('HH:mm') }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[6534,400],"id":"9f8ee07b-b967-4b16-919a-defe6fbf7737","name":"Send Summary to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"cb9c6f8c-f068-4122-bee9-9ac7a2a3e154","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"331b4003-6405-4870-9ea2-5bef8e8ca4ff","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"518a8028-0143-47ee-b5b5-e5effbcbe0de","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"3a0796fb-170d-479d-9db3-44db149a5177","name":"Capture Failure Context"},{"parameters":{"subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","bodyContent":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[6210,1420],"id":"f1d2369f-1995-46a7-9a7b-1c5d4ac5528b","name":"Escalate Failure to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6534,1420],"id":"ddd99012-15ac-4c96-bd6c-197da409666f","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf08624-task`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Compute HMAC Signature","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"36bdea15-e936-ed12-b3d3-53d8a000fdfe","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Compute HMAC Signature\n\nComputes the HMAC-SHA256 of the raw payload to verify the sender's signature before trusting the data.\n\nNext: Signature Valid?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"8260c785-0970-e326-d872-fce36c31a197","name":"Note: Compute HMAC Signature"},{"parameters":{"content":"### Signature Valid?\n\nTwo-way gate on `={{ $json.computedSignature === $json.headers['x-signature']`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Map to Canonical Schema · ②→ Reject (HTTP 401)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"fffea67c-bfc1-3048-b338-d8fc4a1a750e","name":"Note: Signature Valid?"},{"parameters":{"content":"### Reject (HTTP 401)\n\nSends the HTTP 401 response back to the caller — keep this fast; heavy work happens after/async.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"7e8f446f-faf1-8755-f6f6-ace551bd194e","name":"Note: Reject (HTTP 401)"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `taskId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Acknowledge Fast (HTTP 202)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"35070ad3-c61c-c4cb-fbcd-4912d34a1033","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Acknowledge Fast (HTTP 202)\n\nSends the HTTP 202 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Route by Event Kind","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"36954111-def9-2a57-3efe-b616426468ec","name":"Note: Acknowledge Fast (HTTP 202)"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 4 lanes: opened, closed, reopened + fallback.\n\nPorts: ①→ Handle 'opened' → Google Sheets · ②→ Handle 'closed' → Forward API · ③→ Handle 'reopened' → Forward API · ④→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"04aea2a0-ca89-9570-9c9c-816806f0d886","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'opened' → Google Sheets\n\nUpserts a row into 'Task Tracker', matched on `taskId` — re-running with the same key updates the row instead of duplicating it.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,250],"id":"87adf9bf-5cf2-4432-fd4f-6cf5997585a5","name":"Note: Handle 'opened' → Google Sheets"},{"parameters":{"content":"### Handle 'closed' → Forward API\n\nPOST https://api.example.com/v1/tasks — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,760],"id":"b50836e1-6e43-49af-22ab-6becc1c297f4","name":"Note: Handle 'closed' → Forward API"},{"parameters":{"content":"### Handle 'reopened' → Forward API\n\nPOST https://api.example.com/v1/tasks — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1270],"id":"440a2e97-b2b8-16a1-5010-71b12f62c1dc","name":"Note: Handle 'reopened' → Forward API"},{"parameters":{"content":"### Log Unrecognized Kind\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,1780],"id":"d21e1f69-8c9e-292b-3e62-163e9b1b4cd0","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"d4c8225c-926f-a17f-446c-e1abe5679362","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"f5fc81fc-5ffb-3333-2db5-c9eaea22521e","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"7e00d485-59df-e9b0-42f8-de80e14f788d","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"d3c6fb6f-66f1-9785-ed5f-038bd722a3a1","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"f4df3481-143f-4c85-ffdc-5143179a5091","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"41b04481-c620-c999-3e6e-2c480c1a706a","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Send Summary to Outlook · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"83956ecb-0756-82fe-23f0-ed4b516a8367","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Outlook\n\nSends an email via Microsoft Outlook — recipient comes from the item's `email` field.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"1d1fab36-63b1-f18c-61d1-966851cda625","name":"Note: Send Summary to Outlook"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Outlook","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"d3e685b4-dd8f-4373-cfa3-9a479e87b40e","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Outlook\n\nSends an email via Microsoft Outlook — recipient comes from the item's `email` field.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Microsoft OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"8c158216-4480-d197-7574-a37b956e5f6d","name":"Note: Escalate Failure to Outlook"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"aeb5179f-6811-5c5b-580c-8a0c8d745cbd","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Notify the team on new events with Outlook end to end\n\n**Pattern:** Event Notification · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nNotify the team on new events with Outlook end to end. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual onboarding is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Compute HMAC Signature → Signature Valid? → Map to Canonical Schema → Acknowledge Fast (HTTP 202) → Route by Event Kind → Handle 'opened' → Google Sheets → …\n\n## Use it for\n- Teams that want to event notification without manual effort\n- Anyone automating onboarding in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Keeps your systems in sync\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Microsoft OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"f6eaf1e4-69de-e206-ddbc-08de345305d8","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe optional HMAC check runs before any business logic touches the payload — bad signatures are rejected at the door rather than after work has already been done with untrusted data. Acking fast (HTTP 202) and doing the real work after the response is what stops the sender's webhook delivery from timing out and re-delivering the same event.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"eb6fc24a-ef57-106c-2885-9fe4101f9eb1","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAlready production-grade — deepen your understanding:\n\n1. Turn on signature verification and trace what a tampered payload does at the 'Signature Valid?' gate.\n2. Add a new event kind to the switch and give it its own handler.\n3. Remove the fast-ack step and observe how response time changes under a slow downstream write.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"ce16944f-fb48-98de-a5e0-4aa1d9031bcb","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"ab9efcb0-e9bc-fefa-5830-f568d976f97f","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable, and the HMAC signature is verified before any processing. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"fb1b4063-21ef-8db3-996f-e4bbf5ceb399","name":"🔐 Security"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your onboarding process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"6db1bb3b-0c7f-df59-baed-bebe311f8a24","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Compute HMAC Signature","type":"main","index":0}]]},"Compute HMAC Signature":{"main":[[{"node":"Signature Valid?","type":"main","index":0}]]},"Signature Valid?":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}],[{"node":"Reject (HTTP 401)","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Acknowledge Fast (HTTP 202)","type":"main","index":0}]]},"Acknowledge Fast (HTTP 202)":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'opened' → Google Sheets","type":"main","index":0}],[{"node":"Handle 'closed' → Forward API","type":"main","index":0}],[{"node":"Handle 'reopened' → Forward API","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'opened' → Google Sheets":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'closed' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'reopened' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Outlook","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Outlook","type":"main","index":0}]]},"Escalate Failure to Outlook":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Outlook":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Receive Inbound Webhook":[{"json":{"taskId":"TASK-330","title":"Review Q3 automation roadmap","assignee":"jamie@company.com","dueDate":"2026-07-25"}},{"json":{"taskId":"TASK-331","title":"Fix broken webhook retries","assignee":"alex@company.com","dueDate":"2026-07-22"}}]},"versionId":"b4a063f0-14de-4578-a99a-6c465771ff6b","id":"FDX08624"}