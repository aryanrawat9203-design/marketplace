\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.taskId, j.title].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6858,400],"id":"ca8e47e4-6a0c-45f6-ad12-6bd4cd16e407","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[7182,400],"id":"f810db18-c22f-44cd-b26a-5a32e243d129","name":"Drop Already-Processed Items"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7506,400],"id":"aaafa35c-0de6-4b3a-9a67-0766107bc597","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"81996f4b-86d6-4ea4-b9ab-28e55f4c437e","name":"pipeline","value":"Onboarding","type":"string"},{"id":"77e5bf61-b086-4e0d-a187-4bf5d07a31aa","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7830,400],"id":"1e2b3075-31c4-4c6c-8dfb-af92eca684d3","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"taskId","value":"={{ $json.taskId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8154,400],"id":"2d7f2bb8-0c4f-45e9-bc31-9a2dba8f79a5","name":"Save Execution Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"taskId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8478,400],"id":"9036cd22-d37a-45f9-9b3f-ff620af83194","name":"Align Field Names"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[8802,400],"id":"1c26cb5f-6e97-44d9-96cd-55ca61b0569a","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive