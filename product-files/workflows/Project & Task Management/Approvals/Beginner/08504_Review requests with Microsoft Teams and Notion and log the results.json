      "id": "8bdff1ae-6c05-bf7e-bc66-7b9836dd8a4c",
      "name": "Note: New Task Form Submission"
    },
    {
      "parameters": {
        "content": "### Keep Valid Tasks\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Prepare Approval Packet",
        "width": 280,
        "height": 232,
        "color": 7
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
