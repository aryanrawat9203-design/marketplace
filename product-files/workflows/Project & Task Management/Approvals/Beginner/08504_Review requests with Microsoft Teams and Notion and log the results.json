        1938,
        880
      ],
      "id": "1e0a6657-ae43-9dc7-60ef-907ecfbde02d",
      "name": "Note: Record Decline + Notify Requester"
    },
    {
      "parameters": {
        "content": "### Join Decision Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Cap Batch Volume",
        "width": 280,
        "height": 232,
        "color": 7
