        -6,
        520
      ],
      "id": "862d102a-f086-687e-6eac-a4c2e38b184a",
      "name": "Note: Keep Valid Tasks"
    },
    {
      "parameters": {
        "content": "### Prepare Approval Packet\n\nShapes the item: writes `requestId`, `summary`, `requestedBy`. Keeps the schema explicit between stages.\n\nNext: Request Approval via Slack",
        "width": 280,
        "height": 232,
        "color": 7
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
