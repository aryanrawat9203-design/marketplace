{"name":"Alert the team on new events with Gmail with instant alerts","nodes":[{"parameters":{"httpMethod":"POST","path":"wf08429-task","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"00d3611a-bbc3-40a8-a2d6-6a57be9a1376","name":"Receive Inbound Webhook","webhookId":"abebe2ce-b288-4bff-a344-828809081730"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"ebc8b890-96bf-486f-97a8-91aec88a0087","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"54df15b3-d99b-48c9-92a9-187e257308b4","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"15b8dfbf-d560-4b99-a05c-2ccf27664a95","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"6391d2ae-74b0-4047-8ff5-59435cbf573d","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"aa6bf37c-3402-4128-b048-c1f80da510a2","name":"taskId","value":"={{ $json.body?.taskId || $json.body?.id }}","type":"string"},{"id":"df441639-9260-4b64-88cd-c0fdc1ebad5f","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"da657c09-0b1b-4408-8723-a93c7ec9b33f","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"008b49db-6c33-4496-8991-af6b54f65c13","name":"Map to Canonical Schema"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"accepted\": true, \"id\": $json.taskId } }}","options":{"responseCode":202}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[1350,400],"id":"cc4ab8fa-651a-4b27-a0f0-2c6717ed591c","name":"Acknowledge Fast (HTTP 202)"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a4a37115-7349-435f-9c01-1fd9ca91bd37","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8063c6cb-3cf5-4738-8b9b-f3f30aeb1df0","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1674,400],"id":"dfc45682-d49f-41d2-90e9-5ac9fd97eb52","name":"Route by Event Kind"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["taskId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1998,130],"id":"1e95de6c-efe2-486e-b361-756034a6db5b","name":"Handle 'created' → Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/tasks","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2322,640],"id":"8b082a0e-6ad0-40c4-a17c-9404637666f9","name":"Handle 'updated' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,1150],"id":"5fd5f479-012c-496e-b485-5607c32087a2","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3294,400],"id":"2b151b94-011c-4c20-aa4c-6e39d9e36f2e","name":"Consolidate Handling"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.title }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"b8c7e17c-84e1-4e7b-8dac-f83d9c4cfe3b","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"8c36d6c9-7831-4360-8842-ee8562ca7edc","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"692ff29a-4365-41df-abcb-443da1425fab","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"14baa7e7-588a-4968-971b-1acc7cddb558","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"837da6a9-9cc0-48df-9b41-62ec88dd7dac","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"ca2e5f88-1bdd-4f06-8bfa-a203fd3cfd09","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5562,400],"id":"d80776f6-4233-4ece-81ab-e1ba5677f0cb","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"e7842122-b2e7-4efc-99c9-8583c8cb99ed","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a9e09474-1f1e-4f6f-a743-db565436f5f0","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5d767802-d402-4787-ae5e-3b7e97b9979b","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"2a9838b6-787b-4edf-8cb6-668a22db9b1f","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"e85af4c4-a8f5-4ad1-ae04-c8f14eea8d2b","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6534,400],"id":"6c964251-542f-40b0-a68f-350133a04119","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Alert the team on new events with Gmail with instant alerts — run completed a","message":"=✅ Alert the team on new events with Gmail with instant alerts — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[6858,400],"id":"d07eafe6-34b4-4f57-a32e-e025f9e176ad","name":"Send Summary to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e3e4dfaf-bac3-4481-aaa0-029cf436cded","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"0293b9ff-da2d-4acb-a842-782bc3a98eb0","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"d7beb4c8-733b-474d-bb7c-4b53e50dedcd","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,1420],"id":"0c822d1a-865a-4e61-b1c3-87a544461ba5","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#projects","cachedResultName":"#projects"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,1420],"id":"642fb9bc-7de2-436e-a5dc-67d225460f05","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6858,1420],"id":"631a0b51-582f-43fb-9f2a-742e6eeabe71","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf08429-task`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Compute HMAC Signature","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"4dd0d9f1-4ea2-8f21-209b-5e7362ebae27","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Compute HMAC Signature\n\nComputes the HMAC-SHA256 of the raw payload to verify the sender's signature before trusting the data.\n\nNext: Signature Valid?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"19b853a5-b30e-16a1-6ae7-a32c993e1cee","name":"Note: Compute HMAC Signature"},{"parameters":{"content":"### Signature Valid?\n\nTwo-way gate on `={{ $json.computedSignature === $json.headers['x-signature']`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Map to Canonical Schema · ②→ Reject (HTTP 401)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"0560fd29-8fb6-08b5-c145-2bfea1d4633f","name":"Note: Signature Valid?"},{"parameters":{"content":"### Reject (HTTP 401)\n\nSends the HTTP 401 response back to the caller — keep this fast; heavy work happens after/async.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"d20c2cb3-1b83-0fac-59bc-b5250161fda4","name":"Note: Reject (HTTP 401)"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `taskId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Acknowledge Fast (HTTP 202)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"98504335-1e63-454f-88ae-b2a8be7dad2f","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Acknowledge Fast (HTTP 202)\n\nSends the HTTP 202 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Route by Event Kind","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"4338e549-7b88-0d19-4362-385a7d6c1b72","name":"Note: Acknowledge Fast (HTTP 202)"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 3 lanes: created, updated + fallback.\n\nPorts: ①→ Handle 'created' → Google Sheets · ②→ Handle 'updated' → Forward API · ③→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"3783bc81-ce42-4160-14c7-acaa5e917cbb","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'created' → Google Sheets\n\nUpserts a row into 'Task Tracker', matched on `taskId` — re-running with the same key updates the row instead of duplicating it.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,250],"id":"bd9d0adc-5b84-fd0f-1040-19661369744d","name":"Note: Handle 'created' → Google Sheets"},{"parameters":{"content":"### Handle 'updated' → Forward API\n\nPOST https://api.example.com/v1/tasks — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,760],"id":"bc72255b-c6ff-67c5-8f23-e4f6f4ae2689","name":"Note: Handle 'updated' → Forward API"},{"parameters":{"content":"### Log Unrecognized Kind\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1270],"id":"62490065-0c47-49e5-b941-1b270b930586","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"e273bf59-aa24-ad74-9719-a3bd2075aeea","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"23b34bc6-50b0-ffaf-d24d-7ca3bab1a9fe","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"89d34d93-3a1b-331d-0070-e49487cc93b7","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"b01bf79d-a477-e1c7-9526-eab16b67e4f6","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"56e518d5-5340-4d19-9653-f4ad70d750ec","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"2177eef4-365d-894b-241b-afab82ec84a6","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"a94cce6a-37ed-a007-bd43-feec0f3d6458","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"b4c4b338-7455-a9aa-a25c-01d0bd259910","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Send Summary to Gmail · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"9aade19f-2e0c-9195-10d5-cae78b7d22de","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Gmail\n\nSends an email via Gmail — subject is the first line of the message body, recipient comes from the item's `email` field.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"f7e8175e-ac6d-d8c9-d9ba-72df81d3c314","name":"Note: Send Summary to Gmail"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"ea4b2507-a673-008c-e922-ad1fd03e9013","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#projects`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"f99ef8fb-0f82-9b26-914c-215a3171b263","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nAppends a new row to 'Task Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,1540],"id":"2772f704-d272-873a-3c52-458874d674f4","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Alert the team on new events with Gmail with instant alerts\n\n**Pattern:** Event Notification · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nAlert the team on new events with Gmail with instant alerts. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual approvals is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Compute HMAC Signature → Signature Valid? → Map to Canonical Schema → Acknowledge Fast (HTTP 202) → Route by Event Kind → Handle 'created' → Google Sheets → …\n\n## Use it for\n- Teams that want to event notification without manual effort\n- Anyone automating approvals in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Runs 24/7 in the background\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"4f51c43c-7838-a221-12e4-6acaa374fe5e","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe optional HMAC check runs before any business logic touches the payload — bad signatures are rejected at the door rather than after work has already been done with untrusted data. Acking fast (HTTP 202) and doing the real work after the response is what stops the sender's webhook delivery from timing out and re-delivering the same event.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"23d6b42a-448e-4530-0450-da53ca020ea8","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAlready production-grade — deepen your understanding:\n\n1. Turn on signature verification and trace what a tampered payload does at the 'Signature Valid?' gate.\n2. Add a new event kind to the switch and give it its own handler.\n3. Remove the fast-ack step and observe how response time changes under a slow downstream write.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"5e255068-2979-4ea7-b667-6a4ea966477e","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"8fbf3175-11f7-bf6f-2fd4-12b845162bf6","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable, and the HMAC signature is verified before any processing. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"4d2c1c06-bb92-1c35-49bb-f13dbdf55544","name":"🔐 Security"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your approvals process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"16e04314-4a0a-bef7-7e06-44e480a874f2","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Compute HMAC Signature","type":"main","index":0}]]},"Compute HMAC Signature":{"main":[[{"node":"Signature Valid?","type":"main","index":0}]]},"Signature Valid?":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}],[{"node":"Reject (HTTP 401)","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Acknowledge Fast (HTTP 202)","type":"main","index":0}]]},"Acknowledge Fast (HTTP 202)":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'created' → Google Sheets","type":"main","index":0}],[{"node":"Handle 'updated' → Forward API","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'created' → Google Sheets":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'updated' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Gmail":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Receive Inbound Webhook":[{"json":{"taskId":"TASK-330","title":"Review Q3 automation roadmap","assignee":"jamie@company.com","dueDate":"2026-07-25"}},{"json":{"taskId":"TASK-331","title":"Fix broken webhook retries","assignee":"alex@company.com","dueDate":"2026-07-22"}}]},"versionId":"c30e9927-8281-4264-9fa5-265f0bdcfc55","id":"FDX08429"}