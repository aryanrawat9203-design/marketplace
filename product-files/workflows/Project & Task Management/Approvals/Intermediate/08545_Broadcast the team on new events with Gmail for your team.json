{"name":"Broadcast the team on new events with Gmail for your team","nodes":[{"parameters":{"httpMethod":"POST","path":"wf08545-task","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"f3e492d6-78cb-4431-bfa9-9b64311299a1","name":"Receive Inbound Webhook","webhookId":"ffd39aac-a466-4d9d-a2d8-86c2f4369c72"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"b555baf2-e727-4860-9cab-233c803cd6b1","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2e8b556a-1761-4680-bfdd-0b4c8ba6f444","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"f4824827-44aa-4007-87af-a61b034f7c3a","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"26ced5a0-6744-465f-981c-ad62ebf08c68","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"414bb311-8a78-40be-9e7f-6e434ea7b0ac","name":"taskId","value":"={{ $json.body?.taskId || $json.body?.id }}","type":"string"},{"id":"ad1be354-58fa-45d7-842a-d80c761b844a","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"da49e165-cff6-4839-bd8c-c6a8a1c68589","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"fcecd4fe-a2d5-4cfa