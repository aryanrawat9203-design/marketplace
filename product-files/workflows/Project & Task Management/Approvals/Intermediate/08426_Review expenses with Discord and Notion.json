{"name":"Review expenses with Discord and Notion","nodes":[{"parameters":{"formTitle":"Review expenses with Discord and Notion","formFields":{"values":[{"fieldLabel":"Title","requiredField":true},{"fieldLabel":"Assignee","requiredField":false},{"fieldLabel":"Duedate","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"4d44b80e-afdb-4faf-820f-367e84d65f31","name":"New Task Form Submission","webhookId":"1ba0a0f7-621b-40b1-872f-50c8fe1116f6"},{"parameters":{"assignments":{"assignments":[{"id":"8c03577b-060e-4752-be3e-52d9bbd8a650","name":"taskId","value":"={{ $json.taskId || $json.id || $execution.id }}","type":"string"},{"id":"a5a5f8c1-aeca-4f71-84d9-2f2815b32396","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"035b24d1-a5e2-40ab-ae90-03c4e4f7dfac","name":"Stamp & Shape Task"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e3d25a7a-2282-415f-ab15-fd1c600493c9","leftValue":"={{ $json.taskId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"d9d40e53-397c-47f4-b0bf-9ead51148e65","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[378,910],"id":"b7441a3b-9ba3-427e-9b1a-7ca2577bc490","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensit