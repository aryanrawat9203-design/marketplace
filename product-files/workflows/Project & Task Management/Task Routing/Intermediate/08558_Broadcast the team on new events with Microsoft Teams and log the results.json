{"name":"Broadcast the team on new events with Microsoft Teams and log the results","nodes":[{"parameters":{"httpMethod":"POST","path":"wf08558-task","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"02ee01cf-7cf9-41d3-8a8f-85ce7009a01c","name":"Receive Inbound Webhook","webhookId":"93cbc9e7-f109-4cc0-89e8-91acbd63a4c6"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"1c9e8585-99ce-4788-b520-a20b7f78000a","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fe3c0dec-61a8-413f-a240-88b09a14ad96","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"05d5088a-efa0-46f7-bcfe-3521d6401903","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"5c2647f4-084d-40f2-9ed9-e1ab03174871","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"2a6e16c2-d040-4974-8433-0a9c7bb15baa","name":"taskId","value":"={{ $json.body?.taskId || $json.body?.id }}","type":"string"},{"id":"6fdb3c02-01c8-4d0f-9e25-10e5a8085a09","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"0902c627-8ab5-4980-b2c7-3080e975ba5e","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"26