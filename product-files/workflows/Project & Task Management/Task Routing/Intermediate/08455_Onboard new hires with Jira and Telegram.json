{"name":"Onboard new hires with Jira and Telegram","nodes":[{"parameters":{"updates":["message"],"additionalFields":{}},"type":"n8n-nodes-base.telegramTrigger","typeVersion":1.2,"position":[-270,400],"id":"e98c6a41-01cf-497c-a25e-a7c97938d12d","name":"On Telegram Event","webhookId":"866f1edd-bbc9-4c2d-890c-6fcc21a84744"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming task records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    taskId: String(j.taskId ?? j.id ?? '').trim(),\n    title: typeof j.title === 'string' ? j.title.trim() : j.title ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"bb308670-c3a6-420b-9ec7-a0ad9bf78d56","name":"Normalize Task Payload"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"63f71cf2-606f-49f8-af82-dea9d4fdcd3a","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"employee","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"employee"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"9107a3c3-4301-4db3-a5cc-1884394db208","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"contractor","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"contractor"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"106a77ea-8c82-46dc-8cc2-a52527a03e80","name":"Route by Work Type"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Process Employee Task"},"options":{"waitForSubWorkflow":true}},"typ