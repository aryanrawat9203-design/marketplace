es-base.slack","typeVersion":2.3,"position":[3942,1420],"id":"bd1d79a1-771f-461b-af06-37ff0983eeb2","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Task Form Submission\n\nServes an n8n-hosted form (Title, Assignee, Duedate). Each submission becomes one execution.\n\nNext: Keep Valid Tasks","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"4b0fc067-4c21-7fb0-7c02-2ee453a11ddf","name":"Note: New Task Form Submission"},{"parameters":{"content":"### Keep Valid Tasks\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Route by Work Type","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"5d685d93-8cd4-7c30-c53b-01b99fea3744","name":"Note: Keep Valid Tasks"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: auto-approve, needs-review + fallback.\n\nPorts: ①→ Process 'auto-approve' → Google Sheets · ②→ Fast-Track 'needs-review' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"c380982c-1de9-e87b-8f70-e0dea3ac13b4","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'auto-approve' → Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"43698710-842f-5097-0515-6d59379e3cf9","name":"Note: Process 'auto-approve' → Google Sheets"},{"parameters":{"content":"### Fast-Track 'needs-review' + Alert\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"12a4f215-5ba8-439d-aad1-9adf64f6cbff","name":"Note: Fast-Track 'needs-review' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"ce48d9e0-1f0c-91f8-b1c7-a08d7beb6aef","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"a510f027-3323-0f26-f2ac-c2d1df0fce04","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"c9180e38-b719-8794-6897-1c7ad7c4328d","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"2e5a05a5-1758-2dfd-37b1-3003be3f03a9","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Sort Tasks Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"3399d913-33b0-ed6c-52a2-fa34fe141019","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Sort Tasks Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Send Summary to Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"af28a232-c922-5a8d-16ae-8e095988b915","name":"Note: Sort Tasks Newest First"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"9079455b-b892-c42d-daa4-1a85eee7c67d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,1540],"id":"bc5ba3af-b911-7f2f-659b-484331b91d9e","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"48799d60-8c21-6081-c846-9652d1351e02","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Route expenses with Slack and Google Sheets hands-free\n\n**Pattern:** Approval Workflow · **Level:** Core · **Trigger:** Form\n\n## What it does\nRoute expenses with Slack and Google Sheets hands-free. It starts from a hosted form submission.\n\n## Why it exists\nManual task routing is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Task Form Submission → Keep Valid Tasks → Route by Work Type → Process 'auto-approve' → Google Sheets → Merge Routed Work → Save Execution Metadata → Cap Batch Volume → …\n\n## Use it for\n- Teams that want to approval workflow without manual effort\n- Anyone automating task routing in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Saves hours of manual work each week\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9ed84507-d472-ecb2-3814-67092af8fd6d","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"5481badf-4d1c-43d7-c2a6-66aae322ae1f","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your task routing process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"1154a363-d78e-7c58-96c6-e6283852da40","name":"🛠 Customize me"}],"connections":{"New Task Form Submission":{"main":[[{"node":"Keep Valid Tasks","type":"main","index":0}]]},"Keep Valid Tasks":{"main":[[{"node":"Route by Work Type","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'auto-approve' → Google Sheets","type":"main","index":0}],[{"node":"Fast-Track 'needs-review' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'auto-approve' → Google Sheets":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'needs-review' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Sort Tasks Newest First","type":"main","index":0}]]},"Sort Tasks Newest First":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"3da5d607-ab67-44df-b325-105ea798a22b","id":"FDX08398"}