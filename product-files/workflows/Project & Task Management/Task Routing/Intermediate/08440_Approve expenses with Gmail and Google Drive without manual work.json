const prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"6f80a3df-cbb3-4078-8389-761829127336","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"ff29689d-0b7b-420d-a130-673a6d96a466","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"bad6c020-5d08-4392-af00-fcdfb276f1f1","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"bab51c34-7850-4466-849e-95e105b69d6c","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"69b32d6a-775a-454d-9872-cf045d751e89","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"323bc844-286b-423a-944a-c1b84325b2ef","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Approve expenses with Gmail and Google Drive without manual work — run comple","message":"=✅ Approve expenses with Gmail and Google Drive without manual work — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":