{"name":"Notify stakeholders on changes with Gmail on autopilot","nodes":[{"parameters":{"httpMethod":"POST","path":"wf08534-task","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"c68ad948-655b-42b9-a82e-837ec91f5d9c","name":"Receive Inbound Webhook","webhookId":"fd0f913d-dfeb-483b-9055-dfd4d317afbc"},{"parameters":{"operation":"getAll","returnAll":false,"limit":25,"filters":{"receivedAfter":"={{ $now.minus({hours: 24}).toISO() }}"},"options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[54,400],"id":"545ed77b-420e-4414-a66f-be93f897527a","name":"Read Metrics from Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each task 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.title) score += 20;\n  if (j.assignee) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"5e4d3878-0881-45be-a2ed-9238f8ad0c91","name":"Compute Severity Signals"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6a9d1986-f7de-4be1-80fd-78828b667942","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":40,"operator":{"type":"number","operation":"lt"}}],"combinator":"and"},"renameOutput":true,"outputKey":"info"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1d0e0202-46f0-4501-97b2-b4058b0ac767","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":70,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warning"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d79fb0e4-644b-4475-aa8a-369c44b3d750","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":90,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"critical"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"719628fd-35ca-4d69-b108-4fc284ee9970","name":"Grade Severity Tier"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Task Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,-80],"id":"2a8df3a7-5323-4370-bccf-ca67c764da57","name":"Just Record (Info)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🟠 Warning tier reached: {{ $json.taskId }} at {{ $json.score ?? $json.last }}","message":"=🟠 Warning tier reached: {{ $json.taskId }} at {{ $json.score ?? $json.last }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1350,400],"id":"7c97840c-1f43-4d9c-afbe-b77e8ebbacdd","name":"Warn Channel (Gmail)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#projects","cachedResultName":"#projects"},"text":"=🔴 CRITICAL: {{ $json.taskId }} breached threshold — act now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"4b142852-f32e-43d7-9ba0-4434f91bda71","name":"Page Urgently (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append",