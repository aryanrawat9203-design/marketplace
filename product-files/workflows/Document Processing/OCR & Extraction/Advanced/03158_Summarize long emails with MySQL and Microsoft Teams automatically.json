{"name":"Summarize long emails with MySQL and Microsoft Teams automatically","nodes":[{"parameters":{"httpMethod":"POST","path":"wf03158-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"22bb2dff-c613-46e8-862f-51b9fc8b5fba","name":"Receive Inbound Webhook","webhookId":"86d5ea80-6a1d-4aa6-9752-aa8410e490a9"},{"parameters":{"assignments":{"assignments":[{"id":"97e9a4ea-d798-450d-a9a5-fb41398ab858","name":"content","value":"={{ $json.body?.text || $json.content || JSON.stringify($json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"8c8a44ad-ef6b-41ed-99a8-a77a6cda4b0d","name":"Collect Raw Text"},{"parameters":{"text":"={{ $json.text || $json.content }}","attributes":{"attributes":[{"name":"documentId","description":"The documentId of this document.","required":true},{"name":"fileName","description":"The fileName of this document.","required":true},{"name":"docType","description":"The docType of this document.","required":false}]},"options":{"systemPromptTemplate":"You are a precise extraction engine. Only extract values present in the text."}},"type":"@n8n/n8n-nodes-langchain.informationExtractor","typeVersion":1,"position":[378,400],"id":"411be6d3-d0c3-4e8f-9907-a155eced72f6","name":"Extract Structured Fields","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[621,970],"id":"20530e8f-72ac-4910-876d-9e9ff2bab26b","name":"Google Gemini Chat Model"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2c0aacfb-e1c8-4d71-858a-613e29c31a5f","leftValue":"={{ $json.output?.documentId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[945,400],"id":"ab494bf6-43