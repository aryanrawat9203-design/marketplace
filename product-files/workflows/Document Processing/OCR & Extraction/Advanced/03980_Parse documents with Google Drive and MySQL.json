{"name":"Parse documents with Google Drive and MySQL","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":1}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"8f7e84d9-a133-4d96-92d2-5b6decdd7641","name":"Hourly Schedule"},{"parameters":{"resource":"fileFolder","searchMethod":"query","queryString":"={{ $json.searchTerm || '*' }}","returnAll":false,"limit":25,"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[54,400],"id":"89942e11-196f-464d-b422-7600850369b8","name":"List Changed Docs (Google Drive)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"documentId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"cd83e9fa-0a9d-46ea-a86b-95ec8fade3dc","name":"Remove Duplicate Documents"},{"parameters":{"operation":"download","fileId":{"__rl":true,"mode":"id","value":"={{ $json.id }}"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[702,400],"id":"ea6e955a-6c99-4d6e-8f04-9f9eab2b815b","name":"Download File Content","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"pdf","options":{}},"type":"n8n-nodes-base.extractFromFile","typeVersion":1,"position":[1026,400],"id":"f4bf9d2c-207f-4e8b-8202-45eb0f555110","name":"Extract Text from File"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Attach chunk-level metadata before embedding\nreturn $input.all().map((item, i) => ({\n  json: {\n    ...item.json,\n    chunkIndex: i,\n    sourceUrl: item.json.sourceUrl || item.json.url || 'internal',\n    ingestedAt: new Date().toISOString(),\n  },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1350,400],"id":"8fb8fd8e-6607-4f7c-90cf-7571a5ae8794","name":"Attach Chunk Metadata"},{"parameters":{"tableName":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"mode":"insert","options":{}},"type":"@n8n/n8n-nodes-langchain.vectorStoreSupabase","typeVersion":1.3,"position":[1674,400],"id":"f3987840-1b01-420d-9348-2818e3e1eefb","name":"Insert into Vector Store","onError":"continueErrorOutput"},{"parameters":{"options":{"metadata":{"metadataValues":[{"name":"sourceUrl","value":"={{ $json.sourceUrl }}"}]}}},"type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","typeVersion":1,"position":[1674,970],"id":"e791e54d-2e54-41c4-80d1-bdc707efea4b","name":"Prepare Documents"},{"parameters":{"chunkSize":1200,"chunkOverlap":120,"options":{}},"type":"@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter","typeVersion":1,"position":[1674,1480],"id":"98561b4d-fb3e-478a-89e0-e87483c6a349","name":"Chunk with Overlap"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.embeddingsOpenAi","typeVersion":1.2,"position":[1917,970],"id":"eca9c14a-073c-4248-8756-130878936716","name":"Document Embeddings"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[2241,400],"id":"f81b3a34-58e3-47f6-a0b8-55f1cc4b00d5","name":"Count Indexed Chunks"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2565,400],"id":"e8ad9816-708c-4480-9030-6880f5de6651","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2889,400],"id":"f4993d58-7fa0-46ea-a41e-d0e6553a8fe4","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.fileName }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3213,400],"id":"3c8cb72d-cb8c-4816-bdd6-cc88fed14489","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"caf7ed44-e229-4cfa-9a45-8449c8d3a12f","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6c25ba65-ef19-4878-847c-5fe388a7f998","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3537,400],"id":"8c58f815-4ecb-4d48-8690-c7803da0b1c2","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3861,400],"id":"70cf44c3-fe51-470c-a9ce-d05321ed06cf","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[4185,400],"id":"296c121e-32c5-4fce-a912-63682e30f674","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"73d2faa0-ff0e-4ab3-8d42-524b85c70a5a","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"826ea310-7286-4f0a-8947-39d6a1a81da2","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"f4fa0cae-f549-4bbc-b8fc-5836059db2b6","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4509,400],"id":"b8ba1ebc-6bd9-448c-8dd7-4a09ba8a5bd5","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[4833,400],"id":"a9d7add4-8e28-4831-af3c-56209a2873af","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Parse documents with Google Drive and MySQL — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5157,400],"id":"e812604b-41f0-4f48-8cac-774630037094","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b3f9d460-602d-40cc-b354-c1ecb29e940e","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"232d13f5-8e32-4de8-883f-ecafe22d9dd5","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e20a0298-2490-4cd6-9cc2-e493a53a9235","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4509,1420],"id":"1268b6d2-20f3-40c2-9e95-15a9f7d696e9","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4833,1420],"id":"a57093fa-8757-4c9c-87bf-cc113323db67","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[5157,1420],"id":"f66d9f04-cefe-4fe0-bec4-06dc54ff5250","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 1 h. No input data; downstream nodes fetch what they need.\n\nNext: List Changed Docs (Google Drive)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"7f8ff496-7e3d-9748-3030-ef2bde882bf4","name":"Note: Hourly Schedule"},{"parameters":{"content":"### List Changed Docs (Google Drive)\n\ngoogleDrive — `fileFolder` operation against the connected account.\n\nPorts: ①→ Remove Duplicate Documents · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"d6664cd7-4064-0223-79cb-b63f49e0a872","name":"Note: List Changed Docs (Google Drive)"},{"parameters":{"content":"### Remove Duplicate Documents\n\nDrops duplicates within this run (compared on `documentId`).\n\nNext: Download File Content","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"c5caf85b-9c82-fddc-9bba-c8b0650b3799","name":"Note: Remove Duplicate Documents"},{"parameters":{"content":"### Download File Content\n\ngoogleDrive — `download` operation against the connected account.\n\nPorts: ①→ Extract Text from File · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"30dd26b5-f695-e49e-2d9e-68f33c128ef0","name":"Note: Download File Content"},{"parameters":{"content":"### Extract Text from File\n\nParses the incoming PDF binary into JSON items.\n\nNext: Attach Chunk Metadata","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"807920d1-b386-c649-426a-731aea1efad5","name":"Note: Extract Text from File"},{"parameters":{"content":"### Attach Chunk Metadata\n\nCustom JavaScript: Attach chunk-level metadata before embedding\n\nNext: Insert into Vector Store","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"23e342ef-6b09-86c6-6e93-d684e1079b2a","name":"Note: Attach Chunk Metadata"},{"parameters":{"content":"### Insert into Vector Store\n\nWrites embedded chunks into the vector index.\n\nPorts: ①→ Count Indexed Chunks · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail · 🔑 Supabase URL + service key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"99d66e17-d684-a052-e318-422c3890b12c","name":"Note: Insert into Vector Store"},{"parameters":{"content":"### Prepare Documents\n\nWraps incoming items as documents (with metadata) for the vector store.\n\nFeeds **Insert into Vector Store** as `document`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1090],"id":"8b7d03a1-6d74-a93f-69a6-67b690a13941","name":"Note: Prepare Documents"},{"parameters":{"content":"### Chunk with Overlap\n\nChunks documents (~1200 chars, 120 overlap) so retrieval hits stay focused.\n\nFeeds **Prepare Documents** as `textSplitter`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1600],"id":"57cc8055-aa8e-c0d9-40df-1ef81172dc55","name":"Note: Chunk with Overlap"},{"parameters":{"content":"### Document Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Insert into Vector Store** as `embedding`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,1810],"id":"66ee8276-bbb8-cf48-a0b1-ecead465afe6","name":"Note: Document Embeddings"},{"parameters":{"content":"### Count Indexed Chunks\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"fc7a5cfb-c4b2-2506-15c0-45e7daa0c19a","name":"Note: Count Indexed Chunks"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"37b3a0a1-1ade-7855-5bfb-dadfba49b405","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"35639902-3ccc-325a-fb49-0de29ee0ba18","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"4c603558-31f3-76c3-5573-769660371437","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"48495282-6e56-de29-da59-75fe8fa9fbd6","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"6f1e9beb-1256-af5b-c710-dde87f9a8301","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"5282107d-1b64-f924-3470-dbf30ffc8f9c","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"604ef3fc-5058-d10c-4287-aa8db500a3e3","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"2996ac38-7415-c19e-c167-4ea49bb80f82","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"585668d7-6104-6b34-6494-ed39237602ba","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,1540],"id":"3e113322-3c57-ef46-ecd9-ac165fe83ad4","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,1540],"id":"3f372b5c-6b38-3d92-b409-387494fbbd41","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nmySql — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"fda640c6-d518-8862-3c20-760d3c732a29","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Parse documents with Google Drive and MySQL\n\n**Pattern:** File Processing · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nParse documents with Google Drive and MySQL. It runs automatically on a schedule.\n\n## Why it exists\nManual ocr & extraction is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → List Changed Docs (Google Drive) → Remove Duplicate Documents → Download File Content → Extract Text from File → Attach Chunk Metadata → Insert into Vector Store → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating ocr & extraction in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Scales without extra headcount\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; MySQL connection; OpenAI API key; Slack OAuth2; Supabase URL + service key.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a275e310-ecb5-19e5-a033-dcc46e802b74","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"b3620586-0e79-587f-ec8e-9eb0beadd31c","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"f08b3a3f-9e08-f24d-67f4-0b5c09ff4b96","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"0dd57492-68ef-f769-f848-3f8c2bcd6ca1","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your ocr & extraction process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"78a9dbeb-f5b9-fcf9-8ed1-f9abb86b880f","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"List Changed Docs (Google Drive)","type":"main","index":0}]]},"List Changed Docs (Google Drive)":{"main":[[{"node":"Remove Duplicate Documents","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Remove Duplicate Documents":{"main":[[{"node":"Download File Content","type":"main","index":0}]]},"Download File Content":{"main":[[{"node":"Extract Text from File","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Extract Text from File":{"main":[[{"node":"Attach Chunk Metadata","type":"main","index":0}]]},"Attach Chunk Metadata":{"main":[[{"node":"Insert into Vector Store","type":"main","index":0}]]},"Prepare Documents":{"ai_document":[[{"node":"Insert into Vector Store","type":"ai_document","index":0}]]},"Chunk with Overlap":{"ai_textSplitter":[[{"node":"Prepare Documents","type":"ai_textSplitter","index":0}]]},"Document Embeddings":{"ai_embedding":[[{"node":"Insert into Vector Store","type":"ai_embedding","index":0}]]},"Insert into Vector Store":{"main":[[{"node":"Count Indexed Chunks","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count Indexed Chunks":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"c4ca44ad-1f0d-42e6-8520-8165ec929792","id":"FDX03980"}