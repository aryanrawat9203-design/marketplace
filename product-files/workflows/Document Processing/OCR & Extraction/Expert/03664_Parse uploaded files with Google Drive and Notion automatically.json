      "typeVersion": 1.2,
      "position": [
        -200,
        400
      ],
      "id": "459a365f-d7a0-4cae-803a-4900493d699a",
      "name": "Daily Schedule"
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "getAll",
        "databaseId": {
          "__rl": true,
          "mode": "list",
          "value": "",
          "cachedResultName": "Document Database"
        },
        "returnAll": true,
        "options": {}
      },
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        40,
        400
      ],
      "id": "d0b9f94e-ff4a-4681-bd2a-915880cbcdb2",
      "name": "Export All Rows (Notion)",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "operation": "csv",
        "options": {}
      },
      "type": "n8n-nodes-base.convertToFile",
      "typeVersion": 1.1,
      "position": [
        280,
        400
      ],
      "id": "23f64e1c-03e1-4529-96a9-4c0031b9750d",
      "name": "Serialize to CSV"
    },
    {
      "parameters": {
        "operation": "upload",
        "name": "=backup-{{ $now.toFormat('yyyyLLdd-HHmm') }}.zip",
        "driveId": {
          "__rl": true,
          "mode": "list",
          "value": "My Drive"
        },
        "folderId": {
          "__rl": true,
          "mode": "list",
          "value": "",
          "cachedResultName": "Backups"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        520,
        400
      ],
      "id": "b7ebb745-c32f-4c2a-b02c-c71d8acce1b4",
      "name": "Upload Backup to Google Drive",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "60b20f3a-a93e-41e6-a494-79a18abda00c",
              "leftValue": "={{ ($binary.data?.fileSize ?? 1) > 0 }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        760,
        400
      ],
      "id": "ac8e6abd-0f91-46db-8f19-42071fd6ab5c",
      "name": "Backup Size Sane?"
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "name",
          "value": "#docs",
          "cachedResultName": "#docs"
        },
        "text": "=🛑 Tonight's backup came out EMPTY — investigate immediately.",
        "otherOptions": {}
      },
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [
        1000,
        560
      ],
      "id": "6e42728c-91a3-47f9-9ca7-7061fa23e1a9",
      "name": "Alarm — Empty Backup",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "ce7f5174-d7a8-4f63-85f5-018f04cfa189",
              "leftValue": "={{ $json.fileName }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [
        1240,
        400
      ],
      "id": "e27d6fba-f930-4452-b396-8954d8c19af7",
      "name": "Guard Non-Empty fileName"
    },
    {
