{"name":"Issue invoices with HTTP / REST API and Notion end to end","nodes":[{"parameters":{"httpMethod":"POST","path":"wf04048-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"6d09d966-be3a-4ac1-bc64-df2461cc9a84","name":"Receive Inbound Webhook","webhookId":"9f08d1cf-18c7-4067-9a9b-99625d109201"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/documents","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,130],"id":"a2717caa-d3bb-4715-a5a8-a546d16152af","name":"Gather API Numbers","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[378,640],"id":"9a28959b-ffde-4f86-865e-7de6c233b602","name":"Gather from Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1026,400],"id":"c05929dd-a015-41c8-879f-2eecbf5f6d28","name":"Blend Sources"},{"parameters":{"fieldsToSummarize":{"values":[{"aggregation":"count","field":"documentId"}]},"fieldsToSplitBy":"docType","options":{}},"type":"n8n-nodes-base.summarize","typeVersion":1.1,"position":[1998,400],"id":"5484ec46-a9fc-4be6-9f95-bdcdfde8bd79","name":"Roll Up KPIs"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build an HTML digest table from the aggregated rows\nconst rows = $input.all().map(i => i.json);\nconst tr = rows.map(r =>\n  `<tr><td>${r.documentId ?? ''}</td><td>${r.fileName ?? ''}</td><td>${r.count ?? 1}</td></tr>`\n).join('');\nconst html = `<h2>Document digest</h2><table border=\"1\" cellpadding=\"4\">\n<tr><th>ID</th><th>fileName</th><th>Count</th></tr>${tr}</table>`;\nreturn [{ json: { html, rowCount: rows.length, generatedAt: new Date().toISOString() } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2322,400],"id":"5b7595ab-b562-4c1e-9e27-cf8ed27aed88","name":"Compose HTML Report"},{"parameters":{"authentication":"webhook","content":"={{ $json.html }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[2646,400],"id":"a77b79bc-21fd-4ae0-9b67-2637868ae788","name":"Send Report via Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2970,400],"id":"2fd32144-dc2b-46e7-8773-7cf64b66b881","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3294,400],"id":"4901d6f8-cd66-4a11-8fee-1e7cf4c548ea","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3618,400],"id":"d9db0137-0526-42f0-88b3-6e0fdb89a9dc","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3942,400],"id":"da5188b3-36fa-419b-9f96-2b7bb2e0d82e","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.fileName }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"10afdd34-0e06-494d-9779-385cd007fae6","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"22fe0324-e488-4d2d-85cf-1ee25ebed5bf","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"654d5f02-ed19-40df-9d6a-434442b96b64","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"083507aa-3c6e-4e7e-a767-1e24d5d00971","name":"Fold In Enrichment Fields"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Documents"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[4914,400],"id":"4fd66f21-e8e3-47ca-8750-e2ab3298508c","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"49ff7dc5-d306-40c3-beeb-0e650239b7da","name":"Record Sub-workflow Result"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per document (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.documentId, j.fileName].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"cfebc4dd-c59d-49f5-93b9-19a03eadfdde","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5886,400],"id":"74c03700-f57f-4f94-bf41-828cb16907c1","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6210,400],"id":"23b5dc3d-1c56-4862-8e85-bae498bd6d25","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6534,400],"id":"2541bb72-cb46-4b6c-b486-957aa4c3586e","name":"Persist Run Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"ea7e2f23-2f2e-4100-acd5-a85f285a36c6","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7182,400],"id":"ed9ff2a2-77c5-4093-9985-37a5b6b6651d","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"03c5a00d-3f0a-482c-b71d-f13fa37b098d","name":"pipeline","value":"OCR & Extraction","type":"string"},{"id":"6f18b90d-359e-4528-88d9-40d017770b23","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7506,400],"id":"d4cd9322-753b-4cf1-a22f-4affe06e67f2","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"documentId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7830,400],"id":"44c1ce4e-4ba8-43ef-b8b6-5f2fac3e05e5","name":"Align Field Names"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8154,400],"id":"acd2276b-87ef-4e6d-9f2b-e91244adbd2c","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"0af7873e-8448-4696-ae5f-5c9f75fff73d","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e441ba2b-0c64-4ab6-9acf-6187bf70e9d5","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"25e938c8-80e0-431b-b10a-79354b24844e","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,400],"id":"f9a6a480-c7c2-41d7-a02d-b154e0a4f4f3","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[8802,400],"id":"cc29bfeb-6ab6-4f87-bc28-da4d7bfd861c","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=✅ Issue invoices with HTTP / REST API and Notion end to end — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[9126,400],"id":"f5ffc5d3-570b-4782-9336-8f272340ba67","name":"Send Summary to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3bad8ee4-a590-42f4-9f2f-e23c60889992","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"51a5be4b-35e7-4a55-8250-de845bae8876","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"051784dc-4785-4649-a1b6-cd92f2a11acc","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,1420],"id":"3a094e03-6cb5-4bce-b4c0-3dc359cafb05","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8802,1420],"id":"19324d72-932f-4dd6-949a-97429db0868c","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.fileName || $json.documentId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9126,1420],"id":"e1ffe8da-b15a-47ae-9d98-458bef58ed2b","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf04048-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Gather API Numbers","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"87c79947-388c-a12a-1bdd-27b48bdbe784","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Gather API Numbers\n\nGET https://api.example.com/v1/documents — retries 3× with backoff on failure.\n\nPorts: ①→ Blend Sources · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"7d96f19b-2729-7698-44df-65905b5d6461","name":"Note: Gather API Numbers"},{"parameters":{"content":"### Gather from Notion\n\nnotion — `getAll` operation against the connected account.\n\nPorts: ①→ Blend Sources · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,760],"id":"a929f57e-399f-bf9b-f910-97821c99ba93","name":"Note: Gather from Notion"},{"parameters":{"content":"### Blend Sources\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Roll Up KPIs","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"46c08f20-e266-ace9-235b-4e86fccfeaf5","name":"Note: Blend Sources"},{"parameters":{"content":"### Roll Up KPIs\n\nGroup-by + aggregate (like a pivot table) — turns raw rows into KPI numbers.\n\nNext: Compose HTML Report","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"02f30fae-c506-fb3e-bbdf-4a765f4c539a","name":"Note: Roll Up KPIs"},{"parameters":{"content":"### Compose HTML Report\n\nCustom JavaScript: Build an HTML digest table from the aggregated rows\n\nNext: Send Report via Discord","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"f527008e-dd3f-bc48-f872-3f315e95ed3d","name":"Note: Compose HTML Report"},{"parameters":{"content":"### Send Report via Discord\n\ndiscord — `action` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"3d138baa-bb57-d262-de0e-184f56e94660","name":"Note: Send Report via Discord"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"319f3708-8e58-aad3-8662-a52da8952c87","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"db3861c2-96e9-50de-e86e-ab8808c2be6b","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"27eed39d-7fb2-8c35-9a62-72bf56c9ffd0","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"ba5f8833-a3ff-28c7-d8bf-21d5d48169bc","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"8183c454-463e-19b3-b967-f63f14ce7557","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"88b0859e-741b-fcec-63a3-df4512105904","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"76718ec5-bffd-f4df-4df1-7a4ba82a23c3","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"b4c4a867-a130-66f2-9844-f612a06e38d8","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per document (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"ee279ff5-56fe-f4b4-9431-87efcaa00c97","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"0a3c1b4e-ff1f-1576-3bea-ca8ef40e23f6","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"a87f89fb-5e8b-3d65-e424-6db2d6522bea","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"51c28d71-bb91-c6dd-0cc4-647de3e0af12","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"115d37bd-2050-f45a-ef54-bde802841e9c","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"c6014479-fd6f-caab-f749-1c35d3834e7a","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"e60a326e-b9fe-36cf-8334-3a44ce96a4ff","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"198dc647-8f21-bc08-a77d-e2f078921cb6","name":"Note: Align Field Names"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"c5598721-e267-52dc-ac29-149bd8efc296","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"0e1fc0bc-f552-cfc7-da6b-5a2b260a90c6","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Discord · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"d6939d2d-6f6e-1e1d-2fc7-30435da22fe8","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Discord\n\ndiscord — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,520],"id":"af193131-c672-ab97-7646-b4f3ba3fe924","name":"Note: Send Summary to Discord"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,1540],"id":"71fc9215-f4c2-fbe4-5099-5c85550e460a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,1540],"id":"17e56025-4b72-ba29-22a9-177502787141","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,1540],"id":"6a4406e2-de90-f4c9-ed56-5aed641c2f06","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Issue invoices with HTTP / REST API and Notion end to end\n\n**Pattern:** Document Generation · **Level:** Architect · **Trigger:** Webhook\n\n## What it does\nIssue invoices with HTTP / REST API and Notion end to end. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual ocr & extraction is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Gather API Numbers → Blend Sources → Roll Up KPIs → Compose HTML Report → Send Report via Discord → Load Previous Snapshot → …\n\n## Use it for\n- Teams that want to document generation without manual effort\n- Anyone automating ocr & extraction in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Responds in seconds\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Discord webhook URL; Google OAuth2 / service account; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"8774db6e-af8a-8eac-5f8d-1e11186d4ee1","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"bc3e1376-b746-af09-9cda-8349b097f6b1","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"c73afe3d-837c-710c-27f1-3a9d6f3872a8","name":"🔐 Security"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"09adc134-a5a7-6ecf-7ef7-1668c96284e9","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your ocr & extraction process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-290],"id":"adc43308-8f80-9837-5ffd-17f60dca35e5","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Gather API Numbers","type":"main","index":0},{"node":"Gather from Notion","type":"main","index":0}]]},"Gather API Numbers":{"main":[[{"node":"Blend Sources","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Gather from Notion":{"main":[[{"node":"Blend Sources","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Blend Sources":{"main":[[{"node":"Roll Up KPIs","type":"main","index":0}]]},"Roll Up KPIs":{"main":[[{"node":"Compose HTML Report","type":"main","index":0}]]},"Compose HTML Report":{"main":[[{"node":"Send Report via Discord","type":"main","index":0}]]},"Send Report via Discord":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":