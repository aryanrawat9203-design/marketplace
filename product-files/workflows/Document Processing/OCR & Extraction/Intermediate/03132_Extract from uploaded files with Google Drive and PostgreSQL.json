              "id": "45c589a9-dcf1-47aa-9ec8-b807ccf85196",
              "leftValue": "={{ $json.documentId }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.if",
