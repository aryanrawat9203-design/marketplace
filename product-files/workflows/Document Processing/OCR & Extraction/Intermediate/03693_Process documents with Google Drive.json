{"name":"Process documents with Google Drive","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[5],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"bfd96dfd-d20a-4906-8d24-7b0c0b70b128","name":"Weekly Schedule"},{"parameters":{"resource":"fileFolder","searchMethod":"query","queryString":"={{ $json.searchTerm || '*' }}","returnAll":false,"limit":25,"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[54,400],"id":"07d86d71-8ae5-442e-95c6-2c0d744e3649","name":"List Changed Docs (Google Drive)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"documentId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"88d3cb18-01fc-4227-9e50-d905407e0aa6","name":"Remove Duplicate Documents"},{"parameters":{"operation":"download","fileId":{"__rl":true,"mode":"id","value":"={{ $json.id }}"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[702,400],"id":"27fb2868-2cde-4a6b-abb9-cd9dc7ef47ac","name":"Download File Content","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"pdf","options":{}},"type":"n8n-nodes-base.extractFromFile","typeVersion":1,"position":[1026,400],"id":"fddc53b5-09f2-46d4-96c9-b41a75ae0178","name":"Extract Text from File"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Attach chunk-level metadata before embedding\nreturn $input.all().map((item, i) => ({\n  json: {\n    ...item.json,\n    chunkIndex: i,\n    sourceUrl: item.json.sourceUrl || item.json.url || 'internal',\n    ingestedAt: new Date().toISOString(),\n  },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1350,400],"id":"eb11a4fd-b90d-4dde-93c9-6d3dd9629a5a","name":"Attach Chunk Metadata"},{"parameters":{"qdrantCollection":{"__rl":true,"mode":"list","value":"","cachedResultName":"kb_main"},"mode":"insert","options":{}},"type":"@n8n/n8n-nodes-langchain.vectorStoreQdrant","typeVersion":1,"position":[1674,400],"id":"dff933ad-42c2-45ac-a960-a4d75e48857d","name":"Insert into Vector Store","onError":"continueErrorOutput"},{"parameters":{"options":{"metadata":{"metadataValues":[{"name":"sourceUrl","value":"={{ $json.sourceUrl }}"}]}}},"type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","typeVersion":1,"position":[1674,970],"id":"0ac1db93-8c56-48a8-af9c-273672d6fcee","name":"Prepare Documents"},{"parameters":{"chunkSize":1200,"chunkOverlap":120,"options":{}},"type":"@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter","typeVersion":1,"position":[1674,1480],"id":"e299a4e3-2146-48de-94e8-d98050417df9","name":"Chunk with Overlap"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.embeddingsOpenAi","typeVersion":1.2,"position":[1917,970],"id":"261f1461-1b4f-4ed7-b1d3-4d114f7e1c3d","name":"Document Embeddings"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[2241,400],"id":"71aa75c2-ac5a-4770-8655-747a5eefccef","name":"Count Indexed Chunks"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Documents"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[2565,400],"id":"716da11b-2bb1-48db-ae81-ecfd9fd257d2","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2889,400],"id":"9a3f8cd1-bbd0-417a-b07b-ac9b5ae183c2","name":"Record Sub-workflow Result"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[3213,400],"id":"a3c2f9e0-2294-4a91-b41a-43db326df68a","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3537,400],"id":"60e78414-6c00-4643-9d32-449a7860d9e8","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3861,400],"id":"e0f8979f-a097-4aa8-8eb0-4250d15a295a","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[4185,400],"id":"62ac16d5-a7de-43f6-a83d-896c256b2e61","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per document (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.documentId, j.fileName].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4509,400],"id":"3237f1d6-2beb-408f-80e4-ad4ed5f9f390","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4833,400],"id":"8e7ed0e3-0e80-4bc2-ab55-95ce88ee2143","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5157,400],"id":"60c09e19-b50c-49d6-be59-b9229ba6bbab","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5481,400],"id":"79c5d98a-cbbc-4745-9ee4-dc55d565fe45","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.fileName }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5805,400],"id":"9790c6ab-2779-4a10-803f-bb6535c11e06","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"96e55971-f029-4bd5-ad65-183f07ede8e9","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"4eb310e6-bb98-44dc-acf1-769da8e41341","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6129,400],"id":"37a78403-31e7-478d-9934-c5b6c486a88e","name":"Fold In Enrichment Fields"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"documentId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[6453,400],"id":"fad45acc-c6ff-4036-bd58-d3c3f52179fb","name":"Align Field Names"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6777,400],"id":"ddadc884-d173-4b93-8c5d-f0e51435ed7c","name":"Stamp Processing Time"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7101,400],"id":"33347743-a99a-46f7-8db0-fd8d77c9945c","name":"Save Execution Metadata"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7425,400],"id":"eb88364a-30ef-43f1-8f5f-1302a229bd20","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"79027086-bec9-4b21-a8ca-db59ff1f69b1","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f5afa71e-db25-4e2c-ace8-9213f1a54d5a","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"29305ec9-bd62-414f-9dbc-933ccacddfd4","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7749,400],"id":"148017f8-202e-4dec-bdc4-208d9705c307","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.fileName || $json.documentId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8073,400],"id":"897d3a2f-bdd4-44bd-a16a-651fbb7fb152","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Process documents with Google Drive — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8397,400],"id":"65a5c4c0-cf39-4268-8fef-59298d428c66","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"9bc02bb8-b02b-477f-9aa6-107451ef664f","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"28bc97e5-c9e9-4946-bd45-3892d3e2d823","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"18d9df87-ca47-431c-9573-b67c73162541","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7749,1420],"id":"e3f82a2e-460a-41c7-8815-c73f08c8ff83","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8073,1420],"id":"0f9bc561-cc0b-47be-983e-9ea9ef5df137","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[8397,1420],"id":"479af9be-c5c9-4ba1-bbe4-515e4dac1b33","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: List Changed Docs (Google Drive)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"499f3832-559a-0e58-6146-55bf6ea1287d","name":"Note: Weekly Schedule"},{"parameters":{"content":"### List Changed Docs (Google Drive)\n\ngoogleDrive — `fileFolder` operation against the connected account.\n\nPorts: ①→ Remove Duplicate Documents · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"47ced220-00e8-138e-fa89-71ad32076543","name":"Note: List Changed Docs (Google Drive)"},{"parameters":{"content":"### Remove Duplicate Documents\n\nDrops duplicates within this run (compared on `documentId`).\n\nNext: Download File Content","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"be745289-65ef-ea98-2af1-2a53b8c13d57","name":"Note: Remove Duplicate Documents"},{"parameters":{"content":"### Download File Content\n\ngoogleDrive — `download` operation against the connected account.\n\nPorts: ①→ Extract Text from File · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"36be17a4-dd96-e291-121e-750b66d50c3a","name":"Note: Download File Content"},{"parameters":{"content":"### Extract Text from File\n\nParses the incoming PDF binary into JSON items.\n\nNext: Attach Chunk Metadata","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"eedd147a-2e0c-3fc2-288d-e5395f22f52d","name":"Note: Extract Text from File"},{"parameters":{"content":"### Attach Chunk Metadata\n\nCustom JavaScript: Attach chunk-level metadata before embedding\n\nNext: Insert into Vector Store","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"1d6cd140-cf88-01f2-eaf1-410b7d5f8c2a","name":"Note: Attach Chunk Metadata"},{"parameters":{"content":"### Insert into Vector Store\n\nWrites embedded chunks into the vector index.\n\nPorts: ①→ Count Indexed Chunks · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail · 🔑 Qdrant URL + key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"943b260c-6e42-f44c-66f9-57c795515fca","name":"Note: Insert into Vector Store"},{"parameters":{"content":"### Prepare Documents\n\nWraps incoming items as documents (with metadata) for the vector store.\n\nFeeds **Insert into Vector Store** as `document`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1090],"id":"ef397e03-ed89-b1cc-e535-040b54d39e66","name":"Note: Prepare Documents"},{"parameters":{"content":"### Chunk with Overlap\n\nChunks documents (~1200 chars, 120 overlap) so retrieval hits stay focused.\n\nFeeds **Prepare Documents** as `textSplitter`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1600],"id":"261b24f3-5704-628e-c91e-1f18294392ce","name":"Note: Chunk with Overlap"},{"parameters":{"content":"### Document Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Insert into Vector Store** as `embedding`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,1810],"id":"51fc817c-cd5d-0037-7610-03252a009421","name":"Note: Document Embeddings"},{"parameters":{"content":"### Count Indexed Chunks\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"b695179c-3f89-34fd-1a0b-410957b95a99","name":"Note: Count Indexed Chunks"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"72e9c32c-65aa-087f-a9ac-5c7c809c318f","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"4982c4b9-bde2-a5e9-8628-f8aba57ed4ea","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Load Previous Snapshot\n\nnotion — `getAll` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"1aaa71fe-38a3-ed54-70c2-e98325ae5253","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"a6cc9a7f-c607-adb8-0794-d86bfe0e1cdb","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"70884689-a198-8934-2fde-3c326085f7f0","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"b5ed57d2-9e67-df48-5ba8-1549e76684db","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per document (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"fdc31599-683c-e032-678d-d42a66987201","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"7c19eafd-7bfb-167c-256d-dd2b2797d970","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"99850d4a-21ca-a3ac-76da-4679bca33b0d","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"46715d9b-5c41-f614-6a99-8adb217a1b6b","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"7d3739b9-9957-14b2-868a-cf480d873023","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"efc096b8-8b8c-46f5-584e-7653e5597ac7","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"8e05b8c9-8aa0-7190-4d74-e76d7651bd34","name":"Note: Align Field Names"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"4532fcbb-c79d-766a-e18e-14a0780f7b5f","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"911113a5-3d69-04ca-9627-f8cce6259738","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"3ba1d7f4-bd89-5fb6-133b-e51565d3b7db","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"1e0f7104-e820-2d1f-be6e-59b7df9a1b40","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"25b0547e-f63d-4a91-2ecc-1961984af8c4","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,520],"id":"0e12f94b-df88-28b6-bdda-61370d61ecdc","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,1540],"id":"f41f291e-8311-a8f0-a1c6-990b2320407d","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,1540],"id":"9d9e61d3-6996-3d68-7601-7bc416661709","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,1540],"id":"9f9c152a-4420-2c80-6e61-97ca12b2a6a0","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Process documents with Google Drive\n\n**Pattern:** File Processing · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nProcess documents with Google Drive. It runs automatically on a schedule.\n\n## Why it exists\nManual ocr & extraction is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → List Changed Docs (Google Drive) → Remove Duplicate Documents → Download File Content → Extract Text from File → Attach Chunk Metadata → Insert into Vector Store → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating ocr & extraction in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Removes copy-paste errors\n- Standardizes the process every time\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Notion integration token; OpenAI API key; Qdrant URL + key.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"294ae125-32d2-1ca4-f264-3820ca84c46e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"0ef87653-a1eb-138f-3366-f3248f407ef0","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"c32d1d25-a1a1-69c6-0c07-a5d5c94c87f3","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"e8d186ba-5ec9-8b03-65a5-b5b25ab27e2e","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your ocr & extraction process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"d4a1f96e-f3aa-6a45-849f-df9b27f421f3","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"List Changed Docs (Google Drive)","type":"main","index":0}]]},"List Changed Docs (Google Drive)":{"main":[[{"node":"Remove Duplicate Documents","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Remove Duplicate Documents":{"main":[[{"node":"Download File Content","type":"main","index":0}]]},"Download File Content":{"main":[[{"node":"Extract Text from File","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Extract Text from File":{"main":[[{"node":"Attach Chunk Metadata","type":"main","index":0}]]},"Attach Chunk Metadata":{"main":[[{"node":"Insert into Vector Store","type":"main","index":0}]]},"Prepare Documents":{"ai_document":[[{"node":"Insert into Vector Store","type":"ai_document","index":0}]]},"Chunk with Overlap":{"ai_textSplitter":[[{"node":"Prepare Documents","type":"ai_textSplitter","index":0}]]},"Document Embeddings":{"ai_embedding":[[{"node":"Insert into Vector Store","type":"ai_embedding","index":0}]]},"Insert into Vector Store":{"main":[[{"node":"Count Indexed Chunks","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count Indexed Chunks":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"e32c5579-b513-4e30-8caf-be979174d5a2","id":"FDX03693"}