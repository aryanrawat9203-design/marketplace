p Batch Volume"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"documentId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[6210,400],"id":"5e529042-a72c-47c6-90e8-3af7dbafe805","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6534,400],"id":"db675b36-a968-48ae-adbe-f888c593d4ee","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"2410308e-a6a3-4b98-9949-47d42610e01c","name":"pipeline","value":"OCR & Extraction","type":"string"},{"id":"d7530274-0cea-4fcc-b388-82d4e60bf8c1","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"2451aedc-0097-4192-8e1b-58516e515b08","name":"Tag Pipeline Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"69f64d85-cab8-4f25-8b6a-d4b85360f60b","leftValue":"={{ $json.fileName }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7182,400],"id":"d083dea0-c1de-44ef-8083-f9ec9a0ea88e","name":"Guard Non-Empty fileName"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"pageCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7506,400],"id":"26bd17e0-dc51-4e0a-8468-500d911967d1","name":"Sort Documents Newest First"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7830,400],"id":"addc04a7-3722-4e22-966a-45c025409a00","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"37a16ba1-1628-42af-aa40-7a65fe9715b1","name":"runAt","value":"={{ $now.toISO() }}","type