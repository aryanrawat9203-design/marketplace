ght's backup came out EMPTY — investigate immediately.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1350,880],"id":"7e11da62-edc3-4df1-8dda-142f5e126d2d","name":"Alarm — Empty Backup","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"pageCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[1674,400],"id":"8e98c9fd-fed4-40a0-a638-76b862f92937","name":"Sort Documents Newest First"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[1998,400],"id":"4c8f0631-1ad4-47f3-b6ba-452923533773","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2322,400],"id":"48cc2ff6-b706-4e26-94d9-26e0a9a30b3b","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"45fe0fca-c52d-4b74-b2ac-36f123164adc","name":"pipeline","value":"Summarization","type":"string"},{"id":"d8e68bed-f91b-4ae4-9b39-c4c09a9d8334","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2646,400],"id":"b9c7be73-997c-4cbc-91bc-b91f063d9be2","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"documentId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[2970,400],"id":"291072c2-a745-429f-b372-c688d79b269a","name":"Align Field Names"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[3294,400],"id":"4d131d73-646b-44d5-b80b-c94a466defa9","name":"Cap Batch Volume"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a6ad2f4f-cb92-4198-b813-0eca0f98083b","leftValue":"={{ $json.fileName }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3618,400],"id":"f077ce77-67ec-40f9-b76e-a77e2d73cc60","name":"Guard Non-Empty fileName"},{"parameters":{"assignments":{"assignments":[{"id":"9d4b1be3-2b30-419a-878b-9f577e8174df","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"2e1b45dc-6853-4930-afca-d5cecc688927","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"d3833143-b936-4c83-a3b2-924a5cd15edd","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,400],"id":"3eb841d6-f3ed-45d2-a983-2770d131a82d","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO document_log (documentId, fileName, docType, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.documentId, $json.fileName, $json.docType ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4266,400],"id":"de3ef87a-07bf-4868-8d83-67b283cd6f0d","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Parse receipts with Google Drive and PostgreSQL for your team — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4590,400],"id":"7645ae17-9c4b-429a-b8d1-c60750084db5","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"2933332a-bb80-47c1-b862-143c5a2fce46","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"8fd39299-c823-4063-a43e-aba5b33f9ae6","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"840e3dc8-b3f4-4761-9591-8b645f9dc818","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,1420],"id":"0370c75f-3ca7-4c17-93e0-4779fba2bdbd","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,1420],"id":"6ebfcbce-ea2f-42f1-b531-4eb8f6990c08","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Export All Rows (PostgreSQL)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"bd3fece2-6dde-6826-a58c-94babce6fb0c","name":"Note: Daily Schedule"},{"parameters":{"content":"### Export All Rows (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Serialize to CSV · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"6cb714e5-73e5-2d6d-8b14-a78190caa438","name":"Note: Export All Rows (PostgreSQL)"},{"parameters":{"content":"### Serialize to CSV\n\nSerializes items to a CSV binary file.\n\nNext: Upload Backup to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"bb1feaa2-a488-2f62-b836-fb1ed1e44a0e","name":"Note: Serialize to CSV"},{"parameters":{"content":"### Upload Backup to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Backup Size Sane? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"21d93c63-b602-6b39-e605-334b436c8322","name":"Note: Upload Backup to Google Drive"},{"parameters":{"content":"### Backup Size Sane?\n\nTwo-way gate on `={{ ($binary.data?.fileSize ?? 1) > 0 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Sort Documents Newest First · ②→ Alarm — Empty Backup","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"4060e33a-62a9-a097-0fc7-fe9d3276c726","name":"Note: Backup Size Sane?"},{"parameters":{"content":"### Alarm — Empty Backup\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"98537a18-a4e0-d935-16bc-1e643b28e63f","name":"Note: Alarm — Empty Backup"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"a1deca51-6d7e-f7b7-ac64-5b41290d79b5","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"028b7493-d3d2-d955-105e-6523fa9e3465","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"68438d82-a723-700b-cf15-7c92029902a6","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"47ad0b0b-b573-9abb-f9b5-8cd1eb1863c0","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"0f01fd75-f0b3-2d03-835d-c464009527c8","name":"Note: Align Field Names"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Guard Non-Empty fileName","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"6701e9ef-22db-e32b-8394-f4fc23e40eb4","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Guard Non-Empty fileName\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"553f6eb5-480e-1c18-96ee-1534cb825c85","name":"Note: Guard Non-Empty fileName"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"c22ac9cb-f29a-ac94-de71-6d3be460b591","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"90c00380-a6a1-744b-af60-786ab4db4b21","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"682a1540-b642-a670-3b34-495afa323770","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"fc7ca436-f598-4c9c-f5a7-7e7cb5a74e68","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,1540],"id":"c720ebc6-5614-89e1-e74d-109d6acde6e3","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Parse receipts with Google Drive and PostgreSQL for your team\n\n**Pattern:** File Processing · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nParse receipts with Google Drive and PostgreSQL for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual summarization is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Export All Rows (PostgreSQL) → Serialize to CSV → Upload Backup to Google Drive → Backup Size Sane? → Sort Documents Newest First → Save Execution Metadata → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating summarization in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Scales without extra headcount\n- Standardizes the process every time\n\n## Before first run\nConnect credentials: Google OAuth2; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"404dda32-9f31-f026-f78f-400d6e5412c9","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"bb1445aa-9553-6a9d-2be7-2417398eb6be","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your summarization process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"a740b1ba-bf87-81eb-63d4-fc5e9abcab8a","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Export All Rows (PostgreSQL)","type":"main","index":0}]]},"Export All Rows (PostgreSQL)":{"main":[[{"node":"Serialize to CSV","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize to CSV":{"main":[[{"node":"Upload Backup to Google Drive","type":"main","index":0}]]},"Upload Backup to Google Drive":{"main":[[{"node":"Backup Size Sane?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backup Size Sane?":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}],[{"node":"Alarm — Empty Backup","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Guard Non-Empty fileName","type":"main","index":0}]]},"Guard Non-Empty fileName":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Alarm — Empty Backup":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"e23b1fb5-0f6a-478b-aa13-eef1244edb26","id":"FDX03611"}