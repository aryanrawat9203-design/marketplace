{"name":"Summarize documents with Google Sheets and Outlook 24/7","nodes":[{"parameters":{"httpMethod":"POST","path":"wf03154-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"0ef5589a-bc4a-4acb-bc06-a2eecc489969","name":"Receive Inbound Webhook","webhookId":"e252909e-1eba-4350-918c-09ac5c235a74"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"caadc812-d27c-4181-a6c7-30bccb86d19d","leftValue":"={{ $json.documentId || $json.fileName }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"f48c0d19-c53f-4764-9386-6c77beb8af4f","name":"Keep Valid Documents"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.fileName || JSON.stringify($json) }}","options":{"systemMessage":"You are a summarization specialist for the document processing team. Use the attached tools to look up real data before answering — never invent document details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"964f12fe-765a-4cbf-883e-f50f8085a502","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[621,970],"id":"dc82b07e-4661-4368-8854-a99fabe7a68a","name":"OpenAI Chat Model"},{"parameters":{"name":"score_helper","description":"Compute a quality score for a document record.","jsCode":"const j = JSON.parse(query);\nreturn String((j.signals || []).length * 10);"},"type":"@n8n/n8n-nodes-langchain.toolCode","typeVersion":1.3,"position":[621,1390],"id":"f0a2f814-a2bc-4508-98