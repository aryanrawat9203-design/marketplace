caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2ec0dcb6-a832-4241-a1d1-31c6337b80fa","leftValue":"={{ $json.fileName }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3618,400],"id":"b66f3904-564e-4d70-8d73-155348ee2b97","name":"Guard Non-Empty fileName"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3942,400],"id":"ec42e0e2-56d2-489c-a345-210509dff069","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"75936c02-55cf-4fa6-9ab8-38ebf77766c9","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b2548d17-8a9c-43bc-bbc1-7589f7594819","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"fc555caa-50f4-4dd4-a9f8-926e066c22a6","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"7d68998b-9814-4d6c-b8a7-c9c8d5bc11e8","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4590,400],"id":"012b3222-9379-4d97-a0cd-d00dc831deb4","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Extract from documents with Google Drive for your team — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,400],"id":"c4aa24a7-7b69-4a61-b7ee-2564cea25093","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"ef195ce2-c277-446f-aa6b-28acd3c2c0a5","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"9d764bef-bf04-44a0-99ca-4bfd9f8b3006","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"3836ec0a-1e8d-4754-9423-d98aebdafe14","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,1420],"id":"ea453682-c8ed-4e53-8a66-6cadcea2a019","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4590,1420],"id":"8d8e0dec-e582-47bc-831f-15350807dd8a","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Export All Rows (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"6de44e36-e006-fc27-69c2-8b4d6e6a9d1c","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Export All Rows (Google Sheets)\n\nReads every row from 'Document Tracker' — the read side of the store, e.g. for a digest or a downstream sync.\n\nPorts: ①→ Serialize to CSV · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"e12ee13c-f4e0-ae71-9368-b5e70396494e","name":"Note: Export All Rows (Google Sheets)"},{"parameters":{"content":"### Serialize to CSV\n\nSerializes items to a CSV binary file.\n\nNext: Compress Archive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"47f02271-28ce-72ce-f618-77ca63e03a9c","name":"Note: Serialize to CSV"},{"parameters":{"content":"### Compress Archive\n\nZips the binary to cut storage/transfer size before upload.\n\nNext: Upload Backup to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"cd55b57b-be6f-9ded-5cc9-c4beca294c3b","name":"Note: Compress Archive"},{"parameters":{"content":"### Upload Backup to Google Drive\n\nUploads the generated file to Google Drive as a timestamped archive copy.\n\nPorts: ①→ Backup Size Sane? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"8d389852-9327-8fc0-e9f5-3b2205b3a72a","name":"Note: Upload Backup to Google Drive"},{"parameters":{"content":"### Backup Size Sane?\n\nTwo-way gate on `={{ ($binary.data?.fileSize ?? 1) > 0 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Stamp Processing Time · ②→ Alarm — Empty Backup","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"44b042bf-cc9a-7ce8-db4f-12b9e5318ce4","name":"Note: Backup Size Sane?"},{"parameters":{"content":"### Alarm — Empty Backup\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"b437b6a8-283e-66d0-48dd-8ffe64cd63a9","name":"Note: Alarm — Empty Backup"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"59b3be45-bb55-088d-6864-ab3fb70c1a1c","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"c77a246f-a2dc-e887-3d2c-ee5a4f50dd3e","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Documents Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"dacdf023-7c77-d10f-f711-638f90003764","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"95537f58-86b5-be2a-f627-9e059c1bd416","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Guard Non-Empty fileName","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"8fb588c5-18ab-2423-5926-4d539e806f66","name":"Note: Align Field Names"},{"parameters":{"content":"### Guard Non-Empty fileName\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"1169dab8-f84a-894f-d1ef-54daa4c04f04","name":"Note: Guard Non-Empty fileName"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"d999c690-213e-12b2-e51b-c5e45443eb96","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"66e090e8-5771-22aa-09e1-d46f030a04ee","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\nAppends a new row to 'Document Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"14f641ee-3dd6-e636-bd98-74bdd180f6f2","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"f36b9337-7077-c5fa-f996-bc90311c3d08","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,1540],"id":"749c32e1-cfc5-930d-26aa-29ad85473c8a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"2ad73d0a-fbbc-8cb4-8c1b-794f63ff0feb","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Extract from documents with Google Drive for your team\n\n**Pattern:** File Processing · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nExtract from documents with Google Drive for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual summarization is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Export All Rows (Google Sheets) → Serialize to CSV → Compress Archive → Upload Backup to Google Drive → Backup Size Sane? → Stamp Processing Time → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating summarization in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Runs 24/7 in the background\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"5564fa9e-bcd9-210e-3a57-f89a66764f14","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe empty-backup check exists because a backup that silently 'succeeds' with zero rows is worse than an obvious failure — it gives false confidence right up until the day you actually need to restore. Compression runs before upload, not after, cutting both transfer time and storage footprint in the same step.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"9507773d-f69c-eab9-fd02-58164b3c09e7","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nYou've got the basics covered — push further:\n\n1. Point the export at an empty table on purpose and confirm the alarm fires.\n2. Turn off compression and compare the resulting backup file size.\n3. Add a retention step that deletes backups older than N days from the destination.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"26b0a7f0-0d1c-668a-532a-b63f230fcbb4","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"105643a3-57bb-7521-c01b-698d94784519","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your summarization process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"bc06395e-b531-16a3-89fa-5bda2dced4f2","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Export All Rows (Google Sheets)","type":"main","index":0}]]},"Export All Rows (Google Sheets)":{"main":[[{"node":"Serialize to CSV","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize to CSV":{"main":[[{"node":"Compress Archive","type":"main","index":0}]]},"Compress Archive":{"main":[[{"node":"Upload Backup to Google Drive","type":"main","index":0}]]},"Upload Backup to Google Drive":{"main":[[{"node":"Backup Size Sane?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backup Size Sane?":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}],[{"node":"Alarm — Empty Backup","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Guard Non-Empty fileName","type":"main","index":0}]]},"Guard Non-Empty fileName":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Alarm — Empty Backup":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Weekly Schedule":[{"json":{"documentId":"DOCP-330","fileName":"invoice_acme_q3.pdf","docType":"invoice","pageCount":2}},{"json":{"documentId":"DOCP-331","fileName":"contract_beta_nda.pdf","docType":"contract","pageCount":5}}]},"versionId":"d28775c6-7b94-457d-abc3-8c369c522827","id":"FDX03315"}