{"name":"Parse receipts with Google Drive and Notion hands-free","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":8,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"aeba1d01-72bb-4dcd-ab3c-fed5fbf124f9","name":"Daily Schedule"},{"parameters":{"operation":"download","fileId":{"__rl":true,"mode":"id","value":"={{ $json.id || $json.fileId }}"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[54,400],"id":"eb9656ff-0a1c-4556-9d26-1393cd2d0e12","name":"Download from Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.extractFromFile","typeVersion":1,"position":[378,400],"id":"1b38bb88-237a-465e-b8ed-a48d0851a32f","name":"Parse CSV Contents"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming document records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    documentId: String(j.documentId ?? j.id ?? '').trim(),\n    fileName: typeof j.fileName === 'string' ? j.fileName.trim() : j.fileName ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"22341c37-3e60-4cbc-a8a8-e60b4cc431af","name":"Clean & Reshape Rows"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f9e3fa1f-84fa-4fd8-8812-d4e9d7392a03","leftValue":"={{ $json.documentId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1026,400],"id":"b4d2776d-af2e-4a76-a281-862f6b50b4bf","name":"Rows Pass Validation?"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.fileName || $json.documentId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1350,880],"id":"3f349110-4ee4-45bf-b451-ca5c1c1e69dd","name":"Quarantine Bad Rows","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.fileName || $json.documentId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1674,400],"id":"c1ab3479-e1e3-46fc-9cc3-90119bf72b05","name":"Load Rows into Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[1998,400],"id":"ed10c8ad-9317-4032-bd09-c568c3b86549","name":"Save Execution Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"pageCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[2322,400],"id":"ef2fc7fb-a3c6-413e-a1b2-6ffd11343347","name":"Sort Documents Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"documentId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[2646,400],"id":"d125fae5-235f-4ea5-86eb-9ca5d16d2cce","name":"Align Field Names"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[2970,400],"id":"364742d9-0207-44cc-9fa0-21f0ed8a3615","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"e3014d00-26b6-4d23-8adc-58805671c95a","name":"pipeline","value":"Summarization","type":"string"},{"id":"9721ac37-d918-4e10-b15f-1cfb3722911d","name":"version","value":"2.0","type":"string"}]},"