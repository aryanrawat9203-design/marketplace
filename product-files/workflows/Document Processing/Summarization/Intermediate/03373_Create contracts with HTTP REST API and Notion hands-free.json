-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"0124c69a-36c4-4043-9abd-d49f7c0e74a0","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.fileName }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4590,400],"id":"dfbb063c-255a-40a3-a333-5db92e7efbe3","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"1064f1d3-08ff-4036-9a3d-3151aef18fba","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"930d3e70-4908-4a28-be63-501a89f17df2","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"71271860-ccaf-4e61-9d88-9650ff0e9e0f","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5238,400],"id":"9989bdbe-7cc9-487c-b167-b16f9e4c3a43","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.fileName || $json.documentId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5562,400],"id":"2f42031a-ab93-4bb1-9c49-37fe67cbb9a8","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5886,400],"id":"893acc5d-5bda-413b-8f03-54493e0a164e","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate"