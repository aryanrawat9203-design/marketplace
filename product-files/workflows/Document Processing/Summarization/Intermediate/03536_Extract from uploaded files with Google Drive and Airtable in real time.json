{"name":"Extract from uploaded files with Google Drive and Airtable in real time","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[5],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"cd97b90a-ddb2-4f2a-8fc4-da8fc2235c70","name":"Weekly Schedule"},{"parameters":{"resource":"fileFolder","searchMethod":"query","queryString":"={{ $json.searchTerm || '*' }}","returnAll":false,"limit":25,"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[54,400],"id":"4fb82021-f083-4b7f-9201-175d134eb37d","name":"List Changed Docs (Google Drive)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"documentId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"638fb1f9-be84-481c-b431-051fb774cd3c","name":"Remove Duplicate Documents"},{"parameters":{"operation":"download","fileId":{"__rl":true,"mode":"id","value":"={{ $json.id }}"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[702,400],"id":"a8a799cb-b8be-4cfd-adbf-d94834372680","name":"Download File Content","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"pdf","options":{}},"type":"n8n-nodes-base.extractFromFile","typeVersion":1,"position":[1026,400],"id":"d9ab615b-999d-4ba9-8a84-c42dcd64be26","name":"Extract Text from File"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Attach chunk-level metadata before embedding\nreturn $input.all().map((item, i) => ({\n  json: {\n    ...item.json,\n    chunkIndex: i,\n    sourceUrl: item.json.sourceUrl || item.json.url || 'internal',\n    ingestedAt: new Date().toISOString(),\n  },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1350,400],"id":"ef89e5aa-c827-4aea-8176-cfc37a1baf09","name":"Attach Chunk Metadata"},{"parameters":{"tableName":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"mode":"insert","options":{}},"type":"@n8n/n8n-nodes-langchain.vectorStoreSupabase","typeVersion":1.3,"position":[1674,400],"id":"6a135383-74e7-4ea8-951f-2db64c6d4c5e","name":"Insert into Vector Store","onError":"continueErrorOutput"},{"parameters":{"options":{"metadata":{"metadataValues":[{"name":"sourceUrl","value":"={{ $json.sourceUrl }}"}]}}},"type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","typeVersion":1,"position":[1674,970],"id":"681f73c1-dcf2-489b-b649-4e1ab66b2fc6","name":"Prepare Documents"},{"parameters":{"chunkSize":1200,"chunkOverlap":120,"options":{}},"type":"@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter","typeVersion":1,"position":[1674,1480],"id":"4061697e-4d63-4408-9b3f-3c4bdfc5284b","name":"Chunk with Overlap"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.embeddingsOpenAi","typeVersion":1.2,"position":[1917,970],"id":"74bd3656-2662-4ba4-afba-3f757cc0e9cc","name":"Document Embeddings"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[2241,400],"id":"9bb694de-3106-4485-b3ef-f25ce5b6b936","name":"Count Indexed Chunks"},{"parameters":{"operation":"search","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Processing Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Documents"},"filterByFormula":"={LastModified} > DATEADD(NOW(), -1, 'days')","options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2565,400],"id":"c215c033-e79f-47b4-b064-9b5373298880","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2889,400],"id":"771b5c17-6b83-4710-b9ef-c237dd2c375f","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.fileName }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3213,400],"id":"0c3cd14d-74ce-46fe-8722-0682984b98d2","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a68f1acc-5b06-4a77-b83f-e65d6b87b149","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9c9ee24a-7dc4-4342-8738-28ca5595911c","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3537,400],"id":"9c90dd02-b1b1-47ee-821f-eff7eef33db2","name":"Fold In Enrichment Fields"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Documents"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3861,400],"id":"ea360fc0-c1dc-4248-9851-b2988510ee16","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4185,400],"id":"afea7eff-3306-4bcf-b386-bbdd795047c7","name":"Record Sub-workflow Result"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4509,400],"id":"81f22f1d-caf7-4faf-ab8a-df9c94d70cab","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[4833,400],"id":"a36d865a-61f9-4fb6-8495-040cf1fb08ea","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per document (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.documentId, j.fileName].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5157,400],"id":"8363d0b5-4574-4b5f-ade2-16fc13c10a26","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5481,400],"id":"1337cf63-0e80-40fc-8ff3-54cd17b8fca0","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5805,400],"id":"0d45f79a-5f5a-4090-877a-45ba682b7cd2","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6129,400],"id":"4640e86b-628f-47c9-8158-d4ad0b506ef2","name":"Persist Run Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6453,400],"id":"bd8fcd7b-390a-43f0-99eb-3ffe4094b828","name":"Stamp Processing Time"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"pageCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[6777,400],"id":"bba8b5e7-752e-4c93-b62a-e7dc6fd939ec","name":"Sort Documents Newest First"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7101,400],"id":"066eda28-7673-4898-8aec-e5a4bc5ce31e","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"478e86d4-8074-4a0c-a187-ffa5c57d1a67","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"3713b6a8-e4ed-4025-920c-f247d042cb8d","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"3c928aa4-52ff-43da-a56f-7d87a6478347","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7425,400],"id":"0e6374b9-d959-4a36-b853-42ea4a48fe88","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.fileName || $json.documentId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[7749,400],"id":"62fe69cc-f009-4440-a23c-9076e03f45a1","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Extract from uploaded files with Google Drive and Airtable in real tim — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8073,400],"id":"d5e0feb9-64bc-4f0a-a948-6ee414c7e156","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"8ff0a541-6d9c-4940-a23b-216fb2041ac6","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"42409753-b68f-4ae2-a50d-406c53c85de1","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"bc648531-9768-4651-a7c2-482c3d8f4a66","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7425,1420],"id":"4b68c847-dc46-4ed8-b706-efbdd7606fa8","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7749,1420],"id":"87d7b5c3-4661-4ec6-bf3f-aff1d171cc50","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[8073,1420],"id":"79eadd04-b51b-4b1c-a680-4c98aaf37029","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: List Changed Docs (Google Drive)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ebcf5695-b508-6825-5848-fbc185248202","name":"Note: Weekly Schedule"},{"parameters":{"content":"### List Changed Docs (Google Drive)\n\ngoogleDrive — `fileFolder` operation against the connected account.\n\nPorts: ①→ Remove Duplicate Documents · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"48ee6dcb-eef4-feb2-6804-baa55ff2a6f3","name":"Note: List Changed Docs (Google Drive)"},{"parameters":{"content":"### Remove Duplicate Documents\n\nDrops duplicates within this run (compared on `documentId`).\n\nNext: Download File Content","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"e405ce42-72d0-3103-27f4-9100da1002fa","name":"Note: Remove Duplicate Documents"},{"parameters":{"content":"### Download File Content\n\ngoogleDrive — `download` operation against the connected account.\n\nPorts: ①→ Extract Text from File · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"79f51cc6-642d-3871-a291-684e8608d56d","name":"Note: Download File Content"},{"parameters":{"content":"### Extract Text from File\n\nParses the incoming PDF binary into JSON items.\n\nNext: Attach Chunk Metadata","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"733f7323-de88-4357-d47f-6e5dedcc34e0","name":"Note: Extract Text from File"},{"parameters":{"content":"### Attach Chunk Metadata\n\nCustom JavaScript: Attach chunk-level metadata before embedding\n\nNext: Insert into Vector Store","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"6de38f79-3b65-4637-8968-c0c15e226a97","name":"Note: Attach Chunk Metadata"},{"parameters":{"content":"### Insert into Vector Store\n\nWrites embedded chunks into the vector index.\n\nPorts: ①→ Count Indexed Chunks · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail · 🔑 Supabase URL + service key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"1a12c0de-02f0-2ec2-d71e-d104d1a522ab","name":"Note: Insert into Vector Store"},{"parameters":{"content":"### Prepare Documents\n\nWraps incoming items as documents (with metadata) for the vector store.\n\nFeeds **Insert into Vector Store** as `document`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1090],"id":"cd16081f-549d-4b7c-7675-3f1007a3ab9c","name":"Note: Prepare Documents"},{"parameters":{"content":"### Chunk with Overlap\n\nChunks documents (~1200 chars, 120 overlap) so retrieval hits stay focused.\n\nFeeds **Prepare Documents** as `textSplitter`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1600],"id":"46725823-4010-6250-2761-3311eb4dd501","name":"Note: Chunk with Overlap"},{"parameters":{"content":"### Document Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Insert into Vector Store** as `embedding`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,1810],"id":"0128e48f-a90f-e798-09ce-f3718f792a54","name":"Note: Document Embeddings"},{"parameters":{"content":"### Count Indexed Chunks\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"1bb1d958-001c-0f86-5580-fee56ebb79ff","name":"Note: Count Indexed Chunks"},{"parameters":{"content":"### Load Previous Snapshot\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"85d8e20a-77e7-8e2a-64b7-25995d8f4487","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"608baa04-b24a-cfe2-06ba-2c481c3fed7f","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"3abcba35-5164-ac78-960e-5c04bb02e693","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"04571e07-0bf7-9fb2-7ca8-961926419f18","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"d79f0e10-b78d-a9ae-0793-478b576bb3e7","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"679c23c0-9abb-9d9e-18e6-54d561fbfebb","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"abb36a31-f240-fc05-b1a8-21453c6a5385","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"2b9356f0-53b4-5d82-d631-58cc5e2c9307","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per document (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"e2583659-ae43-44ac-1326-bceaf951bd22","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"0fd20265-537a-313d-e3f7-f4ed526ae60a","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"3f6c93b1-6fae-44a9-168a-b4d4498c6b97","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"3642c134-8ffc-e3af-eb91-4b532428f846","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Sort Documents Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"174fe238-95de-a33c-84ba-d4cd955be812","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"445402f1-c79f-7f11-b400-59fd05936b52","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"bbfa619a-1f03-b22b-d0c8-466de3a705ab","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"2023fbc5-0ccb-912d-45a4-a6b2accf2e0f","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"37d1295a-cfeb-7d36-fab5-2b853399bda6","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"608e350c-b93b-6d27-f425-0499f448a7e3","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,1540],"id":"0b9c845b-a10c-5407-4e3e-db6732e61f7c","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,1540],"id":"131cd6d0-470c-8fa4-9aba-f601ecf5e772","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,1540],"id":"1714e38b-182e-d349-3f5b-c419399ef2cc","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Extract from uploaded files with Google Drive and Airtable in real time\n\n**Pattern:** File Processing · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nExtract from uploaded files with Google Drive and Airtable in real time. It runs automatically on a schedule.\n\n## Why it exists\nManual summarization is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → List Changed Docs (Google Drive) → Remove Duplicate Documents → Download File Content → Extract Text from File → Attach Chunk Metadata → Insert into Vector Store → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating summarization in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Scales without extra headcount\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2; Google OAuth2 / service account; Notion integration token; OpenAI API key.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"635c5475-ba1d-ac7b-fbc7-f2983597c8d8","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"16254d82-a633-3291-bb1c-308402828513","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"205c1d48-461c-0758-7253-af42db505aeb","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"40fb7f62-a185-5cf9-5a3d-9371c0c1b254","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your summarization process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"5811f2de-e0bd-3ebf-cca7-929c6942fb3f","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"List Changed Docs (Google Drive)","type":"main","index":0}]]},"List Changed Docs (Google Drive)":{"main":[[{"node":"Remove Duplicate Documents","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Remove Duplicate Documents":{"main":[[{"node":"Download File Content","type":"main","index":0}]]},"Download File Content":{"main":[[{"node":"Extract Text from File","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Extract Text from File":{"main":[[{"node":"Attach Chunk Metadata","type":"main","index":0}]]},"Attach Chunk Metadata":{"main":[[{"node":"Insert into Vector Store","type":"main","index":0}]]},"Prepare Documents":{"ai_document":[[{"node":"Insert into Vector Store","type":"ai_document","index":0}]]},"Chunk with Overlap":{"ai_textSplitter":[[{"node":"Prepare Documents","type":"ai_textSplitter","index":0}]]},"Document Embeddings":{"ai_embedding":[[{"node":"Insert into Vector Store","type":"ai_embedding","index":0}]]},"Insert into Vector Store":{"main":[[{"node":"Count Indexed Chunks","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count Indexed Chunks":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"02fccc2e-afbe-4514-8d13-9a34a36a8be9","id":"FDX03536"}