},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"bbf9ce6b-0e54-45be-8bd7-cb1978b83392","leftValue":"={{ $json.fileName }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3618,400],"id":"d84f9210-f575-4fd2-a069-b975aaf9cf98","name":"Guard Non-Empty fileName"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3942,400],"id":"7a2216ea-a099-4370-b70c-8785101c4ea0","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"b63d0e8b-2f65-47b1-a69c-93465983dcd3","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f371114f-a420-481d-9899-7df054ba625c","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"ff73025e-5f07-484d-a9ee-1805e1045cd1","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"c65cf582-7f05-4df9-8460-4cdcb325c455","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Processing Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Documents"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[4590,400],"id":"686db43c-5ad9-4aa9-bf93-32306ad2f9c1","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Extract from documents with Google Drive and Airtable end to end — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,400],"id":"c90e4feb-c422-49fa-bb63-d20468854c1a","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"32bff2a8-bc7a-4761-9508-42ce722218ed","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"e382776e-6e51-4135-8d9d-43a8eb64d5e8","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"7c73dc05-94ee-4f80-8718-43341dedaa85","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,1420],"id":"0fa2fbad-7867-48a3-9346-2ea1e3f94955","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4590,1420],"id":"15610adf-707c-4ebf-9b7b-c8a0a4b09e7a","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 1 h. No input data; downstream nodes fetch what they need.\n\nNext: Export All Rows (Airtable)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"cab63298-b156-7318-55d4-afe59cbec2c4","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Export All Rows (Airtable)\n\nSearches Airtable's 'Documents' table by formula (`={LastModified} > DATEADD(NOW(), -1, 'days')`) for records the pipeline hasn't handled yet.\n\nPorts: ①→ Serialize to CSV · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"aa1e94bd-beba-5d20-d87a-7aa5c74a69ab","name":"Note: Export All Rows (Airtable)"},{"parameters":{"content":"### Serialize to CSV\n\nSerializes items to a CSV binary file.\n\nNext: Compress Archive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"6fc88655-fff6-b350-5921-985f11feba25","name":"Note: Serialize to CSV"},{"parameters":{"content":"### Compress Archive\n\nZips the binary to cut storage/transfer size before upload.\n\nNext: Upload Backup to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"031bd848-fb73-638f-730a-921ae59befca","name":"Note: Compress Archive"},{"parameters":{"content":"### Upload Backup to Google Drive\n\nUploads the generated file to Google Drive as a timestamped archive copy.\n\nPorts: ①→ Backup Size Sane? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"f2d9687f-6b62-7b2f-df74-465d8189e503","name":"Note: Upload Backup to Google Drive"},{"parameters":{"content":"### Backup Size Sane?\n\nTwo-way gate on `={{ ($binary.data?.fileSize ?? 1) > 0 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Stamp Processing Time · ②→ Alarm — Empty Backup","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"6a60d041-63d5-3ded-16a7-daa8f7ae4165","name":"Note: Backup Size Sane?"},{"parameters":{"content":"### Alarm — Empty Backup\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"07d513a4-8944-e15e-623f-b296095fe3bc","name":"Note: Alarm — Empty Backup"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"9dbd0391-84ae-c6c9-2e41-f16ca517c2da","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Sort Documents Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"d6e303da-6e8d-b7a7-4139-a27ea7fbc2a1","name":"Note: Align Field Names"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"22a640f4-9b46-646d-638c-4ca2ab08a589","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"798f3988-34c1-44c4-65f6-cc5ed375c257","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Guard Non-Empty fileName","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"538f06bb-3c88-94bc-e10d-369f7e1a434e","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Guard Non-Empty fileName\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"d84a99f8-f24e-e7ad-1456-785c1e4b3010","name":"Note: Guard Non-Empty fileName"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"1bf122fb-b526-5572-4b58-fb88ef6dbfd0","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"5d5133a6-6297-9e08-06e5-a84f6d297454","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nCreates a new record in Airtable's 'Documents' table.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"fccccddc-8ac1-7831-1389-d76ca072943e","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"2b33cacf-1434-3210-2ff8-91e116500dc9","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,1540],"id":"50bab581-94bc-d65b-da7b-e0e93e825a6a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"ccf38bdd-3c24-e11a-3dde-1795753d2e5f","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Extract from documents with Google Drive and Airtable end to end\n\n**Pattern:** File Processing · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nExtract from documents with Google Drive and Airtable end to end. It runs automatically on a schedule.\n\n## Why it exists\nManual contracts is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Export All Rows (Airtable) → Serialize to CSV → Compress Archive → Upload Backup to Google Drive → Backup Size Sane? → Stamp Processing Time → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating contracts in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Has retries and error handling built in\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: Airtable PAT; Google OAuth2; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"4a771790-5961-e538-2ef5-9e482b9921f5","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe empty-backup check exists because a backup that silently 'succeeds' with zero rows is worse than an obvious failure — it gives false confidence right up until the day you actually need to restore. Compression runs before upload, not after, cutting both transfer time and storage footprint in the same step.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"35adcc2e-ead7-285b-8ae9-077cd149ae5e","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nYou've got the basics covered — push further:\n\n1. Point the export at an empty table on purpose and confirm the alarm fires.\n2. Turn off compression and compare the resulting backup file size.\n3. Add a retention step that deletes backups older than N days from the destination.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"408ab264-9960-c05a-825c-372e481e9053","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"230016b3-569b-0eba-3cf1-9e40d58915cd","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your contracts process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"e24b38e2-73be-b20d-f15b-b5d3ea9fa59e","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Export All Rows (Airtable)","type":"main","index":0}]]},"Export All Rows (Airtable)":{"main":[[{"node":"Serialize to CSV","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize to CSV":{"main":[[{"node":"Compress Archive","type":"main","index":0}]]},"Compress Archive":{"main":[[{"node":"Upload Backup to Google Drive","type":"main","index":0}]]},"Upload Backup to Google Drive":{"main":[[{"node":"Backup Size Sane?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backup Size Sane?":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}],[{"node":"Alarm — Empty Backup","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Guard Non-Empty fileName","type":"main","index":0}]]},"Guard Non-Empty fileName":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Alarm — Empty Backup":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Hourly Schedule":[{"json":{"documentId":"DOCP-330","fileName":"invoice_acme_q3.pdf","docType":"invoice","pageCount":2}},{"json":{"documentId":"DOCP-331","fileName":"contract_beta_nda.pdf","docType":"contract","pageCount":5}}]},"versionId":"7028dab8-db57-4435-8cbf-8d8b4261b81b","id":"FDX03164"}