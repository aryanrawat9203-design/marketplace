ue,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"6d4260bf-4f8a-4da1-90b3-c3502b27e1af","name":"Backup Size Sane?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🛑 Tonight's backup came out EMPTY — investigate immediately.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"f555d6ca-7c50-4722-9af5-541982b0f5bf","name":"Alarm — Empty Backup","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[1998,400],"id":"e3fcdf42-01c6-4145-9135-dd87d7ecc356","name":"Stamp Processing Time"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"documentId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[2322,400],"id":"81c9ada0-0fb8-43ab-a811-d3a54273e017","name":"Align Field Names"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"pageCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[2646,400],"id":"b5ee9b83-a844-4ec5-82a4-575c3d00bee8","name":"Sort Documents Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"ba5bc086-ee6d-4e6c-86d3-f3ecd750fd3f","name":"pipeline","value":"Contracts","type":"string"},{"id":"5312d63c-b5da-40e3-9ce8-0df6efc30840","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2970,400],"id":"9c331d89-f941-4549-817c-1ccc233ee827","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3294,400],"id":"1706e371-9ef6-447b-a95c-6751fcd1be61","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"8a0f18e0-cf9d-4084-800b-8d2013ed2898","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"77cc7e44-745e-47d0-9871-8f1cb4d1f78e","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"591148e7-fe82-4486-b458-4f0a4e479611","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"36cf1697-1161-4067-af59-7ad095a63bf2","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3942,400],"id":"6a01f6b0-d466-4697-acdc-0380ac317b7e","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Parse uploaded files with Google Drive with instant alerts — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,400],"id":"96ec696e-8a00-487c-a99f-28e484942b90","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"fc21763f-b5c3-4cbe-94d0-e91a9605b272","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"3ddb013c-ef98-4e27-aa6e-3b9b9207c191","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"34cf7769-eb29-428b-9f10-049b1e2b2b20","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,1420],"id":"1daa37e8-7436-4c00-942e-c2e2d18b5bc9","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3942,1420],"id":"83735c06-0af6-44ab-862d-cf8beefe78a6","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 8:00. No input data; downstream nodes fetch what they need.\n\nNext: Export All Rows (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"aee3b216-8440-c59a-c45b-de63faab7fd8","name":"Note: Daily Schedule"},{"parameters":{"content":"### Export All Rows (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Serialize to CSV · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"86620a79-853e-4721-c600-4dcb587feb1f","name":"Note: Export All Rows (Google Sheets)"},{"parameters":{"content":"### Serialize to CSV\n\nSerializes items to a CSV binary file.\n\nNext: Compress Archive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"d2b27abc-47d1-94f9-493b-e3ef204fdbf4","name":"Note: Serialize to CSV"},{"parameters":{"content":"### Compress Archive\n\nZips the binary to cut storage/transfer size before upload.\n\nNext: Upload Backup to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"6392b03c-7645-d6c8-0d05-2beed59b52dd","name":"Note: Compress Archive"},{"parameters":{"content":"### Upload Backup to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Backup Size Sane? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"fb6c6647-e14c-e562-a0d0-e59ef1568159","name":"Note: Upload Backup to Google Drive"},{"parameters":{"content":"### Backup Size Sane?\n\nTwo-way gate on `={{ ($binary.data?.fileSize ?? 1) > 0 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Stamp Processing Time · ②→ Alarm — Empty Backup","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"dd2f5d4b-0d8f-da32-f40f-fa9ede13fc97","name":"Note: Backup Size Sane?"},{"parameters":{"content":"### Alarm — Empty Backup\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"3ccfd39c-3263-58b1-e11c-347545df9b4c","name":"Note: Alarm — Empty Backup"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"658b6235-8fef-bf99-55bb-6234ee728b13","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Sort Documents Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"a442ba22-5c8a-6b69-4c69-113dbdae8f38","name":"Note: Align Field Names"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"e872ca86-6ac2-59ee-3db4-27ac1cd3439f","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"13150670-1e44-4e97-949c-255b00c8303d","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"5c1f5eb2-0705-f34b-e1ea-c33318bb6957","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"a06ec4e7-1970-4b31-2f08-d95bd811eccf","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"57594d69-efd9-32c1-ee13-cf81584d4355","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"7437b900-a62f-e828-973e-2dc70fdb7e68","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,1540],"id":"eb68b2c5-8627-8a27-f506-df5936a89977","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"acf980f1-38dd-da17-7078-c9ee73e1adac","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Parse uploaded files with Google Drive with instant alerts\n\n**Pattern:** File Processing · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nParse uploaded files with Google Drive with instant alerts. It runs automatically on a schedule.\n\n## Why it exists\nManual contracts is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Export All Rows (Google Sheets) → Serialize to CSV → Compress Archive → Upload Backup to Google Drive → Backup Size Sane? → Stamp Processing Time → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating contracts in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Has retries and error handling built in\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"d664b5e8-9678-d0a1-1841-7e3ac464a981","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"aca8a4fa-afa5-5796-4475-e18943439436","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your contracts process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"61c3540c-bf93-bd92-6153-1191edcb129c","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Export All Rows (Google Sheets)","type":"main","index":0}]]},"Export All Rows (Google Sheets)":{"main":[[{"node":"Serialize to CSV","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize to CSV":{"main":[[{"node":"Compress Archive","type":"main","index":0}]]},"Compress Archive":{"main":[[{"node":"Upload Backup to Google Drive","type":"main","index":0}]]},"Upload Backup to Google Drive":{"main":[[{"node":"Backup Size Sane?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Backup Size Sane?":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}],[{"node":"Alarm — Empty Backup","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Alarm — Empty Backup":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"80857cbd-9ebb-43de-837e-b670841c8f8b","id":"FDX03643"}