inator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[945,400],"id":"513be12c-f0c9-45df-b6e8-36c9c233cd58","name":"All Required Fields Found?"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["documentId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1269,160],"id":"8ca160ab-684a-4e3f-b023-4e4c202b0a73","name":"Upsert into Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✍️ Extraction incomplete for {{ $json.fileName || 'document' }} — please review.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,760],"id":"10e5e221-3560-4351-a3de-41bb32f88e1a","name":"Queue for Manual Review","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2241,400],"id":"c890d29f-fa16-4542-a88b-c9d049c426b1","name":"Merge Review Paths"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3213,400],"id":"899f64a5-714e-4b9f-80b6-596a7f82a7d8","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"8928d65f-8a52-44d0-bf3d-b7963341abcc","name":"pipeline","value":"Contracts","type":"string"},{"id":"9878a151-45ad-4b6e-b1ea-0fc69962cc1b","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3537,400],"id":"4106156c-84e2-4b00-bf24-26f6