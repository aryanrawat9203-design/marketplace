{"name":"Summarize long emails with Notion and Gmail","nodes":[{"parameters":{"httpMethod":"POST","path":"wf03217-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"73850095-8305-422e-825d-9e3a97eaf025","name":"Receive Inbound Webhook","webhookId":"71b81781-e11f-4c37-b877-6d997a91492b"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6fc23b84-5a50-4c8f-9a2a-213d793b7814","leftValue":"={{ $json.fileName }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"d31824a4-97b3-4233-9ed5-c0b450dff177","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'fileName' on incoming document."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"4a2f0294-1d08-47aa-bb51-9bcace8daf6f","name":"Abort — Malformed Input"},{"parameters":{"inputText":"={{ $json.fileName || JSON.stringify($json) }}","options":{}},"type":"@n8n/n8n-nodes-langchain.sentimentAnalysis","typeVersion":1,"position":[378,400],"id":"86410a3a-0f37-4daf-8d1f-b8375096764f","name":"Detect Sentiment","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[621,970],"id":"8964df84-1e30-4eb0-a219-4585e0ab35fc","name":"Groq Chat Model"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=😠 Negative document: {{ $json.fileName }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[945,-80],"id":"3b331bda-43a0-4355-af5e-eee2f1ea0068","name":"Escalate Negative — Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1269,400],"id":"afbca9bb-ae95-4410-84b1-385c54c7d4e0","name":"Log Neutral Feedback","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=💚 Positive feedback received: {{ $json.fileName }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,880],"id":"a698d4f4-c59a-4d16-8329-3a04e09bd775","name":"Thank the Sender","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2565,400],"id":"d93fd60f-a82e-465f-911a-6b4eecf07de2","name":"Collect All Outcomes"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.fileName }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3861,400],"id":"68850995-8cfe-4060-995d-46dd30214b7e","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3829f054-e612-49e8-bc97-df9770794809","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"56ddbf94-0d4c-4935-8962-d6f6fcb937a6","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4185,400],"id":"40804427-9ae6-4932-aac