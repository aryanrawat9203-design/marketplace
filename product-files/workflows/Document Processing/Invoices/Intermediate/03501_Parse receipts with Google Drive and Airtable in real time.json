":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"8b42c4bd-9ae2-4d58-a7f2-87a36904419d","name":"Backup Size Sane?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🛑 Tonight's backup came out EMPTY — investigate immediately.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"e30852e1-83f4-46c0-956c-8ae06e212561","name":"Alarm — Empty Backup","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.fileName }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1998,400],"id":"69e5f091-b7c6-42cc-9dbe-fc728285bdbe","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"0c7eb983-1602-4152-aae6-ab15bf31b519","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"abbc620e-9ac7-4055-bd8c-1691889b9dac","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2322,400],"id":"95997d94-2201-49ed-8915-62e538f7f748","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2646,400],"id":"97f060e7-46ec-4d97-aa92-97c7b38e53d1","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2970,400],"id":"3ba295a8-f7d9-4b4e-a96d-b899dce93c7f","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3294,400],"id":"77199ca8-5021-4e59-8c77-be49100b2d6d","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[3618,400],"id":"21d9c06e-2729-49ad-a1e3-5d10299e3964","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per document (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.documentId, j.fileName].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"eaf11350-fedd-426e-b85b-8494efeee680","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4266,400],"id":"60f0e4fa-e715-4555-9e67-9421ecaff7aa","name":"Drop Already-Processed Items"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Documents"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[4590,400],"id":"251961f8-75aa-4501-ba80-f6a1fc4f075c","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"b8989e9e-3c5f-49e5-a98f-e1d00fdfa0fd","name":"Record Sub-workflow Result"},{"parameters":{"operation":"search","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Processing Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Documents"},"filterByFormula":"={LastModified} > DATEADD(NOW(), -1, 'days')","options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[5238,400],"id":"ea8ed184-f3b0-4164-a8c6-d09d7ec50140","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"34fbbc25-271a-475c-82b5-13ae1d90d189","name":"Compute Drift vs Snapshot"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"576fb271-9b56-4636-88ab-484a5dab286a","leftValue":"={{ $json.fileName }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[5886,400],"id":"56d3aa5b-e93e-4704-879a-36b3800a7855","name":"Guard Non-Empty fileName"},{"parameters":{"dataToSave":{"values":[{"key":"documentId","value":"={{ $json.documentId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6210,400],"id":"271d090a-799b-47ce-890a-7998d41ea389","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"bf4f1c7e-ade3-4311-9f8c-2588bad52d72","name":"pipeline","value":"Invoices","type":"string"},{"id":"60575838-4587-4893-a372-f49306cce4ef","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6534,400],"id":"043997fa-f5db-45f4-a6b8-c20499e6b873","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"pageCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[6858,400],"id":"3957e8dc-3e26-4cfa-a436-b22b196bd57e","name":"Sort Documents Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"documentId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7182,400],"id":"d4f1236b-d25e-4ca4-98cd-b210ad102bcb","name":"Align Field Names"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7506,400],"id":"a5c4c3d3-5713-4677-84ba-8fd2b033f9de","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"4e5e9d19-d35f-4dd0-b135-aa4a19f88769","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"24e12f76-834e-493d-8031-59562c0f76a8","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"d2fe6ea5-92ea-48e1-b959-f693708fac02","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7830,400],"id":"fbfd87f0-69ce-43d7-8a69-73ef54345f43","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cac