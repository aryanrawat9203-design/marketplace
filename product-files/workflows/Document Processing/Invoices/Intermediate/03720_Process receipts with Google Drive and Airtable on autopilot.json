":"string"},{"id":"49fa5425-3458-41db-a3ad-098180defb1b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,1420],"id":"6e105795-16f3-41a5-9179-08f0ab86634c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8478,1420],"id":"ffccfd8d-7357-40df-b312-68f09bf1696c","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[8802,1420],"id":"7dc3b279-179d-41be-99ce-1587bdfb61ac","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Download from Google Drive","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"4bcf03b3-e04d-b611-fe48-68bbdcca45fb","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Download from Google Drive\n\nDownloads the file's binary content from Google Drive so the next node can parse it.\n\nPorts: ①→ Parse XLSX Contents · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"202b67b7-7c4e-8bab-1834-d88193c8a883","name":"Note: Download from Google Drive"},{"parameters":{"content":"### Parse XLSX Contents\n\nParses the incoming XLSX binary into JSON items.\n\nNext: Clean & Reshape Rows","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"2d671eda-6513-43fe-c2a8-30fffbaab8b9","name":"Note: Parse XLSX Contents"},{"parameters":{"content":"### Clean & Reshape Rows\n\nCustom JavaScript: Normalize incoming document records to a stable schema\n\nNext: Rows Pass Validation?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"38445c65-9923-a6a4-d9ef-46078155d0f1","name":"Note: Clean & Reshape Rows"},{"parameters":{"content":"### Rows Pass Validation?\n\nTwo-way gate on `={{ $json.documentId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Load Rows into Google Sheets · ②→ Quarantine Bad Rows","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"9b4b2ea8-0f11-4148-5cd6-3ef51e8135a0","name":"Note: Rows Pass Validation?"},{"parameters":{"content":"### Quarantine Bad Rows\n\nCreates a new record in Airtable's 'table' table.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"5e39e20d-3eea-7cf2-15e6-9a216b559770","name":"Note: Quarantine Bad Rows"},{"parameters":{"content":"### Load Rows into Google Sheets\n\nUpserts a row into 'Document Tracker', matched on `documentId` — re-running with the same key updates the row instead of duplicating it.\n\nPorts: ①→ Repack as XLSX · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"389f319b-ca58-86e3-435c-85a9ef4b219d","name":"Note: Load Rows into Google Sheets"},{"parameters":{"content":"### Repack as XLSX\n\nSerializes items to a XLSX binary file.\n\nNext: Archive Processed File (Google Drive)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"eedc693a-f5db-0f10-1e5c-c20bc46b4681","name":"Note: Repack as XLSX"},{"parameters":{"content":"### Archive Processed File (Google Drive)\n\nUploads the generated file to Google Drive as a timestamped archive copy.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"166fb7bd-7f4f-3120-8fa4-5debc9684d06","name":"Note: Archive Processed File (Google Drive)"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"15b41904-d7fb-af39-f9b9-3c6416881d26","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"650e2f09-0260-4e0f-23a7-1b15c09adb23","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Load Previous Snapshot\n\nReads every row from 'Document Tracker' — the read side of the store, e.g. for a digest or a downstream sync.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"3465663a-5766-d5fc-1759-1d1068a1b81d","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"a04b6d9c-59a7-873d-5068-57615c4e8e1e","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"5eb729bd-6938-75c0-f5cf-06ec639e5bd9","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"1071eced-7c07-1385-eebe-4d1efcf0aa34","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per document (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"90df8d8a-8247-394c-7244-7a6b54b76ed6","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"bc0565ad-7b47-10f1-1877-30a140b26f85","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"7c27897c-16b6-efef-b8a4-17b652759997","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"2fc534f7-d72f-9074-b403-43a9de3dc368","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"51ce3869-0f74-df77-8f14-52ef77e6655c","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\nUploads the generated file to Google Drive as a timestamped archive copy.\n\nPorts: ①→ Cap Batch Volume · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"863710a0-1663-35a6-17ab-e1a0b16e4407","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"1e1ff818-1ca7-3a08-865b-1b0824ca1d66","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Guard Non-Empty fileName","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"6bbfa5b4-ac2a-3354-bff0-b3b7122cf398","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Guard Non-Empty fileName\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"c20745be-dfcc-d3de-55d3-91aa1415b662","name":"Note: Guard Non-Empty fileName"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Sort Documents Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"8860fcfd-e150-e293-7e4a-3fb736f48b0e","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"aac41dff-942f-00ae-3f0b-7cab74d85ef8","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"4232416c-4d53-8167-6fe1-c550d341f4f3","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nCreates a new record in Airtable's 'Documents' table.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"16159189-3a3f-d804-3531-ab8add0222a8","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"6f8b380a-a950-5279-9810-74809c3cc82d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,1540],"id":"e81934c9-2d1f-7fff-079f-cfeb08512e62","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#docs`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,1540],"id":"8ee63398-dd3c-6fea-eb9e-473ba42351c7","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nAppends a new row to 'Document Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,1540],"id":"013b126f-6e04-e66f-2756-74e8a3d56ccf","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Process receipts with Google Drive and Airtable on autopilot\n\n**Pattern:** File Processing · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nProcess receipts with Google Drive and Airtable on autopilot. It runs automatically on a schedule.\n\n## Why it exists\nManual invoices is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Download from Google Drive → Parse XLSX Contents → Clean & Reshape Rows → Rows Pass Validation? → Load Rows into Google Sheets → Repack as XLSX → …\n\n## Use it for\n- Teams that want to file processing without manual effort\n- Anyone automating invoices in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Improves response time\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"38cd8666-322b-6e50-d6e4-15a4c568624d","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nBad rows are quarantined into their own store, not dropped silently and not allowed to break the whole batch — one malformed row in a 10,000-row file shouldn't stop the other 9,999 from loading, but it also shouldn't vanish without a trace.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"a4835a6f-4ece-101d-9e50-c44541716118","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAbout as deep as this pattern goes — extend it:\n\n1. Feed it a file with a few deliberately malformed rows and confirm they land in quarantine, not the main store.\n2. Switch the source format (e.g. csv to xlsx) and see how little actually has to change.\n3. Turn on archive mode and confirm the processed file gets repacked and stored.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"b9ff5077-ea85-0082-d987-5c38a8030350","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"3f7f8503-8c41-3e93-ebc0-4045503c709e","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"8cd0b81e-c06b-2ab6-7375-63e0917b2121","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your invoices process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"ca98afc3-7632-3e62-5551-34d69c83cd84","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Download from Google Drive","type":"main","index":0}]]},"Download from Google Drive":{"main":[[{"node":"Parse XLSX Contents","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Parse XLSX Contents":{"main":[[{"node":"Clean & Reshape Rows","type":"main","index":0}]]},"Clean & Reshape Rows":{"main":[[{"node":"Rows Pass Validation?","type":"main","index":0}]]},"Rows Pass Validation?":{"main":[[{"node":"Load Rows into Google Sheets","type":"main","index":0}],[{"node":"Quarantine Bad Rows","type":"main","index":0}]]},"Load Rows into Google Sheets":{"main":[[{"node":"Repack as XLSX","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Repack as XLSX":{"main":[[{"node":"Archive Processed File (Google Drive)","type":"main","index":0}]]},"Archive Processed File (Google Drive)":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Guard Non-Empty fileName","type":"main","index":0}]]},"Guard Non-Empty fileName":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Quarantine Bad Rows":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Weekly Schedule":[{"json":{"documentId":"DOCP-330","fileName":"invoice_acme_q3.pdf","docType":"invoice","pageCount":2}},{"json":{"documentId":"DOCP-331","fileName":"contract_beta_nda.pdf","docType":"contract","pageCount":5}}]},"versionId":"a0486472-a732-4ff9-9e8e-8f52c6b8d7d9","id":"FDX03720"}