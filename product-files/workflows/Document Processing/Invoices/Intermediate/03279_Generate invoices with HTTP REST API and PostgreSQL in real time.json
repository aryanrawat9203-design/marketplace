    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO documents (documentId, fileName, docType, updated_at)\nVALUES ($1, $2, $3, NOW())\nON CONFLICT (documentId) DO UPDATE SET updated_at = NOW();",
