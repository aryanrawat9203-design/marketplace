":true,"mode":"list","value":"","cachedResultName":"Document Processing Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Documents"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[4833,400],"id":"f25cffbb-b0cd-4add-bfa8-10197ec38dd7","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#docs","cachedResultName":"#docs"},"text":"=✅ Distill long emails with Airtable and Microsoft Teams end to end — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5157,400],"id":"a74875c1-59d3-4a47-917e-e575efb8698f","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"0609b40f-ee23-4e90-b866-1c99a452358d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"2f1e62e8-a413-4be6-9016-a2e315c0846f","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"80f0d379-cf56-459b-b0e7-c9c7da1250e7","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4509,1420],"id":"84fe27d7-9979-4cfa-914c-3e96e4edd804","name":"Capture Failure Context"},{"parameters":{"resource":"chatMessage","chatId":"OPS_TEAM_CHAT_ID","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.microsoftTeams","typeVersion":2,"position":[4833,1420],"id":"ec63478d-a5c2-4a6b-b8d6-74c9469affc8","name":"Escalate Failure to Microsoft Teams","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf03455-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Stamp & Shape Document","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"a6e2471b-9c27-b88a-13aa-a686e8d14aa0","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Stamp & Shape Document\n\nShapes the item: writes `documentId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"4413b3f4-8b2b-dfdf-70b9-40a8e700a7dd","name":"Note: Stamp & Shape Document"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.documentId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Classify with AI · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"90343222-f292-d7a0-a300-cdff141ea511","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nairtable — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"fa9e7e94-d303-0f1c-7ead-e494ff3d2a8d","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Classify with AI\n\nLLM classification into: Action Needed, Reference, Ignore (+fallback). Output port order matches this list.\n\nPorts: ①→ Store as Action Needed · ②→ Store as Reference, Capture Failure Context · ③→ Store as Ignore · ④→ Alert Microsoft Teams — Other\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"2f4dd130-19d9-1103-2feb-e9d066b31d5e","name":"Note: Classify with AI"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Classify with AI** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"f2be30df-3e34-772d-cc2a-a4e8f24ba2e0","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Store as Action Needed\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,40],"id":"8bdcd2aa-01c0-d7b5-bb0f-83cfd94d3bf3","name":"Note: Store as Action Needed"},{"parameters":{"content":"### Store as Reference\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,490],"id":"ba9ac372-14ba-0e92-7a17-c47cf23b54b8","name":"Note: Store as Reference"},{"parameters":{"content":"### Store as Ignore\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,940],"id":"fc25a367-3efb-8f68-971a-295dcd160f4c","name":"Note: Store as Ignore"},{"parameters":{"content":"### Alert Microsoft Teams — Other\n\nmicrosoftTeams — `chatMessage` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,1390],"id":"960986dc-1ba3-f019-af1a-ef69b0634e9d","name":"Note: Alert Microsoft Teams — Other"},{"parameters":{"content":"### Reunite Branches\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"3ffe239b-3808-4be8-2e69-8de3136018d7","name":"Note: Reunite Branches"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Guard Non-Empty fileName","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"5684ac15-4984-6a23-924c-288a613e9a95","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Guard Non-Empty fileName\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"c29b3b2e-e0e5-3f8b-8d20-ee662e8bbc36","name":"Note: Guard Non-Empty fileName"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"9073565c-6f65-a7d8-e2b0-c1e10b448082","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"66bf40b5-7cbc-d916-8fa7-ebe448401879","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"71474cbf-88dd-b68f-1e4e-9c03491593e9","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Microsoft Teams","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,1540],"id":"8d1ce287-114e-537d-8b30-5f3c5b00e61c","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Microsoft Teams\n\nmicrosoftTeams — `chatMessage` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Microsoft OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,1540],"id":"8245901f-be3a-e2c6-2e6e-fa9308639d3f","name":"Note: Escalate Failure to Microsoft Teams"},{"parameters":{"content":"# Distill long emails with Airtable and Microsoft Teams end to end\n\n**Pattern:** AI Summarize & Route · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nDistill long emails with Airtable and Microsoft Teams end to end. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual invoices is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Stamp & Shape Document → Payload Valid? → Classify with AI → Store as Action Needed → Reunite Branches → Cap Batch Volume → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating invoices in legal\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Runs 24/7 in the background\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: Airtable PAT; Google AI API key; Microsoft OAuth2; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"2317f833-54e1-3199-3aef-66881a826bd0","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"e6ca3b9a-cad1-d9e0-0458-851b030dba36","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"d5b7c62d-8a25-3e4b-d99a-56d8ca4c9d9f","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"0f4f44be-7e90-0bda-f2ac-45ea95fdd2a5","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your invoices process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-500],"id":"1926e0aa-3632-3658-fa92-c6ed63e504a1","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Stamp & Shape Document","type":"main","index":0}]]},"Stamp & Shape Document":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Classify with AI","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Classify with AI","type":"ai_languageModel","index":0}]]},"Classify with AI":{"main":[[{"node":"Store as Action Needed","type":"main","index":0}],[{"node":"Store as Reference","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Store as Ignore","type":"main","index":0}],[{"node":"Alert Microsoft Teams — Other","type":"main","index":0}]]},"Store as Action Needed":{"main":[[{"node":"Reunite Branches","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Reference":{"main":[[{"node":"Reunite Branches","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Ignore":{"main":[[{"node":"Reunite Branches","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Alert Microsoft Teams — Other":{"main":[[{"node":"Reunite Branches","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Reunite Branches":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Guard Non-Empty fileName","type":"main","index":0}]]},"Guard Non-Empty fileName":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Microsoft Teams","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"02a04385-4fbf-4c26-b9e4-37560e8d170e","id":"FDX03455"}