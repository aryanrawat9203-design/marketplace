              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "e6c721b8-5282-4fd3-8922-92227b74624e",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "01913db5-e22a-4fef-b335-223141e94d7c",
