            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "d1b4a2f2-9950-48f3-b38e-940333a93bc9",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
