          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "790fa5c1-f04c-4d77-b704-788b41ac9887",
              "leftValue": "={{ $json.type }}",
              "rightValue": "active",
              "operator": {
                "type": "string",
