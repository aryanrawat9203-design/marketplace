{"name":"Watch a key metric with HTTP / REST API and Slack at scale","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":30}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"061ee176-94cf-4d1f-b87f-9a67145f65da","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://service-a.example.com/healthz","options":{"timeout":10000,"response":{"response":{"fullResponse":true,"neverError":true}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,130],"id":"828f0d27-add9-4e7e-947e-4e6a6c175d9e","name":"Probe Endpoint A","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"method":"GET","url":"https://service-b.example.com/healthz","options":{"timeout":10000,"response":{"response":{"fullResponse":true,"neverError":true}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[378,640],"id":"a37312c6-33f4-407b-a777-7c905deada64","name":"Probe Endpoint B","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"method":"GET","url":"https://service-c.example.com/healthz","options":{"timeout":10000,"response":{"response":{"fullResponse":true,"neverError":true}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,1150],"id":"801e4e8f-dc90-4796-b714-9889a0f75429","name":"Probe Endpoint C","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1350,400],"id":"e1c18652-072b-45aa-9378-9e030ad30e8d","name":"Combine Probe Results"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"73479064-8528-46fb-862c-be08b66c9084","leftValue":"={{ ($json.statusCode || 200) < 400 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[2322,400],"id":"a4398696-961b-4b5b-84d8-d2c4db164be5","name":"All Healthy?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,160],"id":"769277b8-5015-4ccc-86f4-652b7cb9258b","name":"Record Uptime Metric","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.url || 'probe' }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2970,760],"id":"7f9d4a13-2e8e-4f17-a690-e3b8bd3904bb","name":"Already Alerted? (State Check)"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#reporting","cachedResultName":"#reporting"},"text":"=🔴 Health check failed: {{ $json.url || 'endpoint' }} → {{ $json.statusCode }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3618,760],"id":"984391f4-a0be-45d7-b662-5b569995099c","name":"Page On-Call via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4590,400],"id":"d93f75a3-c68b-42f2-ad04-0a5cd7f48928","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"efcc6764-c40d-4c8b-a5e6-cadca0a591ee","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5238,400],"id":"7392613d-69d1-4764-aa16-e752bc75342e","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"010d023f-6c2b-4d6b-ad84-0c34ff08c7ae","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per metric (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.reportId, j.kpi].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5886,400],"id":"14f9a29d-f88c-4a7d-8fa5-e90a759404a4","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6210,400],"id":"0804b1bc-dd25-4142-a646-6e95addbad90","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.kpi }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6534,400],"id":"f8df812e-1202-438b-88f9-5f6f577f4952","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"65772d5d-6b9d-48a2-96b7-03ff9eadf229","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c09c654c-bc63-4ec2-91bc-9acb1d2a4d63","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"a028f816-1bc7-4f7c-9e83-8ddf48330dde","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"79419073-fc4d-4a14-b3b6-80cbdedc6505","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9958433f-c971-44ce-9a1c-b68ec9982ca7","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"ef7520b4-957e-477c-9bb6-a18a10a02349","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"703166b5-150d-42bd-8b7c-9a7968fa39d3","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7506,400],"id":"1963e4cb-ff91-4ff3-8817-11265d499812","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#reporting","cachedResultName":"#reporting"},"text":"=✅ Watch a key metric with HTTP / REST API and Slack at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7830,400],"id":"615bff29-2f11-4487-bb9f-8448b908079d","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"45de3f31-8f6c-44dc-96d2-2c2ca2d683ce","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"e2aa703f-9c0c-4759-9620-8d45c6c53acf","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"9d7c38a5-7853-4b2c-a43d-7d3757e85eb6","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,1420],"id":"5acf7346-23f4-4b5f-9f5f-42e6ef377a80","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#reporting","cachedResultName":"#reporting"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7506,1420],"id":"e38a700a-3e86-4203-b080-76d61ed225fa","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7830,1420],"id":"044bdee8-45dc-42bb-b93b-443ee357e7d4","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Every Few Minutes\n\nStarts the workflow on a timer — every 30 min. No input data; downstream nodes fetch what they need.\n\nNext: Probe Endpoint A","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"3a8b2ab1-e3f9-1112-6520-8fb5641b146d","name":"Note: Every Few Minutes"},{"parameters":{"content":"### Probe Endpoint A\n\nGET https://service-a.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"99e5a685-d9dd-a659-2307-cdf8a7ff4911","name":"Note: Probe Endpoint A"},{"parameters":{"content":"### Probe Endpoint B\n\nGET https://service-b.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,760],"id":"0a09a7c0-bc9d-355f-2f71-14f3ca986304","name":"Note: Probe Endpoint B"},{"parameters":{"content":"### Probe Endpoint C\n\nGET https://service-c.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1270],"id":"a833cbf4-618c-5043-afee-0263d5d827df","name":"Note: Probe Endpoint C"},{"parameters":{"content":"### Combine Probe Results\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: All Healthy?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"95f60960-d656-b917-0844-edce670315fa","name":"Note: Combine Probe Results"},{"parameters":{"content":"### All Healthy?\n\nTwo-way gate on `={{ ($json.statusCode || 200) < 400 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Record Uptime Metric · ②→ Already Alerted? (State Check)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"b449876a-2882-1894-a572-ee2f26be0c24","name":"Note: All Healthy?"},{"parameters":{"content":"### Record Uptime Metric\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,280],"id":"11f55b3c-f2aa-f925-c030-6f8b16253450","name":"Note: Record Uptime Metric"},{"parameters":{"content":"### Already Alerted? (State Check)\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Page On-Call via Slack","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,880],"id":"ccba830e-d972-a983-f6df-d555605ee1c7","name":"Note: Already Alerted? (State Check)"},{"parameters":{"content":"### Page On-Call via Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,880],"id":"376a9745-417f-7953-178a-9a2c53925ac4","name":"Note: Page On-Call via Slack"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"8e639887-b306-6312-10ca-aa01035cc590","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"cd4d0685-dfc9-af8d-2c68-e11cf592e026","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"95690d18-b906-ac04-dac3-cb14865aadd1","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"7b191ed7-f337-5a4b-39f6-459db63f45fd","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per metric (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"5bcc8f19-a21e-e667-8793-109e62885113","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"41ab5da4-c716-c0a9-4268-a3b52cb2ff89","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"9dcdab25-3067-0ee1-46af-f25a1c4d7a82","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"d5e71671-7f59-1a67-e893-e5bf3785198e","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"ccb8ee18-c236-fe20-9858-16abfa45a740","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"1c2cf8d2-2f06-9922-e3a0-2fd8ac019633","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"8821f6ed-5428-e86a-57dc-9394b21d6100","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"dd76da10-9a34-6c70-aacf-fc3c58e21361","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"f7b5d3b3-9537-c3ca-d0c0-50e98b15a0b8","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,1540],"id":"08b38d97-02b9-6a14-44bd-7ffe7e395e8c","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Watch a key metric with HTTP / REST API and Slack at scale\n\n**Pattern:** Threshold Monitoring · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nWatch a key metric with HTTP / REST API and Slack at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual alerts is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nEvery Few Minutes → Probe Endpoint A → Combine Probe Results → All Healthy? → Record Uptime Metric → Load Previous Snapshot → Compute Drift vs Snapshot → …\n\n## Use it for\n- Teams that want to threshold monitoring without manual effort\n- Anyone automating alerts in data\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Standardizes the process every time\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"615ad996-742f-3d9c-4f8c-37284a08dd58","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"b5112009-e998-3372-e199-63a25508187a","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"472c2ae4-3083-7689-21af-b6c93ad69d8c","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your alerts process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"7f21b8c7-7e39-272c-efd9-02ce6fc7b439","name":"🛠 Customize me"}],"connections":{"Every Few Minutes":{"main":[[{"node":"Probe Endpoint A","type":"main","index":0},{"node":"Probe Endpoint B","type":"main","index":0},{"node":"Probe Endpoint C","type":"main","index":0}]]},"Probe Endpoint A":{"main":[[{"node":"Combine Probe Results","type":"main","index":0}]]},"Probe Endpoint B":{"main":[[{"node":"Combine Probe Results","type":"main","index":1}]]},"Probe Endpoint C":{"main":[[{"node":"Combine Probe Results","type":"main","index":2}]]},"Combine Probe Results":{"main":[[{"node":"All Healthy?","type":"main","index":0}]]},"All Healthy?":{"main":[[{"node":"Record Uptime Metric","type":"main","index":0}],[{"node":"Already Alerted? (State Check)","type":"main","index":0}]]},"Already Alerted? (State Check)":{"main":[[{"node":"Page On-Call via Slack","type":"main","index":0}]]},"Record Uptime Metric":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"