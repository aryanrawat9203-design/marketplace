{"name":"Alert on spend with HTTP / REST API and Gmail hands-free","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":30}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"a9fa10c5-7b46-4aef-a3e5-0e224c5254f4","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/metrics","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"4d30428e-a322-4a88-b89f-28c966213002","name":"Fetch Current Metrics","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each metric 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.kpi) score += 20;\n  if (j.value) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"14a0c32d-7477-4610-8e19-42a0fa2ed456","name":"Compute Severity Signals"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"991ab0e9-e84a-4edc-8af2-8ac36cf17fbb","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":40,"operator":{"type":"number","operation":"lt"}}],"combinator":"and"},"renameOutput":true,"outputKey":"info"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ef0ab1eb-37d3-4197-b73e-2c33ffdcdcbe","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":70,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warning"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0b87dd8c-5c5a-42b5-b3f3-51897f22cc48","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":90,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"critical"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"a0a34e5b-19e8-4c2e-85b7-6ec603e452eb","name":"Grade Severity Tier"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,-80],"id":"dc98ed27-3e38-4d12-abcb-9aca3122a7fd","name":"Just Record (Info)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🟠 Warning tier reached: {{ $json.reportId }} at {{ $json.score ?? $json.last }}","message":"=🟠 Warning tier reached: {{ $json.reportId }} at {{ $json.score ?? $json.last }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1350,400],"id":"6889389b-eb4b-41d1-a5dd-86562c3035ae","name":"Warn Channel (Gmail)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#reporting","cachedResultName":"#reporting"},"text":"=🔴 CRITICAL: {{ $json.reportId }} breached threshold — act now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"4d4f74b6-b512-42c1-9491-4f5fa5b753cb","name":"Page Urgently (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1998,1360],"id":"4bda458d-d31d-4ffd-bb34-8baff7d5b7de","name":"Archive Unscored","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"2bfd2adf-5426-4654-80bc-ac4807181aaa","name":"Merge Tier Outcomes"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3618,400],"id":"5d80cb76-ef4c-4609-a95e-a790191c1e8d","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3942,400],"id":"b41eba06-d72c-456b-898b-0985c2d77e44","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.kpi }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"1904e07a-77c1-4118-9c3a-1823d0733398","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d43419cf-34e4-4e73-9ebc-3f5790a34938","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"8602a404-dac1-4d73-9b18-ac9c2d309640","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"e9dbd940-138a-436c-97eb-b5c092fff6ed","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per metric (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.reportId, j.kpi].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"97ff3123-218e-4f1e-a2dd-21bab8a6b62f","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5238,400],"id":"761d912f-c849-4b5a-b5b1-04aa542d6abd","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"6783c47e-e00e-436c-a578-3b62fa039f9e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"51a293dc-ac96-4688-8cbe-5753ab98dc03","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"04da159e-4560-4a79-945f-4e11d5e3c610","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"fb9df3a0-2609-43a4-8ef7-4ab516b54901","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"45f4e980-8677-4aa0-845a-f8ed7ff016db","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Alert on spend with HTTP / REST API and Gmail hands-free — run completed at {","message":"=✅ Alert on spend with HTTP / REST API and Gmail hands-free — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[6210,400],"id":"44f64509-67bd-438c-a208-43541400b2e1","name":"Send Summary to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"fb3dd6ce-2b06-4207-ac10-f3955d50f03d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"8e76f963-5e73-4c74-b1e0-52057df9ae68","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"c0d7a5c3-e018-46fa-9250-b04a63940397","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"65c8f380-2af2-4ac5-8b3e-c3b744fcd6c8","name":"Capture Failure Context"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[5886,1420],"id":"8d42d6f1-4b8f-485b-9626-df10a484a41b","name":"Escalate Failure to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"7fffd628-d6f6-41f5-ab23-74aed4bd63fb","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Every Few Minutes\n\nStarts the workflow on a timer — every 30 min. No input data; downstream nodes fetch what they need.\n\nNext: Fetch Current Metrics","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"378c0daa-9b8e-6e57-29e3-a342ed5ba4db","name":"Note: Every Few Minutes"},{"parameters":{"content":"### Fetch Current Metrics\n\nGET https://api.example.com/v1/metrics — retries 3× with backoff on failure.\n\nPorts: ①→ Compute Severity Signals · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"c341273c-699e-36dd-79dc-8f02e0bceb69","name":"Note: Fetch Current Metrics"},{"parameters":{"content":"### Compute Severity Signals\n\nCustom JavaScript: Score each metric 0-100 from simple heuristics\n\nNext: Grade Severity Tier","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"d9186774-1cf1-961a-39d7-52423157fec6","name":"Note: Compute Severity Signals"},{"parameters":{"content":"### Grade Severity Tier\n\nRoutes each item to one of 4 lanes: info, warning, critical + fallback.\n\nPorts: ①→ Just Record (Info) · ②→ Warn Channel (Gmail) · ③→ Page Urgently (Slack) · ④→ Archive Unscored","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"46fbb4ed-ba64-5666-9b46-0fdaf63af4cd","name":"Note: Grade Severity Tier"},{"parameters":{"content":"### Just Record (Info)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,40],"id":"b7629604-dcd3-3345-14dd-f170ed0e4994","name":"Note: Just Record (Info)"},{"parameters":{"content":"### Warn Channel (Gmail)\n\ngmail — `action` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"9a37511e-71ba-2715-5090-934ed648a8fd","name":"Note: Warn Channel (Gmail)"},{"parameters":{"content":"### Page Urgently (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"95454859-39ae-ee8f-76cd-b02e344c14cb","name":"Note: Page Urgently (Slack)"},{"parameters":{"content":"### Archive Unscored\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,1480],"id":"a1f1853b-d22b-21d1-642f-85c160f13cec","name":"Note: Archive Unscored"},{"parameters":{"content":"### Merge Tier Outcomes\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"40bf391c-888d-8807-3c55-8c24ab7f1dd4","name":"Note: Merge Tier Outcomes"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"6cc0d20a-0e0e-f540-6349-9044db6511ff","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"67b8b453-5987-576a-cccb-89b24ed9de57","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"faa82e20-a996-c4d7-0844-d3538cfeb73e","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"9733289f-2178-6b9e-f758-9d94a0ccb045","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per metric (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"448d6987-4d75-a9cb-8354-2f8b4b62c75c","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"1579f526-be98-102d-e4b9-24d5d5b685fb","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"85b1f8f4-487e-a600-66e5-76d0cf1666d2","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Gmail · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"968a18dd-4c92-9adc-5fb8-f7c468cc9a91","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"93aca576-c3c8-a02c-fb03-ada5f3ad3cfb","name":"Note: Send Summary to Gmail"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Gmail","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"9701e0d6-90a0-b09f-c9a6-f88c2c1e591f","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Gmail\n\ngmail — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Google OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"d71ef7b4-de2f-e2ee-0166-c1ff4dec1160","name":"Note: Escalate Failure to Gmail"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"60076abb-d804-780b-d079-1de44df1fa95","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Alert on spend with HTTP / REST API and Gmail hands-free\n\n**Pattern:** Threshold Monitoring · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nAlert on spend with HTTP / REST API and Gmail hands-free. It runs automatically on a schedule.\n\n## Why it exists\nManual alerts is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nEvery Few Minutes → Fetch Current Metrics → Compute Severity Signals → Grade Severity Tier → Just Record (Info) → Merge Tier Outcomes → Stamp Completion Time → …\n\n## Use it for\n- Teams that want to threshold monitoring without manual effort\n- Anyone automating alerts in data\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Saves hours of manual work each week\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"711b36d1-fa52-2a32-364c-0c338b23e9c0","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"3a0100fd-6b01-4bf5-8cf7-b3390332b23a","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"d09cbaf9-7201-89f1-ca69-880bf8c9852f","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your alerts process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"be9d18c7-bd12-1ff5-5469-af4d727f92eb","name":"🛠 Customize me"}],"connections":{"Every Few Minutes":{"main":[[{"node":"Fetch Current Metrics","type":"main","index":0}]]},"Fetch Current Metrics":{"main":[[{"node":"Compute Severity Signals","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Severity Signals":{"main":[[{"node":"Grade Severity Tier","type":"main","index":0}]]},"Grade Severity Tier":{"main":[[{"node":"Just Record (Info)","type":"main","index":0}],[{"node":"Warn Channel (Gmail)","type":"main","index":0}],[{"node":"Page Urgently (Slack)","type":"main","index":0}],[{"node":"Archive Unscored","type":"main","index":0}]]},"Just Record (Info)":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Warn Channel (Gmail)":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Page Urgently (Slack)":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Unscored":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Tier Outcomes":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"ma