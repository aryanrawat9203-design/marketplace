      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Build an HTML digest table from the aggregated rows\nconst rows = $input.all().map(i => i.json);\nconst tr = rows.map(r =>\n  `<tr><td>${r.reportId ?? ''}</td><td>${r.kpi ?? ''}</td><td>${r.count ?? 1}</td></tr>`\n).join('');\nconst html = `<h2>Metric digest</h2><table border=\"1\" cellpadding=\"4\">\n<tr><th>ID</th><th>kpi</th><th>Count</th></tr>${tr}</table>`;\nreturn [{ json: { html, rowCount: rows.length, generatedAt: new Date().toISOString() } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
