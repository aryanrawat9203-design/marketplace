              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "6fb6f28e-9a61-4425-8572-df42c252e202",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "d398078c-25ba-4f30-8513-47f4b44b995b",
