          "combinator": "and",
          "conditions": [
            {
              "id": "f6de1a4e-dd20-4b4e-8476-cab2922a2aa0",
              "leftValue": "={{ $json.type }}",
              "rightValue": "paid",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "7575a60a-b157-47f1-b954-9320ebcf5706",
