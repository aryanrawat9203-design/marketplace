          },
          "conditions": [
            {
              "id": "2376bd7a-1413-4fbf-babb-b84199ae7ddf",
              "leftValue": "={{ $json.anomalyDetected }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
