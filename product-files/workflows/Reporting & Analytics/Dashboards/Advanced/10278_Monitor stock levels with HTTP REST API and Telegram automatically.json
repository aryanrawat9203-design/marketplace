    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Score each metric 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.kpi) score += 20;\n  if (j.value) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        400
      ],
      "id": "4b1cc3a8-5f00-4b4a-a5bf-69c688723ab0",
      "name": "Compute Severity Signals"
    },
    {
      "parameters": {
