              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "918e96e5-4c63-4ecd-802a-610e04e93993",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "4c2677f0-e09d-48f1-ba12-5d3f293d25d3",
