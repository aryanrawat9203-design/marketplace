{
  "name": "Monitor spend with HTTP / REST API and Slack without manual work",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "f6717456-c639-4524-8501-9bf4c8fc29e1",
      "name": "Schedule Trigger",
