{"name":"Watch spend with HTTP / REST API and Telegram without manual work","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":30}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"0fd2f6b1-ca41-4ad2-ad58-3663670b8f5a","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://example-market.com/metrics","options":{"timeout":20000,"response":{"response":{"responseFormat":"text"}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"46031119-d6a4-4bc6-a695-090b3cae64f6","name":"Fetch Target Page","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"extractHtmlContent","extractionValues":{"values":[{"key":"title","cssSelector":".listing h2","returnValue":"text","returnArray":true},{"key":"price","cssSelector":".listing .price","returnValue":"text","returnArray":true},{"key":"url","cssSelector":".listing a","returnValue":"attribute","attribute":"href","returnArray":true}]},"options":{}},"type":"n8n-nodes-base.html","typeVersion":1.2,"position":[378,400],"id":"630e0e07-489f-4485-a6a3-4715f87f42bc","name":"Extract Listings (CSS)"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Zip parallel arrays into one item per listing\nconst j = $input.first().json;\nconst n = (j.title || []).length;\nconst out = [];\nfor (let i = 0; i < n; i++) {\n  out.push({ json: { title: j.title[i], price: j.price?.[i], url: j.url?.[i] } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"382a527c-09e0-4eff-a9ed-5c6c8b77ada6","name":"Rows from Arrays"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1026,910],"id":"2191b916-5c67-4523-a5d5-5986aa5c9e1a","name":"Load Previous Snapsho