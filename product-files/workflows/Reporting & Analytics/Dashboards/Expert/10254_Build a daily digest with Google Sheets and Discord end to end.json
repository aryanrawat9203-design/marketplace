 + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.reportId, j.kpi].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6129,400],"id":"cdabf263-a8eb-4bf5-a7df-441aeae6b727","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6453,400],"id":"c3b38de9-1d82-49c0-a60b-ddbabb6b3b89","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6777,400],"id":"0ebd7ff4-0c88-47d5-953b-ed073a0e67be","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7101,400],"id":"63038dc6-8528-472a-bbeb-b09457993e9a","name":"Persist Run Metadata"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Metric Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7425,400],"id":"3a71aa6e-6cae-4fd5-8f81-b2d50d91e168","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7749,400],"id":"5b5d468d-7798-4458-a318-a23b07922b45","name":"Compute Drift vs Snapshot"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"reportId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8073,400],"id":"e071e73b-1bed-4a5d-894c-08d9fe4bcedc","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1061243c-79a1-461d-bb41-252601a9f8bc","leftValue":"={{ $json.kpi }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8397,400],"id":"cfac3f8d-8a7e-4e2c-bcef-959db799b7a8","name":"Guard Non-Empty kpi"},{"parameters":{"assignments":{"assignments":[{"id":"02885f36-74c8-4e1d-84a4-0cc96d6d70cf","name":"pipeline","value":"Dashboards","type":"string"},{"id":"eccf7233-52f1-40b8-bdaf-9ef6364de191","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8721,400],"id":"d991c2ad-7074-402a-a17e-1305029b4f4e","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"reportId","value":"={{ $json.reportId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[9045,400],"id":"865dfdf0-57d9-4966-b3f3-b13cff3eb182","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"c6772a80-431d-40b2-833f-ba5cb241399a","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6183dd8d-99cd-484a-9320-ca182e926502","name":"itemCount","value":"={{ $input.all().length }}","type":"number"