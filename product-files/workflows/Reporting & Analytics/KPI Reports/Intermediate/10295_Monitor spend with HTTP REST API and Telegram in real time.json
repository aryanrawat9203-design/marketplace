            "index": 0
          }
        ]
      ]
    },
    "Validate Input": {
      "main": [
        [
          {
            "node": "Fetch Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Data": {
      "main": [
        [
          {
            "node": "Route on Condition",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Route on Condition": {
      "main": [
        [
          {
