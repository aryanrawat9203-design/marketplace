ine","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[702,400],"id":"0dfbd886-232e-4f58-90d2-ea595e15823b","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a support bots pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[1026,400],"id":"38d0b2f1-1c29-446d-acf3-6ff6818e25cb","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[1269,970],"id":"1a59d1fa-84d9-4848-85c3-14762fbac424","name":"Google Gemini Chat Model"},{"parameters":{"description":"Delegate research sub-tasks for a conversation to the Research specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Research Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[1188,1390],"id":"5ded3119-d9eb-4897-a626-02b25631523c","name":"Research Specialist (Sub-workflow)"},{"parameters":{"description":"Delegate draft sub-tasks for a conversation to the Draft specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Draft Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[144