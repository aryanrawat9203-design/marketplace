{"name":"Power an assistant workflow with Twilio for Support Bots","nodes":[{"parameters":{"httpMethod":"POST","path":"wf07594-conversation","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"6bbf41b5-59a6-44f1-8fcc-77cbba0c2688","name":"Receive Inbound Webhook","webhookId":"2edb683e-63e0-4a25-ae17-eeb10c4f1fbf"},{"parameters":{"assignments":{"assignments":[{"id":"12f688e0-f40d-4eb8-875b-aec6b6fe6e75","name":"content","value":"={{ $json.body?.text || $json.content || JSON.stringify($json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"ba53d5f0-6b05-46fd-8143-562b0cb14271","name":"Collect Raw Text"},{"parameters":{"text":"={{ $json.text || $json.content }}","attributes":{"attributes":[{"name":"sessionId","description":"The sessionId of this conversation.","required":true},{"name":"message","description":"The message of this conversation.","required":true},{"name":"intent","description":"The intent of this conversation.","required":false}]},"options":{"systemPromptTemplate":"You are a precise extraction engine. Only extract values present in the text."}},"type":"@n8n/n8n-nodes-langchain.informationExtractor","typeVersion":1,"position":[378,400],"id":"93066693-913c-40af-b378-2ad6113425cf","name":"Extract Structured Fields","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[621,970],"id":"10962f1d-3b31-47c6-96bf-0a478cf0401d","name":"Anthropic Chat Model"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e99936bd-497d-4cca-9b36-ad50a8282a52","leftValue":"={{ $json.output?.sessionId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[945,400],"id":"7aa670ba-c6e0-