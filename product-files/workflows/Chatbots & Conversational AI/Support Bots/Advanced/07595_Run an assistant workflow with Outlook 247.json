{"name":"Run an assistant workflow with Outlook 24/7","nodes":[{"parameters":{"httpMethod":"POST","path":"wf07595-conversation","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"ca51c14c-eaa3-424e-a4cf-9aa717deb379","name":"Receive Inbound Webhook","webhookId":"a925b7bd-f451-4280-9b1b-b11ea7c97027"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming conversation records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    sessionId: String(j.sessionId ?? j.id ?? '').trim(),\n    message: typeof j.message === 'string' ? j.message.trim() : j.message ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"433605c6-5ff4-4df8-8ee3-dc5092042d7c","name":"Normalize Conversation Payload"},{"parameters":{"assignments":{"assignments":[{"id":"697c64e2-07c0-4982-9f7a-51889e0b07cd","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"ae85b8ba-ef3a-4d25-85c6-3e9ea5b570a7","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"90ab83da-142a-4556-b4cc-8da6f6f4e223","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a support bots pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"59f8f9ab-190c-486e-a81f-d51e2bc4c378","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"mode