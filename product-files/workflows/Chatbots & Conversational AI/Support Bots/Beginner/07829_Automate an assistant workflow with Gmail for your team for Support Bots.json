. Use the attached tools to look up real data before answering — never invent conversation details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"3da5bbfd-b892-460c-aa1a-2823a184328f","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[945,970],"id":"ab24d656-36a6-42a5-b3a4-c7e73117731f","name":"Google Gemini Chat Model"},{"parameters":{"toolDescription":"Fetch live conversation data from the internal REST API by id or query.","url":"https://api.example.com/v1/conversations","options":{}},"type":"@n8n/n8n-nodes-langchain.toolHttpRequest","typeVersion":1.1,"position":[945,1390],"id":"cd49f0f4-5c95-447e-8a39-d0d919d90ffa","name":"Lookup API Data"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[1174,1390],"id":"947a14cc-cc20-4dd8-a64c-bb71820b9e3e","name":"Search Reference Wiki"},{"parameters":{"name":"score_helper","description":"Compute a quality score for a conversation record.","jsCode":"const j = JSON.parse(query);\nreturn String((j.signals || []).length * 10);"},"type":"@n8n/n8n-nodes-langchain.toolCode","typeVersion":1.3,"position":[1633,1390],"id":"f86a1aaa-7d94-4348-b6c6-095e0405be36","name":"Custom Logic Tool"},{"parameters":{"assignments":{"assignments":[{"id":"fbf3c68f-67ab-43a8-bed0-d8b80ac538c2","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"c0cbd797-d509-4ef9-822d-abc0a27e9464","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1957,400],"id":"9f2ae997-02e3-45ce-8e84-6929697ef704","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fdd29305-819d-4c30-b24d-59078f5ea857","leftValue":"={{ $json.confidence }}","rightValue":"high","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[2281,400],"id":"14fc30ed-4739-4bdd-972d-b9a8aa82bed2","name":"Confident Enough?"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Database"},"title":"={{ $json.message || $json.sessionId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2605,160],"id":"a9b43501-969b-430d-a565-95e8eaf15b3d","name":"Deliver Answer + Log to Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#support","cachedResultName":"#support"},"text":"=🙋 Low-confidence answer needs review: {{ $json.answer }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2929,760],"id":"53313bd7-57ed-45cd-900a-96bad3018cee","name":"Escalate to Human Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3577,400],"id":"03f8022e-a527-4646-826b-ffc56f1be2b3","name":"Join Outcomes"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per conversation (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.sessionId, j.message].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4549,400],"