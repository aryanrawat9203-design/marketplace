urn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.sessionId, j.message].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4833,400],"id":"ce6e4113-ba5e-4b32-8c42-0e703433647d","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5157,400],"id":"99ba49e6-f1f2-41fa-a3af-55b52171ba1e","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5481,400],"id":"0fc0ffbd-c68a-4812-8dcc-728694041d9d","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5805,400],"id":"75e0a448-a674-4c26-b333-fde54c594795","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[6129,400],"id":"e60a1e75-b5a7-41dc-8c7f-17fc52892207","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Database"},"title":"={{ $json.message || $json.sessionId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6453,400],"id":"f481c625-844b-426a-a798-fa1739c5fd6a","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6777,400],"id":"660d5047-477a-43be-9ad4-f839b0b6894a","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7101,400],"id":"f3d2982a-d608-4041-a2ac-c261e9d9ea83","name":"Compute Drift vs Snapshot"},{"parameters":{"dataToSave":{"values":[{"key":"sessionId","value":"={{ $json.sessionId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7425,400],"id":"34d7747d-d195-4c45-9f66-17f77fdcd1a3","name":"Save Execution Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"language","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7749,400],"id":"e57d5c0b-8f45-4944-af53-05630ecbebec","name":"Sort Conversations Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"sessionId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8073,400],"id":"e064688d-2d08-4c7c-a46c-94b3bab20976","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"12a7f1c6-cd1b-4c44-a8d5-a075a011bde6","name":"pipeline","value":"Voice","type":"string"},{"id":"4c6c1534-2b35-4c82-a201-89c8a8820e87","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","