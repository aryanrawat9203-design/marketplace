{"name":"Reply to user questions at scale for Voice","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"112f9c6d-0f70-46bd-98f3-f19094271944","name":"When Chat Message Received","webhookId":"2536957d-14a0-4f93-99a9-d32f8148a326"},{"parameters":{"assignments":{"assignments":[{"id":"ba660d6b-19c2-4140-adc0-b85b49be317d","name":"sessionId","value":"={{ $json.sessionId || $json.id || $execution.id }}","type":"string"},{"id":"62f697e3-fe25-46ed-8262-df16166871fb","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"3e69461c-e272-4aae-92f2-5b5c19155126","name":"Stamp & Shape Conversation"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"84943c1e-26a9-4fc1-abb0-34048c67ae40","leftValue":"={{ $json.sessionId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"2e7765cd-dc37-426e-b8a3-9cb485d4ddef","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"b3c94ab2-a61c-4c85-b0e4-d8547496a36a","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"inputText":"={{ $json.message || JSON.stringify($json) }}","categories":{"categories":[{"category":"Question","description":"Conversations that are question for the voice team."},{"category":"Complaint","description":"Conversations that ar