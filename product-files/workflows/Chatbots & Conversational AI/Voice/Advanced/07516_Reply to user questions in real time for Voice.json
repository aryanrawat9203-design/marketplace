{"name":"Reply to user questions in real time for Voice","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"f20cc755-c8a0-4aec-b210-8fe7f6e6929c","name":"When Chat Message Received","webhookId":"412f6cc2-64c9-4cb6-8373-27855903f385"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1bbcf18c-ed0f-4201-9c42-9a41806d0001","leftValue":"={{ $json.message }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"20ba74b4-4df3-403e-8eb4-d7278462b7d5","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'message' on incoming conversation."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"ff09f1cf-64b7-4a16-ae23-976d06e4cbb0","name":"Abort — Malformed Input"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.message || JSON.stringify($json) }}","options":{"systemMessage":"You are a voice specialist for the chatbots & conversational ai team. Use the attached tools to look up real data before answering — never invent conversation details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"9d714b8b-2e13-4b24-b3ee-94b5b97c1867","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[621,970],"id":"3038f951-f451-4048-b387-52d147bae47a","name":"OpenRouter Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[621,1390],"id":"3e5ef