{"name":"Handle chat messages for FAQ Bots","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"8f3021de-e38f-4a52-855a-da34a516f0b1","name":"When Chat Message Received","webhookId":"36ce9295-54dc-43b6-a656-5ea0767337a4"},{"parameters":{"assignments":{"assignments":[{"id":"50295b22-abaa-4e9a-aad0-a09bfb023c94","name":"sessionId","value":"={{ $json.sessionId || $json.id || $execution.id }}","type":"string"},{"id":"e10cd260-1e2e-4f57-b513-2ef3aad79790","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"bb576b0f-252b-4e60-a60c-77e2093be290","name":"Stamp & Shape Conversation"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0fd23324-57f5-46ee-95d8-e6799408e3d7","leftValue":"={{ $json.sessionId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"d5bbb655-3499-4f17-a5bc-1a20b311941b","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"04639db5-8892-40e2-a508-ed1ff96e488b","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"inputText":"={{ $json.message || JSON.stringify($json) }}","categories":{"categories":[{"category":"Question","description":"Conversations that are question for the faq bots team."},{"category":"Complaint","description":"Conversations that are comp