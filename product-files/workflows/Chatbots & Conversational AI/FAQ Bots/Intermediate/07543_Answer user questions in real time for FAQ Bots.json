        "jsCode": "// Normalize incoming conversation records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    sessionId: String(j.sessionId ?? j.id ?? '').trim(),\n    message: typeof j.message === 'string' ? j.message.trim() : j.message ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
