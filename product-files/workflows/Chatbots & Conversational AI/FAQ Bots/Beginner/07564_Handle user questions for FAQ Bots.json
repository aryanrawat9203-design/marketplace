{"name":"Handle user questions for FAQ Bots","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"e5361e35-ec55-42aa-817f-08eab9557a55","name":"When Chat Message Received","webhookId":"6665f05a-0c34-4de6-a3ad-89dc2d439d8b"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming conversation records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    sessionId: String(j.sessionId ?? j.id ?? '').trim(),\n    message: typeof j.message === 'string' ? j.message.trim() : j.message ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"f4e469c0-15ef-4f8f-8d23-d5db8bffeee7","name":"Normalize Conversation Payload"},{"parameters":{"assignments":{"assignments":[{"id":"7a6258b2-87ed-47ac-ad85-ed675f548850","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"6ea0eaf5-9edc-4215-ba03-de4077833ac7","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"1554843b-bfce-412c-8710-e20c189151ee","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a faq bots pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"7818c8b5-fd0d-4672-af1a-12083cd04a23","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list",