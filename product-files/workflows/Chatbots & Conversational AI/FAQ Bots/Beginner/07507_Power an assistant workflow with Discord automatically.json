d":"c37d4da5-8f4f-4a2f-b4cb-0d97a5c86c18","name":"Return Answer (HTTP 200)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2308,760],"id":"d5c4edde-c4ac-4b7a-bfac-0caa32cf08ac","name":"Log Knowledge Gap","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#support","cachedResultName":"#support"},"text":"=📚 Unanswered question logged: {{ $json.chatInput || $json.question }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2956,760],"id":"cffba624-0c6d-4e42-b043-8efa2224909f","name":"Flag Gap to KB Owners","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"assignments":{"assignments":[{"id":"acbb9cc4-f546-46de-ba70-1531cf1dd86e","name":"pipeline","value":"FAQ Bots","type":"string"},{"id":"e72992ae-8d67-435c-b5a4-ab33aaac92f5","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3928,400],"id":"93c1f955-f448-4e74-993c-b98613b3743d","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"f98b8258-7d98-4e42-8dc2-8546a90e1d67","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6e122662-3131-46c1-a282-51f739bac987","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"2d6a32b2-bb8f-427f-8d89-db01ba5227d1","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4252,400],"id":"3a3114c5-f966-4e27-999b-be347d14894e","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4576,400],"id":"abb50208-1e9a-4858-b426-34ab5d5795df","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#support","cachedResultName":"#support"},"text":"=✅ Power an assistant workflow with Discord automatically — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4900,400],"id":"db6808cf-08e3-4290-a359-8c3cea10f6af","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4eee6822-5650-4e21-ba33-d79cacb4eb58","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a4a48818-e658-4f47-a2a0-20e2e428ad49","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"a2c1d842-c1a3-4ca7-94ca-e303cf104ada","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4252,1420],"id":"0e77acec-e0f4-445b-ab1d-0417fbcc18a2","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#support","cachedResultName":"#support"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4576,1420],"id":"3d9024ba-182c-4272-b6d4-3e9e29f0269e","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf07507-conversation`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Stamp & Shape Conversation","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"54413b35-c9a6-1eb0-82ec-4a860a257976","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Stamp & Shape Conversation\n\nShapes the item: writes `sessionId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"d9cbe6e6-5463-bf69-0373-cf2e6e9b59f3","name":"Note: Stamp & Shape Conversation"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.sessionId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Answer from Knowledge Base · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"ad038434-e5f5-2f08-a75b-33015dd1277a","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"c1337878-f208-a9c5-f6b2-27981998463b","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Answer from Knowledge Base\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Grounded Answer Found? · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"1beeb1ac-975b-e265-d1d9-6e4ab4de2df1","name":"Note: Answer from Knowledge Base"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Answer from Knowledge Base** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"6d06b8fb-eda8-6c17-2e7c-1c95a636f3f1","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Knowledge Base Retriever\n\nExposes the vector index to the agent as a semantic-search tool.\n\nFeeds **Answer from Knowledge Base** as `tool`\n\n🔑 Qdrant URL + key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[939,1510],"id":"583b7ea7-3a32-5b63-5d90-f8df10d93cd1","name":"Note: Knowledge Base Retriever"},{"parameters":{"content":"### Query Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Knowledge Base Retriever** as `embedding`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[993,2020],"id":"884ba914-e95c-d99a-48c0-3646baf7af37","name":"Note: Query Embeddings"},{"parameters":{"content":"### Rerank Retrieved Chunks\n\nRe-scores retrieved chunks so only the most relevant reach the model.\n\nFeeds **Knowledge Base Retriever** as `reranker`\n\n🔑 Cohere API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1276,2020],"id":"7ffe4617-ae93-dd98-ed01-655f444d0bcb","name":"Note: Rerank Retrieved Chunks"},{"parameters":{"content":"### Grounded Answer Found?\n\nTwo-way gate on `={{ !($json.output || '').includes('needsHuman') }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Return Answer (HTTP 200) · ②→ Log Knowledge Gap","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1600,520],"id":"45dee2da-8ced-6126-e3a3-dd733a261d6c","name":"Note: Grounded Answer Found?"},{"parameters":{"content":"### Return Answer (HTTP 200)\n\nSends the HTTP 200 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1924,280],"id":"210fb545-3737-481d-78fe-03b98f04193d","name":"Note: Return Answer (HTTP 200)"},{"parameters":{"content":"### Log Knowledge Gap\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Flag Gap to KB Owners · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2248,880],"id":"6c4ba6ab-14d6-7f03-ef60-94b1427df6e1","name":"Note: Log Knowledge Gap"},{"parameters":{"content":"### Flag Gap to KB Owners\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2896,880],"id":"acde4e33-7638-ae15-66fa-eaa56a4baeaa","name":"Note: Flag Gap to KB Owners"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3868,520],"id":"4316c031-44fa-b3df-4dfe-b087094f9253","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4192,520],"id":"3fcc6a59-d3e9-2ed5-9d5e-4e7970200861","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4516,520],"id":"ea6d4941-c5d6-8ce7-080e-6af3cd0d3f66","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4840,520],"id":"edb55f2f-a217-5e59-5f87-eadf82897890","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4192,1540],"id":"ca0f9e76-2255-abae-35bd-e1eb75c2c812","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4516,1540],"id":"c22cb023-92cf-6e11-6688-97385965e73e","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Power an assistant workflow with Discord automatically\n\n**Pattern:** AI Agent · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nPower an assistant workflow with Discord automatically. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual faq bots is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Stamp & Shape Conversation → Payload Valid? → Answer from Knowledge Base → Grounded Answer Found? → Return Answer (HTTP 200) → Tag Pipeline Metadata → …\n\n## Use it for\n- Teams that want to ai agent without manual effort\n- Anyone automating faq bots in customer support\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Keeps your systems in sync\n- Improves response time\n\n## Before first run\nConnect credentials: Cohere API key; Google AI API key; Google OAuth2 / service account; Qdrant URL + key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a258a035-879f-e3db-adfa-02e92b8ca43e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"0565d213-2898-5bf6-031b-1c950aa42a36","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"cfbf2e48-f4f1-72f9-c257-cb4bca61f061","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"90f8d585-d73d-d4ca-5d97-f8f602444c89","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your faq bots process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"08cf78f3-d86a-b98e-76be-bfdbe4085609","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Stamp & Shape Conversation","type":"main","index":0}]]},"Stamp & Shape Conversation":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Answer from Knowledge Base","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Answer from Knowledge Base","type":"ai_languageModel","index":0}]]},"Knowledge Base Retriever":{"ai_tool":[[{"node":"Answer from Knowledge Base","type":"ai_tool","index":0}]]},"Query Embeddings":{"ai_embedding":[[{"node":"Knowledge Base Retriever","type":"ai_embedding","index":0}]]},"Rerank Retrieved Chunks":{"ai_reranker":[[{"node":"Knowledge Base Retriever","type":"ai_reranker","index":0}]]},"Answer from Knowledge Base":{"main":[[{"node":"Grounded Answer Found?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Grounded Answer Found?":{"main":[[{"node":"Return Answer (HTTP 200)","type":"main","index":0}],[{"node":"Log Knowledge Gap","type":"main","index":0}]]},"Log Knowledge Gap":{"main":[[{"node":"Flag Gap to KB Owners","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Return Answer (HTTP 200)":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"2f40163e-2379-44ca-a1e2-67dc1728bdb8","id":"FDX07507"}