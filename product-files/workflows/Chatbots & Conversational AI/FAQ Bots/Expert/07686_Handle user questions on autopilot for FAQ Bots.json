{"name":"Handle user questions on autopilot for FAQ Bots","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"090e3b80-a6ed-47c0-851e-7e2c5ef24b50","name":"When Chat Message Received","webhookId":"6b5e3e9d-1a1b-4670-a6e9-c0c823d7b171"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"3a5fb6af-c8d7-4cf3-8cf6-14cd3d97be2b","leftValue":"={{ $json.sessionId || $json.message }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"dbec9496-5b2b-4fa5-9858-b452b424cb03","name":"Keep Valid Conversations"},{"parameters":{"inputText":"={{ $json.message || JSON.stringify($json) }}","categories":{"categories":[{"category":"Question","description":"Conversations that are question for the faq bots team."},{"category":"Complaint","description":"Conversations that are complaint for the faq bots team."},{"category":"Feedback","description":"Conversations that are feedback for the faq bots team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"e1dbb2a1-a527-43be-9083-fdc0ad1713fe","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[621,970],"id":"05f186cc-faa5-43ef-8f94-7745f2588c83","name":"Groq Chat Model"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"positio