ll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6844,400],"id":"31947c2c-ca05-4e78-9a26-27bafde02360","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7168,400],"id":"70a32489-1754-4a7c-8642-60d64596826a","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"f43939c7-0068-43cc-97cc-0709b860f0cf","name":"pipeline","value":"FAQ Bots","type":"string"},{"id":"0ae7401f-af71-4f0b-b775-0ca2a86118d6","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7492,400],"id":"d9a81286-0281-4302-86c4-e84e92eb337f","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"sessionId","value":"={{ $json.sessionId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7816,400],"id":"00358872-a342-40f2-817e-ea21f2d70fff","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"f181382c-9668-436d-a6e2-6a13f63a7f7e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"51bc0bcc-1868-47c6-a417-c109d4435866","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"b9608afc-2746-45f8-a000-e09a04e1617c","name":"status","value":"completed","type":"string"}]}