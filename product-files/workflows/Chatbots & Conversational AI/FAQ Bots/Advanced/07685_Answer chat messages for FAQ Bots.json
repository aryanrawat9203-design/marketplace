{"name":"Answer chat messages for FAQ Bots","nodes":[{"parameters":{"public":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.chatTrigger","typeVersion":1.1,"position":[-270,400],"id":"cc0dcbb1-5e64-444d-88e7-2b8aadf5b97a","name":"When Chat Message Received","webhookId":"91b0c60b-b491-4f69-a9e8-3356e99c000f"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming conversation records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    sessionId: String(j.sessionId ?? j.id ?? '').trim(),\n    message: typeof j.message === 'string' ? j.message.trim() : j.message ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"1cb5f8ce-9755-4fcb-bd0e-76e67f42f813","name":"Normalize Conversation Payload"},{"parameters":{"inputText":"={{ $json.message || JSON.stringify($json) }}","categories":{"categories":[{"category":"Question","description":"Conversations that are question for the faq bots team."},{"category":"Complaint","description":"Conversations that are complaint for the faq bots team."},{"category":"Feedback","description":"Conversations that are feedback for the faq bots team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"82207047-2468-4ed0-aee9-4b91c300d14b","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[621,970],"id":"2d0613bc-818c-4855-a886-c2b8f0c607d8","name":"Google Gemini Chat Model"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Database"},"title":"={{ $json.message || $json.sessionId }}","options":{}},"type":"n8n-