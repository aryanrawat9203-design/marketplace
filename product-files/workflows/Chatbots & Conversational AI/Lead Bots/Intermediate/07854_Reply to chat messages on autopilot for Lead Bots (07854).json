:[4738,400],"id":"49fe85cf-9858-4d4d-b14d-617f02475c20","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per conversation (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.sessionId, j.message].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5062,400],"id":"5c99d9ec-85d4-440d-a45d-0dbe1782531a","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5386,400],"id":"4cdb0e41-7624-4862-bbc1-6dcb4968f513","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5710,400],"id":"dc7620dc-7a16-4ade-bec9-13feb980b807","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Database"},"title":"={{ $json.message || $json.sessionId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6034,400],"id":"de3fa2e7-5662-4096-8369-5a566de844ca","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Conversation Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6358,400],"id":"ed42b3a6-21be-4f14-9d6c-24ab113853c6","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6682,400],"id":"44f77685-030c-4410-a33b-319713de08ff","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.message }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[7006,400],"id":"4fd65eca-0ca1-41e8-9546-822a2b84d640","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4bcf3b5a-6853-4b9c-8bc6-853af82fafd8","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"bbc28d6c-92c4-405c-ac6d-4828b747212c","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7330,400],"id":"33e0892e-8882-4556-ae30-72a5e97ec3ef","name":"Fold In Enrichment Fields"},{"parameters":{"dataToSave":{"values":[{"key":"sessionId","value":"={{ $json.sessionId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7654,400],"id":"dcd15289-3511-4497-97a2-f6903f43c109","name":"Save Execution Metada