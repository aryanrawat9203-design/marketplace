{"name":"Power an assistant workflow with Slack end to end","nodes":[{"parameters":{"httpMethod":"POST","path":"wf07548-conversation","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"67d4afc0-d512-4d97-8ce4-143296a90a89","name":"Receive Inbound Webhook","webhookId":"1d67ad33-bdb7-43af-bb9e-fb4067249201"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c856f4c5-6d66-4735-9ab7-9228c50db6f3","leftValue":"={{ $json.message }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"7eafa2f3-1824-44f0-9b6a-530707fdb7c4","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'message' on incoming conversation."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"a4b5b5c3-710c-47e1-b8d2-8c02e59f308e","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"645b522e-e82d-49ee-874b-732b3e588852","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"6f35c3b5-1c0a-44f5-8767-429572a7479c","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"4654da21-a1c7-4b9f-acf3-6effe2944d2c","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a lead bots pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"ab14f3bd-