":3.4,"position":[6777,400],"id":"c53a4765-a1fc-4dcd-b2d9-08595a50be5d","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7101,400],"id":"5e64d150-c57e-4855-814d-a89bb00cd8ff","name":"Stamp Processing Time"},{"parameters":{"dataToSave":{"values":[{"key":"sessionId","value":"={{ $json.sessionId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7425,400],"id":"1a907baa-168a-4628-b2bc-f40dec777b09","name":"Save Execution Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"sessionId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7749,400],"id":"afead2bf-e3e0-4b33-b80d-909ccc50c7a3","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"906d2a1c-e3bf-4958-9027-e6819ffa80aa","leftValue":"={{ $json.message }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8073,400],"id":"fc8f5c2c-ff24-4c70-b673-f722a0f65d1f","name":"Guard Non-Empty message"},{"parameters":{"assignments":{"assignments":[{"id":"7e81b7c2-fcef-4390-9ee8-411bd692f007","name":"pipeline","value":"Lead Bots","type":"string"},{"id":"26d39546-b4a6-4dc0-a89f-072395753cab","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8397,400],"id":"e9085be7-5c29-4da3-a06d-c76436341654","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"language","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8721,400],"id":"6a468cea-651f-4bf0-bc14-e0201ce03721","name":"Sort Conversations Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"7d6416