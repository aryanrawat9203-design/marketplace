      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "b6709b11-2f70-46ff-8876-6ae13a22ba9d",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "c7922ba7-7177-415a-8219-847f77f20468",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "fd468800-8dcf-489e-9ab9-b2834ebf32c6",
