":"continueErrorOutput"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Notifications & Alerts Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Events"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[1917,400],"id":"f276af49-4dfd-46e2-83d5-fd8daf1dd10e","name":"Archive Digest in Airtable","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[2241,400],"id":"16855197-234f-4728-8251-294104d6bded","name":"Cap Batch Volume"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b93dac80-debc-431b-9d2a-8dde310e1147","leftValue":"={{ $json.severity }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[2565,400],"id":"563b4f18-b094-478c-91be-d7b1f7e0df49","name":"Guard Non-Empty severity"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"metric","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[2889,400],"id":"af1ab36c-c097-4ee8-b76e-010d9854179a","name":"Sort Events Newest First"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3213,400],"id":"92caed35-6880-4e55-b9f5-32206e687d84","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"b54bd7a2-b24e-437a-9be2-86e61518ffb6","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"1a07ab90-d2fe-4d89-b3e5-775d193e3f48","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"748eebea-365f-43cb-8e25-02e423a682ca","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3537,400],"id":"4f84c944-a101-4f28-874d-5264ecd8015e","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Notifications & Alerts Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Events"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3861,400],"id":"f6aa2abf-6abd-4224-9dc9-5895866247df","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Deliver a weekly summary with Airtable and Gmail for your team — run complete","message":"=✅ Deliver a weekly summary with Airtable and Gmail for your team — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[4185,400],"id":"a849787a-a150-4712-9b42-efb9d65c6567","name":"Send Summary to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e16ada1b-0169-42b9-a559-047ed433dcc3","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"fdaa2224-9318-4cfd-98f2-c1fe68f77684","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"55b8c876-a4e8-4976-8fa2-c564e2968c6b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3537,1420],"id":"ce86443b-c60d-4bea-9547-99cbdf11d26b","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#alerts","cachedResultName":"#alerts"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3861,1420],"id":"0bdb59a5-5b62-4fed-ada6-b916b791bb81","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Read Recent from Gmail","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"dfb6b8fd-dbdf-16e0-daba-3643c7da471c","name":"Note: Daily Schedule"},{"parameters":{"content":"### Read Recent from Gmail\n\ngmail — `getAll` operation against the connected account.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"a0df212d-6b2c-a831-7146-aa26d60bfbe5","name":"Note: Read Recent from Gmail"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"c0ba301c-a82e-3d53-c49a-a3797f995e33","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"0abbdff8-8b04-4cab-0e5f-ade775e259a3","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Post Digest to Gmail · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"721a87f2-e4f0-be19-55aa-f7b1f5f96fca","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"c1ee2fba-1307-e7a0-15d2-0662cf5c0558","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Post Digest to Gmail\n\ngmail — `action` operation against the connected account.\n\nPorts: ①→ Archive Digest in Airtable · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"63efeb44-4c92-e845-3883-6030d19f4b78","name":"Note: Post Digest to Gmail"},{"parameters":{"content":"### Archive Digest in Airtable\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Cap Batch Volume · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"76f3222e-8a92-68cb-6bdf-f0b5b47a0294","name":"Note: Archive Digest in Airtable"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Guard Non-Empty severity","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"95845c7f-bf4f-e3ec-0a77-f95033011df9","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Guard Non-Empty severity\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Sort Events Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"d7a5f1b6-2449-01b7-95bd-cf7245160d4e","name":"Note: Guard Non-Empty severity"},{"parameters":{"content":"### Sort Events Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"ab95c158-4e72-e8ef-790a-3ebc1f03ca6f","name":"Note: Sort Events Newest First"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"f5b4cbb3-d023-fb50-5183-03c33cc19a7f","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"23e8f07b-c85d-6504-7297-fae671eb5577","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Gmail · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"a54d6052-a638-a27a-5956-0d7cf66ae781","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"fa5c285b-749c-1642-fb30-33abac3e1dd7","name":"Note: Send Summary to Gmail"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,1540],"id":"3f574493-81c7-3345-d058-9cff24a5b498","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,1540],"id":"a503a4d4-fcf6-26f5-000a-c676a7b3c44f","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Deliver a weekly summary with Airtable and Gmail for your team\n\n**Pattern:** Scheduled Digest · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nDeliver a weekly summary with Airtable and Gmail for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual escalations is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Read Recent from Gmail → Newest First → Trim to Digest Size → Summarize Content (AI) → Post Digest to Gmail → Archive Digest in Airtable → …\n\n## Use it for\n- Teams that want to scheduled digest without manual effort\n- Anyone automating escalations in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Removes copy-paste errors\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: Airtable PAT; Google AI API key; Google OAuth2; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"58000a56-a9ef-0c73-cd44-92fc1d1c1236","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"1656f9df-c6aa-eed9-72ee-1042bec9a8fa","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"a92323b3-4bbe-1410-f80e-6d70d35b16ff","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your escalations process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"735aeb8d-6110-a8ab-0d12-c59bf47bdb82","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Read Recent from Gmail","type":"main","index":0}]]},"Read Recent from Gmail":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Post Digest to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Post Digest to Gmail":{"main":[[{"node":"Archive Digest in Airtable","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Digest in Airtable":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Guard Non-Empty severity","type":"main","index":0}]]},"Guard Non-Empty severity":{"main":[[{"node":"Sort Events Newest First","type":"main","index":0}]]},"Sort Events Newest First":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Gmail":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"75606827-cf21-4c34-a4cf-965ca002b936","id":"FDX09610"}