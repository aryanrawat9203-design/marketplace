{"name":"Send a daily digest with Airtable and Gmail on autopilot","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":17,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"c5a96645-32ea-4a65-a1fe-ca92741a6824","name":"Daily Schedule"},{"parameters":{"url":"https://news.example.com/feed.xml","options":{}},"type":"n8n-nodes-base.rssFeedRead","typeVersion":1.2,"position":[54,400],"id":"4b472d8b-1608-4c23-aeaa-8d27c5aebbf7","name":"Read Source Feed","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.link }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"2506d175-025f-4284-97d9-a346497efa83","name":"Skip Already-Seen Posts"},{"parameters":{"maxItems":5},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"7e6439c4-2fa9-4c79-9cab-024bbf2e3ee4","name":"Keep Top Stories"},{"parameters":{"promptType":"define","text":"=Rewrite this story as a punchy 3-sentence post for our audience:\n\n{{ $json.title }}\n{{ $json.contentSnippet || $json.content }}","options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"6695f871-c463-4d0b-bdab-df2834f22da2","name":"Rewrite for Our Audience (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[1269,970],"id":"8e1ffbca-b2e1-4873-b655-c2fd33e262c9","name":"Anthropic Chat Model"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"={{ $json.text || $json.title }}","message":"={{ $json.text || $json.title }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1593,160],"id":"00d09ef0-7b18-405d-ae98-5085c56e9f54","name":"Publish to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#alerts","cachedResultName":"#alerts"},"text":"={{ $json.text || $json.title }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1917,640],"id":"70ffbb38-3fee-4019-94f3-ba50f74b4efd","name":"Publish to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2565,400],"id":"7d1e7c92-eb2a-453f-84a5-bed42cd6982c","name":"Confirm Cross-Post"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Notifications & Alerts Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Events"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3537,400],"id":"f6524d15-10dd-4544-9fc7-68ab9ce35034","name":"Log Published Posts (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per event (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.eventId, j.severity].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3861,400],"id":"188dfc7c-05d0-46e6-8bae-45639fec6258","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4185,400],"id":"92d19df8-dfad-463b-9d39-ec965650e8a9","name":"Drop Already-Processed Items"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[4509,400],"id":"35e7d5aa-527d-49ca-9650-3ffa9f2443df","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4833,400],"id":"4dddae76-7219-41ca-9674-2f5b0c8e2a55","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.severity }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5157,400],"id":"5343f355-92c0-4ffe-bba8-5778c002a1a5","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b19838a5-296b-44d5-a3a1-6dbbbf25d136","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"99317e9e-a5c8-443a-ad7d-7b4c7c6778f1","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,400],"id":"708750b0-996b-4009-a180-762a1766e713","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5805,400],"id":"907c4994-01e7-4893-9487-3a161b3c3d59","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Notifications & Alerts Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Events"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[6129,400],"id":"40102778-9f19-4fc7-8545-eb172c6e4326","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6453,400],"id":"0656e0b5-8f0d-46ec-b3b8-185ca1c857a9","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6777,400],"id":"3a34112d-4820-4a35-9245-bf849e8e3314","name":"Persist Run Metadata"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Events"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[7101,400],"id":"4db4c7a8-3751-4005-8fbc-7c8421af7f56","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7425,400],"id":"c877218f-ccf6-4d78-8d69-cda3cdeafd45","name":"Record Sub-workflow Result"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f24ab724-ae21-4475-b405-019b7908df5c","leftValue":"={{ $json.severity }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7749,400],"id":"df658fdb-36b8-466d-b337-e959afde8869","name":"Guard Non-Empty severity"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[8073,400],"id":"a548b89c-ea1b-4b87-8e9e-5d4d05a0d2e7","name":"Stamp Processing Time"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8397,400],"id":"9eb4be4d-7960-43ac-9402-86f345d8ab46","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"metric","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8721,400],"id":"2f49edc5-2b59-4082-979d-75b2d807c7d7","name":"Sort Events Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"97542237-8440-4b3f-a94f-7404a0338af3","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"d5d27d64-5d80-422b-af1c-ae4d12d323a5","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"aa756e61-5213-426f-bfdd-e286c7710d7a","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9045,400],"id":"fdce1f5e-1f87-4a75-ac10-fd4155fab8fa","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Notifications & Alerts Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Events"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[9369,400],"id":"3961ac05-5bef-4b14-b05c-266ea962f4be","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#alerts","cachedResultName":"#alerts"},"text":"=✅ Send a daily digest with Airtable and Gmail on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9693,400],"id":"65eb56ca-f455-4ea9-b3cb-167bda42a5cc","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"41bea77f-9170-49cf-96b6-31c87f3b5fbe","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"c9fc0ab5-c7cf-468a-b226-8844889b3508","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e371d21b-eac6-4a95-9398-1196f3b40c4f","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9045,1420],"id":"f708e749-bff1-42ae-ada0-64bdd0bdf77f","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#alerts","cachedResultName":"#alerts"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9369,1420],"id":"4e4d47c5-2ee1-46dc-b9a3-48175daa71e9","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Database"},"title":"={{ $json.severity || $json.eventId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9693,1420],"id":"07412f62-8436-4875-ba4f-8958a49e78d9","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Read Source Feed","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"33ed0d16-5184-bc3b-c639-3f82062882f9","name":"Note: Daily Schedule"},{"parameters":{"content":"### Read Source Feed\n\nPulls the RSS feed and emits one item per entry (title, link, content).\n\nPorts: ①→ Skip Already-Seen Posts · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"a4402455-fd95-0087-85d2-e0afe344e47b","name":"Note: Read Source Feed"},{"parameters":{"content":"### Skip Already-Seen Posts\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Keep Top Stories","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"7d8dbf7a-801c-368f-d743-ad1e9d3a2f56","name":"Note: Skip Already-Seen Posts"},{"parameters":{"content":"### Keep Top Stories\n\nCaps the stream at 5 items to protect downstream quotas.\n\nNext: Rewrite for Our Audience (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"0ef663aa-b70b-845a-cc62-2426e92c29fa","name":"Note: Keep Top Stories"},{"parameters":{"content":"### Rewrite for Our Audience (AI)\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish to Gmail, Publish to Slack · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"89be322c-57e7-1919-76b8-da048be601f9","name":"Note: Rewrite for Our Audience (AI)"},{"parameters":{"content":"### Anthropic Chat Model\n\nChat model powering the AI step (model: `claude-sonnet-4-5-20250929`). Swap providers here without rewiring.\n\nFeeds **Rewrite for Our Audience (AI)** as `languageModel`\n\n🔑 Anthropic API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"8abaa910-25d8-6d37-651a-a003bd1935ba","name":"Note: Anthropic Chat Model"},{"parameters":{"content":"### Publish to Gmail\n\nSends an email via Gmail — subject is the first line of the message body, recipient comes from the item's `email` field.\n\nPorts: ①→ Confirm Cross-Post · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,280],"id":"2b2e1c2e-424e-70cd-8521-8fae05bcf712","name":"Note: Publish to Gmail"},{"parameters":{"content":"### Publish to Slack\n\nPosts a message to Slack (`#alerts`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nPorts: ①→ Confirm Cross-Post · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,760],"id":"6f4d122d-02c2-e0c0-76a9-9247a0355b89","name":"Note: Publish to Slack"},{"parameters":{"content":"### Confirm Cross-Post\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Log Published Posts (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"a834a2c9-3b74-1600-42bb-48845986105b","name":"Note: Confirm Cross-Post"},{"parameters":{"content":"### Log Published Posts (Airtable)\n\nCreates a new record in Airtable's 'Events' table.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"e99180ba-901d-9a05-49a7-f6f183019356","name":"Note: Log Published Posts (Airtable)"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per event (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"023a25f6-b40e-234e-4e4c-4fd55ace1b82","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"07642418-4549-bec4-a5cb-9935f0a024de","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Load Previous Snapshot\n\nPulls every page from the Notion database — fine for small datasets; add a filter if the database grows large.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"6add1617-0d69-7626-7e35-035fa375e585","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"edc88459-55f8-52ce-e212-1ee021190a23","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"59bbdfd4-973c-019f-4004-65fe8121b1fd","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"5c37d17d-97e8-6436-897a-1dfa6e9101fd","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"b6af77c2-59bc-16c7-cf98-f1e6d2bca3a1","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nCreates a new record in Airtable's 'Events' table.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"6214e56f-618c-655c-4310-e799c727b3f1","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"9aeea0c2-eba1-223d-7fc3-e3efff564353","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"d069491a-44fb-ced6-ff5e-fda0e6faf6ab","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"ea560b03-68a9-abe3-aaf6-8e0bebaa8f3e","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Guard Non-Empty severity","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"3a0f715c-80f2-9392-f2f8-be1cde00e91e","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Guard Non-Empty severity\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"ec8f573a-4a70-78d5-4f09-eb97e289383d","name":"Note: Guard Non-Empty severity"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"4ee90ffb-7c8c-c32a-7e59-bedfd6d4214c","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Sort Events Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,520],"id":"e81ace49-f1fc-607b-918d-4710e7ddf8c5","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Sort Events Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,520],"id":"df21e09f-5afd-1df8-ce3d-561bcce7a607","name":"Note: Sort Events Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,520],"id":"4889dad3-22d5-301f-de55-047fc984be80","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nCreates a new record in Airtable's 'Events' table.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9309,520],"id":"841d27a7-ba3a-4729-d915-1c0bf49e5c39","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#alerts`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9633,520],"id":"85ad52d1-bd29-92ee-9f35-c4217f56605e","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,1540],"id":"78dd28b8-9733-a121-9eec-548c7372759c","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#alerts`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9309,1540],"id":"1fd82a55-f129-af1b-015f-75b8e7288345","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9633,1540],"id":"0755698b-aa5b-0a4c-14b0-ef3d4fbf688b","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Send a daily digest with Airtable and Gmail on autopilot\n\n**Pattern:** Scheduled Digest · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nSend a daily digest with Airtable and Gmail on autopilot. It runs automatically on a schedule.\n\n## Why it exists\nManual escalations is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Read Source Feed → Skip Already-Seen Posts → Keep Top Stories → Rewrite for Our Audience (AI) → Publish to Gmail → Confirm Cross-Post → …\n\n## Use it for\n- Teams that want to scheduled digest without manual effort\n- Anyone automating escalations in software development\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Saves hours of manual work each week\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Anthropic API key; Google OAuth2; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"ab9a17bf-b40f-8258-e980-0b268fe61f49","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nDeduplication is cross-execution, not just within a single run — an RSS feed re-serves the same items on every poll, and without this the same story would get posted again on every scheduled check.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"e8378e97-2719-1db1-5b48-f1177c7ab4f6","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAbout as deep as this pattern goes — extend it:\n\n1. Turn off the AI rewrite step and compare the raw feed text against the rewritten version.\n2. Add a second RSS source and merge both into one feed before dedupe.\n3. Change 'Keep Top Stories' from 5 to 1 and see how it changes posting cadence.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"3c2e4b47-dfe9-7d0c-6553-e22d8b590d1d","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"8e6f3fcf-24bf-30e1-e462-0e2a2118dadb","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"f5ec6e85-31a9-f104-a057-f84b2c277d66","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"0d8b2f38-276b-dd4e-4517-6d422d3b8f45","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your escalations process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"af4061d0-c5ac-13ce-8a14-ffaa402f8ea2","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Read Source Feed","type":"main","index":0}]]},"Read Source Feed":{"main":[[{"node":"Skip Already-Seen Posts","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Skip Already-Seen Posts":{"main":[[{"node":"Keep Top Stories","type":"main","index":0}]]},"Keep Top Stories":{"main":[[{"node":"Rewrite for Our Audience (AI)","type":"main","index":0}]]},"Anthropic Chat Model":{"ai_languageModel":[[{"node":"Rewrite for Our Audience (AI)","type":"ai_languageModel","index":0}]]},"Rewrite for Our Audience (AI)":{"main":[[{"node":"Publish to Gmail","type":"main","index":0},{"node":"Publish to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Gmail":{"main":[[{"node":"Confirm Cross-Post","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Slack":{"main":[[{"node":"Confirm Cross-Post","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Confirm Cross-Post":{"main":[[{"node":"Log Published Posts (Airtable)","type":"main","index":0}]]},"Log Published Posts (Airtable)":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Guard Non-Empty severity","type":"main","index":0}]]},"Guard Non-Empty severity":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Sort Events Newest First","type":"main","index":0}]]},"Sort Events Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Daily Schedule":[{"json":{"eventId":"EVT-1201","severity":"warning","source":"api-gateway","metric":"latency_ms=820"}},{"json":{"eventId":"EVT-1202","severity":"critical","source":"payments-service","metric":"error_rate=12%"}}]},"versionId":"743b994c-f702-4a2e-bb2b-fdf49ec41cd0","id":"FDX09576"}