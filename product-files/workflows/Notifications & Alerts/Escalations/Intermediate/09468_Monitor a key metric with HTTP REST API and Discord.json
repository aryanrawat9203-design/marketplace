              "type": "string"
            },
            {
              "id": "f80a648c-e44d-4a30-aa0e-e5bb2c5d38c9",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "236a60b3-558a-4b98-8eb5-3c918a45dee4",
