eErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Database"},"title":"={{ $json.severity || $json.eventId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1998,1360],"id":"d8e94a33-2f7f-4867-a6ce-f87d1a2db75b","name":"Archive Unscored","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"bf83e0b1-e95b-4d91-af75-337a2a27f0a5","name":"Merge Tier Outcomes"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Events"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3618,400],"id":"1f126fac-250f-4ab1-94bf-1c0cb5d6cbb0","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3942,400],"id":"0687ab0f-87da-432d-b580-81795189c8df","name":"Record Sub-workflow Result"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4266,400],"id":"0184c40d-5800-45b2-a910-e72ff3601ab0","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4590,400],"id":"0a72dbbc-262b-4901-aa3d-8f9c768dd8bd","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.severity }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4914,400],"id":"adede645-bc03-4d0b-b9dd-377c6e3bbf6e","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"12b49c5d-90a6-4485-9a8a-063cb85d9bc4","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9c07c38b-c9ba-44d4-a17b-5ee089ba796f","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"af3f85cc-afd4-4ee8-a267-0f59cf58ed25","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per event (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.eventId, j.severity].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"7c171cf2-84ec-4c9b-9244-f9292b98cec6","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5886,400],"id":"342cf589-413a-43e3-98e0-33c0cc015737","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[6210,400],"id":"0741e1c0-f14c-4a45-bd8a-409343f80b25","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Database"},"title":"={{ $json.severity || $json.eventId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6534,400],"id":"84c02060-2531-4f7d-8b68-e2b8dc110011","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6858,400],"id":"382ccacd-4c3d-49f6-9959-1b3058be7a84","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"c01ae586-8350-4e3f-b1d2-becf805ee65a","name":"Compute Drift vs Snapshot"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"aad4c2d4-797f-4600-8d51-8cee7fb6729d","leftValue":"={{ $json.severity }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7506,400],"id":"dbaf0e4a-f3eb-4d81-bbeb-1982f23eb6a4","name":"Guard Non-Empty severity"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":