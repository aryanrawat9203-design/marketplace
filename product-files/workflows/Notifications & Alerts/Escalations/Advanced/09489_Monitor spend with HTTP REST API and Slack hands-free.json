              "type": "string"
            },
            {
              "id": "f26654c4-d729-40d0-84b6-9b52dd161530",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "af182570-dec0-4a39-b4b6-8b030df699e4",
