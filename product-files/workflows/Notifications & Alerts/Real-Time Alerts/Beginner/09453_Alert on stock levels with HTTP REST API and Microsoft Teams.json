{"name":"Alert on stock levels with HTTP / REST API and Microsoft Teams","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":30}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"26f5754e-c8fe-4d5b-ba77-d984cbc6bcf0","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/events","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"3947b2be-ad11-4d4f-8634-1f6bd1e7b516","name":"Fetch Current Metrics","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each event 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.severity) score += 20;\n  if (j.source) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"0430e5a8-d37e-4bed-a230-b90bfe7c2d84","name":"Compute Severity Signals"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2b3bd11f-3eca-433e-895a-a3d2ba0369d2","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":40,"operator":{"type":"number","operation":"lt"}}],"combinator":"and"},"renameOutput":true,"outputKey":"info"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f0225cdc-3ffa-4a33-83ba-990abf697915","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":70,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warning"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"11c2c0ac-9da6-4db1-a0fd-74b3e2efaaae","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":90,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"critical"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"4cb019f2-1788-4c3d-9619-b7d9ea7c7927","name":"Grade Severity Tier"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,-80],"id":"3f1a14c2-532e-4b49-9d56-baf0c1119bac","name":"Just Record (Info)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"chatMessage","chatId":"OPS_TEAM_CHAT_ID","message":"=🟠 Warning tier reached: {{ $json.eventId }} at {{ $json.score ?? $json.last }}","options":{}},"type":"n8n-nodes-base.microsoftTeams","typeVersion":2,"position":[1350,400],"id":"443634ca-665c-479c-b5b2-f76df10568f8","name":"Warn Channel (Microsoft Teams)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#alerts","cachedResultName":"#alerts"},"text":"=🔴 CRITICAL: {{ $json.eventId }} breached threshold — act now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"d54e9fb6-90ac-4d7f-9c68-7e6458344686","name":"Page Urgently (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1998,1360],"id":"5bad6701-4edd-4db8-b6a3-276257d1db7e","name":"Archive Unscored","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"925171b7-5835-442d-87e8-75bfab95b75c","name":"Merge Tier Outcomes"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3618,400],"id":"0b0beb4f-5b4f-4a38-8209-3476067fe2df","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"c467caaf-68b0-4911-a3de-c8abc53e542f","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4266,400],"id":"95b9eab6-d91b-4686-bbc0-6f7991caa94b","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4590,400],"id":"c6210de3-024f-411e-92a1-336912cd07e3","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4914,400],"id":"239e0f1c-c0de-41d0-89b4-a0074a453ec7","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"ac6dfa71-26b7-4827-b631-101adca7a138","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"5b2e0505-406a-417e-a87d-8c58160a4d2c","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f8a483d2-1c15-423f-bdd2-6ede2baa3662","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"91f3e198-5a95-41ee-8a72-8a9e8765e1e9","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"a0e62e91-b9cf-4ce3-87c2-9c82263c23be","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"71ec1b6c-186f-4c3c-ae07-eeea79045054","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#alerts","cachedResultName":"#alerts"},"text":"=✅ Alert on stock levels with HTTP / REST API and Microsoft Teams — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,400],"id":"ccc73ce9-d304-4d68-843e-80c167f6eea1","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"570a43e7-896f-4077-b2fb-17c2bfd358f7","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"7a291756-e499-4768-bb75-2d4ff470691c","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"1ba3a423-3186-4465-a112-e77893caa3c4","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"e5c13a37-b56e-45c0-a448-5b92737c7cbb","name":"Capture Failure Context"},{"parameters":{"resource":"chatMessage","chatId":"OPS_TEAM_CHAT_ID","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.microsoftTeams","typeVersion":2,"position":[5886,1420],"id":"6efea681-c841-4f33-b639-9210f89bf5e3","name":"Escalate Failure to Microsoft Teams","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Event Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappin