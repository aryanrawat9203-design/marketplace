                },
                "conditions": [
                  {
                    "id": "f21add1f-620b-4f4f-9b76-29b18442d1fb",
                    "leftValue": "={{ $json.score ?? $json.momentum ?? 0 }}",
                    "rightValue": 40,
                    "operator": {
                      "type": "number",
                      "operation": "lt"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
