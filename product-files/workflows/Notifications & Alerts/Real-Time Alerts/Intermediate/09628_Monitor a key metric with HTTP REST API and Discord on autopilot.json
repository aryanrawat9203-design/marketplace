              "type": "string"
            },
            {
              "id": "12579c83-267b-4c4c-a4bb-fad27885a7e5",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "cb176fb0-bda5-4cd2-acaf-9e9a387ed7ea",
