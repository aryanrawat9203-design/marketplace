                    "id": "156f4fc5-051c-4439-b6c5-161f02212df3",
                    "leftValue": "={{ $json.score ?? $json.momentum ?? 0 }}",
                    "rightValue": 40,
                    "operator": {
                      "type": "number",
                      "operation": "lt"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
