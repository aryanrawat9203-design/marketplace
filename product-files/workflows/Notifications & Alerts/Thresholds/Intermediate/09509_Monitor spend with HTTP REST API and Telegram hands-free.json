              "type": "string"
            },
            {
              "id": "acc9c75e-bad5-42c8-b5e0-e855a84f7d21",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "4d08aef5-be83-4b7b-9385-97126bb35a7c",
