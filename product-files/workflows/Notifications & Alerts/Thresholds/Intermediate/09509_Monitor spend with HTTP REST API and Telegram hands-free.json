          "combinator": "and",
          "conditions": [
            {
              "id": "a2fc577a-ddbc-4757-92f4-e2a546d77155",
              "leftValue": "={{ $json.category }}",
              "rightValue": "paid",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "ff202554-f08a-456d-a24a-cd86a1a69ca4",
      "name": "Route on Condition",
