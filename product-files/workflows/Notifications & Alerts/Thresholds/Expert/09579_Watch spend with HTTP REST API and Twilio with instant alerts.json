          "combinator": "and",
          "conditions": [
            {
              "id": "2f06f099-48c4-4569-b232-a27269b7d961",
              "leftValue": "={{ $json.type }}",
              "rightValue": "high",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "286040f1-9d5a-4a5b-b79b-1db1f986380e",
