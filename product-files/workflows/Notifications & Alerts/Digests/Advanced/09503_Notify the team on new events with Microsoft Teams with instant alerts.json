{"name":"Notify the team on new events with Microsoft Teams with instant alerts","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09503-event","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"194b5182-b6e0-4890-a1eb-2bf4c2e82170","name":"Receive Inbound Webhook","webhookId":"e83246cf-d51a-4c63-93f7-e0decdee7922"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"f8303f2c-646e-4386-acef-3c18063d7e17","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e5713162-1f6a-4217-820a-5e6129021692","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"d47060fa-ed9b-4b7a-befa-1283719f9c45","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"b36fe785-f0ad-4704-ac1d-841ebb20f963","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"f9e3fb4d-6683-4d8c-8866-b455a9eb5ba8","name":"eventId","value":"={{ $json.body?.eventId || $json.body?.id }}","type":"string"},{"id":"65201ed6-0732-40e5-98db-14731621102f","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"064db582-0e3e-49fc-9e31-83fd963b25f8","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"84