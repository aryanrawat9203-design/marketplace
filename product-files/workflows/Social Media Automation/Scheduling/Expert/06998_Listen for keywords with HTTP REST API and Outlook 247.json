            {
              "id": "66fbb51a-50fe-4847-8c61-4a1d93c7679e",
              "leftValue": "={{ $json.score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "4275e5b3-7531-461b-9981-98a923bb41d7",
