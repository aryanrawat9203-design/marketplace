{"name":"Auto-post the content calendar with PostgreSQL and WordPress 24/7","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":4}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"5b0e92d9-a501-42a8-b551-3eadbac51633","name":"Hourly Schedule"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[54,400],"id":"65933fd9-7d2e-4621-ac8f-7a8f110580a4","name":"Read Content Calendar (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d8c8edd2-40c1-44dd-9b8c-1b1b1a300707","leftValue":"={{ new Date($json.scheduledAt || 0) <= new Date() }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}},{"id":"fb9a2e14-e103-4c9d-90f8-7ade273cbbff","leftValue":"={{ $json.status }}","rightValue":"published","operator":{"type":"string","operation":"notEquals"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[378,400],"id":"be85c6c9-25f2-44a8-8055-121a5649bd1a","name":"Due for Publishing?"},{"parameters":{"batchSize":1,"options":{"reset":false}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[702,400],"id":"18ab12bb-533b-4073-9a5d-e4443d78e18d","name":"Post One at a Time"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"={{ $json.content }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1026,880],"id":"27e6c630-909b-4184-bae5-f885ee4971d3","name":"Publish to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":30,"unit":"seconds"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1674,880],"id":"bd54e0fb-ebb9-4f8c-b989-036004921b6f","name":"Space Out Posts"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["postId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,880],"id":"84b07bf0-90f9-47ba-b6dc-677101a2607c","name":"Mark Row Published","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[2970,400],"id":"d866ea9b-cdfd-4456-bf39-0085b247b512","name":"Count Published"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3294,400],"id":"3b787da0-d366-47bc-9450-7afe81fdd744","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO post_log (postId, content, platform, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.postId, $json.content, $json.platform ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[3618,400],"id":"644e024d-2fca-4bb8-b6db-d186eca52214","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3942,400],"id":"f5d79c32-b62d-4072-9ffb-aabb2260528d","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4266,400],"id":"b93ef65f-e43f-4722-80d4-5aacc6f4ad0f","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.content }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4590,400],"id":"7777cb18-ff81-4cc9-8003-a546cf35e7f2","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"20560b10-1431-418a-bec8-21419bbf39e2","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"258a430b-5d01-43d7-8e31-96dc62ae8077","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"824cc201-cc55-40dd-a7ae-8619b50c9bfe","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"4bb00bc2-0cd4-44df-9914-2198cfeca25a","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"ebd70d48-af1a-480c-917e-d7b5faec4f14","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"889c1051-fa72-4924-bf1b-5d89cb6cbef5","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c2de9ccc-a02e-4fe8-a9cf-7091a32f085b","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"07f6ac7b-2ba3-4c1b-b25e-01bf46a6c9d0","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"00ebed3d-8f15-409d-95dd-6910d5aeef33","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO post_log (postId, content, platform, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.postId, $json.content, $json.platform ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[6210,400],"id":"afcb88bd-0951-42ca-b6be-4ae12af10af5","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=✅ Auto-post the content calendar with PostgreSQL and WordPress 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,400],"id":"f2412c7c-c54f-46e6-b845-5a68cfed1744","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"79a415a8-552d-4bb3-91df-34680ec9cf4f","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"f36348f4-beab-4339-a7b3-a18886b0d015","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ac002560-a08e-4fb6-8dae-3cb80d804929","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"1327ee0b-c650-47b0-9317-bb7576f81157","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,1420],"id":"07479c9a-d6f4-422e-99b4-255b0c88a5d2","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6534,1420],"id":"e098e830-a167-4fc8-add7-10c55b8659a0","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 4 h. No input data; downstream nodes fetch what they need.\n\nNext: Read Content Calendar (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"4b2b040c-1ad8-b86c-1161-d1b01bf3102c","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Read Content Calendar (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Due for Publishing? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"6cc94bad-60cd-bda6-4cb8-539fcb834113","name":"Note: Read Content Calendar (Google Sheets)"},{"parameters":{"content":"### Due for Publishing?\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Post One at a Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"a2b669ed-a9bc-990d-4973-d3b0789cbb75","name":"Note: Due for Publishing?"},{"parameters":{"content":"### Post One at a Time\n\nLoop controller — releases 1 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Count Published · ②→ Publish to Slack","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"e7a44dc2-0ebf-b628-405f-3dc8545be1c0","name":"Note: Post One at a Time"},{"parameters":{"content":"### Publish to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Space Out Posts · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1000],"id":"75723d46-40f1-f944-95ee-d816a988ab22","name":"Note: Publish to Slack"},{"parameters":{"content":"### Space Out Posts\n\nPauses 30 seconds — spacing calls to respect rate limits.\n\nNext: Mark Row Published","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"0bca8b68-073f-ed51-11f3-9aa73bfafe98","name":"Note: Space Out Posts"},{"parameters":{"content":"### Mark Row Published\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Post One at a Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1000],"id":"c5018f7d-b2b5-7de7-d297-7c57999a5f17","name":"Note: Mark Row Published"},{"parameters":{"content":"### Count Published\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"e8103551-c044-05a8-381c-0110ec201854","name":"Note: Count Published"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"1eea74a3-95ca-8336-5270-f0dbae920edb","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"a4095437-57f1-7e89-8a95-1245168feeba","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"15a70510-52e1-dbe3-c226-760d66856f79","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"67eec05e-b1c5-3823-3bf1-b340c576f0d2","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"7fa58ab7-7f62-ada2-9e9a-9b631103ce2c","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"dd605009-e612-fc7d-9644-1089e58f622c","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"6cbc3dec-5577-a650-e4e6-08cbe99806b0","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"de644485-cc83-897e-058d-b05019cbfe54","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"fa8c11b0-ca4d-867e-b924-c6e4c41d4134","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"4dba3daf-f9c3-7b9f-fd96-ef83d3a46eec","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"fad898a6-3701-a67e-897a-4ae946596bf8","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"f46b2fe4-5d3c-fa13-e28e-6ee3478def5a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"c7ffcc5e-6e61-12db-17f3-0a1915810d69","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"6fd75ba2-30fe-b828-dfa0-452d9d907c49","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Auto-post the content calendar with PostgreSQL and WordPress 24/7\n\n**Pattern:** Social Scheduler · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nAuto-post the content calendar with PostgreSQL and WordPress 24/7. It runs automatically on a schedule.\n\n## Why it exists\nManual scheduling is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Read Content Calendar (Google Sheets) → Due for Publishing? → Post One at a Time → Count Published → Serialize Run Output (CSV) → Archive Row Snapshot → …\n\n## Use it for\n- Teams that want to social scheduler without manual effort\n- Anyone automating scheduling in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Has retries and error handling built in\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"aa64b95c-d373-0b56-88b0-655bf77c1c91","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"cf570676-eb7a-2921-fc87-7a1433bbc627","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"3fad3d3e-f9c1-fb93-4d9c-1696c239f929","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your scheduling process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"ea823ea6-e4bc-d63f-d728-0335686fbd3f","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Read Content Calendar (Google Sheets)","type":"main","index":0}]]},"Read Content Calendar (Google Sheets)":{"main":[[{"node":"Due for Publishing?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Due for Publishing?":{"main":[[{"node":"Post One at a Time","type":"main","index":0}]]},"Post One at a Time":{"main":[[{"node":"Count Published","type":"main","index":0}],[{"node":"Publish to Slack","type":"main","index":0}]]},"Publish to Slack":{"main":[[{"node":"Space Out Posts","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Space Out Posts":{"main":[[{"node":"Mark Row Published","type":"main","index":0}]]},"Mark Row Published":{"main":[[{"node":"Post One at a Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count Published":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"761fbd39-b2a8-4ec4-af55-6ca9f740079b","id":"FDX07093"}