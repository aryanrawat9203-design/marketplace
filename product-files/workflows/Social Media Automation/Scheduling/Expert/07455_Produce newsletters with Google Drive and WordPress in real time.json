          "conditions": [
            {
              "id": "ec894a00-853d-4df1-a963-21c425c46f42",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
