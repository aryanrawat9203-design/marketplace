          "conditions": [
            {
              "id": "e995b0fa-0ba9-4759-8fd4-425ed5834a96",
              "leftValue": "={{ $json.receivedAt || $now.toISO() }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "cb8a2d7f-2448-4e4d-9b77-03893443332a",
