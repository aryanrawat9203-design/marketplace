{"name":"Listen for keywords with HTTP / REST API and Microsoft Teams 24/7","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":6}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"4c599a7a-8033-4dc4-9c3d-0c39ee1cfef5","name":"Hourly Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"03da501b-85fa-44b3-9f32-fee09ee8c382","leftValue":"={{ $json.postId || $json.content }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"216f35f9-e643-4f2f-9843-e492edfc882e","name":"Keep Valid Posts"},{"parameters":{"inputText":"={{ $json.content || JSON.stringify($json) }}","categories":{"categories":[{"category":"Mention","description":"Posts that are mention for the scheduling team."},{"category":"Question","description":"Posts that are question for the scheduling team."},{"category":"Complaint","description":"Posts that are complaint for the scheduling team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"e2102269-99e0-439d-b077-50f32053c64c","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[621,970],"id":"010c5029-36a9-4ecb-b003-d6e56b1bbbe5","name":"Anthropic Chat Model"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[945,-80],"id":"66e89ad3-3eb0-4b9f-a483-