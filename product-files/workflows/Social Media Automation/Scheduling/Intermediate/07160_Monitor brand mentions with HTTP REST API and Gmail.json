00],"id":"f7d0da4b-1ef2-403d-93c2-3ae3bf315984","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5157,400],"id":"a52ace65-0868-4545-b3e6-7cfddb0cc601","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=✅ Monitor brand mentions with HTTP / REST API and Gmail — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5481,400],"id":"49606b44-dbb4-43d1-a14c-50665907888d","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"7d9c4a5b-b2f8-4b65-a6f1-90e703bea1cd","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"794793e0-82c8-4e2a-9bcb-ef5ffcd4ef95","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"c1cf6008-e0e6-499e-a068-20cf51ca5f0d","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4833,1420],"id":"a443b5d3-8931-439f-ae53-f236c7a8fba9","name":"Capture Failure Context"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[5157,1420],"id":"c4952493-b162-4118-9ed5-3350ea023f29","name":"Escalate Failure to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 2 h. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Post","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d355cbe6-c08f-c18b-7a04-74f5f15d5d78","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Stamp & Shape Post\n\nShapes the item: writes `postId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"7c59387e-7469-473b-5ac7-976a0492bdb4","name":"Note: Stamp & Shape Post"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.postId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Classify with AI · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"1f5b45c4-cb3e-3e3d-32ff-02ad31579a97","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"44f094e9-5a9b-f4e0-5457-b3f14718fd8d","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Classify with AI\n\nLLM classification into: Mention, Question, Complaint (+fallback). Output port order matches this list.\n\nPorts: ①→ Store as Mention · ②→ Store as Question, Capture Failure Context · ③→ Store as Complaint · ④→ Alert Slack — Other\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"b293280d-71b2-f32d-f995-5723272d0736","name":"Note: Classify with AI"},{"parameters":{"content":"### Anthropic Chat Model\n\nChat model powering the AI step (model: `claude-sonnet-4-5-20250929`). Swap providers here without rewiring.\n\nFeeds **Classify with AI** as `languageModel`\n\n🔑 Anthropic API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"17d68890-ed96-4787-88ec-603655c149dc","name":"Note: Anthropic Chat Model"},{"parameters":{"content":"### Store as Mention\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,40],"id":"de9d8fbc-e988-5a12-6b10-a60a5da8b714","name":"Note: Store as Mention"},{"parameters":{"content":"### Store as Question\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,490],"id":"e06eb5f4-c972-9b8d-0e41-06d1538e48dd","name":"Note: Store as Question"},{"parameters":{"content":"### Store as Complaint\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,940],"id":"29109620-c3cc-de17-c8ea-c066299cb4e3","name":"Note: Store as Complaint"},{"parameters":{"content":"### Alert Slack — Other\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,1390],"id":"7f886f4c-0d2e-9da9-68f8-8db1ce8aa57b","name":"Note: Alert Slack — Other"},{"parameters":{"content":"### Reunite Branches\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"152f5c8f-9283-11f5-53d4-212429c6c069","name":"Note: Reunite Branches"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"6ab9e4d5-3ae5-b8da-3b02-f5026041cd66","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"8959560c-bcdc-7ee5-3405-62c4ca17bb16","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"c84903ac-f6c8-7972-a6cb-3c2ec0c8a14a","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"3bb3e4ec-6c57-4c97-8e4c-9f96ed5b00d5","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"adc48b51-43e4-e3e0-5b2c-b40943c6a198","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"b6b4c65b-30c5-c7f1-6444-922bd4d43922","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Gmail","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,1540],"id":"4a21a90d-9afc-7e20-3fbb-fb3921e7af5a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"7e86bead-7a40-721e-d8fc-bd6b9e531e0c","name":"Note: Escalate Failure to Gmail"},{"parameters":{"content":"# Monitor brand mentions with HTTP / REST API and Gmail\n\n**Pattern:** Social Listening · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nMonitor brand mentions with HTTP / REST API and Gmail. It runs automatically on a schedule.\n\n## Why it exists\nManual scheduling is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Stamp & Shape Post → Payload Valid? → Classify with AI → Store as Mention → Reunite Branches → Cap Batch Volume → …\n\n## Use it for\n- Teams that want to social listening without manual effort\n- Anyone automating scheduling in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Removes copy-paste errors\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: Anthropic API key; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a79fccf7-41b0-8fb6-a6f8-855c333ea299","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"41adce13-1c85-2d13-b863-6a3308c6bf72","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"13089aa3-a06d-ad49-d297-f81ec8ac1ab8","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your scheduling process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"c76a2a83-c5eb-11a7-ab73-b5f48587908b","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Stamp & Shape Post","type":"main","index":0}]]},"Stamp & Shape Post":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Classify with AI","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Anthropic Chat Model":{"ai_languageModel":[[{"node":"Classify with AI","type":"ai_languageModel","index":0}]]},"Classify with AI":{"main":[[{"node":"Store as Mention","type":"main","index":0}],[{"node":"Store as Question","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Store as Complaint","type":"main","index":0}],[{"node":"Alert Slack — Other","type":"main","index":0}]]},"Store as Mention":{"main":[[{"node":"Reunite Branches","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Question":{"main":[[{"node":"Reunite Branches","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Complaint":{"main":[[{"node":"Reunite Branches","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Alert Slack — Other":{"main":[[{"node":"Reunite Branches","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Reunite Branches":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Gmail","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"49c0f893-866f-4d56-9849-0844babd9079","id":"FDX07160"}