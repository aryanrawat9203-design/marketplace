          "combinator": "and",
          "conditions": [
            {
              "id": "ec096e0e-07db-4dbf-9391-cf1a252ac738",
              "leftValue": "={{ $json.score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "38358863-302d-4d89-8058-18f3838accff",
      "name": "Filter Items",
