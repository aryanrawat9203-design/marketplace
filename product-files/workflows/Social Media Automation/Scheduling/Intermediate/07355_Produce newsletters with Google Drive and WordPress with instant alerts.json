    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming post records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    postId: String(j.postId ?? j.id ?? '').trim(),\n    content: typeof j.content === 'string' ? j.content.trim() : j.content ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40,
        400
      ],
      "id": "30e19655-4921-42f9-aaaa-e4f066502eaa",
      "name": "Normalize Post Payload"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "b7490c4c-262d-43d6-b3f1-8252a5365ee3",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "cb40dcd6-70fb-401f-838f-13392b476b9f",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        280,
        400
      ],
      "id": "4dde0c8a-6726-4938-ab9f-2c63a1444d3f",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality scheduling content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        520,
        400
      ],
      "id": "4aa4fd13-2e01-4d98-a727-f1a2c09e9a28",
      "name": "Draft with AI Writer",
      "onError": "continueErrorOutput"
    },
    {
