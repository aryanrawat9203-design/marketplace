nt","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[945,970],"id":"786fa913-720b-4412-9b8f-1b2164470ace","name":"Anthropic Chat Model"},{"parameters":{"description":"Delegate research sub-tasks for a post to the Research specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Research Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[864,1390],"id":"3a6683b4-b21a-4ae0-8145-bd431464ad6f","name":"Research Specialist (Sub-workflow)"},{"parameters":{"description":"Delegate draft sub-tasks for a post to the Draft specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Draft Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[1120,1390],"id":"a640e34f-f46d-4387-b8e0-f3864b08d6fd","name":"Draft Specialist (Sub-workflow)"},{"parameters":{"description":"Delegate review sub-tasks for a post to the Review specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Review Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[1552,1390],"id":"8cba3d66-b8a4-486a-a857-aaaef1a64153","name":"Review Specialist (Sub-workflow)"},{"parameters":{"jsonSchemaExample":"{\n  \"summary\": \"string\",\n  \"sections\": [\"string\"],\n  \"status\": \"complete\"\n}"},"type":"@n8n/n8n-nodes-langchain.outputParserStructured","typeVersion":1.3,"position":[1714,970],"id":"ebda6faf-d562-4085-b831-fdd3ca3d2e32","name":"Enforce Result Schema"},{"parameters":{"fieldToSplitOut":"output.sections","options":{}},"type":"n8n-nodes-base.splitOut","typeVersion":1,"position":[2038,400],"id":"f59f0ad1-3902-470d-b5a0-40d1ce93f2fa","name":"Unpack Sections"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO post_log (postId, content, platform, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.postId, $json.content, $json.platform ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2362,400],"id":"7ea84893-1add-4b97-b1ab-6741ef103e88","name":"Persist Deliverable to PostgreSQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Posts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[2686,400],"id":"43cf6c3c-34b7-48ff-8dc3-921073acd2b0","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3010,400],"id":"4d6c4be9-3038-4045-88d9-b5a650482662","name":"Record Sub-workflow Result"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3334,400],"id":"80de27df-e685-47b0-9a27-8cc869b9766e","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3658,400],"id":"63e7f757-1e16-42f7-ae5c-a6ace6539619","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3982,400],"id":"6155017b-8486-4db5-8dca-e0c003c89fb2","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4306,400],"id":"8fdbef74-9dee-45d1-9a1e-1c2107f17dbc","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4630,400],"id":"5a1c3443-90cc-4d54-9d13-e63424d2ae66","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Database"},"title":"={{ $json.content || $json.postId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[4954,400],"id":"a60e54c0-6a8d-4628-a61b-8325fc555818","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per post (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.postId, j.content].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5278,400],"id":"18c8624c-c9eb-4424-97a0-3d68fb644bff","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5602,400],"id":"9186ee73-aeb8-44ab-ac29-6ae4831be6db","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.content }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5926,400],"id":"bf8f249f-c0d3-4b4a-8bbb-1c99d6076091","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"73e9938d-d024-4b32-a5eb-7378d45c8a88","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5b77aaab-4a6c-4c09-bdf5-64ccdbed2ca7","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6250,400],"id":"b53927f3-5c55-44a1-8482-988fc6f147ca","name":"Fold In Enrichment Fields"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[6574,400],"id":"6db1a90d-2072-428a-afd5-15138f02e2a1","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"e1a0909e-0646-4833-917c-116eba6ec17f","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{