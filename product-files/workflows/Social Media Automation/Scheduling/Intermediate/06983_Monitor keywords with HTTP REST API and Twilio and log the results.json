          "conditions": [
            {
              "id": "27b069dd-19b5-489b-98b3-84c20229f15e",
              "leftValue": "={{ $json.receivedAt || $now.toISO() }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
