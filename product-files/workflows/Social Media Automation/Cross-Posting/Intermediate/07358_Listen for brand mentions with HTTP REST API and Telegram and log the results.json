            {
              "id": "3582a7ab-373b-4108-a7f3-32ddea2e055a",
              "leftValue": "={{ $json.score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "4f021109-c80c-4e72-8645-cf8e99b113e5",
