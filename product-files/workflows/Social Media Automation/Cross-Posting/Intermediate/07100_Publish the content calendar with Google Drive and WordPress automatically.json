      "id": "87d8e0e6-adf3-4dd1-8d66-30581aae82a9",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality cross-posting content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
