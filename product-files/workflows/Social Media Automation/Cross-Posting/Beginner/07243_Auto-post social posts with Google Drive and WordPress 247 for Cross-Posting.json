dPress 24/7 for Cross- — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,400],"id":"b1fe33ac-f30d-44d2-a815-abcbb0dfa4ae","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"86ea862d-680c-485f-ba32-775e51bbfbdf","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a864a49e-ddc5-4af9-b25d-196ab3a21d50","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"532028bc-4219-4afd-8d01-f843887ca8bf","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,1420],"id":"cbea2ad8-8404-4213-ae5b-c3e797b692d2","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5562,1420],"id":"ed524fc6-5ac6-4239-98ff-889c7dbb1171","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 12 h. No input data; downstream nodes fetch what they need.\n\nNext: Read Content Calendar (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"44f175dd-dee3-4428-1ad0-c2fc3c2d58a2","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Read Content Calendar (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Due for Publishing? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"09e9e353-a5bd-5337-7bab-12ad5a36f198","name":"Note: Read Content Calendar (Google Sheets)"},{"parameters":{"content":"### Due for Publishing?\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Post One at a Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"1cfb24b0-801a-ee8c-5c5f-9cad6835b892","name":"Note: Due for Publishing?"},{"parameters":{"content":"### Post One at a Time\n\nLoop controller — releases 1 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Count Published · ②→ Publish to Slack","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"f21fcccc-ed24-b8f7-ba52-3efb25fdd88a","name":"Note: Post One at a Time"},{"parameters":{"content":"### Publish to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Space Out Posts · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1000],"id":"14d356c7-ea84-89e1-1c04-7d1bbfd3d40d","name":"Note: Publish to Slack"},{"parameters":{"content":"### Space Out Posts\n\nPauses 30 seconds — spacing calls to respect rate limits.\n\nNext: Mark Row Published","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"d028f7fb-2723-6991-d052-bf23722d7925","name":"Note: Space Out Posts"},{"parameters":{"content":"### Mark Row Published\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Post One at a Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1000],"id":"163c2157-27c9-e8cd-5694-d45d22bd9683","name":"Note: Mark Row Published"},{"parameters":{"content":"### Count Published\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"4459536c-6ccc-85e2-419c-5f0bb17ee85d","name":"Note: Count Published"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Guard Non-Empty content","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"34b1af65-d637-7db1-ff72-adba1c792b2f","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Guard Non-Empty content\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"0e1361c0-7948-4ce7-5d05-2b5eed8db015","name":"Note: Guard Non-Empty content"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"de26eebf-9f90-b244-15b0-4a540be4824e","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"c9d16e57-dadb-108e-ab49-dfb32d9df830","name":"Note: Align Field Names"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Posts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"62531d16-6284-d812-08d9-c45a05af4f5e","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Posts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"9e80b5db-3449-08bc-a260-b12b71cd7005","name":"Note: Sort Posts Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"dd50b202-1833-41bd-201e-a5171cea5224","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"00576ebb-c5b4-9157-a67a-3c8db111c638","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"e73255ec-1d52-66fd-b20c-6dba900861c0","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"e0b4fc3b-fbc8-895e-5dea-4bfff51e7cba","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"25b9bb26-f78f-5ec0-edc3-516fd3059b51","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Auto-post social posts with Google Drive and WordPress 24/7 for Cross-Posting\n\n**Pattern:** Social Scheduler · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nAuto-post social posts with Google Drive and WordPress 24/7 for Cross-Posting. It runs automatically on a schedule.\n\n## Why it exists\nManual cross-posting is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Read Content Calendar (Google Sheets) → Due for Publishing? → Post One at a Time → Count Published → Cap Batch Volume → Guard Non-Empty content → …\n\n## Use it for\n- Teams that want to social scheduler without manual effort\n- Anyone automating cross-posting in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Removes copy-paste errors\n- Standardizes the process every time\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"04c1b440-66e5-281a-dc1c-d30a5772fc2c","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"86055d5c-9b4b-9686-b405-fcc17c400c63","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"53eb229e-e215-3751-bacd-c13d5164aaaf","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your cross-posting process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"b4c7ee46-9c78-66b2-e06d-847dadc8e445","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Read Content Calendar (Google Sheets)","type":"main","index":0}]]},"Read Content Calendar (Google Sheets)":{"main":[[{"node":"Due for Publishing?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Due for Publishing?":{"main":[[{"node":"Post One at a Time","type":"main","index":0}]]},"Post One at a Time":{"main":[[{"node":"Count Published","type":"main","index":0}],[{"node":"Publish to Slack","type":"main","index":0}]]},"Publish to Slack":{"main":[[{"node":"Space Out Posts","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Space Out Posts":{"main":[[{"node":"Mark Row Published","type":"main","index":0}]]},"Mark Row Published":{"main":[[{"node":"Post One at a Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count Published":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Guard Non-Empty content","type":"main","index":0}]]},"Guard Non-Empty content":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Posts Newest First","type":"main","index":0}]]},"Sort Posts Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"8067cae0-0159-4a0c-b610-e8510df53cac","id":"FDX07243"}