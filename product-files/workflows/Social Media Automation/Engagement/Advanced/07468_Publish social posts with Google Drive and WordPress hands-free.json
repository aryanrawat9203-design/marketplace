":"67bcf82f-4493-40b9-8a1d-1db032e8b67c","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"078d5bab-a7b6-4286-a1f2-26aba160253a","name":"Tag Pipeline Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7506,400],"id":"b41d0b40-7617-4207-b714-d69e899e892f","name":"Stamp Processing Time"},{"parameters":{"dataToSave":{"values":[{"key":"postId","value":"={{ $json.postId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7830,400],"id":"18218ce3-25e5-40a9-a1c7-8cca7f391de2","name":"Save Execution Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"scheduledAt","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8154,400],"id":"44b53f60-2857-4e1a-835f-0497f306c96e","name":"Sort Posts Newest First"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8478,400],"id":"18768919-e676-4941-abae-98affc57aad6","name":"Cap Batch Volume"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"630e5356-601e-4430-af2b-5d8db9c46bfa","leftValue":"={{ $json.content }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8802,400],"id":"cea38a6a-8e0e-49cf-9d36-26cf8a3a961f","name":"Guard Non-Empty content"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"postId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[9126,400],"id":"58ea60ca-a37a-4428-a722-7fd872afd619","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"9749115d-8c6a-4468-af13-50f107f6de7e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"