      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "inputText": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "fc7a2b1b-b956-4129-8c4a-b82eae81d0e6",
