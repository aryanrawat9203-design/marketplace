          "combinator": "and",
          "conditions": [
            {
              "id": "a2d4cb1f-9daf-4edd-acf0-8fe44dd592d0",
              "leftValue": "={{ $json.score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "83f9f7f7-dd42-4313-8bcd-6e25f578262c",
