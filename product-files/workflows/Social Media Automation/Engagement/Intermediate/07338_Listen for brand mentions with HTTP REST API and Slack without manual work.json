            {
              "id": "39b4d917-ac31-45f5-a855-cfacf789d94d",
              "leftValue": "={{ $json.score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "9c1189d7-5357-44bf-a168-f50009210d68",
