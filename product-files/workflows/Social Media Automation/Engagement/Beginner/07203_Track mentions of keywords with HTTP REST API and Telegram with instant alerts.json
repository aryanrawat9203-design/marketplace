{"name":"Track mentions of keywords with HTTP / REST API and Telegram with instant alerts","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":4}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"ca945c5f-0918-48b7-b9ad-b010b576af2f","name":"Hourly Schedule"},{"parameters":{"method":"GET","url":"https://example-market.com/posts","options":{"timeout":20000,"response":{"response":{"responseFormat":"text"}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"b1bc7f34-cdf0-4f7f-93a4-3e6154e71d5a","name":"Fetch Target Page","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"extractHtmlContent","extractionValues":{"values":[{"key":"title","cssSelector":".listing h2","returnValue":"text","returnArray":true},{"key":"price","cssSelector":".listing .price","returnValue":"text","returnArray":true},{"key":"url","cssSelector":".listing a","returnValue":"attribute","attribute":"href","returnArray":true}]},"options":{}},"type":"n8n-nodes-base.html","typeVersion":1.2,"position":[378,400],"id":"1db11eba-95ac-4b80-ad71-f14ed6a5b3a5","name":"Extract Listings (CSS)"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Zip parallel arrays into one item per listing\nconst j = $input.first().json;\nconst n = (j.title || []).length;\nconst out = [];\nfor (let i = 0; i < n; i++) {\n  out.push({ json: { title: j.title[i], price: j.price?.[i], url: j.url?.[i] } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"89bd0b34-bb03-434e-8359-c933098e965b","name":"Rows from Arrays"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,910],"id":"cae32fe5-6fed-47f1-b8a