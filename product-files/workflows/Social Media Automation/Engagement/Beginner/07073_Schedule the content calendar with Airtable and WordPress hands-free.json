}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"744bea6b-3721-4bc3-89d7-1e9f57743a77","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"scheduledAt","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3942,400],"id":"9063df76-084c-4821-a4ee-813948b57b38","name":"Sort Posts Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"postId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[4266,400],"id":"67c91ec6-bca2-4f0f-9784-aaee6d2f0d25","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"ffbc3af1-2ad9-4d67-898f-3e6717ae9c0b","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e5543d47-fd67-40c1-96c8-efd2e0a7e96e","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"24bba52d-c918-4e13-aea2-edea66875dce","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"295725f0-48d5-4640-b92d-830109d8d21a","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Social Media Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Posts"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[4914,400],"id":"5245c920-c9cd-4146-aa9a-514200c8feba","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=✅ Schedule the content calendar with Airtable and WordPress hands-free — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5238,400],"id":"4f5bfb4f-2edb-48fd-8b10-81f9bf65f6a0","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"1addf4af-583a-455b-84fc-42744399f96a","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"d9b7c614-e2a8-4f3c-9b07-f6729a13a6b2","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"15b8b48c-dc4d-4e07-8e17-ebbcf44612a9","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,1420],"id":"689eaf13-515c-41b5-a910-922eac05d4d0","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,1420],"id":"6b17acca-7984-438d-a5b4-80ac7dbb6439","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 12 h. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Posts","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"7f7e3e7c-8f19-b2b8-2789-611eac70afff","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Keep Valid Posts\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Prepare Approval Packet","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"ce26f4fb-dcbf-2859-e3e4-2c0ee0b9cd2b","name":"Note: Keep Valid Posts"},{"parameters":{"content":"### Prepare Approval Packet\n\nShapes the item: writes `requestId`, `summary`, `requestedBy`. Keeps the schema explicit between stages.\n\nNext: Request Approval via Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"0bf390a3-ec9c-cde1-1155-5e2ded72804f","name":"Note: Prepare Approval Packet"},{"parameters":{"content":"### Request Approval via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Hold for Decision · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"fe51c7db-e485-0527-37cd-24f1f35406af","name":"Note: Request Approval via Slack"},{"parameters":{"content":"### Hold for Decision\n\nPauses the execution until the resume webhook is called — this is the approval/HITL gate.\n\nNext: Approved?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"80fac92e-591f-bae1-cf52-27ca5e3f7673","name":"Note: Hold for Decision"},{"parameters":{"content":"### Approved?\n\nTwo-way gate on `={{ $json.body?.decision || $json.decision }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Apply Approved Change (Airtable) · ②→ Record Decline + Notify Requester","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"606dca3a-8642-ca0e-2600-87685acef4fc","name":"Note: Approved?"},{"parameters":{"content":"### Apply Approved Change (Airtable)\n\nairtable — `upsert` operation against the connected account.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"273991e1-6e6b-aa9d-8bb3-b6fa0da5c98b","name":"Note: Apply Approved Change (Airtable)"},{"parameters":{"content":"### Record Decline + Notify Requester\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"fdb5c75b-7a46-5431-d821-b6652ec40cd7","name":"Note: Record Decline + Notify Requester"},{"parameters":{"content":"### Join Decision Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"82e3ba33-e8c0-98dc-eb25-a4183d3d47e7","name":"Note: Join Decision Paths"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Posts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"35c34746-d8c2-db3a-6756-60db1b8412e0","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Posts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"af20f292-6c1b-59c2-953c-c4e81fd10713","name":"Note: Sort Posts Newest First"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"dea63dd3-06ac-8f54-6874-76cde499d5d3","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"fd5919be-9a89-e331-5ba0-30bc1bc896bc","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"bb194d5e-7d1d-a1ae-e967-51a7df0ae745","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"da79bfc9-37e8-f740-64c0-8372df811c50","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"77e62c15-57a6-7366-4e11-42cbc08da6c3","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"f5b93954-a60c-0024-2e29-eac71281a0f2","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Schedule the content calendar with Airtable and WordPress hands-free\n\n**Pattern:** Social Scheduler · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nSchedule the content calendar with Airtable and WordPress hands-free. It runs automatically on a schedule.\n\n## Why it exists\nManual engagement is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Keep Valid Posts → Prepare Approval Packet → Request Approval via Slack → Hold for Decision → Approved? → Apply Approved Change (Airtable) → …\n\n## Use it for\n- Teams that want to social scheduler without manual effort\n- Anyone automating engagement in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Scales without extra headcount\n- Responds in seconds\n\n## Before first run\nConnect credentials: Airtable PAT; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a8b7c63b-3482-a1f8-fec2-4077d45abaa4","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"09f08516-3153-0374-c453-10cdefb2c250","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"76c5399d-bc6b-d3e1-331f-067b010c44f4","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🙋 Human in the loop\n\nThe workflow pauses at the Wait node until a human posts a decision to the resume URL (included in the approval message). Approve → the action executes; anything else → recorded as declined. No timeout is set by default — add one under the Wait node's options if approvals go stale.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"517238a5-c1ba-709d-4ad0-b756a55b5171","name":"🙋 Human in the loop"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your engagement process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"bd065479-984b-e897-afe2-a8ea7cd62647","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Keep Valid Posts","type":"main","index":0}]]},"Keep Valid Posts":{"main":[[{"node":"Prepare Approval Packet","type":"main","index":0}]]},"Prepare Approval Packet":{"main":[[{"node":"Request Approval via Slack","type":"main","index":0}]]},"Request Approval via Slack":{"main":[[{"node":"Hold for Decision","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold for Decision":{"main":[[{"node":"Approved?","type":"main","index":0}]]},"Approved?":{"main":[[{"node":"Apply Approved Change (Airtable)","type":"main","index":0}],[{"node":"Record Decline + Notify Requester","type":"main","index":0}]]},"Apply Approved Change (Airtable)":{"main":[[{"node":"Join Decision Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Decline + Notify Requester":{"main":[[{"node":"Join Decision Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Decision Paths":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Posts Newest First","type":"main","index":0}]]},"Sort Posts Newest First":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"0efc5374-ef8b-434d-ae13-791e9a3dbcec","id":"FDX07073"}