              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "8d9e3f13-11af-4a08-bc5d-d45913961947",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
