{"name":"Draft newsletters with Google Drive and WordPress for your team","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":4}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"c22bed1b-f2cb-4c87-97ba-b4a592635c91","name":"Hourly Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b060235f-fb7f-4b82-abb7-06e061ef6000","leftValue":"={{ $json.postId || $json.content }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"d2ea3d88-72f8-40f8-9ad1-47e987380bda","name":"Keep Valid Posts"},{"parameters":{"assignments":{"assignments":[{"id":"a3bbbba8-9519-44c5-9902-c14e0e9c060f","name":"brief","value":"={{ $json.topic || $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"96346a18-3c2a-4c66-835e-a9cf705f0fa0","name":"tone","value":"={{ $json.tone || 'professional' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"03b75329-d972-4c76-b999-996a40154cb4","name":"Build the Brief"},{"parameters":{"promptType":"define","text":"=Write {{ $json.tone }} content for: {{ $json.brief }}","messages":{"messageValues":[{"message":"You write production-quality listening content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[702,400],"id":"c5544b11-c6d6-48f5-90f0-f5dd95cc8234","name":"Draft with AI Writer","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[945,970],"id":"bfe32d8e-dbe8-43ea-a480-e71be5dc62ae","name":"OpenAI Writer Model"},{"parameters":{"promptType":"define","text":"=Improve this draft without changing facts:\n\n{{ $json.text }}","messages":{"messageValues":[{"message":"You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1269,400],"id":"5a9216ac-f334-41bd-97f7-f12c6b339622","name":"Refine with AI Editor","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[1512,970],"id":"af94ec6f-4df4-47ff-ac07-846a640dec75","name":"OpenAI Editor Model"},{"parameters":{"title":"={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}","additionalFields":{"content":"={{ $json.html || $json.text }}","status":"draft"}},"type":"n8n-nodes-base.wordpress","typeVersion":1,"position":[1836,400],"id":"ced04fd8-fe6f-45f8-ba19-a055fbb34b9a","name":"Publish Draft to WordPress","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2160,400],"id":"1b9af870-5511-4071-8776-5147ac9e27b5","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2484,400],"id":"a9ba0b2b-237a-4b1e-bedf-c10ffc631d57","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.content }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2808,400],"id":"c2de2242-0c1d-4edf-a2f9-17f3adcb9b55","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"610fe5d0-218f-4274-a0bc-16c41f0b50b3","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5d64a810-0625-459b-92a3-791f1e3a6289","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3132,400],"id":"5758d2bc-2242-475a-8145-98e37a369533","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per post (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.postId, j.content].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3456,400],"id":"9d0a2071-ac1a-4a83-8139-73b3e2a0f1d8","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3780,400],"id":"bb5540c5-be4d-4fc8-8745-a91511cdc262","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4104,400],"id":"20905e57-6b60-478a-9cc3-423716a68bf3","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[4428,400],"id":"266ed2bc-f61c-43c2-bf0f-023123c74bb3","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d31fc096-db52-4eb0-8930-66183c996836","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"dca71107-37f4-4105-9798-73495e3c5687","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"c6630a45-bb40-4c9a-9887-d06736a4b1dd","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4752,400],"id":"80d27b3e-0b46-4bbc-ad55-7cfdc5472342","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5076,400],"id":"8602e9fe-e6cc-4b7a-bd56-d9895268f948","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=✅ Draft newsletters with Google Drive and WordPress for your team — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5400,400],"id":"b4c4af94-65dd-44b3-9c2c-32913c93852e","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"8b6f3e67-244e-46ac-b1a4-7f4ece36271a","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"2f07ce78-81b4-4c16-ab27-3d44f6977d4e","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"9d3b2792-bc44-43b1-a3d7-0c5c0f956b20","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4752,1420],"id":"3c6c2831-7cc8-4d60-b3e3-df746669cfa6","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5076,1420],"id":"988c31d9-fcd0-4699-a94e-daf741c61ee7","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5400,1420],"id":"04b6904d-8aae-4385-9315-c4bfc588e2f4","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 4 h. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Posts","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"868402e6-a636-52b4-7d90-0e8f562a7cc2","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Keep Valid Posts\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Build the Brief","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"778dc1e9-aa93-531d-79af-87617cfc3f39","name":"Note: Keep Valid Posts"},{"parameters":{"content":"### Build the Brief\n\nShapes the item: writes `brief`, `tone`. Keeps the schema explicit between stages.\n\nNext: Draft with AI Writer","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"e793a5dd-1db2-2325-8919-b5d22de3afa8","name":"Note: Build the Brief"},{"parameters":{"content":"### Draft with AI Writer\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Refine with AI Editor · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"e66c00c7-ef48-ea40-e91d-fcd2c5f590a1","name":"Note: Draft with AI Writer"},{"parameters":{"content":"### OpenAI Writer Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Draft with AI Writer** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"f3f0349e-a0e6-4fde-b5b4-cc7634375db5","name":"Note: OpenAI Writer Model"},{"parameters":{"content":"### Refine with AI Editor\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish Draft to WordPress · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,520],"id":"a5d37b9c-2762-039a-f553-a8e7e85b22fe","name":"Note: Refine with AI Editor"},{"parameters":{"content":"### OpenAI Editor Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Refine with AI Editor** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1452,1090],"id":"02ba39de-4968-7c36-a619-a91f7017258f","name":"Note: OpenAI Editor Model"},{"parameters":{"content":"### Publish Draft to WordPress\n\nwordpress — `action` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 WordPress credentials","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,520],"id":"7bbdd65b-290e-69ba-af3c-87725ea44080","name":"Note: Publish Draft to WordPress"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2100,520],"id":"b89c3667-1436-9402-a704-977c0389baeb","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2424,520],"id":"705f82dd-7add-3f5e-0d87-e85c7a7ac39c","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2748,520],"id":"a0e706a4-1d81-f61c-4e0b-cd4cadd89344","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3072,520],"id":"67214283-853f-c4f2-c542-753acb00bfb5","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per post (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,520],"id":"484262f2-926a-6740-2433-24eff7021e50","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,520],"id":"238f0398-0390-20f5-4aa4-db24d6d20c7e","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4044,520],"id":"3b671f29-8ce8-2e3d-b9d6-d16a2c401643","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4368,520],"id":"bbfbd2e3-c913-deab-d61c-246585e5f9e6","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,520],"id":"84db6c0b-7e1b-49a3-c982-cf7a9ed6bf8d","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,520],"id":"c991cffd-94df-b1b6-b7b2-1842673c28f3","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5340,520],"id":"19120eb8-df01-99d0-2458-268a05571d5d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,1540],"id":"182c2b84-1541-d4bb-41b0-f5258064957a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,1540],"id":"6684ec28-945e-49db-1c8c-3dca60f88dfb","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5340,1540],"id":"6cbb6bab-caa0-4c09-8baa-20f87d631921","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Draft newsletters with Google Drive and WordPress for your team\n\n**Pattern:** Content Generation · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nDraft newsletters with Google Drive and WordPress for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual listening is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Keep Valid Posts → Build the Brief → Draft with AI Writer → Refine with AI Editor → Publish Draft to WordPress → Stamp Completion Time → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating listening in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Responds in seconds\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; OpenAI API key; Slack OAuth2; WordPress credentials.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"03a12449-0181-96e1-1ff3-c056f3fa2f30","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"163cb2a6-af8e-fa2a-5588-255c16c52dbb","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"dcae3e5c-4958-783b-23eb-924605d84725","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"fb09076c-ddeb-32a3-cde2-1779c364fd92","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your listening process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"933db8bb-0314-7c36-ccb3-860434f466b9","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Keep Valid Posts","type":"main","index":0}]]},"Keep Valid Posts":{"main":[[{"node":"Build the Brief","type":"main","index":0}]]},"Build the Brief":{"main":[[{"node":"Draft with AI Writer","type":"main","index":0}]]},"OpenAI Writer Model":{"ai_languageModel":[[{"node":"Draft with AI Writer","type":"ai_languageModel","index":0}]]},"Draft with AI Writer":{"main":[[{"node":"Refine with AI Editor","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"OpenAI Editor Model":{"ai_languageModel":[[{"node":"Refine with AI Editor","type":"ai_languageModel","index":0}]]},"Refine with AI Editor":{"main":[[{"node":"Publish Draft to WordPress","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish Draft to WordPress":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to S