{
  "name": "Schedule the content calendar with PostgreSQL and WordPress without manual work",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "triggerAtHour": 7,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -200,
        400
      ],
      "id": "d57c4c0e-e2cf-46fb-83a0-2ae1bd258f82",
      "name": "Daily Schedule"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming post records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    postId: String(j.postId ?? j.id ?? '').trim(),\n    content: typeof j.content === 'string' ? j.content.trim() : j.content ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40,
        400
      ],
      "id": "c17bd1a5-e1b3-4cb5-a1b6-f7f3b5e09010",
      "name": "Normalize Post Payload"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "09106bb5-5acb-47b8-88dc-bf49a1588021",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "298123d8-4744-48a1-9389-39ee9af96e83",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        280,
        400
      ],
      "id": "25640cb7-b0c8-419e-94d7-f2d596ce632c",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality listening content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        520,
        400
      ],
      "id": "67ad1950-055a-4ca8-8370-c9c824f462a6",
      "name": "Draft with AI Writer",
