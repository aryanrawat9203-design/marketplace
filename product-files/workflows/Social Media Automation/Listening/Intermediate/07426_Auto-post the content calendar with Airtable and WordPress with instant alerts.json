tems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4104,400],"id":"80a388ea-1b80-4d14-8627-c876655643ad","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"96451802-7eb8-4135-9dad-b14387661b2e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6f780380-10fe-4d81-bc3e-cadb84f4ec6d","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"a77a8bc7-5fbe-450e-8fea-19fc7f175162","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4428,400],"id":"aa28acbb-117c-4478-a34f-4a89017c0ddb","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Social Media Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Posts"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[4752,400],"id":"6dbacea4-f770-43c7-9677-ee9697c8a942","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=✅ Auto-post the content calendar with Airtable and WordPress with instan — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5076,400],"id":"ce1498c6-8411-4a0d-989c-9e63bc7da504","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6b5a1e28-745b-49bd-a727-9fa92ff9e9e1","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"81270de3-f4f8-4242-870f-8ed1cf17b315","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"01556ad8-e157-44db-9406-36cead8a9f8c","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4428,1420],"id":"a9f96466-e5bb-4f99-918b-3eaac66c4734","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#social","cachedResultName":"#social"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4752,1420],"id":"f131c17d-328e-449b-87b9-1decdeeee3b8","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5076,1420],"id":"a88202da-7145-4486-bc84-edf1b64616e3","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 12 h. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Post","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"379c4bd4-8a48-7fb9-269d-197425faf371","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Stamp & Shape Post\n\nShapes the item: writes `postId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"cc03f4c5-0593-b5c8-76d8-7af87f3da1df","name":"Note: Stamp & Shape Post"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.postId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Build the Brief · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"217bf333-9c7c-67cc-d489-542e41352fea","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"62c2ea02-95cc-10a8-71fc-c6d86d6341ca","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Build the Brief\n\nShapes the item: writes `brief`, `tone`. Keeps the schema explicit between stages.\n\nNext: Draft with AI Writer","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"8227422c-fd53-76c8-5cfb-ef428eebbf32","name":"Note: Build the Brief"},{"parameters":{"content":"### Draft with AI Writer\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Refine with AI Editor · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"6d60194b-fbf5-107c-371c-20da7a3b9f8f","name":"Note: Draft with AI Writer"},{"parameters":{"content":"### OpenAI Writer Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Draft with AI Writer** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"342224de-ba4f-e477-3dc0-00fb87440835","name":"Note: OpenAI Writer Model"},{"parameters":{"content":"### Refine with AI Editor\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish Draft to WordPress · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"8d2c09e4-acbd-fc90-7fa7-158332d0b619","name":"Note: Refine with AI Editor"},{"parameters":{"content":"### OpenAI Editor Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Refine with AI Editor** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,1090],"id":"8116025a-8e34-21f8-9d68-ee598fdc2b9d","name":"Note: OpenAI Editor Model"},{"parameters":{"content":"### Publish Draft to WordPress\n\nwordpress — `action` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 WordPress credentials","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2100,520],"id":"88ee21a6-107f-aede-f081-7d843373b52f","name":"Note: Publish Draft to WordPress"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2424,520],"id":"0083a562-556b-7823-9285-23d788824c79","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2748,520],"id":"0f80f830-3738-376b-5e9e-3a95edf393a9","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3072,520],"id":"4a4844bb-25a4-3f7b-5247-9c8930854cc0","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,520],"id":"bf8249ff-6bc2-3a10-2d54-3c2d78539cd6","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,520],"id":"40b6150e-fc5f-7f3f-2fd8-6b062c40a9a1","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4044,520],"id":"daca8816-7dff-ecb3-310b-8705100e3f0a","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4368,520],"id":"44d0fb51-5e3f-8370-5a20-ab12f863d5e2","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,520],"id":"4d1bc9bf-4c4b-a408-e596-5c3d2b729057","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,520],"id":"1cd8d9ea-d5ff-69c1-340f-27034fc288a8","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4368,1540],"id":"6ba9c88b-2858-7763-9bf3-5d6913cfa6c4","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,1540],"id":"4c29a465-39f0-7390-bcff-4ff895fc317e","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,1540],"id":"8984dbb0-9ec3-3986-1e9d-658ae0bc90a4","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Auto-post the content calendar with Airtable and WordPress with instant alerts\n\n**Pattern:** Social Scheduler · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nAuto-post the content calendar with Airtable and WordPress with instant alerts. It runs automatically on a schedule.\n\n## Why it exists\nManual listening is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Stamp & Shape Post → Payload Valid? → Build the Brief → Draft with AI Writer → Refine with AI Editor → Publish Draft to WordPress → …\n\n## Use it for\n- Teams that want to social scheduler without manual effort\n- Anyone automating listening in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Standardizes the process every time\n- Improves response time\n\n## Before first run\nConnect credentials: Airtable PAT; Google OAuth2 / service account; OpenAI API key; Slack OAuth2; WordPress credentials.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"646e6b30-a294-39ea-2ce6-86898e083c40","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"74527123-925b-b3f6-8a5b-fbf4dc2721f9","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"34dfba53-41ef-b0e4-0070-d045d5a2271e","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your listening process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"9807149d-0406-0087-869d-b9539e88ea33","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Stamp & Shape Post","type":"main","index":0}]]},"Stamp & Shape Post":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Build the Brief","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Build the Brief":{"main":[[{"node":"Draft with AI Writer","type":"main","index":0}]]},"OpenAI Writer Model":{"ai_languageModel":[[{"node":"Draft with AI Writer","type":"ai_languageModel","index":0}]]},"Draft with AI Writer":{"main":[[{"node":"Refine with AI Editor","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"OpenAI Editor Model":{"ai_languageModel":[[{"node":"Refine with AI Editor","type":"ai_languageModel","index":0}]]},"Refine with AI Editor":{"main":[[{"node":"Publish Draft to WordPress","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish Draft to WordPress":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"52939b53-d69d-458a-ab47-fed2f68e433e","id":"FDX07426"}