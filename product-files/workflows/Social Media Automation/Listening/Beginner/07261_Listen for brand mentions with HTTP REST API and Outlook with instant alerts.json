            {
              "id": "cf83d91d-2ff2-4fc7-be38-8604c0dfbb92",
              "leftValue": "={{ $json.score }}",
              "rightValue": 50,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "bbf1cc94-a2c4-479b-8033-8f6cd00a6ccd",
