}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[702,400],"id":"e9f95a06-5080-4e70-838f-20a94250d91e","name":"Build the Brief"},{"parameters":{"promptType":"define","text":"=Write {{ $json.tone }} content for: {{ $json.brief }}","messages":{"messageValues":[{"message":"You write production-quality listening content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"874d3591-3130-4aed-baa5-f48364752663","name":"Draft with AI Writer","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[1269,970],"id":"09053f99-c244-461d-801f-a1d33a793934","name":"Anthropic Writer Model"},{"parameters":{"promptType":"define","text":"=Improve this draft without changing facts:\n\n{{ $json.text }}","messages":{"messageValues":[{"message":"You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1593,400],"id":"1d4e2c20-cedb-4b09-93b0-4c6cdecbe12c","name":"Refine with AI Editor","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[1836,970],"id":"814b5e27-d1cf-4aa9-be89-b58facfed5b1","name":"Anthropic Editor Model"},{"parameters":{"title":"={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}","additionalFields":{"content":"={{ $json.html || $json.text }}","status":"draft"}},"type":"n8n-nodes-base.wordpress","typeVersion":1,"position":[2160,400],"id":"d38ca454-fe88-4dae-bc69-8508e3f7b41f","name":"Publish Draft to WordPress","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Post Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2484,400],"id":"c37a687e-b1ec-4054-bfd6-15de482696ec","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2808,400],"id":"58ea103f-c22d-44d1-a2f9-f4e45cad814d","name":"Compute Drift vs Snapshot"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per post (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.postId, j.content].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3132,400],"id":"198c549d-49c9-4c8e-8d7e-95359c13817a","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3456,400],"id":"df36c181-b24d-4c38-8ea4-1d42dcdd277c","name":"Drop Already-Processed Items"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Posts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3780,400],"id":"be4ba8af-1e99-4f5f-959f-d50293e01fff","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4104,400],"id":"4bffa274-adfc-4a72-a13c-889d210e7fc6","name":"Record Sub-workflow Result"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.content }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4428,400],"id":"38f1d7a5-5a6e-466d-8f55-767de6a36cf2","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4ee75b3b-b8c1-4e96-9945-a787db43d622","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"3fba71d5-d5b0-4576-9fe3-77d1a6eb0652","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4752,400],"id":"3210c94b-8f2c-48c9-9b0f-f45f1e18bff3","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5076,400],"id":"8c22e2ee-6385-46d1-8728-03dd3c29bfa6","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5400,400],"id":"acf49d4c-54d6-40c2-8492-59d842872188","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5724,400],"id":"a05d7eac-006d-4cd5-b1ad-6562b5a1a60d","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[6048,400],"id":"9ffec7b7-806d-428b-add1-c01e1e264f26","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"40a652ac-3ece-46c0-98db-c534df7ba09b","name":"pipeline","value":"Listening","type":"string"},{"id":"6146a0bb-2b6e-4c81-b233-b10898c6bdef","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6372,400],"id":"6b6a4e09-ba44-4f1b-b736-7550ef41837f","name":"Tag Pipeline Metadata"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[6696,400],"id":"6014a53c-b381-465c-abf3-f8930b73aacf","name":"Cap Batch Volume"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"20742eba-3898-4067-8c92-213bc49ba96b","leftValue":"={{ $json.content }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7020,400],"id":"d062787d-1a62-44f8-8bd4-b82bbf0670d0","name":"Guard Non-Empty content"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName