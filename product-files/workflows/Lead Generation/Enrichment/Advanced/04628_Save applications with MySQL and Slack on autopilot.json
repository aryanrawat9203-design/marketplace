nueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2646,400],"id":"0a8e0d67-a2a3-4b91-9774-4593d1246207","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2970,400],"id":"83892997-4820-4efc-9bec-5f8cfea389d4","name":"Persist Run Metadata"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3294,400],"id":"1e1be201-d5f9-4d49-ad41-fdaf8fcc7c33","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3618,400],"id":"5af7cae1-d4e0-4eeb-927f-2fd18f393446","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3942,400],"id":"21d76a55-c89d-40a5-a07b-f32ed53a105d","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"78d0d183-7497-4547-b8ee-769b8c2d410f","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"63bdf6ec-480a-401c-9a52-ec4f0863b737","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"41bcbeeb-1f82-44ad-8b02-7d7057dca8da","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"81d38f95-d3c3-466b-8854-2fe8c7e876c4","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"30fbd8ae-04e7-4169-9843-175c14624917","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"4d476492-caba-45d3-97b5-a24e7f9312a9","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"db4defaa-d3eb-47e3-8bd2-20a5badc0a13","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4914,400],"id":"97568721-9d42-41e7-803a-ea9fe76399eb","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Save applications with MySQL and Slack on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5238,400],"id":"abb2f8eb-27d9-4c5b-990a-037d99ab5380","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"2d610848-5e14-42c3-8010-7f6d3792274f","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"29b81771-8f94-463a-b871-fe1fc615b2ee","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"814de250-589b-488b-b018-a9a68478c115","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,1420],"id":"bffd7577-2fdf-409a-9f14-86723de4a26c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,1420],"id":"40af0970-e124-4d9a-ac75-043f7f36f81d","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"leads","cachedResultName":"leads"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[5238,1420],"id":"fe6ee64f-4c0e-4f5f-a5a6-587fa6c4f7af","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Lead Form Submission\n\nServes an n8n-hosted form (Email, Company, Score). Each submission becomes one execution.\n\nNext: Download Source File","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"bf176c39-2fb0-b4a7-c8a1-c65f6364f421","name":"Note: New Lead Form Submission"},{"parameters":{"content":"### Download Source File\n\nGET ={{ $json.fileUrl }} — retries 3× with backoff on failure.\n\nPorts: ①→ Parse CSV Contents · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"c4ab6e31-4e48-7b6d-7c0b-54f5e599188f","name":"Note: Download Source File"},{"parameters":{"content":"### Parse CSV Contents\n\nParses the incoming CSV binary into JSON items.\n\nNext: Clean & Reshape Rows","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"125062ef-2755-96de-45bb-9c9ee2adbb12","name":"Note: Parse CSV Contents"},{"parameters":{"content":"### Clean & Reshape Rows\n\nCustom JavaScript: Normalize incoming lead records to a stable schema\n\nNext: Rows Pass Validation?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"32249a14-9492-b570-80ca-fa8584c63186","name":"Note: Clean & Reshape Rows"},{"parameters":{"content":"### Rows Pass Validation?\n\nTwo-way gate on `={{ $json.leadId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Load Rows into Google Sheets · ②→ Quarantine Bad Rows","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"64003148-4c39-d347-43c1-5cea462a2ac4","name":"Note: Rows Pass Validation?"},{"parameters":{"content":"### Quarantine Bad Rows\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"4b56afaa-8366-d5e5-d05b-40b0e50288a8","name":"Note: Quarantine Bad Rows"},{"parameters":{"content":"### Load Rows into Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Serialize Run Output (CSV) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"a6fcf8ce-c70c-44d3-ecf1-27d14d60fc0f","name":"Note: Load Rows into Google Sheets"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"8df59865-61e3-2a6c-151c-2341fbcfdf99","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"b198d757-7481-711f-43c5-86fdbf9090e7","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"fc0c5181-e452-a849-1917-88e32a999751","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"43e38b8b-f406-7425-3c2e-3cb829b6e0ff","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"a300bc7a-cefc-0705-a7ce-a5f0a24e1809","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"8cb2e151-818f-52de-7d11-d12b1478531a","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"28f0a055-5917-07ef-1bd7-05951817aec7","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"13f1abac-c96d-a947-4061-3545f11569d2","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"bae963a8-77d5-7702-c0f4-6af91117b1ce","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"3b580f4a-d9b9-cda9-f556-dec6b81774d4","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"1dab89b3-07a4-9782-1e66-cb195dfa1ee5","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"34b4d099-f69d-c23b-a4f4-dede612a61fc","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"b42e7f0d-49bb-75aa-77a9-e6ed50a81857","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nmySql — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"11e015fe-079c-cf46-ab7b-301740e0725b","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Save applications with MySQL and Slack on autopilot\n\n**Pattern:** Form Intake · **Level:** Production · **Trigger:** Form\n\n## What it does\nSave applications with MySQL and Slack on autopilot. It starts from a hosted form submission.\n\n## Why it exists\nManual enrichment is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Lead Form Submission → Download Source File → Parse CSV Contents → Clean & Reshape Rows → Rows Pass Validation? → Load Rows into Google Sheets → Serialize Run Output (CSV) → …\n\n## Use it for\n- Teams that want to form intake without manual effort\n- Anyone automating enrichment in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Removes copy-paste errors\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; MySQL connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"e1a8a186-9137-814a-ee97-ee1d99cda59d","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"35dd8e59-df7f-3328-4de5-69c34d0ed72f","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your enrichment process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"b9426e55-6e2d-c1a2-def6-ebb07a64bcfa","name":"🛠 Customize me"}],"connections":{"New Lead Form Submission":{"main":[[{"node":"Download Source File","type":"main","index":0}]]},"Download Source File":{"main":[[{"node":"Parse CSV Contents","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Parse CSV Contents":{"main":[[{"node":"Clean & Reshape Rows","type":"main","index":0}]]},"Clean & Reshape Rows":{"main":[[{"node":"Rows Pass Validation?","type":"main","index":0}]]},"Rows Pass Validation?":{"main":[[{"node":"Load Rows into Google Sheets","type":"main","index":0}],[{"node":"Quarantine Bad Rows","type":"main","index":0}]]},"Load Rows into Google Sheets":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Quarantine Bad Rows":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"043997e1-e1dd-4bfc-987a-45bdac2a315b","id":"FDX04628"}