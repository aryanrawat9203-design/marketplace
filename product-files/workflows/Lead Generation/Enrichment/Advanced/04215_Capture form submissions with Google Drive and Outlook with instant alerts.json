{"name":"Capture form submissions with Google Drive and Outlook with instant alerts","nodes":[{"parameters":{"formTitle":"Capture form submissions with Google Drive and Outlook with ","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"0258033f-f649-4874-ade4-de2cc2516d72","name":"New Lead Form Submission","webhookId":"78217d60-155a-42c6-affa-b02b4063d16c"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"060dacdc-fce1-432f-aa56-41d3f00716eb","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"da254f6a-d148-4df5-b378-ca3bcdbef080","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'email' on incoming lead."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"53895694-ba37-4908-956f-5b252d31b088","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"f1d4aea7-8ee6-4166-a76a-30e306ef9256","name":"requestId","value":"={{ $json.leadId || $execution.id }}","type":"string"},{"id":"50c6eef6-c6f4-43f0-b5d7-66289feed83d","name":"summary","value":"={{ ($json.email || '').toString().slice(0, 200) }}","type":"string"},{"id":"f810734a-6e86-4f0c-99ed-300bc71af3b6","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"f89b31a4-b228-411c-8468-c887aad02bab","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,400],"id":"d18fb9c5-fe1e-477e-a555-2ab572eae97a","name":"Request Approval via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resume":"webhook","httpMethod":"POST","options":{}},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1026,400],"id":"541b6dc3-6a07-46d3-aa21-5a051c2f0256","name":"Hold for Decision","webhookId":"3ab890ab-66f5-4659-a503-4812bbe803f7"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d562b217-d333-4f6e-ba8b-f8d578b9e0c7","leftValue":"={{ $json.body?.decision || $json.decision }}","rightValue":"approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"3c6101db-44ed-4345-80a8-ed21336a70c1","name":"Approved?"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/leads","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1674,160],"id":"22ccd185-e773-4d0c-b4a6-66ce98e82b31","name":"Execute Approved Action (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=❌ Request {{ $json.requestId }} was declined.","bodyContent":"=❌ Request {{ $json.requestId }} was declined.","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1998,760],"id":"87c2c797-d32f-4419-bec3-31552b67a101","name":"Record Decline + Notify Requester","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"ff3cf7e1-c391-4d25-a4bc-436654ef124c","name":"Join Decision Paths"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3618,400],"id":"448223d0-a5f9-474b-9158-740034e28ae6","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"bdfe1c2a-9509-4329-a822-cdd56689b274","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4266,400],"id":"03e3f3d0-aca4-4fc1-8104-d81cf9f4caa1","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[4590,400],"id":"59eb7326-d4e4-45a7-a59f-ef8a2b921c15","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"f245317b-5ac7-46cc-8262-2faf8e1c8b02","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"d0cc5054-2270-4159-8490-ca577fde9d03","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"543a03f6-9f35-484f-b091-9819ee075069","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b7fca355-366e-4634-8556-49f6c59a8e02","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9ee89620-9004-4a5d-b438-28e4066acad3","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"b47aa1a9-3b8e-488d-884f-4e23710e1a8a","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"79b57e5d-afdc-452a-9834-18ea4051cb7b","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Capture form submissions with Google Drive and Outlook with instant al — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,400],"id":"ed005a8f-a657-494e-9b7e-094f89d91155","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"77dd41ed-910b-452d-833b-78fb05991b2b","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"d7c3febd-9df2-4c0d-bfe1-4eabc24092c8","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"cc21ed70-52c8-4c31-b8c1-067950da59cf","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"69b2631f-5bad-4f45-96b9-a17ea18235ab","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,1420],"id":"79a4c910-d8dd-405d-8148-75015da9b205","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"45f99ebe-2ca8-49ee-b9a5-f9da752839ca","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Lead Form Submission\n\nServes an n8n-hosted form (Email, Company, Score). Each submission becomes one execution.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"0ef03933-a7bf-8a3d-7aef-df1875face1a","name":"Note: New Lead Form Submission"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.email }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Prepare Approval Packet · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"6c88dc0c-62a3-82d6-d597-1b47114137b9","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"c5b06880-f8a3-5c10-4ab0-63d610dff56d","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Prepare Approval Packet\n\nShapes the item: writes `requestId`, `summary`, `requestedBy`. Keeps the schema explicit between stages.\n\nNext: Request Approval via Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"aa3582df-b436-1c78-e235-3974837c837f","name":"Note: Prepare Approval Packet"},{"parameters":{"content":"### Request Approval via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Hold for Decision · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"a3e208b7-edd6-03e4-1d3e-d532077bf6fa","name":"Note: Request Approval via Slack"},{"parameters":{"content":"### Hold for Decision\n\nPauses the execution until the resume webhook is called — this is the approval/HITL gate.\n\nNext: Approved?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"e82a9e63-85b7-0a86-fbdc-7769cb2a8768","name":"Note: Hold for Decision"},{"parameters":{"content":"### Approved?\n\nTwo-way gate on `={{ $json.body?.decision || $json.decision }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Execute Approved Action (API) · ②→ Record Decline + Notify Requester","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"a850a03d-0b3f-11b4-a44f-13a15b6a93a1","name":"Note: Approved?"},{"parameters":{"content":"### Execute Approved Action (API)\n\nPOST https://api.example.com/v1/leads — retries 3× with backoff on failure.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"64adc006-2528-5650-b3a6-17dab1d5c368","name":"Note: Execute Approved Action (API)"},{"parameters":{"content":"### Record Decline + Notify Requester\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"d42c90c8-7e4b-b3b5-410c-8bca31779555","name":"Note: Record Decline + Notify Requester"},{"parameters":{"content":"### Join Decision Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"fda729d1-7476-4945-3824-34a057c54a6e","name":"Note: Join Decision Paths"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"c11a2290-7c7d-1479-ed18-e9bd6ff6549d","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"8b594ae2-d712-df85-40c7-7ffc898bdf5b","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Copy to Google Drive","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"96cc845e-131e-e79a-a965-4dfd7cf65c8b","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Copy to Google Drive\n\ngoogleDrive — `upload` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"9ea51712-f03b-1213-c26a-77036a8943ae","name":"Note: Archive Copy to Google Drive"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"3d65bac7-467c-4bf3-1059-02b2e9562a5d","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"32134459-b9ed-ddbb-bfbb-80964ba8d69e","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"32514627-db78-b774-e7e1-e629b128f388","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"f48e6cbf-7fd7-e851-e911-6ead6cc9b7d4","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"db9ca64d-71e5-ce49-069c-656e1fd574b4","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"5830cd08-7f05-2006-d685-4eea2f3ee57b","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"60c0b150-d2fe-0c5a-bc8b-bd4c5e6f6394","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"8e0f1e40-de6b-ff19-4fbf-73eb1ba5794c","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Capture form submissions with Google Drive and Outlook with instant alerts\n\n**Pattern:** Form Intake · **Level:** Production · **Trigger:** Form\n\n## What it does\nCapture form submissions with Google Drive and Outlook with instant alerts. It starts from a hosted form submission.\n\n## Why it exists\nManual enrichment is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Lead Form Submission → Required Fields Present? → Prepare Approval Packet → Request Approval via Slack → Hold for Decision → Approved? → Execute Approved Action (API) → …\n\n## Use it for\n- Teams that want to form intake without manual effort\n- Anyone automating enrichment in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Saves hours of manual work each week\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"55f4ec32-dc4d-bc79-5e8e-11bbd9fa4db0","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"78ca10eb-4636-3d6a-f120-52dfa6daba72","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"efde453a-3ce9-c18a-d8ac-fd34dfebbe1d","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🙋 Human in the loop\n\nThe workflow pauses at the Wait node until a human posts a decision to the resume URL (included in the approval message). Approve → the action executes; anything else → recorded as declined. No timeout is set by default — add one under the Wait node's options if approvals go stale.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"541e9cf5-af3a-5d3d-8dcb-50dfc2ea0531","name":"🙋 Human in the loop"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your enrichment process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"993ca160-0dc1-1c5d-2d8e-87dcb1a4e6b9","name":"🛠 Customize me"}],"connections":{"New Lead Form Submission":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Prepare Approval Packet","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Prepare Approval Packet":{"main":[[{"node":"Request Approval via Slack","type":"main","index":0}]]},"Request Approval via Slack":{"main":[[{"node":"Hold for Decision","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold for Decision":{"main":[[{"node":"Approved?","type":"main","index":0}]]},"Approved?":{"main":[[{"node":"Execute Approved Action (API)","type":"main","index":0}],[{"node":"Record Decline + Notify Requester","type":"main","index":0}]]},"Execute Approved Action (API)":{"main":[[{"node":"Join Decision Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Decline + Notify Requester":{"main":[[{"node":"Join Decision Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Decision Paths":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Copy to Google Drive","type":"main","index":0}]]},"Archive Copy to Google Drive":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"d8d0f939-d02b-4639-bdd0-54d42cd26287","id":"FDX04215"}