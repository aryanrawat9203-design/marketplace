on":2,"position":[6210,400],"id":"00684665-a127-4131-a7ee-769a538e5bb0","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6534,400],"id":"9ad77e47-9fdc-4ba4-8ed3-59f0b50103f0","name":"Drop Already-Processed Items"},{"parameters":{"dataToSave":{"values":[{"key":"leadId","value":"={{ $json.leadId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"8f7c33e6-cbd9-4147-a1f4-1e6c1c88d242","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"17e8fe3c-a11e-4ab8-90d0-ef2d00356dd8","name":"pipeline","value":"Enrichment","type":"string"},{"id":"7c0db8dd-1a75-4234-9bbb-fa6b77c83902","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"7a3e4a01-aa81-4d4e-83b0-f2b20a240441","name":"Tag Pipeline Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7506,400],"id":"445947da-ddd5-41c3-ab88-018d24f9d63d","name":"Stamp Processing Time"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"score","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7830,400],"id":"4cd44adf-e98b-453a-a8f2-78793f3a5c29","name":"Sort Leads Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"leadId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8154,400],"id":"d283380c-bcb5-4bb7-8c46-677ca87d683e","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"c2e38456-a6a8-4442-a6f9-246f6fb6857a","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"29a918ea-3ac8-4603-aac6-99758e54e6