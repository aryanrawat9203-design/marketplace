{"name":"Qualify inbound leads with HubSpot and Microsoft Teams at scale","nodes":[{"parameters":{"formTitle":"Qualify inbound leads with HubSpot and Microsoft Teams at sc","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"edad7b08-50be-4c0f-bd05-14269ce46fd7","name":"New Lead Form Submission","webhookId":"64160ec4-f0ff-456f-aa39-c505a0cdfae8"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e072dd77-b835-4239-8dc7-a9f4ede8b00f","leftValue":"={{ $json.leadId || $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"1106e306-c1e1-460c-a244-42eb32623cf6","name":"Keep Valid Leads"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each lead 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.email) score += 20;\n  if (j.company) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"0de5bdf3-98a2-430e-9424-ab4f11c9edac","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"0f2e772b-10f8-47b0-b55c-3b4b34910979","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options