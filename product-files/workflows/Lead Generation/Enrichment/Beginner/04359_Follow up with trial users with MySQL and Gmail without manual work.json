tats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"568d7881-351c-456b-b524-e3809efb119c","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Follow up with trial users with MySQL and Gmail without manual work — run com","message":"=✅ Follow up with trial users with MySQL and Gmail without manual work — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[5562,400],"id":"98012c2a-3525-4fd2-b457-64a83d233063","name":"Send Summary to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a495b58e-f9d9-4140-ab95-8b4e39b75ed6","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"060bc438-c0f6-418a-b085-91cdcdacf21f","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"3631ca6f-3790-4ae4-9884-a2e143c8bd1b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,1420],"id":"a2593a7e-2ec9-4874-aa56-de37007ce292","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5238,1420],"id":"adeb162e-0b38-485c-a788-a8e7204a4892","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,1420],"id":"53bfb2c7-ec48-409a-8478-e3ea5df9391e","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 4 h. No input data; downstream nodes fetch what they need.\n\nNext: Read Pending Queue (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"0f1782b5-1e48-fa86-e63b-958e1d7f36fe","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Read Pending Queue (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Stamp & Shape Lead · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"5d684107-15c4-3ccc-38b9-6630e8448cb9","name":"Note: Read Pending Queue (Google Sheets)"},{"parameters":{"content":"### Stamp & Shape Lead\n\nShapes the item: writes `leadId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"0dc45d31-2e00-4102-7147-30f8bd82ca5c","name":"Note: Stamp & Shape Lead"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.leadId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Work in Batches · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"26a71f09-8f1f-075e-ab9b-5053d1b7f00f","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1030],"id":"42c96ba2-e6ef-75da-9967-99615ccf8c03","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Work in Batches\n\nLoop controller — releases 5 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Aggregate Batch Results · ②→ Process Batch Item","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"3d886a23-4b57-5915-a733-b3c31644e766","name":"Note: Work in Batches"},{"parameters":{"content":"### Process Batch Item\n\nPOST https://api.example.com/v1/leads — retries 3× with backoff on failure.\n\nPorts: ①→ Respect Rate Limits · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"bb66f0e3-1f23-98d3-111f-12ee38622289","name":"Note: Process Batch Item"},{"parameters":{"content":"### Respect Rate Limits\n\nPauses 2 seconds — spacing calls to respect rate limits.\n\nNext: Work in Batches","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,1000],"id":"32dd527d-f830-57c9-1be4-76487f7e3ac1","name":"Note: Respect Rate Limits"},{"parameters":{"content":"### Aggregate Batch Results\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Mark Completed in MySQL","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"15ef8d7d-93a8-ba6f-1743-63b3dfa0cad1","name":"Note: Aggregate Batch Results"},{"parameters":{"content":"### Mark Completed in MySQL\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"8e6b7e3e-36b7-4630-63f3-7cdc54e5048a","name":"Note: Mark Completed in MySQL"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"df9c2234-dcde-3e78-b87d-02d317b43a16","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"476e43ab-42f0-68b0-8678-a145b1469d40","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"71d91975-f746-f1e9-41b0-4ec3052adfbe","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"43bb29eb-ee96-efd1-41d2-53f3e9cb2f59","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"532899af-d4dd-814d-7fca-51e5dbbef6bf","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"df654545-9cfd-92d2-97aa-1d74290a1384","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"cf953385-7dd7-74d8-9a33-66f43ddb52fd","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Gmail · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"60e7ac69-2c7f-3b10-1fc2-e2a6276c4bdc","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"a7de611a-64c2-3dd6-4177-93dd2bc63a28","name":"Note: Send Summary to Gmail"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"d357695a-46fe-a540-8aef-fefeac2a38e2","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"9fba5cea-f814-e771-36c2-315f6a956b61","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"ceb2265a-04ed-a9d3-ab4f-a942e5f74b9a","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Follow up with trial users with MySQL and Gmail without manual work\n\n**Pattern:** Drip Sequence · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nFollow up with trial users with MySQL and Gmail without manual work. It runs automatically on a schedule.\n\n## Why it exists\nManual enrichment is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Read Pending Queue (Google Sheets) → Stamp & Shape Lead → Payload Valid? → Work in Batches → Aggregate Batch Results → Mark Completed in MySQL → …\n\n## Use it for\n- Teams that want to drip sequence without manual effort\n- Anyone automating enrichment in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Improves response time\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; MySQL connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"f583a4b3-487b-a952-6f90-ee7f986d8e96","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"b3e623ba-d590-d460-22f8-38a967e5d712","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"e748fee1-61c8-f8df-64e5-45d819b51483","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your enrichment process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"6ddb3bef-dbda-6f10-aaca-d10f4b906a00","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Read Pending Queue (Google Sheets)","type":"main","index":0}]]},"Read Pending Queue (Google Sheets)":{"main":[[{"node":"Stamp & Shape Lead","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp & Shape Lead":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Work in Batches","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Work in Batches":{"main":[[{"node":"Aggregate Batch Results","type":"main","index":0}],[{"node":"Process Batch Item","type":"main","index":0}]]},"Process Batch Item":{"main":[[{"node":"Respect Rate Limits","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Respect Rate Limits":{"main":[[{"node":"Work in Batches","type":"main","index":0}]]},"Aggregate Batch Results":{"main":[[{"node":"Mark Completed in MySQL","type":"main","index":0}]]},"Mark Completed in MySQL":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Gmail":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"222c1694-0330-4cd1-ae70-3fe115af6942","id":"FDX04359"}