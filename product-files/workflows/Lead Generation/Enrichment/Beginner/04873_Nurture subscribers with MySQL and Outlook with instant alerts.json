ResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4266,400],"id":"6d7af2da-483c-4131-a84f-9176587c9022","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4590,400],"id":"a8010ad0-5876-434f-8eeb-fd83843ed7e8","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"dec5aedc-2a0a-4269-9b08-01c1fe216b2e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"cbdcddf9-05e1-4e61-9b02-0792af102758","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"b8e2eaea-4969-4856-ab8c-e56da8cabe3b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"fd180459-5c61-4f5d-bbca-2712cb4fd2d6","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"1648e1df-d59e-420b-aa7f-11bee1f937fc","name":"Append Audit Row (Google Sheets)","re