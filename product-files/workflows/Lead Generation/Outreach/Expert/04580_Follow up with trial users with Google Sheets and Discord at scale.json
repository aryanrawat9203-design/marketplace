ombinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[702,400],"id":"d8e28b32-c831-4e54-b6c5-57fee33adbe6","name":"Segment Audience"},{"parameters":{"authentication":"webhook","content":"=Hi {{ $json.name || 'there' }}, here's how to get started…","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[1026,160],"id":"1b8fa3b5-43a3-4c27-b732-c24a75176a06","name":"Step 1 — Welcome (Discord)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["leadId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1350,760],"id":"ff2e037f-9477-4ce4-ae75-9c4dbc2cfce7","name":"Tag for Slow Nurture","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":2,"unit":"days"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1674,400],"id":"5c122ef1-1903-46a4-b0e7-46286c403d56","name":"Wait Before Step 2","webhookId":"69bb0495-5a48-4622-ac79-bbd092c795b3"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"485001d5-ba8a-49a1-b2a2-46da9e1022f6","leftValue":"={{ $json.status }}","rightValue":"converted","operator":{"type":"string","operation":"notEquals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1998,400],"id":"646b11f2-55bc-466b-ab99-2120504665b2","name":"Converted Already?"},{"parameters":{"authentication":"webhook","content":"=Quick tip for {{ $json.company || 'your team' }} — see what others automate.","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[2322,160],"id":"ef56ac0d-c