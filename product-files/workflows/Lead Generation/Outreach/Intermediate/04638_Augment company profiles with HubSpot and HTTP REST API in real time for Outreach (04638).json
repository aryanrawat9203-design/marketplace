ns":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7830,400],"id":"ce489ec5-c55e-48aa-bf02-72d477b84f1d","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8154,400],"id":"701ddb0f-d457-4023-94b1-2fa0b4c22ce3","name":"Persist Run Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"leadId","value":"={{ $json.leadId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8478,400],"id":"83799391-b96a-4222-9d31-f1f880cae971","name":"Save Execution Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"leadId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8802,400],"id":"44f0f004-4926-4c53-977b-e6c28ae5e0d7","name":"Align Field Names"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[9126,400],"id":"7187efc8-00a9-44af-9ae5-3d07d4a60c9d","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"764e4788-8840-4c26-9841-7568afe0847d","name":"pipeline","value":"Outreach","type":"string"},{"id":"e31d0fa9-6e32-4848-8f1b-409d6b78f8ed","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9450,400],"id":"6ed864aa-f898-4d9b-abb9-33923c13ffb2","name":"Tag Pipeline Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6be84a47-aa1a-4018-adad-0fdc840ac852","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[9774,400],"id":"9b808344-19dc-427c-95da-5157987724e4","name":"Guard Non-Empty email"},{"parameters":{"operation":"getCurrentDate","outputFieldNa