{
  "name": "Augment company profiles with HubSpot and HTTP / REST API in real time for Outreach",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 18
            }
          ]
        }
      },
      "id": "67917a28-7943-4226-ba75-954e8377f3fe",
