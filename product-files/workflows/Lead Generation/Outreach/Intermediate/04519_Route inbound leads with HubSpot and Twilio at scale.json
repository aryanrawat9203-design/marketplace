{"name":"Route inbound leads with HubSpot and Twilio at scale","nodes":[{"parameters":{"formTitle":"Route inbound leads with HubSpot and Twilio at scale","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"30bb2bb5-756e-40a4-a843-744b4d296584","name":"New Lead Form Submission","webhookId":"5e98b9e2-b723-47f7-8cff-f077dabc8291"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"75384920-d687-4be5-8628-4100716d12ae","leftValue":"={{ $json.leadId || $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"d64c77ea-59c6-4b2b-9510-9840afd0d3ed","name":"Keep Valid Leads"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fb8cf3cb-de44-4fbd-9cf0-a229929efa8c","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"inbound","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"inbound"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f297653b-7b5f-4ca7-a050-8736914f97f8","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"outbound","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"outbound"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"aae41bed-898f-4697-b591-f7a2bfdabf55","name":"Route by Work Type"},{"parameters":{"operation":"appendOrUpdate","docum