7-42af-b43d-1d6f476ce4c5","name":"Guard Non-Empty email"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"leadId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7830,400],"id":"c130bbc5-4a25-4d00-8868-c7d24912c7c2","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"a28e51b2-b935-4c34-866c-56931cf4e485","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"1c1067ef-b880-411a-ae50-e209055d530d","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9c420b18-eb68-468b-a445-946be668b888","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"ffb4c4e9-002c-4024-87d6-d283baebe2b9","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Database"},"title":"={{ $json.email || $json.leadId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8478,400],"id":"6b3e5aa7-30f7-47d6-ab0e-f8ea954fcc69","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Clean company profiles with HubSpot and HTTP / REST API with instant a — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8802,400],"id":"f7a8cbcd-b71d-4b7f-bd9c-7683acdd475f","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"16b84345-194a-4cb0-a998-44fe35b082d1","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ff71f4a1-aa9d-40e0-9436-2958551e2450","