    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO leads (leadId, email, company, updated_at)\nVALUES ($1, $2, $3, NOW())\nON CONFLICT (leadId) DO UPDATE SET updated_at = NOW();",
        "options": {
          "queryReplacement": "={{ [ $json.leadId, $json.email, $json.company ] }}"
