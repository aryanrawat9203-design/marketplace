{"name":"Log form submissions with PostgreSQL and Twilio","nodes":[{"parameters":{"formTitle":"Log form submissions with PostgreSQL and Twilio","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"f7e69ca0-ba69-4621-ae71-0f7dca0d8be5","name":"New Lead Form Submission","webhookId":"84d0c2a1-8f43-4829-8730-de47b88a3add"},{"parameters":{"assignments":{"assignments":[{"id":"3d4f2d1a-df16-4345-97e4-1883f1270b44","name":"leadId","value":"={{ $json.leadId || $json.id || $execution.id }}","type":"string"},{"id":"2c64c7ae-3da8-4239-9ef9-e457c4d35e3e","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"76f1579b-b23b-4c5a-bab1-f9e6de004cc2","name":"Stamp & Shape Lead"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"739105cb-6c9c-4760-bd81-ac7cf04d23e2","leftValue":"={{ $json.leadId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"f38d5265-e766-4df5-bd79-eabf9d88936b","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[378,910],"id":"e047042d-d131-4eed-882e-85491a45d2a6","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each lead 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.email) score += 20;\n  if (j.company) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"cbe2223d-144b-4f26-b631-b5c4401d80b0","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1026,400],"id":"d54a2021-dcfa-4f1a-8ce1-f531d6a2799b","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"aa6bdc18-b438-467d-b30e-df045a77a85f","leftValue":"={{ $json.score }}","rightValue":80,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"hot"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fcd08de7-d2db-48b0-81c3-0c176a79affe","leftValue":"={{ $json.score }}","rightValue":50,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warm"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1350,400],"id":"56ad2229-0494-45ed-a2cd-c17e18edbcf1","name":"Route by Heat"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["leadId"],"sc