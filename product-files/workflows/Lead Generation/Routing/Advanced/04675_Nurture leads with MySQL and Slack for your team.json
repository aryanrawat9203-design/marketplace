{"name":"Nurture leads with MySQL and Slack for your team","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":9,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"83b0d3a9-977d-4b76-ada0-b9a9cf446e49","name":"Daily Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"54076b6a-f235-4e58-b650-4b6c61bfbed9","name":"leadId","value":"={{ $json.leadId || $json.id || $execution.id }}","type":"string"},{"id":"62a22746-e672-4065-90de-ffe6f9d918ec","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"a81d148f-5991-4379-9426-f84b9f980b1b","name":"Stamp & Shape Lead"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1ce7d9bc-c6c2-4ff2-ac38-cba980867e70","leftValue":"={{ $json.leadId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"4c5faba4-8c37-4bc6-8f4b-7f80d011239e","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[378,910],"id":"23d7b9bc-da36-4229-b558-5adb35740a0e","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each lead 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.email) score += 20;\n  if (j.company) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"9feeec1f-e49f-4e67-8ef1-4157b94b4965","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1026,400],"id":"332b2a6c-f85d-44ca-ab92-7820a17fb531","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d895ea8c-d2db-4615-9429-665374fba41b","leftValue":"={{ $json.score }}","rightValue":80,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"hot"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c3d0c13d-2a7b-459d-b750-3ad256356737","leftValue":"={{ $json.score }}","rightValue":50,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warm"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1350,400],"id":"3ee30199-c912-410f-9377-a530d59f97df","name":"Route by Heat"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["leadId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1674,-80],"id":"29128903-9140-4fe3-988e-8479c6e8c80f","name":"Hot → Google Sheets + Instant Ping","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🔥 New hot lead {{ $json.email }} → {{ $json.owner }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2322,-80],"id":"1241c179-cba1-4f9d-8f70-05f6eb06a88c","name":"Notify Assigned Owner","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=Thanks for your interest — here's a quick-start guide.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2646,400],"id":"2855eeef-1ae8-4156-9d9d-47f80a7bba00","name":"Warm → Drip via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[2970,880],"id":"e0987d79-1976-4f2a-a7fd-1cea255de3ca","name":"Cold → Park in Nurture List","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3942,400],"id":"054a542e-e600-4b75-9664-364e6e25e0a0","name":"Combine Lead Paths"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5238,400],"id":"04667de6-5884-4520-8844-7446e56716cf","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"a09c948b-ba5a-4641-9e1f-1e94c1109a46","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5886,400],"id":"3367398f-a361-4cea-96e8-b8a426579530","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"cd5e1b02-4f33-407b-868d-2e760d62d4b5","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"22750277-e3c9-47d3-b1c9-3da75b7e8a31","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"e021c247-9a9b-4f30-a58b-e9d4ed387611","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per lead (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.leadId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6534,400],"id":"9b904a71-9e64-47fe-96eb-4308ef4d624b","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6858,400],"id":"2066d966-9924-4b31-a3b0-a42933c1e680","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"bd5c49a4-a185-4fde-84ea-ad5ed2703868","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5a2a2543-dfe4-45b0-a67d-12202c11d7ab","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"7c435fe0-f968-46f9-8684-3384be869151","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"0956b7b2-6ff6-4d7f-8597-b4c79061a025","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7506,400],"id":"7e572635-8f11-4d6a-84bd-e69689f783ef","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Nurture leads with MySQL and Slack for your team — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7830,400],"id":"00ace8ab-b047-4559-80b2-0c608e3b841c","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"be6e2224-29ce-44a8-ab55-476b181a6613","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"435a4da5-a93d-44a1-aa59-ee1fd1d10491","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"d0697822-bb1c-434f-9bcb-28287b27e4c6","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,1420],"id":"dc4a9911-f7ef-4df8-8bd4-b05dc6995fb4","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7506,1420],"id":"86aef2d7-5da9-4819-aa38-59448934740d","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"leads","cachedResultName":"leads"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[7830,1420],"id":"fc475b42-ef64-4175-88ae-372e8d12dad8","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 9:00. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Lead","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ef743666-5c2c-c6c6-427e-cece8c8f19b0","name":"Note: Daily Schedule"},{"parameters":{"content":"### Stamp & Shape Lead\n\nShapes the item: writes `leadId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"a841dd5e-896e-c288-8bc3-3f3b6d1e518c","name":"Note: Stamp & Shape Lead"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.leadId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Score the Lead · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"301ce1b9-1fca-f190-517f-e9e7f4a17468","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nmySql — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"8b4168e9-7192-cc32-21f4-adf13ae2f459","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Score the Lead\n\nCustom JavaScript: Score each lead 0-100 from simple heuristics\n\nNext: Assign Round-Robin Owner","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"c3a210ef-641a-559d-b273-463f5af1a45a","name":"Note: Score the Lead"},{"parameters":{"content":"### Assign Round-Robin Owner\n\nCustom JavaScript: Round-robin owner assignment\n\nNext: Route by Heat","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"fb547903-4dd4-2d51-5a7d-6c12c0393a8b","name":"Note: Assign Round-Robin Owner"},{"parameters":{"content":"### Route by Heat\n\nRoutes each item to one of 3 lanes: hot, warm + fallback.\n\nPorts: ①→ Hot → Google Sheets + Instant Ping · ②→ Warm → Drip via Slack · ③→ Cold → Park in Nurture List","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"f7aa23b1-5fee-c873-22be-9370625576ee","name":"Note: Route by Heat"},{"parameters":{"content":"### Hot → Google Sheets + Instant Ping\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Notify Assigned Owner · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,40],"id":"a658d3e0-d897-99a2-ff2a-0450de8ed699","name":"Note: Hot → Google Sheets + Instant Ping"},{"parameters":{"content":"### Notify Assigned Owner\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,40],"id":"bc5969e2-d98b-8bcf-4f3d-84e3daaf4445","name":"Note: Notify Assigned Owner"},{"parameters":{"content":"### Warm → Drip via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"0851f1fb-c211-3a67-c8c7-9d78e8fbefe6","name":"Note: Warm → Drip via Slack"},{"parameters":{"content":"### Cold → Park in Nurture List\n\nmySql — `append` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,1000],"id":"08a15697-8a41-6bf7-78ce-4290ffc42d00","name":"Note: Cold → Park in Nurture List"},{"parameters":{"content":"### Combine Lead Paths\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"4ea67d86-75fb-6b71-5bac-3a0423eceeb0","name":"Note: Combine Lead Paths"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"8c89b9cc-5060-c683-ebb5-4ca89abdbe48","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"f07c449f-eea6-b96c-6987-e2a9c042ae24","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"c21d88ac-d0c3-fc15-772c-921464ab4544","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"086680db-5cbb-c586-4dfa-bbe2f418ea6a","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per lead (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"9ab35e9f-bf7c-2ec9-d316-be66324c23bb","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"11ec2801-7c19-2e9a-ef45-83a29d9bb777","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"9198f842-573a-5af7-f829-c0cd6a2ae801","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"5844395e-54f0-5312-6787-c34f4c5a61c2","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"438be042-601d-ee7a-be58-8f006c864dbd","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"75363820-b537-f1b8-7425-41dc634545a8","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"baa3a9d8-0fc9-44ab-6a88-09901b620e22","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nmySql — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,1540],"id":"6be9604f-036b-e035-5e79-f863a1a1dcdb","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Nurture leads with MySQL and Slack for your team\n\n**Pattern:** Drip Sequence · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nNurture leads with MySQL and Slack for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual routing is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Stamp & Shape Lead → Payload Valid? → Score the Lead → Assign Round-Robin Owner → Route by Heat → Hot → Google Sheets + Instant Ping → …\n\n## Use it for\n- Teams that want to drip sequence without manual effort\n- Anyone automating routing in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Runs 24/7 in the background\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; MySQL connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"ec2b53d3-2228-a2f3-5cc3-d350af36a226","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"13f3257d-c194-cbe6-3ae1-44b4324f3bc0","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"edc02027-07e5-322d-696e-16f74af96172","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your routing process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"d64c5e70-7a60-ac98-8cb2-3ad0cc648a56","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Stamp & Shape Lead","type":"main","index":0}]]},"Stamp & Shape Lead":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Score the Lead","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Score the Lead":{"main":[[{"node":"Assign Round-Robin Owner","type":"main","index":0}]]},"Assign Round-Robin Owner":{"main":[[{"node":"Route by Heat","type":"main","index":0}]]},"Hot → Google Sheets + Instant Ping":{"main":[[{"node":"Notify Assigned Owner","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Route by Heat":{"main":[[{"node":"Hot → Google Sheets + Instant Ping","type":"main","index":0}],[{"node":"Warm → Drip via Slack","type":"main","index":0}],[{"node":"Cold → Park in Nurture List","type":"main","index":0}]]},"Notify Assigned Owner":{"main":[[{"node":"Combine Lead Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Warm → Drip via Slack":{"main":[[{"node":"Combine Lead Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Cold → Park in Nurture List":{"main":[[{"node":"Combine Lead Paths","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Combine Lead Paths":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"62612f25-a779-441b-afa0-610dc7aa0cc9","id":"FDX04675"}