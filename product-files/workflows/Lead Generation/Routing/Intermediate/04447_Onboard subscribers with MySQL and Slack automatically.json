          "conditions": [
            {
              "id": "af99f00c-db1c-443d-b189-ada801601efa",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
