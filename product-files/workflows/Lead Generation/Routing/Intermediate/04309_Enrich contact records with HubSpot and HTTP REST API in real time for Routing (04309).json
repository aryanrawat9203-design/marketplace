prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5238,400],"id":"ee808c9f-3629-4405-b446-41561a57e397","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"56eff2b1-539b-46b9-8a5a-60b75bd9cc71","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b5e4c46f-20a0-4a1d-a8ad-ee467baaa9c0","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"630ccd8a-f9d5-4c83-9673-68dd10a6a520","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"72f8e6c9-c2ec-4202-9875-d91e7d883251","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"ffe3323d-7257-4a4a-a8f7-16ced94207e9","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Enrich contact records with HubSpot and HTTP / REST API in real time f — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,400],"id":"9b2af010-9327-452f-9829-161208eb7a9a","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id"