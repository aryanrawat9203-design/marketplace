nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"149bb66e-3688-4a22-9866-37a0672881eb","name":"Compute Drift vs Snapshot"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"leadId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[5886,400],"id":"4f9dce92-3329-4a64-aa1c-5b9735a27675","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"12dc6962-98b0-493b-b1bf-06cc7e81c656","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[6210,400],"id":"9e779a64-803f-438d-8856-029b184369c8","name":"Guard Non-Empty email"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6534,400],"id":"5beeb7c6-b586-4b58-a55d-f5178459ebf8","name":"Stamp Processing Time"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"score","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[6858,400],"id":"d2b9f98d-f9dc-47a4-a921-982523e993d1","name":"Sort Leads Newest First"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7182,400],"id":"f9cb737a-dcc0-46d9-8ee7-89b77e213398","name":"Cap Batch Volume"},{"parameters":{"dataToSave":{"values":[{"key":"leadId","value":"={{ $json.leadId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7506,400],"id":"75484a98-9fbc-4640-a873-0bc858353a6b","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"971ff2bb-792e-4011-83f2-923b3f93c317","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id"