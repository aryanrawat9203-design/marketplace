{"name":"Capture inbound leads with HubSpot and Outlook and log the results","nodes":[{"parameters":{"formTitle":"Capture inbound leads with HubSpot and Outlook and log the r","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"513b8a09-2e80-43cf-ac1a-26d0895b2520","name":"New Lead Form Submission","webhookId":"fcf680a4-da22-4108-a3ac-4d537cf11972"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming lead records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    leadId: String(j.leadId ?? j.id ?? '').trim(),\n    email: typeof j.email === 'string' ? j.email.trim() : j.email ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"3b3a9d15-64be-4469-b0b9-6815dc9ee9c1","name":"Normalize Lead Payload"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f7d362b4-341b-4c29-8d73-5add00003716","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"mql","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"mql"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"35ec6764-1a06-4227-97bb-5e102130247b","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"sql","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"sql"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,