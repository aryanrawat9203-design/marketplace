t[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"9105c2e6-e538-45d7-8823-84c71c915485","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[7506,400],"id":"2df79077-28a6-4403-9091-121ffa102795","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b9041955-8943-49f3-ad43-732fc4303617","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f51f7736-61bc-48c3-972d-7960150ba179","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7830,400],"id":"de4fc9c0-5d05-4a63-9f57-6e7c41c27695","name":"Fold In Enrichment Fields"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"score","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8154,400],"id":"438d1d57-c9d6-4dc2-904f-b21a4954cc96","name":"Sort Leads Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"leadId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8478,400],"id":"5e901cdf-36c4-4f85-a06c-4f3cd6a886a6","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"b712f3f1-e084-445f-b39e-1bb8aaf0bc53","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"337803f9-d549-49d4-96d4-e7090e54b3ad","name":"itemCount","value":"={{ $input.all().length }}","type":"number"