] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[8154,400],"id":"2be379ba-a5fe-4215-ba29-ede5ecab5387","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"f778ce28-cf54-4952-a27b-1b37a1a2ae92","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"41ca077e-cecb-4810-8a2b-f1959141d713","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"a82a9e57-cc8f-4db2-886f-270b38c8e438","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,400],"id":"cd224498-a7a6-4452-98b8-8a9fede92f56","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[8802,400],"id":"530dcaf3-dbd4-48e2-ad4e-04e50ce283b0","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Qualify demo requests with HubSpot and Gmail — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9126,400],"id":"1f12aaef-a8c9-4214-8125-910b1593ea5d","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"c2c742b1-7cd9-4fa9-a259-268ce7