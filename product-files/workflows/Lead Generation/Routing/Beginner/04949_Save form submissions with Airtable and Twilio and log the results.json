tion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5886,400],"id":"d129d6ee-6ddf-4c49-b23a-0be110aca94f","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"99c4957c-7c38-43e3-98dd-fc498d13eeb1","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"16a9be2d-ef30-491a-8946-8e6980ad0894","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"f0ba3de6-6dd6-4918-b4dd-45c760b78f96","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"cddd6924-c2f7-45f7-ae71-448077d8ba9f","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Generation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Leads"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[6534,400],"id":"b9c510ae-91b8-40a7-b877-4c4f60e7ccb5","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Save form submissions with Airtable and Twilio and log the results — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[6858,400],"id":"717d8774-2720-4d45-94c3-e38c3a2ed5f1","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"315f9912-4fcc-4514-b837-ef9f4c85c8ae","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","