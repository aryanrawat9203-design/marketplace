"type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"428bcd92-6bfb-44fe-847a-5317ec9a0556","name":"Summarize Run Stats"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.hubspot","typeVersion":2,"position":[5238,400],"id":"9e70666d-de31-46c4-8b5d-4dd4bc811f48","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Capture inbound leads with HubSpot and Telegram hands-free — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[5562,400],"id":"1ae8b887-359b-4084-963a-42764580d623","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"27eb631f-eb99-4156-8dbc-efa5f1483b0f","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"5831fe9f-394a-4df6-a1e8-2d1d1ddc2332","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"032f353f-bba5-4f22-96ce-f3be0b0dfb91","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,1420],"id":"4f3502b9-d85f-4c84-aafd-9c9f5e2af543","name":"Capture Failure Context"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[5238,1420],"id":"cb70fee5-9f56-443a-b035-b14e94f06906","name":"Escalate Failure to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Lead Form Submission\n\nServes an n8n-hosted form (Email, Company, Score). Each submission becomes one execution.\n\nNext: Stamp & Shape Lead","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"016dd807-a788-41ee-48cc-b7fa68537d2c","name":"Note: New Lead Form Submission"},{"parameters":{"content":"### Stamp & Shape Lead\n\nShapes the item: writes `leadId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"73386b47-de79-b0bd-bccd-42fc4bae4853","name":"Note: Stamp & Shape Lead"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.leadId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Route by Work Type · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"62e8193d-b036-821c-080d-4fae0cd31064","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nCreates or updates a HubSpot contact by email — HubSpot is the CRM system of record for this pipeline.\n\n↻ retries 3×/2s · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"90da693a-aee9-1ec3-921f-4f09562f52a8","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: inbound, outbound + fallback.\n\nPorts: ①→ Process 'inbound' → HubSpot · ②→ Fast-Track 'outbound' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"0426eb60-ae6e-283f-f68f-985f229c41b0","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'inbound' → HubSpot\n\nCreates or updates a HubSpot contact by email — HubSpot is the CRM system of record for this pipeline.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,250],"id":"a645b2fd-02d6-8148-b2b7-92eb7c326f69","name":"Note: Process 'inbound' → HubSpot"},{"parameters":{"content":"### Fast-Track 'outbound' + Alert\n\nPosts a message to Slack (`#sales`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,760],"id":"89531bc1-4aae-2568-2871-c9e5292aea0e","name":"Note: Fast-Track 'outbound' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\nCreates or updates a HubSpot contact by email — HubSpot is the CRM system of record for this pipeline.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1270],"id":"d51c0d3a-8a75-52cd-1b32-3ae0b1a3bc70","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"b4648e6b-68c7-37ae-ed89-acde09a368c9","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"bbc4945c-a3a5-4835-cdca-318cd609e19d","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Guard Non-Empty email","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"c8a8d6a1-777a-0b72-3b8d-de8c4913c77a","name":"Note: Align Field Names"},{"parameters":{"content":"### Guard Non-Empty email\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"7a023e42-d4f5-bc37-8d30-1089e8bc11fc","name":"Note: Guard Non-Empty email"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"44fb13fe-84b9-6989-1f3f-377f2357fb4f","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"da51f0ed-1c6c-45d4-b489-77f55cc99bb9","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"c3e388bc-0f12-4765-d631-e1b84ac5697b","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nCreates or updates a HubSpot contact by email — HubSpot is the CRM system of record for this pipeline.\n\nPorts: ①→ Send Summary to Telegram · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"5bce7d6e-a457-cc7d-225e-bb2790a521ca","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Telegram\n\nSends a Telegram message to the configured chat — the same bot can also receive replies, so this doubles as a two-way ops channel.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"0018fd4e-847f-1cc6-f8fa-8f644900b505","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Telegram","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"f60b936b-13f8-2926-fe42-ea6418da7e24","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Telegram\n\nSends a Telegram message to the configured chat — the same bot can also receive replies, so this doubles as a two-way ops channel.\n\n↻ retries 3×/2s · 🔑 Telegram bot token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"99d2b0a0-991b-23b9-bb14-0be46a4aecd1","name":"Note: Escalate Failure to Telegram"},{"parameters":{"content":"# Capture inbound leads with HubSpot and Telegram hands-free\n\n**Pattern:** Lead Capture & Routing · **Level:** Advanced · **Trigger:** Form\n\n## What it does\nCapture inbound leads with HubSpot and Telegram hands-free. It starts from a hosted form submission.\n\n## Why it exists\nManual capture forms is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Lead Form Submission → Stamp & Shape Lead → Payload Valid? → Route by Work Type → Process 'inbound' → HubSpot → Merge Routed Work → Save Execution Metadata → …\n\n## Use it for\n- Teams that want to lead capture & routing without manual effort\n- Anyone automating capture forms in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Responds in seconds\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: HubSpot private-app token; Slack OAuth2; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9e609f6d-28a0-2f38-f49d-e1aae24de054","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nUnrecognized work types are parked in a dead-letter lane instead of erroring the whole run or silently dropping the item — new event kinds will show up eventually, and this is where you'd notice one without losing it. One kind is deliberately routed through a sub-workflow to show how heavier per-type logic can be extracted without touching this router at all.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"c018ebcd-1479-5c57-598a-85245194fdeb","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nYou've got the basics covered — push further:\n\n1. Send a work-type value that matches no switch rule and confirm it lands in the dead-letter branch.\n2. Add a new work type and its own handling branch.\n3. Replace the direct-write branch with a sub-workflow call, matching the pattern already used for the first kind.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"31344891-1928-2e6a-e63e-26866e7055d7","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"b5f37f68-de97-7992-a48b-98aef463f684","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your capture forms process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"9cf2dcc8-1f5b-4797-10c3-91b68d70bec0","name":"🛠 Customize me"}],"connections":{"New Lead Form Submission":{"main":[[{"node":"Stamp & Shape Lead","type":"main","index":0}]]},"Stamp & Shape Lead":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Route by Work Type","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'inbound' → HubSpot","type":"main","index":0}],[{"node":"Fast-Track 'outbound' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'inbound' → HubSpot":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'outbound' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Guard Non-Empty email","type":"main","index":0}]]},"Guard Non-Empty email":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Telegram","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Telegram","type":"main","index":0}]]},"Send Summary to Telegram":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"New Lead Form Submission":[{"json":{"leadId":"LEAD-8801","email":"tom.becker@innotech.com","company":"InnoTech Solutions","score":82}},{"json":{"leadId":"LEAD-8802","email":"grace.kim@harborworks.com","company":"Harborworks","score":47}}]},"versionId":"7450a166-7758-462e-9463-54d0a29c4f52","id":"FDX04528"}