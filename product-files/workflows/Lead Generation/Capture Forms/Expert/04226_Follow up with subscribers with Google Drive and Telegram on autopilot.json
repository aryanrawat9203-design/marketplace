    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "fed38cf0-893b-4f6c-8d7a-caebed4cf9b1",
              "leftValue": "={{ $json.receivedAt || $now.toISO() }}",
