{"name":"Log applications with Airtable and Twilio automatically","nodes":[{"parameters":{"formTitle":"Log applications with Airtable and Twilio automatically","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"82efdf33-f919-475c-90c6-2da49f4861eb","name":"New Lead Form Submission","webhookId":"cf355a35-52a6-42d1-a165-01de91b408e3"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4e5adc0e-a63a-4b98-bbd4-65fac754035c","leftValue":"={{ $json.leadId || $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"60ed0f92-8e9d-4477-951e-7f9be42b89a2","name":"Keep Valid Leads"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b2994b32-5d16-4479-9e7e-e36ce62ea8e7","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"sales","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"sales"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"5c7227fd-22bf-4cc1-90ed-381ab2faf32c","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"support","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"support"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"30bcf079-4938-446b-869e-d428fc7d06a4","name":"Route by Work Type"},{"parameters":{"workflowId":{"__rl":true,"mode":"l