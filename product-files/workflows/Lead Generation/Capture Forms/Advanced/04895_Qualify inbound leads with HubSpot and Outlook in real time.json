{"name":"Qualify inbound leads with HubSpot and Outlook in real time","nodes":[{"parameters":{"formTitle":"Qualify inbound leads with HubSpot and Outlook in real time","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"68328182-a65b-4697-9b41-48342fb01e8a","name":"New Lead Form Submission","webhookId":"587fa833-983b-4785-93bc-5c8a76284ae5"},{"parameters":{"assignments":{"assignments":[{"id":"486b6d17-56b7-4eb4-af12-937d94397b0a","name":"leadId","value":"={{ $json.leadId || $json.id || $execution.id }}","type":"string"},{"id":"8745babe-23dc-4b4a-b3d4-06643f26e010","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"a2b73add-572c-437d-a390-6a3c19fb2e79","name":"Stamp & Shape Lead"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b88cf192-feec-446b-9c03-70d4eb4e8863","leftValue":"={{ $json.leadId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"fc2029b3-b3db-4b07-b5e7-3611056d81b3","name":"Payload Valid?"},{"parameters":{"resource":"contact","email":"={{ $json.email }}","additionalFields":{"companyName":"={{ $json.company }}"},"authentication":"appToken"},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"c88d4a09-5352-4003-b137-ad08a57c88c1","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"74425d8c-98b1-4681-997e-3ba2e3404b5c","leftVal