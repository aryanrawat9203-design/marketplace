":"n8n-nodes-base.hubspot","typeVersion":2,"position":[6210,400],"id":"9cbd2530-d182-4b42-9575-f4254f39784c","name":"Append Audit Row (HubSpot)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Route inbound leads with HubSpot and Gmail with instant alerts — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,400],"id":"5758a79d-5eec-4aa5-a8cb-cc9bfaa7954f","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"83846ecd-ff72-4175-bf71-d056a22c44fa","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ca8c47dd-6b1f-49d2-aecd-eb96454214f8","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"9d43113d-e020-49c7-83ae-2e8f0a4e4c54","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"62c5787a-4f0f-4569-9b36-739597e77a9c","name":"Capture Failure Context"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[6210,1420],"id":"51dff9a9-e858-4dab-9bb3-2a156d45d400","name":"Escalate Failure to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Lead Form Submission\n\nServes an n8n-hosted form (Email, Company, Score). Each submission becomes one execution.\n\nNext: Keep Valid Leads","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"f3bbe095-529e-3a13-29e0-283c7789ab21","name":"Note: New Lead Form Submission"},{"parameters":{"content":"### Keep Valid Leads\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Score the Lead","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"fe0d6899-de17-31c9-6608-988e9d4c2e4e","name":"Note: Keep Valid Leads"},{"parameters":{"content":"### Score the Lead\n\nCustom JavaScript: Score each lead 0-100 from simple heuristics\n\nNext: Assign Round-Robin Owner","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"f4317d39-c3bc-a267-49d8-03606b782d3a","name":"Note: Score the Lead"},{"parameters":{"content":"### Assign Round-Robin Owner\n\nCustom JavaScript: Round-robin owner assignment\n\nNext: Route by Heat","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"29b8656f-a412-a5c7-6915-6c73549346bf","name":"Note: Assign Round-Robin Owner"},{"parameters":{"content":"### Route by Heat\n\nRoutes each item to one of 3 lanes: hot, warm + fallback.\n\nPorts: ①→ Hot → HubSpot + Instant Ping · ②→ Warm → Drip via Gmail · ③→ Cold → Park in Nurture List","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"6439734a-1357-09fc-689a-a998f58c33b7","name":"Note: Route by Heat"},{"parameters":{"content":"### Hot → HubSpot + Instant Ping\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Notify Assigned Owner · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,40],"id":"84a4ce00-44bd-25f2-d93c-4bcc76cee065","name":"Note: Hot → HubSpot + Instant Ping"},{"parameters":{"content":"### Notify Assigned Owner\n\ngmail — `action` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,40],"id":"c4944a1d-67c0-4abb-1eb4-54e46d9b4da7","name":"Note: Notify Assigned Owner"},{"parameters":{"content":"### Warm → Drip via Gmail\n\ngmail — `action` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"b94ba019-aae7-43f0-3784-a521385c5bca","name":"Note: Warm → Drip via Gmail"},{"parameters":{"content":"### Cold → Park in Nurture List\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1000],"id":"58646d11-365a-7466-26a9-dca364353ecc","name":"Note: Cold → Park in Nurture List"},{"parameters":{"content":"### Combine Lead Paths\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"b78b9d38-bca5-afd2-6167-0f9ea3bc9608","name":"Note: Combine Lead Paths"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Sort Leads Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"3b3c1954-c4de-ad93-a470-7a2535437008","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Sort Leads Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"edf1aa7a-0d9c-28f5-271d-8f43a67b9f4f","name":"Note: Sort Leads Newest First"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"86746362-db2f-b781-3f99-190c062dee00","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (HubSpot)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"17c89615-417a-0711-edb3-e5622301e8fc","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (HubSpot)\n\nhubspot — `contact` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 HubSpot private-app token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"f58d2875-6aff-78c6-8220-b9040d843a3f","name":"Note: Append Audit Row (HubSpot)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"1c147a1f-3629-3264-7509-22779b5ab74b","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Gmail","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"dc35b319-8f32-8d39-af39-aabc4c67568b","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"aef1363a-558f-e186-82f3-03fccdd66407","name":"Note: Escalate Failure to Gmail"},{"parameters":{"content":"# Route inbound leads with HubSpot and Gmail with instant alerts\n\n**Pattern:** Lead Capture & Routing · **Level:** Advanced · **Trigger:** Form\n\n## What it does\nRoute inbound leads with HubSpot and Gmail with instant alerts. It starts from a hosted form submission.\n\n## Why it exists\nManual capture forms is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Lead Form Submission → Keep Valid Leads → Score the Lead → Assign Round-Robin Owner → Route by Heat → Hot → HubSpot + Instant Ping → Notify Assigned Owner → …\n\n## Use it for\n- Teams that want to lead capture & routing without manual effort\n- Anyone automating capture forms in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Improves response time\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Google OAuth2; HubSpot private-app token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"86fa10a1-7071-c713-a468-7a933e9f3339","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"87985520-0263-4a3a-f410-ae5948a85589","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your capture forms process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"0399b6d1-2840-8cd8-1638-aec3cc25df2c","name":"🛠 Customize me"}],"connections":{"New Lead Form Submission":{"main":[[{"node":"Keep Valid Leads","type":"main","index":0}]]},"Keep Valid Leads":{"main":[[{"node":"Score the Lead","type":"main","index":0}]]},"Score the Lead":{"main":[[{"node":"Assign Round-Robin Owner","type":"main","index":0}]]},"Assign Round-Robin Owner":{"main":[[{"node":"Route by Heat","type":"main","index":0}]]},"Hot → HubSpot + Instant Ping":{"main":[[{"node":"Notify Assigned Owner","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Route by Heat":{"main":[[{"node":"Hot → HubSpot + Instant Ping","type":"main","index":0}],[{"node":"Warm → Drip via Gmail","type":"main","index":0}],[{"node":"Cold → Park in Nurture List","type":"main","index":0}]]},"Notify Assigned Owner":{"main":[[{"node":"Combine Lead Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Warm → Drip via Gmail":{"main":[[{"node":"Combine Lead Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Cold → Park in Nurture List":{"main":[[{"node":"Combine Lead Paths","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Combine Lead Paths":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Sort Leads Newest First","type":"main","index":0}]]},"Sort Leads Newest First":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (HubSpot)","type":"main","index":0}]]},"Append Audit Row (HubSpot)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Gmail","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"7bec3c33-2e14-4c31-a0ae-135f92ff4423","id":"FDX04838"}