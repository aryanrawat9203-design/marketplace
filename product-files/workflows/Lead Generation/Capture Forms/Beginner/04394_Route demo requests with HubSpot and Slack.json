,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5886,400],"id":"a31ee387-25b0-4adb-8829-d9e4f22c29a5","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6210,400],"id":"e3893f7f-646f-45e0-9984-5e97d053b3c8","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6534,400],"id":"f30624d6-9b2d-484f-900e-42abb33b495e","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"d28b90ad-8560-401d-89ca-f66a0903a4da","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"2700ab27-8033-4c74-902c-d081eb865616","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"47e265c8-dd2d-4522-a8f8-49008a46bd80","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"2aa134ea-5001-4199-b1d1-ea9f96715921","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name"