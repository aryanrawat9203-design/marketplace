{"name":"Save applications with PostgreSQL and Outlook end to end","nodes":[{"parameters":{"formTitle":"Save applications with PostgreSQL and Outlook end to end","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"e2e5c990-ccde-4fb5-92e6-e3ee765ce414","name":"New Lead Form Submission","webhookId":"1b3f337f-efee-4a1a-8307-7681d12eeb0a"},{"parameters":{"assignments":{"assignments":[{"id":"ded93840-12aa-47d3-bcd2-354226a6ba38","name":"leadId","value":"={{ $json.leadId || $json.id || $execution.id }}","type":"string"},{"id":"462aaa80-b855-4f59-aab9-632b77f304f7","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"f3c631b8-bec0-4ede-8a1a-f00109f5ddef","name":"Stamp & Shape Lead"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2aaece77-b8d6-4761-92a4-ce480e5efbe7","leftValue":"={{ $json.leadId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"0051bf35-d087-4ff8-9467-26ab16de20f1","name":"Payload Valid?"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO lead_log (leadId, email, company, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.leadId, $json.email, $json.company ] }}"}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"4fa734eb-3fac-4f7c-b26e-3b205bc4bdba","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each lead 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.email) score += 20;\n  if (j.company) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"7db05616-fafb-408f-8536-8edf2aae3c60","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1026,400],"id":"9375364f-6999-40b6-9726-d58e37d65a11","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a52a3a26-1102-48ea-a770-4156f0509781","leftValue":"={{ $json.score }}","rightValue":80,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"hot"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2e5b9662-c24a-4f2f-8a1c-06970cafcf8d","leftValue":"={{ $json.score }}","rightValue":50,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warm"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1350,400],"id":"0aea079c-ac05-480b-95c1-34c4d01cad51","name":"Route by Heat"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["leadId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1674,-80],"id":"8e71b152-3787-4594-8941-3ddb0e09f067","name":"Hot → Google Sheets + Instant Ping","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=🔥 New hot lead {{ $json.email }} → {{ $json.owner }}","bodyContent":"=🔥 New hot lead {{ $json.email }} → {{ $json.owner }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[2322,-80],"id":"628bd3aa-9e5b-47f5-9090-aa188722a923","name":"Notify Assigned Owner","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=Thanks for your interest — here's a quick-start guide.","bodyContent":"=Thanks for your interest — here's a quick-start guide.","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[2646,400],"id":"5aa6b642-8184-43d2-8263-5929a00385ae","name":"Warm → Drip via Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2970,880],"id":"8681ace0-db16-4343-b4c4-ef2ae112bcba","name":"Cold → Park in Nurture List","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3942,400],"id":"d76ceee8-2ba4-4a45-a4a2-d35632226e5c","name":"Combine Lead Paths"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile