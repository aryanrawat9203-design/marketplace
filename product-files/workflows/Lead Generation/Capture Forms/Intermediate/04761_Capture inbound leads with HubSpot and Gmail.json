{"name":"Capture inbound leads with HubSpot and Gmail","nodes":[{"parameters":{"formTitle":"Capture inbound leads with HubSpot and Gmail","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"c9be9ed1-ff66-41cf-9d11-6a0512e50066","name":"New Lead Form Submission","webhookId":"43d91a1a-0721-4483-a1b5-07f19d07ce9d"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming lead records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    leadId: String(j.leadId ?? j.id ?? '').trim(),\n    email: typeof j.email === 'string' ? j.email.trim() : j.email ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"baaf3421-9c8f-4247-8d14-b9dae48658ab","name":"Normalize Lead Payload"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"dbcce840-3c0e-4801-ae72-4b6d536bcf77","leftValue":"={{ ($json.score ?? 50) >= 50 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"89da888a-4bad-4c62-b857-cb5377455998","name":"Segment Audience"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=Hi {{ $json.name || 'there' }}, here's how to get started…","message":"=Hi {{ $json.name || 'there' }}, here's how to get started…","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[702,160],"id":"b138dea6-611c-4e6e-88b5-d955754ddd9b","name":"Step 1 — Welcome (Gmail)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"o