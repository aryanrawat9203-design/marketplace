eld Names"},{"parameters":{"assignments":{"assignments":[{"id":"25566186-e033-4e64-8fcd-3928a4ac5961","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"bbcf27d5-ea65-44a1-ac27-c86c079aec8f","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"69ca25db-9e0d-41cd-8951-74a2b5364535","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8802,400],"id":"06f4ebe7-8db0-4e63-9304-2dec63d91d06","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Database"},"title":"={{ $json.email || $json.leadId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9126,400],"id":"93cfc577-dcf6-44a0-9096-521f2782586d","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Clean contact records with HubSpot and HTTP / REST API without manual  — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9450,400],"id":"6c87c454-eb38-406d-b6ba-8b9e54420066","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b21a34c5-3b99-49c7-83a8-7f90dac5ed10","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a674f3e1-f04c-418b-8f82-c67255f6a644","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"6f3cc3c9-35c8-4f2d-a712-8e2de38e9053","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3