es-base.splitInBatches","typeVersion":3,"position":[1026,400],"id":"2372a69b-affe-4ec8-92ea-d1a14d7aac54","name":"Work in Batches"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/leads","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1350,880],"id":"5cd7f863-d278-4856-8f33-11ae94d46fb4","name":"Process Batch Item","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":2,"unit":"seconds"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1998,880],"id":"97697eaf-ea07-4626-91bf-2af482b75eee","name":"Respect Rate Limits"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[2322,400],"id":"f5eba2e3-f140-44ea-b27d-744735819343","name":"Aggregate Batch Results"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["leadId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,400],"id":"2b41d340-27a7-4dd9-844f-708b61b0dce3","name":"Mark Completed in Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"9101ee22-052a-4ac0-a683-9af53b1f7cb4","name":"pipeline","value":"Capture Forms","type":"string"},{"id":"55d71b3c-1593-4260-882f-1cb0714112d9","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2970,400],"id":"ec1710f7-8e53-4ee4-84fd-80e05d0723c3","name":"Tag Pipeline Metadata"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[3294,400],"id":"c79e405a-f177-46a9-acbe-8bde5378d4fa","name":"Cap Batch Volume"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3618,400],"id":"80620427-0054-4ec5-ad31-5983ddcc2ec8","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"c498482e-e7d1-4224-ae01-375c18945d20","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"36310c87-7355-4ed3-869c-d68e38405e72","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"5bd3a701-3040-4981-a4cd-3a661ce36a60","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,400],"id":"da2fa4ac-bb3f-4db5-a252-a9bef1d9f043","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"leads","cachedResultName":"leads"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[4266,400],"id":"4733fdd7-85f3-4abc-9b3a-5da2b9e0ba38","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Nurture trial users with MySQL and Telegram automatically — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[4590,400],"id":"91e87a15-b2fc-40d3-946a-07e2ae85d616","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"8b038af4-d562-40be-953d-29e49fe1d259","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"70b7ac3f-9e68-4dc8-9bed-d87fdf357254","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"b8a8a5d2-4e3f-49ba-b826-fb5843070e0a","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,1420],"id":"1b735d6f-abf9-46c1-8173-4b3076295d02","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,1420],"id":"4632fab4-2106-4c89-9394-0c62d5f7e111","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 6 h. No input data; downstream nodes fetch what they need.\n\nNext: Read Pending Queue (MySQL)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d175a474-3205-7164-8abd-72f9c5c8f1eb","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Read Pending Queue (MySQL)\n\nmySql — `select` operation against the connected account.\n\nPorts: ①→ Stamp & Shape Lead · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"4a724784-b924-fc3f-9cab-e75b801ed9e8","name":"Note: Read Pending Queue (MySQL)"},{"parameters":{"content":"### Stamp & Shape Lead\n\nShapes the item: writes `leadId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"02be4e42-e7d8-60e2-da64-ed8d396c1fab","name":"Note: Stamp & Shape Lead"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.leadId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Work in Batches · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"ce83f1f6-ec26-1eb6-976a-0a5fd52599a0","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nmySql — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1030],"id":"7fbfc5f3-a0ee-0fa9-cd8a-f7c66b69d441","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Work in Batches\n\nLoop controller — releases 20 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Aggregate Batch Results · ②→ Process Batch Item","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"9504eb95-152d-4108-350d-8cbafdb8cb31","name":"Note: Work in Batches"},{"parameters":{"content":"### Process Batch Item\n\nPOST https://api.example.com/v1/leads — retries 3× with backoff on failure.\n\nPorts: ①→ Respect Rate Limits · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1000],"id":"1fccdab9-b3a8-672c-7303-c9e8b6c31b4e","name":"Note: Process Batch Item"},{"parameters":{"content":"### Respect Rate Limits\n\nPauses 2 seconds — spacing calls to respect rate limits.\n\nNext: Work in Batches","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,1000],"id":"371708d5-de6e-39e1-8b68-ae23aa62bf6b","name":"Note: Respect Rate Limits"},{"parameters":{"content":"### Aggregate Batch Results\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Mark Completed in Google Sheets","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"c3700d6d-e70d-8142-62d8-4091dbfd7526","name":"Note: Aggregate Batch Results"},{"parameters":{"content":"### Mark Completed in Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Tag Pipeline Metadata · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"8f4e6eaf-97eb-c3fb-bf43-1efb86b0692e","name":"Note: Mark Completed in Google Sheets"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"a1e8cdde-4c02-ea17-a3c9-5ac3f24f1bc4","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"2a7080f0-f236-dbfd-dd13-78225933bc4d","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"8d0ab53b-93b9-3032-cd58-3da85ebbf0df","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"12e62a68-ce52-b3ea-f412-0170ba5f20e0","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Telegram · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"15cf461d-9f55-35f9-e40b-544e04cad01d","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Telegram\n\ntelegram — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"efa59317-51ea-aaa3-0e9e-fb60e7c8b8f7","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"d80584ab-90fc-2b6c-7171-11d62d32dc16","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,1540],"id":"498d4e89-fbd9-07ac-133e-bfc768136f64","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Nurture trial users with MySQL and Telegram automatically\n\n**Pattern:** Drip Sequence · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nNurture trial users with MySQL and Telegram automatically. It runs automatically on a schedule.\n\n## Why it exists\nManual capture forms is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Read Pending Queue (MySQL) → Stamp & Shape Lead → Payload Valid? → Work in Batches → Aggregate Batch Results → Mark Completed in Google Sheets → …\n\n## Use it for\n- Teams that want to drip sequence without manual effort\n- Anyone automating capture forms in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Improves response time\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; MySQL connection; Slack OAuth2; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"e074cb79-cb8e-3156-055f-734f1daf6bb2","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"44e656e4-713a-42a4-ae78-5ffdd6cf6989","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"38a6f79e-2387-aa37-7f37-fbd7cb7400df","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your capture forms process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"524d1a15-816c-fcbd-ea0d-3ae16709efda","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Read Pending Queue (MySQL)","type":"main","index":0}]]},"Read Pending Queue (MySQL)":{"main":[[{"node":"Stamp & Shape Lead","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp & Shape Lead":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Work in Batches","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Work in Batches":{"main":[[{"node":"Aggregate Batch Results","type":"main","index":0}],[{"node":"Process Batch Item","type":"main","index":0}]]},"Process Batch Item":{"main":[[{"node":"Respect Rate Limits","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Respect Rate Limits":{"main":[[{"node":"Work in Batches","type":"main","index":0}]]},"Aggregate Batch Results":{"main":[[{"node":"Mark Completed in Google Sheets","type":"main","index":0}]]},"Mark Completed in Google Sheets":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Telegram","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Telegram":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"f04a40a0-1a43-4110-89e0-3ef2537f7ff9","id":"FDX04259"}