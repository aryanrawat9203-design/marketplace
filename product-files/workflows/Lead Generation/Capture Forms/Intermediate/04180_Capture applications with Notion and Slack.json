{"name":"Capture applications with Notion and Slack","nodes":[{"parameters":{"formTitle":"Capture applications with Notion and Slack","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"5db44d2e-826f-4a97-b9dd-78ed75784920","name":"New Lead Form Submission","webhookId":"d759da17-426d-4fe0-986a-07758255adc5"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"dd5fe22a-a236-4f12-9b7d-81a68b81f430","leftValue":"={{ $json.leadId || $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"86d16f28-f6d0-4b51-ad90-6920a83cbefe","name":"Keep Valid Leads"},{"parameters":{"assignments":{"assignments":[{"id":"b4f092cf-2303-4f09-8a98-047d1af43b0d","name":"requestId","value":"={{ $json.leadId || $execution.id }}","type":"string"},{"id":"ebef65bf-f0fd-44be-a5c1-46f52a00d0ce","name":"summary","value":"={{ ($json.email || '').toString().slice(0, 200) }}","type":"string"},{"id":"49800c9a-ec07-4c07-a19a-d695ab11e7f6","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"46168e59-5a47-4725-afa1-48a167a555b6","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,400],"id":"09021d53-2bb5-4bf2-ab0a-54d10acdf2da","name":"Request Approval via Slack","retryOnFail":true,"maxTr