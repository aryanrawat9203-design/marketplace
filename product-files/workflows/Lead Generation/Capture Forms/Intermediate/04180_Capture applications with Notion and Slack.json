"name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"c6c7884c-78e5-430e-98f3-ef7d1512c93e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"78bfc4e9-b28e-4bc7-acaa-afb64c0bfdc1","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"7022b4f6-89c3-4b21-97f0-6db603f2a308","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"6389ca78-064f-44c9-b695-f17de5705d01","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Database"},"title":"={{ $json.email || $json.leadId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5886,400],"id":"f424a943-7838-42df-9116-8c4dd00b297b","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=✅ Capture applications with Notion and Slack — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,400],"id":"78403739-44d8-4fc3-963d-443d857d8e52","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e6ca35ed-63f3-4ac3-b069-a8697c2c190d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"52c915c7-08fc-44ab-b64f-6941e211b4ff","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"57505462-5e19-4c01-a0e8-e84df6f80914","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"e5c45ec8-0001-45da-a01d-dc52b52b8a6a","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#sales","cachedResultName":"#sales"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,1420],"id":"12d2fc9e-d8d5-4d3d-8240-d3e02b18ab9b","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"2dbc31b4-d01c-44ec-ac9a-69532404e96c","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Lead Form Submission\n\nServes an n8n-hosted form (Email, Company, Score). Each submission becomes one execution.\n\nNext: Keep Valid Leads","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"72276dc4-0c5d-1905-6e7a-d0bb1b282352","name":"Note: New Lead Form Submission"},{"parameters":{"content":"### Keep Valid Leads\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Prepare Approval Packet","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"b19adec1-20d8-fbfd-db07-70ec564fed2e","name":"Note: Keep Valid Leads"},{"parameters":{"content":"### Prepare Approval Packet\n\nShapes the item: writes `requestId`, `summary`, `requestedBy`. Keeps the schema explicit between stages.\n\nNext: Request Approval via Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"e4c584a9-a720-2acc-ff5e-c2db1917519a","name":"Note: Prepare Approval Packet"},{"parameters":{"content":"### Request Approval via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Hold for Decision · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"1771186b-22f5-272d-5be2-d01f1f8ee7d6","name":"Note: Request Approval via Slack"},{"parameters":{"content":"### Hold for Decision\n\nPauses the execution until the resume webhook is called — this is the approval/HITL gate.\n\nNext: Approved?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"acbd3bfb-879c-7e6e-30c7-d5df76cb4fab","name":"Note: Hold for Decision"},{"parameters":{"content":"### Approved?\n\nTwo-way gate on `={{ $json.body?.decision || $json.decision }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Execute Approved Action (API) · ②→ Record Decline + Notify Requester","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"ac330862-a423-edb5-9c68-239b31a0d5f0","name":"Note: Approved?"},{"parameters":{"content":"### Execute Approved Action (API)\n\nPOST https://api.example.com/v1/leads — retries 3× with backoff on failure.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"2956308a-a199-3f6f-6aca-f407a267b3af","name":"Note: Execute Approved Action (API)"},{"parameters":{"content":"### Record Decline + Notify Requester\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"e530ca55-6530-fe36-3412-70697c9f335e","name":"Note: Record Decline + Notify Requester"},{"parameters":{"content":"### Join Decision Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"a42d0f6e-454c-dcfe-ed5e-0d792a92b692","name":"Note: Join Decision Paths"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"dcdb42bc-5acf-17dd-3f6f-d9c6d6d95cd0","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"67b6980c-b842-4a6d-a7da-5ed87016cbe9","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"3037bb30-edb3-8333-b9a9-e7f3a4b3554a","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"993f04d4-1503-c85e-0aa7-92692a11de59","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"57ffe00a-208e-0672-3018-2a26fdaa5172","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"c295b80a-6fb8-1843-017b-9a8dac0cbfba","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"e47594f3-0152-2a4e-f865-8ced0ed555f6","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"08cc4da1-e09a-f65b-816c-08ac34be5a88","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"9172f87a-febc-0fc0-5b9b-27944938bd3e","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"7ee8dbd4-67ab-aa9f-10e0-41c88caeaaf6","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"16f76e2c-b691-4e55-031d-17afac39fa9a","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"acd7261d-4f38-ac7c-c7a7-dbbbf2ad2afb","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Capture applications with Notion and Slack\n\n**Pattern:** Form Intake · **Level:** Production · **Trigger:** Form\n\n## What it does\nCapture applications with Notion and Slack. It starts from a hosted form submission.\n\n## Why it exists\nManual capture forms is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Lead Form Submission → Keep Valid Leads → Prepare Approval Packet → Request Approval via Slack → Hold for Decision → Approved? → Execute Approved Action (API) → …\n\n## Use it for\n- Teams that want to form intake without manual effort\n- Anyone automating capture forms in sales\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Removes copy-paste errors\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9c2489f3-968d-fb54-aa57-144593c5b84d","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"0a2b035d-776e-4ab9-b82f-2b6c620f3cf4","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"4a349295-ab0d-4ef2-0dfc-3d5b46427ed7","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🙋 Human in the loop\n\nThe workflow pauses at the Wait node until a human posts a decision to the resume URL (included in the approval message). Approve → the action executes; anything else → recorded as declined. No timeout is set by default — add one under the Wait node's options if approvals go stale.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"1da54cee-7996-f6ee-df24-e6c47c3adcd2","name":"🙋 Human in the loop"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your capture forms process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"3a6d8159-25a1-b8c0-9adf-044347513881","name":"🛠 Customize me"}],"connections":{"New Lead Form Submission":{"main":[[{"node":"Keep Valid Leads","type":"main","index":0}]]},"Keep Valid Leads":{"main":[[{"node":"Prepare Approval Packet","type":"main","index":0}]]},"Prepare Approval Packet":{"main":[[{"node":"Request Approval via Slack","type":"main","index":0}]]},"Request Approval via Slack":{"main":[[{"node":"Hold for Decision","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold for Decision":{"main":[[{"node":"Approved?","type":"main","index":0}]]},"Approved?":{"main":[[{"node":"Execute Approved Action (API)","type":"main","index":0}],[{"node":"Record Decline + Notify Requester","type":"main","index":0}]]},"Execute Approved Action (API)":{"main":[[{"node":"Join Decision Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Decline + Notify Requester":{"main":[[{"node":"Join Decision Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Decision Paths":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"77e4d178-3f68-496c-9b78-e58123eb1735","id":"FDX04180"}