{"name":"Save form submissions with Airtable and Slack","nodes":[{"parameters":{"formTitle":"Save form submissions with Airtable and Slack","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Company","requiredField":false},{"fieldLabel":"Score","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"63d383ae-32cd-4c6a-a38f-20a1fbfa628d","name":"New Lead Form Submission","webhookId":"9dfe25ab-c216-458b-8a76-8e5c9a79f338"},{"parameters":{"assignments":{"assignments":[{"id":"e45c7f45-b57d-4a2d-aabf-4d368e5ca846","name":"leadId","value":"={{ $json.leadId || $json.id || $execution.id }}","type":"string"},{"id":"f4ede31b-c494-487a-a62c-5c3408cb3b4e","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"7461bb27-fa60-4cd8-b244-d735037d1a77","name":"Stamp & Shape Lead"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"063599e6-ac83-4699-ba46-820e8e7aa53d","leftValue":"={{ $json.leadId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"251dcd01-7833-4687-913b-ee901369b679","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Lead Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[378,910],"id":"97a2e066-9c55-4f2d-a40c-ecd269088ff8","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"rules":{"values":[{"conditions":{"options":{