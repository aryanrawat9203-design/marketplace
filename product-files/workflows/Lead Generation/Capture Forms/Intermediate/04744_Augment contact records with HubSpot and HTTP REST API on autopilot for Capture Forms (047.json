id":"c6156ee5-36bd-4d7d-9fbf-763e12f77c66","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5886,400],"id":"b062140f-0947-4392-b11a-82d43ccf349a","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3dac9d3f-0025-43d8-a4ea-daf2f3a8a82e","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"012b33db-37da-4ec6-9ec8-49e94dc5f837","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6210,400],"id":"4da0840b-e761-49c5-abbc-ab713668e102","name":"Fold In Enrichment Fields"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b8b5b83b-8f94-43f5-a6b6-8b12e9ab5711","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[6534,400],"id":"0ed5ec88-eb86-49c4-8015-be481c8bd981","name":"Guard Non-Empty email"},{"parameters":{"dataToSave":{"values":[{"key":"leadId","value":"={{ $json.leadId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"604c89ef-62c4-4fa0-b78f-5b639ad8e8e2","name":"Save Execution Metadata"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7182,400],"id":"11aab717-6b12-4e88-9f2a-ca21ce093d1a","name":"Cap Batch Volume"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"leadId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":