{"name":"Re-engage upcoming appointments with Google Sheets and Discord 24/7","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":7,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"f4c267c2-176b-4a89-b6b0-4c3cab92591a","name":"Daily Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"5a30fcba-1e83-4add-a1ec-eeac5f531af9","leftValue":"={{ $json.messageId || $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"afd6e72f-eb91-4dcb-b865-ee39f09cf140","name":"Keep Valid Emails"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d9c814d3-7e97-4c77-a87e-d067b6bd71f8","leftValue":"={{ $items().length === 0 || !$json.id }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"e202a32f-fef5-4404-96e2-fa56e59e6388","name":"Slot Free?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[702,160],"id":"d7f740b2-ce4b-4d86-97f6-39be8bd39ae6","name":"Record Booking","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ You're booked for {{ $json.startTime }} — see you then!","otherOptions":{}},"type":"n