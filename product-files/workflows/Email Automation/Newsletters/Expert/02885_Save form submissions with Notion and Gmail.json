{"name":"Save form submissions with Notion and Gmail","nodes":[{"parameters":{"formTitle":"Save form submissions with Notion and Gmail","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"c8be8207-3f93-4555-a7b0-a67328f4ab45","name":"New Email Form Submission","webhookId":"e579b7e9-2446-4be7-8723-9788144ba27c"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4c0db845-18c9-48aa-b45d-ab08dea59d11","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"c6d6562c-fb58-4aa3-a209-3e775091214e","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'from' on incoming email."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"3ac19eda-9d8c-4b63-bc2d-1f5c8b71254d","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"14457d10-4acb-4d50-9f63-725929b2bb5f","name":"requestId","value":"={{ $json.messageId || $execution.id }}","type":"string"},{"id":"ce763e74-b56e-49da-8efd-0e8ba8282181","name":"summary","value":"={{ ($json.from || '').toString().slice(0, 200) }}","type":"string"},{"id":"6d9e84db-1333-41d7-a811-a030ed7617fe","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"ff38aea9-4be7-461f-ade6-10ac49a14c6c","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,400],"id":"acaa5ed7-5365-4ff9-a075-c9436d96a8ff","name":"Request Approval via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resume":"webhook","httpMethod":"POST","options":{}},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1026,400],"id":"3d99f727-d62c-47de-ab51-d518100da19c","name":"Hold for Decision","webhookId":"21462fc6-8e2a-4ab9-9697-8499ba610777"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d98251c3-a4e8-4728-8a58-b270db902f9e","leftValue":"={{ $json.body?.decision || $json.decision }}","rightValue":"approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"8c3259da-d89b-4eb9-b5f7-062a9ede2964","name":"Approved?"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/emails","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1674,160],"id":"32187074-dae5-4912-a789-4f8300e8e5dc","name":"Execute Approved Action (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=❌ Request {{ $json.requestId }} was declined.","otherOptions":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1998,760],"id":"5cc82afa-6aef-4302-a5fa-76c9bd717a9d","name":"Record Decline + Notify Requester","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"0cc4e671-38ae-4822-b4b9-ca8bf7889a35","name":"Join Decision Paths"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3618,400],"id":"34a5390b-13b5-49ff-96e8-604c38c825b8","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3942,400],"id":"a1265ea0-6c50-4a66-b0fe-148a8300c127","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"57761d90-5222-4dc6-864e-2c4c48d15ebb","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d94deba9-2a87-4c7e-9fed-87cf7bb93a82","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9af6050a-cca0-4fde-bbc6-ae0204f88959","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"6db18540-bb21-4b80-b47c-f6aa51d0bf71","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"0182c2fe-077f-4dc6-805d-61480456a28b","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"889ab64d-62db-4e95-b716-d2bd97dfd233","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"4813f8ea-e62f-456a-ae05-a380b4410d59","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"25aebe47-18f9-48cc-ae29-ab1ed237b037","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"20189132-c5af-4d79-902c-2e84e87fd59b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"776572d9-1dee-4664-9aa0-a4524846a352","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"723d5e39-805e-48e0-9d9d-d2aa9d243647","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Save form submissions with Notion and Gmail — run completed at {{ $now.toForm","message":"=✅ Save form submissions with Notion and Gmail — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[6210,400],"id":"52af79e8-02e1-4216-b934-164cd554d94a","name":"Send Summary to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"2cea311d-3d16-4151-8bfe-69eb42736836","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a5051910-54c6-46e5-81de-a5046bfcada9","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"511896ab-366d-4ef8-8495-7943f2e9f90c","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"78b0289d-49e8-4d84-bdd9-15169bf59f99","name":"Capture Failure Context"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[5886,1420],"id":"cae6ee73-b636-4280-b8ac-c346b269e531","name":"Escalate Failure to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"7ed2c0e2-e3b9-48ea-85cd-5bcfdb625e36","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Email Form Submission\n\nServes an n8n-hosted form (From, Subject, Receivedat). Each submission becomes one execution.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"935a2dce-fbb4-e32a-6144-38246ba37712","name":"Note: New Email Form Submission"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.from }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Prepare Approval Packet · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"19583d04-6b92-3a4a-81ed-c8ee3bd85139","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"d3d6992e-5356-f76e-fb1d-99a0f6adf052","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Prepare Approval Packet\n\nShapes the item: writes `requestId`, `summary`, `requestedBy`. Keeps the schema explicit between stages.\n\nNext: Request Approval via Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"90d69ee2-6640-c12e-2413-345592ba224a","name":"Note: Prepare Approval Packet"},{"parameters":{"content":"### Request Approval via Slack\n\nPosts a message to Slack (`#inbox-ops`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nPorts: ①→ Hold for Decision · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"e731890c-0fbd-03bb-7220-9feceb38e1cd","name":"Note: Request Approval via Slack"},{"parameters":{"content":"### Hold for Decision\n\nPauses the execution until the resume webhook is called — this is the approval/HITL gate.\n\nNext: Approved?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"ac52d9f9-68a4-3c8f-6da5-5d45c2215948","name":"Note: Hold for Decision"},{"parameters":{"content":"### Approved?\n\nTwo-way gate on `={{ $json.body?.decision || $json.decision }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Execute Approved Action (API) · ②→ Record Decline + Notify Requester","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"73737ef1-aeee-b7ee-9487-95aa14715fbc","name":"Note: Approved?"},{"parameters":{"content":"### Execute Approved Action (API)\n\nPOST https://api.example.com/v1/emails — retries 3× with backoff on failure.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"c8c447c6-2fb1-31f8-dd01-32a5dab41ea2","name":"Note: Execute Approved Action (API)"},{"parameters":{"content":"### Record Decline + Notify Requester\n\nSends an email via Gmail — subject is the first line of the message body, recipient comes from the item's `email` field.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"bea39284-a72e-e090-2da8-e907c1393014","name":"Note: Record Decline + Notify Requester"},{"parameters":{"content":"### Join Decision Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"d2787360-096b-8a2c-ad1a-4fe21a148821","name":"Note: Join Decision Paths"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"de10a48c-2669-fd96-e9bb-9dc6adb63320","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nAppends a new row to 'Email Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"00645da1-4ff9-ca7f-b81f-75fd1dd075ef","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"11b5d6be-2cea-b505-b9c9-edbb45120c38","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"c4a49421-0172-3b70-d7f5-ecf9a33e0371","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"9cdbe267-1ae0-d869-51a4-e639442e7449","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"2c820c39-0109-b4cd-b3d5-797761bcc495","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"d8b406e1-93bc-cb44-46c0-1f0cbdd3e361","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\nAppends a new row to 'Email Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Send Summary to Gmail · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"15bce4a8-c98d-7650-7db3-8286b98e962f","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Gmail\n\nSends an email via Gmail — subject is the first line of the message body, recipient comes from the item's `email` field.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"e769bbf7-bdb2-c645-0434-f2fe764c6226","name":"Note: Send Summary to Gmail"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Gmail","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"4a625c28-569d-4081-6d84-f761128eb924","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Gmail\n\nSends an email via Gmail — subject is the first line of the message body, recipient comes from the item's `email` field.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Google OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"01207042-47cd-f505-143b-162ea1df3b63","name":"Note: Escalate Failure to Gmail"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nAppends a new row to 'Email Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"35d83185-2606-bf16-dd15-837c41587ac9","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Save form submissions with Notion and Gmail\n\n**Pattern:** Form Intake · **Level:** Production · **Trigger:** Form\n\n## What it does\nSave form submissions with Notion and Gmail. It starts from a hosted form submission.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Email Form Submission → Required Fields Present? → Prepare Approval Packet → Request Approval via Slack → Hold for Decision → Approved? → Execute Approved Action (API) → …\n\n## Use it for\n- Teams that want to form intake without manual effort\n- Anyone automating newsletters in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Keeps your systems in sync\n- Standardizes the process every time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9b26dfb7-68a7-9381-47ae-7eb30ada09eb","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe workflow pauses on a Wait node configured to resume via webhook — n8n's actual human-in-the-loop primitive, not a polling loop. The resume URL is embedded directly in the approval message so approving is one click, and the paused execution burns no compute for however long the decision takes.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"b492b3cf-8810-90ba-7bf8-74f9fb16a3e7","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAlready production-grade — deepen your understanding:\n\n1. Add a timeout to the Wait node so unanswered approvals auto-decline after N hours.\n2. Change the approval channel and confirm the resume link still works.\n3. Add a third outcome (e.g. 'needs changes') alongside approve/decline.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"0cf7e200-c80f-01ec-c072-cc001b95508b","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"5d0d2066-a904-503b-d265-dc1e13307ad5","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"885160da-a3da-572e-c288-8fd6e1bab61d","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🙋 Human in the loop\n\nThe workflow pauses at the Wait node until a human posts a decision to the resume URL (included in the approval message). Approve → the action executes; anything else → recorded as declined. No timeout is set by default — add one under the Wait node's options if approvals go stale.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"0fa30f4c-f76d-1698-fd88-8aaa9efc44b7","name":"🙋 Human in the loop"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"b18dbfc7-5f57-90ec-f8e5-3b02bcd5ed37","name":"🛠 Customize me"}],"connections":{"New Email Form Submission":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Prepare Approval Packet","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Prepare Approval Packet":{"main":[[{"node":"Request Approval via Slack","type":"main","index":0}]]},"Request Approval via Slack":{"main":[[{"node":"Hold for Decision","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold for Decision":{"main":[[{"node":"Approved?","type":"main","index":0}]]},"Approved?":{"main":[[{"node":"Execute Approved Action (API)","type":"main","index":0}],[{"node":"Record Decline + Notify Requester","type":"main","index":0}]]},"Execute Approved Action (API)":{"main":[[{"node":"Join Decision Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Decline + Notify Requester":{"main":[[{"node":"Join Decision Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Decision Paths":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Gmail","type":"main","index":0}]]},"Escalate Failure to Gmail":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Gmail":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"New Email Form Submission":[{"json":{"messageId":"MSG-6601","from":"support@vendor.com","subject":"Your invoice is ready","receivedAt":"2026-07-19T08:12:00.000Z"}},{"json":{"messageId":"MSG-6602","from":"newsletter@partner.io","subject":"July product digest","receivedAt":"2026-07-19T09:40:00.000Z"}}]},"versionId":"25fe8d85-7c9d-46cb-b55a-52f90515e4cb","id":"FDX02885"}