{"name":"Follow up open deals with Google Drive and Discord","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":7,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"fce2de69-2325-46b2-8517-1e6fd01672d8","name":"Daily Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"db9727e4-7963-443f-8c8f-e0e5b93f25f3","name":"messageId","value":"={{ $json.messageId || $json.id || $execution.id }}","type":"string"},{"id":"39ad6772-5b8b-428b-8dcd-afa189132120","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"260e8085-b01d-4cce-b3ad-71530aca9944","name":"Stamp & Shape Email"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6135e502-06cc-4a27-9022-5ca814bc24f5","leftValue":"={{ $json.messageId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"ec273ed4-3f71-41e0-a4b2-abd6c9126d04","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"06ba5b4c-c511-43d4-8d6d-ad44e3f62ded","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"63d0d81d-28b9-4282-8670-e27849b43c0e","leftValue":"={{ $items().length === 0 || !$json.id }}","rightValue":true,"operator":{"type":"boolean","op