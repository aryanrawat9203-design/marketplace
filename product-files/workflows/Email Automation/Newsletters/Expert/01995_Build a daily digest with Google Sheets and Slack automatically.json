      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "142bfa21-35b7-4eaa-a7c1-064349f1fa95",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "afa0f09b-ae50-4397-94c8-35ca3aae2de2",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
