odes-base.slack","typeVersion":2.3,"position":[3618,1420],"id":"447c548a-8cc6-4597-9c0b-515bf351eed0","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 6:00. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Email","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"764488d2-9e0f-6d89-7dda-3d1c638928b3","name":"Note: Daily Schedule"},{"parameters":{"content":"### Stamp & Shape Email\n\nShapes the item: writes `messageId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"ba8d787e-26ec-9c08-a54c-94d169557c06","name":"Note: Stamp & Shape Email"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.messageId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Slot Free? · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"7f54a06d-e4a1-0965-70ff-20912eaac4bf","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nairtable — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"c27403fe-9ba7-481d-a052-ea806b26636a","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Slot Free?\n\nTwo-way gate on `={{ $items().length === 0 || !$json.id }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Record Booking · ②→ Propose Alternative Slots","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"0ca4b394-7bbb-cf32-e553-c711e9bf71de","name":"Note: Slot Free?"},{"parameters":{"content":"### Record Booking\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Confirmation (Slack) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,280],"id":"eeb4e591-8120-e8c6-c370-bfbbbea1d72a","name":"Note: Record Booking"},{"parameters":{"content":"### Send Confirmation (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Hold Until Reminder Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"2882e25b-998f-27ab-af16-86916b436f7b","name":"Note: Send Confirmation (Slack)"},{"parameters":{"content":"### Propose Alternative Slots\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"6288865b-d102-2ae0-9eb6-88fa8349aaf4","name":"Note: Propose Alternative Slots"},{"parameters":{"content":"### Hold Until Reminder Time\n\nPauses 1 hours — spacing calls to respect rate limits.\n\nNext: Send Reminder (Slack)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"9db930ed-1e31-b887-afed-0ced3f69837e","name":"Note: Hold Until Reminder Time"},{"parameters":{"content":"### Send Reminder (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Tag Pipeline Metadata · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"756af2d6-f919-3694-5de9-c330fa4450e5","name":"Note: Send Reminder (Slack)"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Send Summary to Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"6b179a40-0a51-b373-4189-5ac893cd3331","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"fd0d345f-70b1-ac58-ffbc-99d42a267b9a","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,1540],"id":"c8729fce-769b-6d40-3414-c7b5175a7530","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,1540],"id":"855bba90-e6ba-f740-55ea-7d6d93cfe51e","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Remind open deals with Airtable and Slack\n\n**Pattern:** Reminders & Follow-ups · **Level:** Core · **Trigger:** Scheduled\n\n## What it does\nRemind open deals with Airtable and Slack. It runs automatically on a schedule.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Stamp & Shape Email → Payload Valid? → Slot Free? → Record Booking → Send Confirmation (Slack) → Hold Until Reminder Time → …\n\n## Use it for\n- Teams that want to reminders & follow-ups without manual effort\n- Anyone automating newsletters in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Keeps your systems in sync\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: Airtable PAT; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"5d030dad-9d0b-17ec-ef25-ba2d5c023a25","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"0ac78191-edf9-ffae-7f6a-369fe8e4e328","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"76ab400b-fdaa-e813-736a-1f152c9b76f5","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"98fc815a-f350-f42a-aa47-41c2bce3cc1d","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Stamp & Shape Email","type":"main","index":0}]]},"Stamp & Shape Email":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Slot Free?","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Slot Free?":{"main":[[{"node":"Record Booking","type":"main","index":0}],[{"node":"Propose Alternative Slots","type":"main","index":0}]]},"Record Booking":{"main":[[{"node":"Send Confirmation (Slack)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Confirmation (Slack)":{"main":[[{"node":"Hold Until Reminder Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Until Reminder Time":{"main":[[{"node":"Send Reminder (Slack)","type":"main","index":0}]]},"Send Reminder (Slack)":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Propose Alternative Slots":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"a49c8435-58f7-409b-bec5-9542d9c84ba3","id":"FDX02338"}