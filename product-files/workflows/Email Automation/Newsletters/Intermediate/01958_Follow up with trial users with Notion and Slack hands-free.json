{"name":"Follow up with trial users with Notion and Slack hands-free","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":12}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"1c4f09a4-de5e-4ddf-bba2-95a678f372fd","name":"Hourly Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"44ae69e2-602e-4634-bbf4-edf42cbb36f9","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"c31d6f33-ffcd-4418-9d43-72be341193dc","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'from' on incoming email."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"9da2e16a-8233-4bae-acac-212f725bf5d8","name":"Abort — Malformed Input"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each email 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.from) score += 20;\n  if (j.subject) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"b45608e3-9095-4656-a247-f59dfa85ff75","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"515c58be-85a0-4692-93e0-7f552e55cb10","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"left