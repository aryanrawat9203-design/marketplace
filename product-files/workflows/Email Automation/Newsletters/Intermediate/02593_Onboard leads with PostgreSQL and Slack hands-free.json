{
  "name": "Onboard leads with PostgreSQL and Slack hands-free",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 8
            }
          ]
        }
      },
      "id": "e8cd460a-54c4-4424-9cfd-a2cf7601e487",
