{"name":"Capture form submissions with PostgreSQL and Slack","nodes":[{"parameters":{"formTitle":"Capture form submissions with PostgreSQL and Slack","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"d33a1123-27c8-483d-a9df-e0882c21cd8d","name":"New Email Form Submission","webhookId":"c90adee0-4efa-4e33-b57e-474330219a2e"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"5f5e2d92-51e9-4609-bf5a-39fb8cd04b96","leftValue":"={{ $json.messageId || $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"0126228a-72c8-442a-a202-fba8ff949dcd","name":"Keep Valid Emails"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each email 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.from) score += 20;\n  if (j.subject) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"725d8a75-8b09-4181-a49c-48df5eaf644b","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"16182595-3833-4c1b-a389-9d4346ad4c23","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensiti