{"name":"Compile a weekly summary with Airtable and Slack automatically","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":17,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"4144ebcb-e38e-4ca6-9dc9-c26b5f1d4cf6","name":"Daily Schedule"},{"parameters":{"url":"https://news.example.com/feed.xml","options":{}},"type":"n8n-nodes-base.rssFeedRead","typeVersion":1.2,"position":[54,400],"id":"32c48239-3d40-4bff-81c7-8e5ee5c0cb13","name":"Read Source Feed","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.link }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"ea734471-2bf6-4f2f-b30a-47a1582ea2de","name":"Skip Already-Seen Posts"},{"parameters":{"maxItems":5},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"474c4145-ca40-4e3d-98ef-a1d5947b2d1e","name":"Keep Top Stories"},{"parameters":{"promptType":"define","text":"=Rewrite this story as a punchy 3-sentence post for our audience:\n\n{{ $json.title }}\n{{ $json.contentSnippet || $json.content }}","options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"c1dba74b-c50c-43dd-99d2-442bf93ae9ec","name":"Rewrite for Our Audience (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[1269,970],"id":"7dc95f8e-7d0f-420b-8149-cdf663b74e3e","name":"Google Gemini Chat Model"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"={{ $json.text || $json.title }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,160],"id":"109bfbd8-7f69-4d02-9f20-b8196f17a174","name":"Publish to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1917,400],"id":"3f8c20c5-2aba-4ab1-8960-e6cb461045f1","name":"Log Published Posts (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2241,400],"id":"1d3a1947-9ab9-4f3c-8b7b-18bee66c3d63","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"f960b838-b996-4c80-8bce-fc207dba150e","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f2524dcd-afff-4de7-900e-4c954f138c31","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2565,400],"id":"612856fc-f173-46d0-b1b3-694f9e1e92c7","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[2889,400],"id":"fbeb45f9-f528-4418-8450-f4bc81d97683","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3213,400],"id":"2274472e-5c03-4d09-9289-a1e861341383","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"search","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"filterByFormula":"={LastModified} > DATEADD(NOW(), -1, 'days')","options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3537,400],"id":"a614bca7-94df-407c-8187-306a8eb2f7e3","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3861,400],"id":"ddc26ab2-4e79-4c9b-9243-d3a145748ddc","name":"Compute Drift vs Snapshot"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4185,400],"id":"6e77d10e-db77-4bc3-8a44-53111d8d2a19","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4509,400],"id":"030e4424-bd46-460c-9974-7e799f4498de","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4833,400],"id":"19504a58-f282-482f-a23a-7202465f08ee","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5157,400],"id":"270d2a26-79bd-47a0-87a5-b6ac642bb9b6","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"c46c10ba-29d0-40c0-90b5-ead0e96fae00","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"d7007793-0812-42b3-af3c-53c2b5df0ee5","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"f20c9f81-5445-4845-a2ce-9c5c6f21a8c7","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,400],"id":"30db4dee-9111-4cc3-add9-332f29362a79","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5805,400],"id":"ae8b8ed4-0009-4b82-a9bf-dda0f411a4f0","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Compile a weekly summary with Airtable and Slack automatically — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6129,400],"id":"60db7577-6d13-4d10-9e99-08763b6713fd","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a31e7864-06eb-4177-9fee-45875e2da83f","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"f23bb6f6-f08c-43d4-8eed-3be33bc1b4f1","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"a55f4eff-2340-493d-befe-e8c6d253f98e","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,1420],"id":"0482ba37-9ed0-410c-bd7d-47d2b5c462fa","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,1420],"id":"847f623d-8b75-4d96-9739-7e0d72505eec","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[6129,1420],"id":"cc752e6c-65da-4f6b-9b50-b2f4fc417d68","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Read Source Feed","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"f62ef2f5-5345-4189-26e4-67274e7c41e7","name":"Note: Daily Schedule"},{"parameters":{"content":"### Read Source Feed\n\nPulls the RSS feed and emits one item per entry (title, link, content).\n\nPorts: ①→ Skip Already-Seen Posts · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"df9d68bb-809e-6e36-119b-e004f0e9f7b7","name":"Note: Read Source Feed"},{"parameters":{"content":"### Skip Already-Seen Posts\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Keep Top Stories","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"6a27d03b-876b-e3a7-0fb8-87703e244253","name":"Note: Skip Already-Seen Posts"},{"parameters":{"content":"### Keep Top Stories\n\nCaps the stream at 5 items to protect downstream quotas.\n\nNext: Rewrite for Our Audience (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"68369207-051a-043e-ad29-59d2771ab46b","name":"Note: Keep Top Stories"},{"parameters":{"content":"### Rewrite for Our Audience (AI)\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish to Slack · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"a6b5e7d7-6262-8720-82bb-f5d081b759f0","name":"Note: Rewrite for Our Audience (AI)"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Rewrite for Our Audience (AI)** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"93bf99f2-c14c-21d2-636f-c269e0fad0b2","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Publish to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Log Published Posts (Google Sheets) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,280],"id":"e934ba3a-f155-de93-0193-a98e1a048243","name":"Note: Publish to Slack"},{"parameters":{"content":"### Log Published Posts (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"ccd1ccb0-45d9-2c39-cbcc-03d44688fd9d","name":"Note: Log Published Posts (Google Sheets)"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"598c6f21-6549-3138-3804-38623e467f00","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"22a208d1-c414-e8b5-12bc-ce7cf7024c77","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"108a4d48-bef8-a509-999f-e96ceaa5d051","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"bba9d1d3-03b7-7989-9bba-5921c85fc444","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Load Previous Snapshot\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"e79f9b58-7b4a-ecc2-a503-28afac92354e","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"b76a9b2a-fa69-7646-d1bc-1a7d87240704","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"8f1ee98a-a92c-7e5d-3562-5eb4c33508cf","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"d49bfdf1-20db-0265-6055-9d96f63b4acb","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"7daaa3e7-7edc-2f0e-bb76-d1316295e794","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"2472ec2a-ceeb-7d35-3513-0b861db6a562","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"6ed5b567-0320-2c58-795b-b05c3432dfb4","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"9c1144a0-aff6-43e7-1cdd-485a76a668e0","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"7757c48d-ea01-d7e1-6021-d811698e4046","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"612ff1dd-5adc-b577-b972-93b4350d9b51","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,1540],"id":"64d20e39-42d5-8fff-a1f5-f21f4735464a","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nairtable — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,1540],"id":"f064d2f5-e758-ce64-9ccc-a95ce88af71a","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Compile a weekly summary with Airtable and Slack automatically\n\n**Pattern:** Scheduled Digest · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nCompile a weekly summary with Airtable and Slack automatically. It runs automatically on a schedule.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Read Source Feed → Skip Already-Seen Posts → Keep Top Stories → Rewrite for Our Audience (AI) → Publish to Slack → Log Published Posts (Google Sheets) → …\n\n## Use it for\n- Teams that want to scheduled digest without manual effort\n- Anyone automating newsletters in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Keeps your systems in sync\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google AI API key; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"89646a85-0080-3c6f-0114-c4b8bee8c1a6","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"c5ef2128-461d-640c-dc16-5deb3d8fdb43","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"51c346c0-a8ff-5d1c-04c3-6427f3d55b63","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"39652eea-afc3-758b-5884-77aa4bcc562b","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"65edac71-a395-5e56-bd89-896139061584","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Read Source Feed","type":"main","index":0}]]},"Read Source Feed":{"main":[[{"node":"Skip Already-Seen Posts","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Skip Already-Seen Posts":{"main":[[{"node":"Keep Top Stories","type":"main","index":0}]]},"Keep Top Stories":{"main":[[{"node":"Rewrite for Our Audience (AI)","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Rewrite for Our Audience (AI)","type":"ai_languageModel","index":0}]]},"Rewrite for Our Audience (AI)":{"main":[[{"node":"Publish to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Slack":{"main":[[{"node":"Log Published Posts (Google Sheets)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Published Posts (Google Sheets)":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"f65a93b0-7791-4f7b-ba3d-daa6800b335b","id":"FDX03111"}