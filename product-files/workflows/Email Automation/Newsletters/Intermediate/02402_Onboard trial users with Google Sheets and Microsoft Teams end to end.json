des-base.set","typeVersion":3.4,"position":[3618,400],"id":"4854a46b-a297-49de-9b57-5c20b0a8ac88","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3942,400],"id":"a797af63-7711-483d-8cf2-dee3aacdee2e","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Onboard trial users with Google Sheets and Microsoft Teams end to end — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4266,400],"id":"a09fcf85-a6a0-4055-98af-73d782d11e10","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a84b9bc8-6901-4394-96d8-3b8c2a3cd5ec","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"1cd0d97c-6056-4cbb-b006-d1f6ab294ec4","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"596754ca-d0ea-4256-bc03-83620c4cf063","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,1420],"id":"3399fc39-55c7-4b56-96cc-2ff7f68908d9","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3942,1420],"id":"83734406-7bf8-4116-9bc6-081c1c63807f","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Read Pending Queue (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"f0378f08-c7da-a51b-4b32-060a3e3ce18d","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Read Pending Queue (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Keep Valid Emails · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"2b791870-01b6-1274-cee8-4d5b766e0bab","name":"Note: Read Pending Queue (Google Sheets)"},{"parameters":{"content":"### Keep Valid Emails\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Work in Batches","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"c39696e4-d2c9-aac6-b73f-3c020d7883ca","name":"Note: Keep Valid Emails"},{"parameters":{"content":"### Work in Batches\n\nLoop controller — releases 20 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Aggregate Batch Results · ②→ Process Batch Item","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"21b8abf2-e80b-810c-0075-c18ec0693284","name":"Note: Work in Batches"},{"parameters":{"content":"### Process Batch Item\n\nPOST https://api.example.com/v1/emails — retries 3× with backoff on failure.\n\nPorts: ①→ Respect Rate Limits · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1000],"id":"357ef26f-d726-3a74-5c7b-f1a2d4234fcf","name":"Note: Process Batch Item"},{"parameters":{"content":"### Respect Rate Limits\n\nPauses 2 seconds — spacing calls to respect rate limits.\n\nNext: Work in Batches","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"63546de0-ca84-77c2-44bb-a5a975334897","name":"Note: Respect Rate Limits"},{"parameters":{"content":"### Aggregate Batch Results\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Mark Completed in Google Sheets","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"29efc1e4-50b5-014a-0df0-b1e1936fb1d9","name":"Note: Aggregate Batch Results"},{"parameters":{"content":"### Mark Completed in Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Sort Emails Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"950c81ba-0598-a17d-abaa-fe0ccefe2d40","name":"Note: Mark Completed in Google Sheets"},{"parameters":{"content":"### Sort Emails Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"ba1f6d33-4394-b67f-3946-25cab06daa30","name":"Note: Sort Emails Newest First"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"f94a092a-d24d-323d-35d9-59b86f420541","name":"Note: Align Field Names"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"a5c2f47d-fea5-c248-e931-1e551e4592cc","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"bbafa1eb-1368-2a7f-84b7-afe3ffd9efa8","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"f46d2923-0ab9-2837-0a08-0fc1b1b17081","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"5566ad57-0bd9-a313-fc1e-92c14c609ec2","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,1540],"id":"31a056f4-516c-0e3d-0197-b5c58651cba2","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"27f35e3a-0a91-6b0f-73aa-f22891398906","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Onboard trial users with Google Sheets and Microsoft Teams end to end\n\n**Pattern:** Drip Sequence · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nOnboard trial users with Google Sheets and Microsoft Teams end to end. It runs automatically on a schedule.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Read Pending Queue (Google Sheets) → Keep Valid Emails → Work in Batches → Aggregate Batch Results → Mark Completed in Google Sheets → Sort Emails Newest First → …\n\n## Use it for\n- Teams that want to drip sequence without manual effort\n- Anyone automating newsletters in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Improves response time\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"5a7e334c-f3ef-6a97-c287-d26c40dc82aa","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"343ea525-1ef7-f3d0-e886-9f60c9fe23b3","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"3abbefc1-49e8-9b51-9b45-c26c13f1f7ef","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"d7887e98-bb48-f6b5-724d-b3d70881811e","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Read Pending Queue (Google Sheets)","type":"main","index":0}]]},"Read Pending Queue (Google Sheets)":{"main":[[{"node":"Keep Valid Emails","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Keep Valid Emails":{"main":[[{"node":"Work in Batches","type":"main","index":0}]]},"Work in Batches":{"main":[[{"node":"Aggregate Batch Results","type":"main","index":0}],[{"node":"Process Batch Item","type":"main","index":0}]]},"Process Batch Item":{"main":[[{"node":"Respect Rate Limits","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Respect Rate Limits":{"main":[[{"node":"Work in Batches","type":"main","index":0}]]},"Aggregate Batch Results":{"main":[[{"node":"Mark Completed in Google Sheets","type":"main","index":0}]]},"Mark Completed in Google Sheets":{"main":[[{"node":"Sort Emails Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Sort Emails Newest First":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"86cb35cf-c4e9-4bbe-844c-c0c13f543f71","id":"FDX02402"}