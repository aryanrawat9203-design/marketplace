:{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6858,400],"id":"0ff659db-52ee-4abd-8cd6-6f33c1d0dfd9","name":"Drop Already-Processed Items"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7182,400],"id":"ae987f57-c370-4077-9d83-d5a0268964e0","name":"Cap Batch Volume"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"messageId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7506,400],"id":"8bca591e-690e-4e53-ac2e-736656102798","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"messageId","value":"={{ $json.messageId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7830,400],"id":"889cbeca-746e-477d-af8a-1245fcdb0c91","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"25b7ab4d-2618-4415-90c9-45849759971c","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"442f4139-c62c-4f68-88e1-b9003833799c","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"ecc0a328-9156-47c9-8f40-61008af54dd8","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"96f784d2-1f1c-4b72-aad5-44f3cb5bafc3","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[8478,400],"id":"74b0b4ac-4fa4-4fe2-9bad-205a4ada4a20","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Follow up upcoming a