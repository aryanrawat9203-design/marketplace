{"name":"Follow up with subscribers with MySQL and Slack","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[1],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"1997c5b7-3ba7-460c-ab7f-b35e4ff5f5b4","name":"Weekly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"3db62939-e0b8-4712-9a0a-a0c6767baf9e","name":"messageId","value":"={{ $json.messageId || $json.id || $execution.id }}","type":"string"},{"id":"6d9cd6c3-4490-4d20-95d9-eaea4b9ed8f9","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"42db5e9d-6f5b-47a4-9e3d-92217a743868","name":"Stamp & Shape Email"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d909d0b2-e790-43cb-b565-7919edd22da2","leftValue":"={{ $json.messageId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"a8a31fd5-0265-4fbc-9aea-e56e8f0a642e","name":"Payload Valid?"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"c86f3abb-0a0d-4f9f-980c-6ee132fdd388","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"425e058b-fb2f-457f-9e39-52b32d52c65d","leftValue":"={{ ($json.score ?? 50) >= 50 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[702,400],"id":"80837e67-dbfa-4675-93ce-5308d0b06ad5","name":"Segment Audience"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Hi {{ $json.name || 'there' }}, here's how to get started…","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1026,160],"id":"6c621500-54e0-44ac-8d3a-e410f9ff8a19","name":"Step 1 — Welcome (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1350,760],"id":"1e8bf11b-b80a-4467-8144-ffa8556b8e78","name":"Tag for Slow Nurture","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":3,"unit":"days"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1674,400],"id":"d3fdde65-45f2-49bd-acd8-5cd13e0be3c4","name":"Wait Before Step 2","webhookId":"f4079721-daa7-4997-9339-a42604407970"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c2dc06d2-0e07-4176-b9c9-038b3cae7083","leftValue":"={{ $json.status }}","rightValue":"converted","operator":{"type":"string","operation":"notEquals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1998,400],"id":"d82e4fcd-1666-4d00-b707-2d63fd86c4ef","name":"Converted Already?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Quick tip for {{ $json.company || 'your team' }} — see what others automate.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2322,160],"id":"607c1402-2cc8-45b1-959a-81a4f15bc334","name":"Step 2 — Value Nudge (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,760],"id":"401a6f2f-4661-4145-beee-b424d0e32733","name":"Mark Converted — Stop Drip","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":3,"unit":"days"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[2970,400],"id":"e21f0317-1440-414f-981d-3ba2d32ca0bc","name":"Wait Before Final Step","webhookId":"826f560a-fb67-4734-b7ee-478dbb0fb4ee"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Last nudge: your workspace is ready. Reply to claim onboarding help.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3294,400],"id":"0d87c109-3057-4a62-9752-d82a4683a10c","name":"Step 3 — Final Offer (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[3618,400],"id":"1bc184da-52a3-4a9f-93ed-f887d0a3fb7d","name":"Update Drip Status","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3942,400],"id":"2311480e-90dd-4e6b-8d38-d326d4d62614","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={