{"name":"Log form submissions with MySQL and Slack with instant alerts","nodes":[{"parameters":{"formTitle":"Log form submissions with MySQL and Slack with instant alert","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"b644737b-1eec-4d0f-b87b-1169887232cc","name":"New Email Form Submission","webhookId":"db0e4b30-1be4-46fd-a709-790e32c27286"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b538f1cf-df58-4306-8c79-a8f705ba905e","leftValue":"={{ $json.messageId || $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"cb9365ce-19ec-4c71-8e7e-6564494cdc33","name":"Keep Valid Emails"},{"parameters":{"assignments":{"assignments":[{"id":"d6c8f255-7548-4843-88fd-5f4a423e78d6","name":"requestId","value":"={{ $json.messageId || $execution.id }}","type":"string"},{"id":"f9b0cd81-698f-4f14-bb3a-e3df61ba9fe2","name":"summary","value":"={{ ($json.from || '').toString().slice(0, 200) }}","type":"string"},{"id":"c749d75b-0542-4121-bfd6-64a62a144390","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"a2516e94-6284-4845-b939-44aa15de9aa2","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,400],"id":"200749d5-e6a8-4219-bbed-568e8944fc20","name"