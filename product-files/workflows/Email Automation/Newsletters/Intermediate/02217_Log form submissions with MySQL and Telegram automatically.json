{"name":"Log form submissions with MySQL and Telegram automatically","nodes":[{"parameters":{"formTitle":"Log form submissions with MySQL and Telegram automatically","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"8dcaf7c0-e604-41a4-8854-b0a53890179e","name":"New Email Form Submission","webhookId":"14e850a9-ad87-4755-8292-95e201ac567b"},{"parameters":{"assignments":{"assignments":[{"id":"b8c02cd8-a49b-45e4-ac6b-12c166b1ae6d","name":"messageId","value":"={{ $json.messageId || $json.id || $execution.id }}","type":"string"},{"id":"1a252f05-0ece-4bf7-90ee-4309235c07c3","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"199a8298-0abc-4a66-a6bc-8855cce32dab","name":"Stamp & Shape Email"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"89e63fe7-d730-43c4-81fd-2d53b3d65235","leftValue":"={{ $json.messageId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"76b7606c-2688-4caf-9f60-ff52f643d5e9","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"c6fd1460-0a47-4084-978f-d73ce2c31b7b","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":