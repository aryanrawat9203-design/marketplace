          "conditions": [
            {
              "id": "4cd31b28-d69e-4b9f-99d7-2cc17ee6c09e",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
