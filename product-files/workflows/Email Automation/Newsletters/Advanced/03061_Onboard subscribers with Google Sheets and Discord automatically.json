          "assignments": [
            {
              "id": "7660de40-18ab-4818-b629-1991f0070fe5",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "c660aa2b-40cf-4476-86f8-cd8cc8599cdd",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
