              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "fae75c35-536f-442d-9101-35ab00ed084d",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
