            {
              "id": "36176376-00b6-42f7-8dc4-20150983e3d4",
              "name": "status",
              "value": "='processed'",
              "type": "string"
            },
            {
              "id": "eba224df-8c74-4488-80a0-8f60dfa05247",
              "name": "summary",
              "value": "={{ JSON.stringify($json).slice(0, 280) }}",
              "type": "string"
            },
            {
              "id": "b6a95b51-5cf1-493f-8a08-9ee99304f5ba",
              "name": "count",
