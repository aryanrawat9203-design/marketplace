de":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2646,400],"id":"04612994-918f-4f1a-969e-cd428c36e931","name":"Update Drip Status","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2970,400],"id":"a9d15889-2f0d-4bcb-9960-bb4a8d2ab42f","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3294,400],"id":"f3e2465c-a2e5-4240-9fd4-38e51dff9250","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3618,400],"id":"6dbbaaa1-91b4-46fb-bbe7-52ef0eb2774f","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3942,400],"id":"127705ed-bc25-49b8-bd69-8b