    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Build an HTML digest table from the aggregated rows\nconst rows = $input.all().map(i => i.json);\nconst tr = rows.map(r =>\n  `<tr><td>${r.messageId ?? ''}</td><td>${r.from ?? ''}</td><td>${r.count ?? 1}</td></tr>`\n).join('');\nconst html = `<h2>Email digest</h2><table border=\"1\" cellpadding=\"4\">\n<tr><th>ID</th><th>from</th><th>Count</th></tr>${tr}</table>`;\nreturn [{ json: { html, rowCount: rows.length, generatedAt: new Date().toISOString() } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2140,
        400
      ],
      "id": "6ec5a5bc-8bd3-4ab7-931c-2455eb15f6d2",
      "name": "Compose HTML Report"
