    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "7b94ff89-a23a-47d2-bd0d-d3d2cd2bd9c4",
              "leftValue": "={{ $json.receivedAt || $now.toISO() }}",
              "rightValue": "",
