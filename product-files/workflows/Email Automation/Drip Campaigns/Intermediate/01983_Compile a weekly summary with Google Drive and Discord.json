    {
      "parameters": {},
      "id": "2dc63c24-290d-4c03-ba69-06811afc8793",
      "name": "Log Invalid Input",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        780,
        500
      ],
