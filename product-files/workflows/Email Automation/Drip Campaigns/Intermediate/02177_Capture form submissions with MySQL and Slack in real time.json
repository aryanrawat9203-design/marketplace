string"},{"id":"e6b68eb1-ae4e-4b61-b133-3d05a320c630","name":"summary","value":"={{ ($json.from || '').toString().slice(0, 200) }}","type":"string"},{"id":"0d18e42a-733d-4085-98bd-a9a3c86ed3e6","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[702,400],"id":"7caef994-f0ba-4fde-b014-71059b93e797","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1026,400],"id":"0b7989f5-4e5c-4b60-a930-e0a37dcfd73c","name":"Request Approval via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resume":"webhook","httpMethod":"POST","options":{}},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1350,400],"id":"a72fdac8-0896-4f31-b398-00ea4c4780c5","name":"Hold for Decision","webhookId":"d10e4a3a-e3de-49cf-a2d0-a47ddcfe56d3"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"cd2493c7-af97-4737-bed8-bd31afbc517e","leftValue":"={{ $json.body?.decision || $json.decision }}","rightValue":"approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1674,400],"id":"2e354ad0-06c8-413d-a15d-43a739185381","name":"Approved?"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[1998,160],"id":"065f5808-36e9-41d3-807e-85a60b54535f","name":"Apply Approved Change (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2