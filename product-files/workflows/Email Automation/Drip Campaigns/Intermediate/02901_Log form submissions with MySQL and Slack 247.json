Pct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"fd5ee876-487a-4da0-b640-b11bb9e5eec6","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"bc11fc55-e8cb-48eb-92ef-27b1c10c43b3","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"1850c43b-9211-4f24-9bda-6d14cf7ac1c0","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"55f0d26d-5dfc-40c3-ad01-68554aa9dd58","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7506,400],"id":"3c1c8737-7b26-4c9d-b79b-36349894543a","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[7830,400],"id":"b8b6e0c4-4ff2-4d42-a012-cc7374da8d9d","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Log form submissions with MySQL and Slack 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8154,400],"id":"f001b622-1536-4751-a589-e22d46505331","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"faf96b13-e2aa-450f-8674-916459a190a3","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"fc85ef55-066a-411d-8b74-f2e1fe182b55","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e119374b-5afd-4