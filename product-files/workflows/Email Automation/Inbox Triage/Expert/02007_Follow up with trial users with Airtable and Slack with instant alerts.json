osition":[2970,400],"id":"93bdd803-01bd-4ae4-a301-a6f6aa4a92a2","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3294,400],"id":"86db8f76-5354-41c7-a483-d1276c43dd6f","name":"Persist Run Metadata"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Emails"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3618,400],"id":"7a9f06d4-0045-44f6-84a9-36a0fd878714","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3942,400],"id":"070b3d3d-689a-47f0-8c38-577755b4a2cc","name":"Record Sub-workflow Result"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"4419bc57-726f-47b7-8d9a-224b881def9d","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"9873e8ae-d7e9-4632-a0ee-296ae04647c9","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"4b4e895b-bd38-43a3-965f-58c3aa4488b9","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"6967dbd2-032e-4d81-b003-8b3282530ba0","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4914,400],"id":"15c16b7b-b370-472a-ac0f-2e55c0aef8a7","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[5238,400],"id":"1a314c89-2f90-4ed5-9f05-1455e6c848cd","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"2a95d0c8-d2a0-4586-932c-49708f5a6fd3","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5886,400],"id":"b66eb09e-35ce-431d-8110-bc1444012d17","name":"Drop Already-Processed Items"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6210,400],"id":"394f4acc-a73e-4df9-96e9-dbd3d4ce9d8d","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6534,400],"id":"10653f5b-d9d1-423d-9c96-d7ee9dcb660e","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6858,400],"id":"026ea63e-534a-42d5-bdf4-457602b225c4","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"2ed2aa48-ff3b-4ed0-be9e-a9d2d04c559e","name":"pipeline","value":"Inbox Triage","type":"string"},{"id":"1b20f71b-e331-4d4b-bfec-c32c935107da","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"7330d9d2-1024-424f-a7b4-d474560502d5","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"messageId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7506,400],"id":"d12338ec-5f0c-4c48-9288-f9df11b4e995","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"messageId","value":"={{ $json.messageId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7830,400],"id":"340d4620-cc0d-4e64-ba1a-ff564a1b553a","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"7949b61f-7949-4e17-a7bf-bc09d60ad357","name":"runAt","value":"={