          "conditions": [
            {
              "id": "a37833c5-664d-426c-9687-9b6f23bd8f5f",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "6a552b26-95b6-492f-ac56-780abfa5b46f",
      "name": "Input Valid?",
