      "id": "3186e012-fc40-47a2-825a-4298c56884eb",
      "name": "Draft Summary with AI",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.6,
      "position": [
        1280,
        300
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "model": "openai/gpt-4o-mini",
        "options": {}
      },
      "id": "b465d28a-e3b0-4bac-aa86-2bfeaad5fc50",
      "name": "OpenRouter Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [
        1220,
        520
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "ec0585f7-a1c3-4aff-98be-2c72d3236c40",
              "name": "status",
              "value": "='processed'",
              "type": "string"
            },
            {
              "id": "67d1ed0c-ddfe-41e5-a848-024a05e339e9",
              "name": "summary",
              "value": "={{ JSON.stringify($json).slice(0, 280) }}",
