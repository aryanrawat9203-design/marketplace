{"name":"Build a daily digest with Google Sheets and Microsoft Teams hands-free","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":9,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"4d9d60f2-6497-4f57-afa7-7a4f5293b17e","name":"Daily Schedule"},{"parameters":{"url":"https://news.example.com/feed.xml","options":{}},"type":"n8n-nodes-base.rssFeedRead","typeVersion":1.2,"position":[54,400],"id":"48957c3e-6759-4ed9-9306-2cd71fa54322","name":"Read Source Feed","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.link }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"d1fbfb0c-4d9d-4f35-890b-d1c0e03403a6","name":"Skip Already-Seen Posts"},{"parameters":{"maxItems":5},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"1d73e078-ff88-414a-9572-8714a1fe2a1a","name":"Keep Top Stories"},{"parameters":{"promptType":"define","text":"=Rewrite this story as a punchy 3-sentence post for our audience:\n\n{{ $json.title }}\n{{ $json.contentSnippet || $json.content }}","options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"7d01ca82-a124-4730-9c5f-07517d52b57e","name":"Rewrite for Our Audience (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[1269,970],"id":"21457be0-0928-45e8-a6b6-3066ae28d7a7","name":"Anthropic Chat Model"},{"parameters":{"resource":"chatMessage","chatId":"OPS_TEAM_CHAT_ID","message":"={{ $json.text || $json.title }}","options":{}},"type":"n8n-nodes-base.microsoftTeams","typeVersion":2,"position":[1593,160],"id":"52cf2808-b5fb-44be-bd42-f9dca2e1e6b2","name":"Publish to Microsoft Teams","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"={{ $json.text || $json.title }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1917,640],"id":"f7488356-5405-4e32-a2bb-194de2b22149","name":"Publish to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2565,400],"id":"9added35-e221-4ee6-a267-22fccb7fdf58","name":"Confirm Cross-Post"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3537,400],"id":"380261af-6230-4f88-bf8b-7b8bab672615","name":"Log Published Posts (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"f61477fc-9508-4f5b-a690-2674652b309b","name":"pipeline","value":"Inbox Triage","type":"string"},{"id":"b68b2aca-6bfc-4b64-87ee-d86d9c2fae81","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3861,400],"id":"1323c417-7ebd-4b83-8d7a-4f348d14d0b4","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"messageId","value":"={{ $json.messageId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4185,400],"id":"75f0e0b6-fff4-4740-84d0-ff81e5717686","name":"Save Execution Metadata"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[4509,400],"id":"11724b52-4c4f-421e-af96-4f4a9655adc8","name":"Cap Batch Volume"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"efc699d3-6c92-4ca1-a37d-43f391f151d7","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[4833,400],"id":"0d215312-e7ab-4c8f-b8b0-dd1bf905a3d9","name":"Guard Non-Empty from"},{"parameters":{"assignments":{"assignments":[{"id":"4c070952-b156-41cd-90ec-ff59c1a6e752","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"2ce71d5f-7384-493c-aa33-c115cb296993","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"35bac93a-2de8-4adf-8f24-cd9e3a1fee62","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,400],"id":"8a5758de-5c01-4618-9746-c7c2804b1529","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5481,400],"id":"b7303a21-5c1f-44d4-a3ce-bc1880f15fa5","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Build a daily digest with Google Sheets and Microsoft Teams hands-free — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,400],"id":"6d99d356-c4c4-4cc2-bfbd-0e5454afdd3f","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b1cd4718-e36b-4eb1-951d-6c6102997ced","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"34d239f6-30bd-45ee-ade9-f0fc7f786a02","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ae3dcb89-2d52-4ee1-b31c-5f346f44f636","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,1420],"id":"ed62bf13-b495-431a-bee3-23cb914b72e8","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5481,1420],"id":"cc2e50bd-793b-4ec4-b377-a6569c43e1cf","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 9:00. No input data; downstream nodes fetch what they need.\n\nNext: Read Source Feed","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"ff2ac063-6da0-3290-55aa-440528373f66","name":"Note: Daily Schedule"},{"parameters":{"content":"### Read Source Feed\n\nPulls the RSS feed and emits one item per entry (title, link, content).\n\nPorts: ①→ Skip Already-Seen Posts · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"6379884b-76e0-adfe-b2e1-03c320dabd40","name":"Note: Read Source Feed"},{"parameters":{"content":"### Skip Already-Seen Posts\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Keep Top Stories","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"1ec247e6-63a1-ae21-e85e-6203472b98bf","name":"Note: Skip Already-Seen Posts"},{"parameters":{"content":"### Keep Top Stories\n\nCaps the stream at 5 items to protect downstream quotas.\n\nNext: Rewrite for Our Audience (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"9db642bd-e397-44e1-f488-8b8d71f23a7f","name":"Note: Keep Top Stories"},{"parameters":{"content":"### Rewrite for Our Audience (AI)\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish to Microsoft Teams, Publish to Slack · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"f6022112-1617-6fa4-a68c-75b6469a76a3","name":"Note: Rewrite for Our Audience (AI)"},{"parameters":{"content":"### Anthropic Chat Model\n\nChat model powering the AI step (model: `claude-sonnet-4-5-20250929`). Swap providers here without rewiring.\n\nFeeds **Rewrite for Our Audience (AI)** as `languageModel`\n\n🔑 Anthropic API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"bbfeb213-537c-4ad2-7654-2db0fbfdb6f0","name":"Note: Anthropic Chat Model"},{"parameters":{"content":"### Publish to Microsoft Teams\n\nmicrosoftTeams — `chatMessage` operation against the connected account.\n\nPorts: ①→ Confirm Cross-Post · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,280],"id":"1b853898-9d37-6a9a-fec2-71ea8e3d2d19","name":"Note: Publish to Microsoft Teams"},{"parameters":{"content":"### Publish to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Confirm Cross-Post · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,760],"id":"bf37b89c-6a02-402a-ac3f-93498f59556e","name":"Note: Publish to Slack"},{"parameters":{"content":"### Confirm Cross-Post\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Log Published Posts (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"ca08fb25-1f6c-6d1b-4211-4f93e2e5d96a","name":"Note: Confirm Cross-Post"},{"parameters":{"content":"### Log Published Posts (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Tag Pipeline Metadata · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"14c790bb-e28d-89aa-b83a-b45f0def815c","name":"Note: Log Published Posts (Google Sheets)"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"5c27e20a-77fb-9cda-aa06-d2561549b1cb","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"45c8f91f-30bc-aafd-8bf7-7a4c39e89973","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Guard Non-Empty from","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"a8c714f2-d451-aad5-c9ea-331f7c68958f","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Guard Non-Empty from\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"17ebdd64-6da5-068c-468a-c282297225ef","name":"Note: Guard Non-Empty from"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"b5009f8b-9138-c6c4-d726-e197c44577ff","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"fee7a09e-c65e-d221-8c85-ab5ecb62f811","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"b1df7139-a4b7-f814-7071-785834353775","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"1a2a1370-2a4d-1335-6902-ae01e9544d72","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"6cc6988d-ef6e-73bd-4301-8feb07b5e5a4","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Build a daily digest with Google Sheets and Microsoft Teams hands-free\n\n**Pattern:** Scheduled Digest · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nBuild a daily digest with Google Sheets and Microsoft Teams hands-free. It runs automatically on a schedule.\n\n## Why it exists\nManual inbox triage is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Read Source Feed → Skip Already-Seen Posts → Keep Top Stories → Rewrite for Our Audience (AI) → Publish to Microsoft Teams → Confirm Cross-Post → …\n\n## Use it for\n- Teams that want to scheduled digest without manual effort\n- Anyone automating inbox triage in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Runs 24/7 in the background\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: Anthropic API key; Google OAuth2 / service account; Microsoft OAuth2; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9e6a0f2d-e492-045d-eba8-3318ee975e9f","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"fc13390e-24f9-032a-5c5d-fc62051f88b6","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"2fa198eb-a91c-bda2-e547-e01d333fae0a","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"ccf62c87-8e4b-b06a-7dfe-d63d9bfb0a2f","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your inbox triage process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"2c9ac114-a3b2-1af6-f6b5-a22a25ffa6d2","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Read Source Feed","type":"main","index":0}]]},"Read Source Feed":{"main":[[{"node":"Skip Already-Seen Posts","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Skip Already-Seen Posts":{"main":[[{"node":"Keep Top Stories","type":"main","index":0}]]},"Keep Top Stories":{"main":[[{"node":"Rewrite for Our Audience (AI)","type":"main","index":0}]]},"Anthropic Chat Model":{"ai_languageModel":[[{"node":"Rewrite for Our Audience (AI)","type":"ai_languageModel","index":0}]]},"Rewrite for Our Audience (AI)":{"main":[[{"node":"Publish to Microsoft Teams","type":"main","index":0},{"node":"Publish to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Microsoft Teams":{"main":[[{"node":"Confirm Cross-Post","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Slack":{"main":[[{"node":"Confirm Cross-Post","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Confirm Cross-Post":{"main":[[{"node":"Log Published Posts (Google Sheets)","type":"main","index":0}]]},"Log Published Posts (Google Sheets)":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Guard Non-Empty from","type":"main","index":0}]]},"Guard Non-Empty from":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"7279b5e5-6868-4dae-abfb-7502a26e2633","id":"FDX01972"}