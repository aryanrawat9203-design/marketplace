:"7dd366ac-0149-44b6-8383-df3db4032d9b"},{"parameters":{"authentication":"webhook","content":"=Last nudge: your workspace is ready. Reply to claim onboarding help.","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[2970,400],"id":"d95c8ee7-2af1-4ea7-9dcb-c1d1131a1f3c","name":"Step 3 — Final Offer (Discord)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[3294,400],"id":"8880861a-bd03-4c4c-99aa-594fc4478d05","name":"Update Drip Status","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3618,400],"id":"6f62468f-351f-4882-b614-4655dff2fd25","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"f4e674b6-3aae-4c55-a8c2-49dfe7c9d6b1","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"8a4a527a-c7c4-4d65-a47f-f1bfcef99025","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"657ff094-e8de-4304-a371-4f6d848c98bb","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"93e373c0-a319-4203-8242-0490e94e1ed0","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"182e6a7e-6b44-492b-ac64-eaf92c758249","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4590,400],"id":"4c1182f8-c7e9-4f95-b849-9103a225b7f9","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Re-engage upcoming appointments with MySQL and Discord on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,400],"id":"03781ccf-e6f0-476a-a2b3-3c7f5842a2f2","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"7c340a11-ecad-4ae7-bfdd-23e604573e0e","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a340fec9-1005-4b7e-87bf-fd2804cb244e","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"dbd3433f-c820-49bb-9a93-b69ca9d38520","name":"workflow","valu