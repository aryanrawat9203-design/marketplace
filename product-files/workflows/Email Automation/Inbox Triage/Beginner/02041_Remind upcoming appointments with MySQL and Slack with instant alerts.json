{"name":"Remind upcoming appointments with MySQL and Slack with instant alerts","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":7,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"6748b9ba-c9ca-429f-843d-9697adb9b632","name":"Daily Schedule"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"35a0d921-41b6-4c72-859b-cb8873554937","name":"Normalize Email Payload"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d5ad0e3c-c27a-49e7-9ebb-1f17eece99c2","leftValue":"={{ ($json.score ?? 50) >= 50 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"5e16332d-f7a9-4c00-b897-e07b7fad010c","name":"Segment Audience"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Hi {{ $json.name || 'there' }}, here's how to get started…","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,160],"id":"9bd4d16b-77c1-4091-a70a-7c88faeda9ba","name":"Step 1 — Welcome (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[1026,760],"id":"73c15976-c7e6-446b-8112-aea786cbf300","name":"Tag for Slow Nurture","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":1,"unit":"days"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1350,400],"id":"2a5bb2eb-e5ed-4050-b941-3d1de807369a","name":"Wait Before Step 2","webhookId":"72fc1710-e9f8-4f3c-a888-dcf5c9844f3a"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"5b274c95-94b4-4af9-90e2-6e44db15d740","leftValue":"={{ $json.status }}","rightValue":"converted","operator":{"type":"string","operation":"notEquals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1674,400],"id":"014fec5b-c860-4747-88ec-d4713898f8d0","name":"Converted Already?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Quick tip for {{ $json.company || 'your team' }} — see what others automate.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1998,160],"id":"c3c7c949-0b7e-4262-abbb-69f1d0c5e1fa","name":"Step 2 — Value Nudge (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2322,760],"id":"87c3aa08-7793-4ed6-b485-f9ab978d18c3","name":"Mark Converted — Stop Drip","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":3,"unit":"days"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[2646,400],"id":"1acbce50-403c-4fee-a064-8200a1fb9bac","name":"Wait Before Final Step","webhookId":"7713d786-ec10-41fe-b22f-d44814c35cc0"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Last nudge: your workspace is ready. Reply to claim onboarding help.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2970,400],"id":"9974fff9-ffd6-4ed7-a183-507d89ded7e2","name":"Step 3 — Final Offer (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[3294,400],"id":"e49bdf66-8426-46f8-a693-ed36977a595c","name":"Update Drip Status","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3618,400],"id":"316e7fa2-9a4b-4e35-b70e-8cf15b5dc3b7","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"63b39531-4a50-4b96-9de4-ff8b6c7b6e27","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"aa09e3e3-401f-44ef-8972-fcab476160d9","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,400],"id":"d1855214-7e73-4b34-9807-0b8adee4cca0","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"49467aa2-8ef1-49f6-ae8f-751e2e6ff0ce","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4590,400],"id":"0d00b0c3-a057-4146-9ac8-60a7a85a7075","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"eececf07-f5b4-49d4-a5bc-285f53bcae5e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"da6bd373-f801-47c6-839d-9d0ee95ee551","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8477a645-fbc2-470a-b6d4-6895b8e19625","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"b96017ce-4527-4dcc-932b-05b759eccba2","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"69a2466a-9a5b-4204-a744-f8f0a501cebf","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Remind upcoming appointments with MySQL and Slack with instant alerts — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5562,400],"id":"f383e6d0-70ee-4dd4-bb0b-8bbbfad483e8","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"372c1e18-a3ba-4118-85b5-6481c35a1fb3","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"d30e7168-8231-4a09-b64f-a749f59cb07b","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"0d79ba55-1d4f-4d30-82f4-647e37b8c77d","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,1420],"id":"ff596c73-f9e6-42cb-89ce-69d4560aff3a","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5238,1420],"id":"ed77aa98-b4eb-4bbf-ab42-a9346faac62e","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[5562,1420],"id":"cd56c557-e361-4330-b23d-a2e444024d39","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 7:00. No input data; downstream nodes fetch what they need.\n\nNext: Normalize Email Payload","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"f63a12a4-39c3-79f7-43f0-cc308269846e","name":"Note: Daily Schedule"},{"parameters":{"content":"### Normalize Email Payload\n\nCustom JavaScript: Normalize incoming email records to a stable schema\n\nNext: Segment Audience","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"462b8496-b060-1f2f-ab0d-3debf46ca621","name":"Note: Normalize Email Payload"},{"parameters":{"content":"### Segment Audience\n\nTwo-way gate on `={{ ($json.score ?? 50) >= 50 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 1 — Welcome (Slack) · ②→ Tag for Slow Nurture","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"83403c06-12c2-ee80-aedf-245495f85ff5","name":"Note: Segment Audience"},{"parameters":{"content":"### Step 1 — Welcome (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Wait Before Step 2 · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,280],"id":"ffd664cf-304f-f532-4b2e-c5ad558e0dd5","name":"Note: Step 1 — Welcome (Slack)"},{"parameters":{"content":"### Tag for Slow Nurture\n\nmySql — `appendOrUpdate` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,880],"id":"0e995982-3c9e-4a2d-46ad-7fd63e30f41c","name":"Note: Tag for Slow Nurture"},{"parameters":{"content":"### Wait Before Step 2\n\nPauses 1 days — spacing calls to respect rate limits.\n\nNext: Converted Already?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"c105670d-8264-c33f-cb0f-1565ac532d33","name":"Note: Wait Before Step 2"},{"parameters":{"content":"### Converted Already?\n\nTwo-way gate on `={{ $json.status }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 2 — Value Nudge (Slack) · ②→ Mark Converted — Stop Drip","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"41e8c139-80bf-23e3-726d-717760a9296b","name":"Note: Converted Already?"},{"parameters":{"content":"### Step 2 — Value Nudge (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Wait Before Final Step · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,280],"id":"7c62d9f2-f073-4e36-cfc5-649dd054e41c","name":"Note: Step 2 — Value Nudge (Slack)"},{"parameters":{"content":"### Mark Converted — Stop Drip\n\ngoogleSheets — `insert` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,880],"id":"b28db563-0f02-32d8-1c0d-1cd2e4b15d04","name":"Note: Mark Converted — Stop Drip"},{"parameters":{"content":"### Wait Before Final Step\n\nPauses 3 days — spacing calls to respect rate limits.\n\nNext: Step 3 — Final Offer (Slack)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"385c418e-4339-5ce1-32cc-e47135c63e5f","name":"Note: Wait Before Final Step"},{"parameters":{"content":"### Step 3 — Final Offer (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Update Drip Status · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"75f5bdf4-1c58-95e5-ccb1-246c326df5cc","name":"Note: Step 3 — Final Offer (Slack)"},{"parameters":{"content":"### Update Drip Status\n\nmySql — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"9cc9336d-5a39-9ad6-4b48-77b14166d1ed","name":"Note: Update Drip Status"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"1b887e68-f374-63c4-0a18-4335fd7ba45e","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"bebf8d51-14ce-9e27-8252-0b237fed27d4","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"9fcef203-0fd4-5ec6-23b9-5541fb60f8e1","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"ab22f5a9-5e6f-3c55-7067-2c1969b003b7","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"368572e1-aade-e4f4-ac76-1de697085e01","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"a81f5092-bb0d-0105-1db7-be5e563f93b4","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"81f9c5e0-24df-b54d-9ace-f157e8988553","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"1c499ccb-71c3-bef7-8d82-d5042ed6bffb","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"df4f5f3c-5626-edfe-c6c7-8a7ff3ee64ed","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nmySql — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"0f820290-f483-7b71-00b1-716889a55b34","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Remind upcoming appointments with MySQL and Slack with instant alerts\n\n**Pattern:** Reminders & Follow-ups · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nRemind upcoming appointments with MySQL and Slack with instant alerts. It runs automatically on a schedule.\n\n## Why it exists\nManual inbox triage is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Normalize Email Payload → Segment Audience → Step 1 — Welcome (Slack) → Wait Before Step 2 → Converted Already? → Step 2 — Value Nudge (Slack) → …\n\n## Use it for\n- Teams that want to reminders & follow-ups without manual effort\n- Anyone automating inbox triage in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Standardizes the process every time\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; MySQL connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9d568d0f-b949-166b-d890-d421e428f58c","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"79688799-877c-2a11-4631-02d81198c537","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"689f970d-21b2-f58d-d1be-c63bfe49b08a","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"b7854259-4858-a8a7-1666-8dad8ae0525c","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your inbox triage process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"f0f2c27c-04d7-4c68-a678-991b032a7130","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Normalize Email Payload","type":"main","index":0}]]},"Normalize Email Payload":{"main":[[{"node":"Segment Audience","type":"main","index":0}]]},"Segment Audience":{"main":[[{"node":"Step 1 — Welcome (Slack)","type":"main","index":0}],[{"node":"Tag for Slow Nurture","type":"main","index":0}]]},"Step 1 — Welcome (Slack)":{"main":[[{"node":"Wait Before Step 2","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Wait Before Step 2":{"main":[[{"node":"Converted Already?","type":"main","index":0}]]},"Converted Already?":{"main":[[{"node":"Step 2 — Value Nudge (Slack)","type":"main","index":0}],[{"node":"Mark Converted — Stop Drip","type":"main","index":0}]]},"Step 2 — Value Nudge (Slack)":{"main":[[{"node":"Wait Before Final Step","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Wait Before Final Step":{"main":[[{"node":"Step 3 — Final Offer (Slack)","type":"main","index":0}]]},"Step 3 — Final Offer (Slack)":{"main":[[{"node":"Update Drip Status","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Update Drip Status":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Tag for Slow Nurture":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Mark Converted — Stop Drip":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"c0879520-d16b-4220-9ca6-ab1ab096c1ad","id":"FDX02041"}