      "typeVersion": 1.3,
      "position": [
        1220,
        520
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "170a6690-27c5-4487-83a6-3870044d08cd",
              "leftValue": "={{ $json.category }}",
              "rightValue": "urgent",
              "operator": {
