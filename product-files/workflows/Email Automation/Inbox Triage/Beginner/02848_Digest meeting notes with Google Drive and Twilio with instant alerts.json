{"name":"Digest meeting notes with Google Drive and Twilio with instant alerts","nodes":[{"parameters":{"httpMethod":"POST","path":"wf02848-email","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"089c72f9-e9fc-4f9c-a598-3a1faf72ab5a","name":"Receive Inbound Webhook","webhookId":"ffcb75df-60e0-4aca-9294-7a7579c525ac"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"63f7fbc2-5c1e-4857-b7ac-457e106adf9d","name":"Normalize Email Payload"},{"parameters":{"inputText":"={{ $json.from || JSON.stringify($json) }}","options":{}},"type":"@n8n/n8n-nodes-langchain.sentimentAnalysis","typeVersion":1,"position":[378,400],"id":"0cdcc7e0-260e-4cb2-b288-d6956290d23a","name":"Detect Sentiment","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[621,970],"id":"074d91ad-9944-47e3-99f0-9d0d72bfc189","name":"Google Gemini Chat Model"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=😠 Negative email: {{ $json.from }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[945,-80],"id":"d9d6fabc-5a81-4d0a-9be6-b3ee7a4b8a43","name":"Escalate Negative — Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","valu