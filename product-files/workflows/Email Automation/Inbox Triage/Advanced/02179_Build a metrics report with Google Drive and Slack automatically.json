{
  "name": "Build a metrics report with Google Drive and Slack automatically",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 4
            }
          ]
        }
      },
      "id": "f7450feb-7a22-4a99-9bfa-660f27e87c12",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "2be5611f-325a-418e-89bc-d2926b772e4e",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "75443a5c-930d-482c-8d6c-3684a298c93b",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "c3035e1a-4bfb-493f-a86a-49540812ac7d",
      "name": "Validate Input",
