{"name":"Log form submissions with Notion and Twilio for your team","nodes":[{"parameters":{"formTitle":"Log form submissions with Notion and Twilio for your team","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"aa8c9472-126d-4fc5-b942-84d0292df54b","name":"New Email Form Submission","webhookId":"aa47cb54-3c32-4e9e-9e6f-a19d8a7c8e6a"},{"parameters":{"assignments":{"assignments":[{"id":"e5a1307d-9060-49bd-9aa1-cb11bbe163c5","name":"messageId","value":"={{ $json.messageId || $json.id || $execution.id }}","type":"string"},{"id":"3012a65e-75da-4640-9f1a-69390a71d690","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"455fb46c-3654-449b-8fa7-c7e8840c7b98","name":"Stamp & Shape Email"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d0b348d9-c80e-469e-a807-aca5e8acfb10","leftValue":"={{ $json.messageId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"b6805bc7-1d03-4c8d-8604-1e6a3a57953d","name":"Payload Valid?"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[378,910],"id":"c7ef0df9-8bb5-4190-afa8-95e671919046","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"stri