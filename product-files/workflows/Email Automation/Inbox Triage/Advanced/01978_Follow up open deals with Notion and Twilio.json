mpotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"9fc633be-ecf2-4d63-b2ee-d08264a53d18","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4590,400],"id":"c89df1cf-a440-4436-a569-0c970690aadc","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"4a840b2d-deda-4e26-86c4-6070afe136f1","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"3685f48b-ed31-466b-82b5-069228297eb2","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"3f1d0062-50b2-49c3-998c-1cdfea8d2a4b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"a100ac52-a9cf-46e9-aed7-b6bedb4f2eab","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5238,400],"id":"18ea23a3-ba9b-4c32-b991-25702a733916","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Follow up open deals with Notion and Twilio — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5562,400],"id":"dedee493-83b3-442d-a23d-1d069fc8e1c5","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":