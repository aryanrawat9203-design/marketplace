{"name":"Summarize meeting notes with Google Drive and Outlook hands-free","nodes":[{"parameters":{"httpMethod":"POST","path":"wf02364-email","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"75f70e66-693d-43b0-8301-ba39ad179b78","name":"Receive Inbound Webhook","webhookId":"58626c75-8fa1-4769-a34b-1dd1daeaddb3"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"0b5d9039-4b6f-42f6-ace0-4e3df752c436","name":"Normalize Email Payload"},{"parameters":{"inputText":"={{ $json.from || JSON.stringify($json) }}","categories":{"categories":[{"category":"Action Needed","description":"Emails that are action needed for the inbox triage team."},{"category":"Reference","description":"Emails that are reference for the inbox triage team."},{"category":"Ignore","description":"Emails that are ignore for the inbox triage team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"dee86f67-8101-43ae-a97b-9b12ea6dc098","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[621,970],"id":"3beea86a-95ec-40c8-88d9-376f64644bbd","name":"Anthropic Chat Model"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nod