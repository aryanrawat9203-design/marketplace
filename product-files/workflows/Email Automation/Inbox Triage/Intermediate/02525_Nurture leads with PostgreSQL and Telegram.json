"retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"b10dffa4-8417-4238-b27f-72f25fa4c93e","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4266,400],"id":"e9ebc5ed-f7f5-40d0-8205-0a09151f01f0","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"6ab28d9d-6061-4bdd-9171-f989d90aefa0","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b938986a-053e-49f9-8b2d-e1d313381a99","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"4201ca00-ddea-4f71-b3d6-eae49cd9091f","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"52cc19a9-7203-4d4e-bbca-3d9aeb77bbc7","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4914,400],"id":"38619622-e06b-490c-8f22-c7b6be4ec600","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Nurture leads with PostgreSQL and Telegram — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5238,400],"id":"ede4d391-4a06-40de-a10f-e151d847daff","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3eb8b644-88f3-419c-a508-47559d7d9ec9","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"8041fa9f-c9de-472b-9c1b-0cf970083451","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"edf4c37d-f7d6-42f9-bf20-e63f575d863b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,1420],"id":"3c43ca58-ae60-4492-b7ae-f631495bca88","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,1420],"id":"b10ae200-2b56-4eba-8274-84cededbecab","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,1420],"id":"39cab373-fae2-4534-bf22-366102d14287","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 6:00. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Email","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"4ff30126-f19c-0923-dec8-87a2604bf06a","name":"Note: Daily Schedule"},{"parameters":{"content":"### Stamp & Shape Email\n\nShapes the item: writes `messageId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"234475cd-71d0-56de-70b8-800cd3b626a5","name":"Note: Stamp & Shape Email"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.messageId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Segment Audience · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"0ce182a0-56d9-99e5-7f92-33ca391a7952","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `executeQuery` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"d1e417ed-921b-6752-ceb8-cadbefac6f00","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Segment Audience\n\nTwo-way gate on `={{ ($json.score ?? 50) >= 50 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 1 — Welcome (Slack) · ②→ Tag for Slow Nurture","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"c1f166a5-a684-05f5-0538-e9e9ba51f2a8","name":"Note: Segment Audience"},{"parameters":{"content":"### Step 1 — Welcome (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Wait Before Step 2 · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,280],"id":"b3f8dae3-9c40-78dc-c5ba-aa79de9b482e","name":"Note: Step 1 — Welcome (Slack)"},{"parameters":{"content":"### Tag for Slow Nurture\n\npostgres — `appendOrUpdate` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,880],"id":"f92aba63-77df-e3ad-d66d-cfbf6860bf9f","name":"Note: Tag for Slow Nurture"},{"parameters":{"content":"### Wait Before Step 2\n\nPauses 2 days — spacing calls to respect rate limits.\n\nNext: Converted Already?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"5a04a0e4-2fc7-47ae-b09a-59b670123327","name":"Note: Wait Before Step 2"},{"parameters":{"content":"### Converted Already?\n\nTwo-way gate on `={{ $json.status }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 2 — Value Nudge (Slack) · ②→ Mark Converted — Stop Drip","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"bd32ee31-1b19-0b50-177a-aca51a671437","name":"Note: Converted Already?"},{"parameters":{"content":"### Step 2 — Value Nudge (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Wait Before Final Step · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,280],"id":"7bb0c6ec-ba98-416b-db83-9411e01960c7","name":"Note: Step 2 — Value Nudge (Slack)"},{"parameters":{"content":"### Mark Converted — Stop Drip\n\npostgres — `appendOrUpdate` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,880],"id":"998605dd-3c1b-4933-dda3-dabd656eb780","name":"Note: Mark Converted — Stop Drip"},{"parameters":{"content":"### Wait Before Final Step\n\nPauses 3 days — spacing calls to respect rate limits.\n\nNext: Step 3 — Final Offer (Slack)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"d2169259-af17-d0c2-28f2-17aa36c20e47","name":"Note: Wait Before Final Step"},{"parameters":{"content":"### Step 3 — Final Offer (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Update Drip Status · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"4fa1cd24-d3b7-fbf0-725f-f16466ec4873","name":"Note: Step 3 — Final Offer (Slack)"},{"parameters":{"content":"### Update Drip Status\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"5c996859-768f-79a7-9cc8-280f57ddab5b","name":"Note: Update Drip Status"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"1f1fbf56-f1f6-998b-a552-591a2f32516d","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"cd6c7250-dd8c-ebf5-e391-7e85cb3b1561","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"787711b6-e39c-d58d-76f7-fd495a07a158","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"e3a191ee-8516-15a2-0022-1760af37bd0c","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"9abf4879-8c98-1c9f-fca1-39816ba2628c","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"0f05ac37-3eeb-70a3-b352-a671c2213371","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"3f0888b1-4232-ded6-6155-942c5a284e10","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"a92acea4-8db7-16a1-b4b7-a119b8538dcd","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Nurture leads with PostgreSQL and Telegram\n\n**Pattern:** Drip Sequence · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nNurture leads with PostgreSQL and Telegram. It runs automatically on a schedule.\n\n## Why it exists\nManual inbox triage is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Stamp & Shape Email → Payload Valid? → Segment Audience → Step 1 — Welcome (Slack) → Wait Before Step 2 → Converted Already? → …\n\n## Use it for\n- Teams that want to drip sequence without manual effort\n- Anyone automating inbox triage in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Runs 24/7 in the background\n- Improves response time\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"492f3346-6856-18a9-9236-512868046103","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"a3014082-eacd-7afb-1dfe-86e2b54b1ed6","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"6f979f75-c889-9f68-5c21-752012e8ea50","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"88d4f3da-a992-730c-aedd-2a3d486b2905","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your inbox triage process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"df9e102f-584d-3399-1d56-390caedd748c","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Stamp & Shape Email","type":"main","index":0}]]},"Stamp & Shape Email":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Segment Audience","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Segment Audience":{"main":[[{"node":"Step 1 — Welcome (Slack)","type":"main","index":0}],[{"node":"Tag for Slow Nurture","type":"main","index":0}]]},"Step 1 — Welcome (Slack)":{"main":[[{"node":"Wait Before Step 2","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Wait Before Step 2":{"main":[[{"node":"Converted Already?","type":"main","index":0}]]},"Converted Already?":{"main":[[{"node":"Step 2 — Value Nudge (Slack)","type":"main","index":0}],[{"node":"Mark Converted — Stop Drip","type":"main","index":0}]]},"Step 2 — Value Nudge (Slack)":{"main":[[{"node":"Wait Before Final Step","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Wait Before Final Step":{"main":[[{"node":"Step 3 — Final Offer (Slack)","type":"main","index":0}]]},"Step 3 — Final Offer (Slack)":{"main":[[{"node":"Update Drip Status","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Update Drip Status":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Tag for Slow Nurture":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Mark Converted — Stop Drip":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"06a99392-4e35-479a-b279-12659b367943","id":"FDX02525"}