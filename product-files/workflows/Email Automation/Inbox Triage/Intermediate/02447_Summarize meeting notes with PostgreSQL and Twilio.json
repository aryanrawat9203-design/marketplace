-ops"},"text":"=[Other] {{ $json.from }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2241,1270],"id":"fac6cced-8b8e-49a6-bcad-8491a6512426","name":"Alert Slack — Other","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2889,400],"id":"2591effc-c6e6-417d-be4e-9656ca0e18dc","name":"Reunite Branches"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Emails"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3861,400],"id":"95efc21e-66eb-459e-8e01-1c972828742a","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4185,400],"id":"01bcc90e-6de1-485d-b7fd-d7bd743d9a2e","name":"Record Sub-workflow Result"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4509,400],"id":"9c92ce5d-4608-4b45-8fcf-1d27568dbda1","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4833,400],"id":"7710e5cf-eafa-43e8-876e-fa67a63694c1","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5157,400],"id":"31944871-27bf-4e89-8138-a5f6ff4e5097","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5481,400],"id":"4e47c5b1-4abe-43ce-bd5c-bc2fd6ebc6ba","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5805,400],"id":"1fe564dc-e994-414d-a1ee-512a6cd3713b","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6129,400],"id":"d5cd23f8-1545-4ccb-862a-a1558b1a8909","name":"Persist Run Metadata"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6453,400],"id":"428a428e-e2d8-4635-865b-472608d93b43","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6777,400],"id":"3f6f3101-e527-44d0-a78f-32dea45b0afa","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[7101,400],"id":"9c94018a-fb25-43f7-96b2-a72367cc8d81","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"655c2f93-b006-4972-8766-533c8e0d1beb","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9a56f608-174f-4d64-b493-69d6b5fd135b","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7425,400],"id":"475a987a-4659-4346-ac09-e760641679e9","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7749,400],"id":"5661b427-2b81-4d64-b50e-21590738c932","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e510671d-4a01-4fc9-963e-c3a72d8aa439","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8073,400],"id":"c62eb96e-f76f-4876-8572-305f2176e02a","name":"Guard Non-Empty from"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8397,400],"id":"e14901c8-6bf1-4afd-a461-bc01e8072cf6","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"7607975e-ee7c-4a93-8d99-723860ac84a6","name":"pipeline","value":"Inbox Triage","type":"string"},{"id":"07c6583b-6b6a-4d12-8065-4639f8b15350","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8721,400],"id":"020b00ad-3b0c-481a-a88a-26864d34c4c5","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"1f9fee7a-e289-4660-9657-8ab392c0df8d","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"cf93dbd6-b86b-4751-904a-de4492726253","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"a758432f-14b5-4291-8896-09e709564ad1","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9045,400],"id":"86e63683-ceb1-4fbf-9be7-378a86e5b3e7","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO email_log (messageId, from, subject, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.messageId, $json.from, $json.subject ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[9369,400],"id":"2e727142-64e9-424f-97cd-0e439a5f1957","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Summarize meeting notes with PostgreSQL and Twilio — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9693,400],"id":"23ff4ec6-5217-4e59-9993-4688