{"name":"Capture applications with Notion and Gmail for your team","nodes":[{"parameters":{"formTitle":"Capture applications with Notion and Gmail for your team","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"b6c8857d-3657-4c35-9f48-57acbdf19c5b","name":"New Email Form Submission","webhookId":"b1b66cc6-10da-437e-9eb1-f734875e0afa"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"442e5a3b-dc22-44e8-a8d1-a7dc06414c2e","name":"Normalize Email Payload"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"27c1d846-d6af-492f-b8ed-64001fff5ad4","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"standard","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"standard"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f84f9cce-5d62-43bd-ba36-3c28dd77694f","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"priority","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"priority"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","v