name":"Process Batch Item","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":2,"unit":"seconds"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1674,880],"id":"3fd46524-4461-4c48-8913-e95f709d545f","name":"Respect Rate Limits"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[1998,400],"id":"1f0c0a08-ad8f-4219-b16c-ca4af4f60c76","name":"Aggregate Batch Results"},{"parameters":{"operation":"upsert","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2322,400],"id":"6890a48e-3e79-4dd9-a1ea-72440f998825","name":"Mark Completed in Airtable","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"search","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"filterByFormula":"={LastModified} > DATEADD(NOW(), -1, 'days')","options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2646,400],"id":"7178ccb9-4928-407c-877b-1c756e745230","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2970,400],"id":"ef834acc-b8c4-49ef-8710-c2f116cbd56f","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3294,400],"id":"e03228a6-6127-481d-9040-87d24c0dc954","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"1db191aa-a285-4724-908c-d7b36fd82634","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"1fce2429-9d01-4095-aa82-5c4ff10fef52","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"49cc92d8-00a8-4b85-a76c-cf0ad9b4e4d7","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"71b61fab-bccd-4105-afa4-8d8c1f9cdae0","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4266,400],"id":"9882e756-876e-4877-9018-4e268124ddf8","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"ca715910-84e3-4beb-b114-cd2a33b2d9a3","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"2d464d41-eaa1-419f-b813-1019e798cccb","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"7268a5d5-6676-4fa1-9166-59688ce0b397","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6b1bdb2f-d45e-481e-8db2-6712ff095f7f","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"e1ab8a59-4744-49cc-816d-cf3b5d6cea5c","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"c240357c-5648-4a06-bccf-2640f27bfa71","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"831316af-f11f-40e4-9724-cf92e65e96be","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Follow up open deals with Airtable and Telegram automatically — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[5886,400],"id":"1a9dbca0-62b4-49bf-99e1-02e6c0a522ef","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3bc8ccb3-bbd3-47ad-9e05-f30f23794bf9","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"670ab9da-ccfd-414c-9c41-775c75b57d35","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ab4faf9a-0565-411f-8ecf-6291d13a6780","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,1420],"id":"09291f45-5232-4121-88b9-ffab3ebb3827","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5562,1420],"id":"3a82aa63-4428-4dec-8a9a-dd5d5cb9a80f","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[5886,1420],"id":"0695699e-9e43-4a5e-bc79-aa4731f30115","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Read Pending Queue (Google Sheets)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d2cc5e2d-dfd5-d3c0-6fea-5f51051ef1f5","name":"Note: Daily Schedule"},{"parameters":{"content":"### Read Pending Queue (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Required Fields Present? · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"0d998ac7-3ad0-d1d7-dda6-820cbf0439b0","name":"Note: Read Pending Queue (Google Sheets)"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.from }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Work in Batches · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"af4c13fb-e93b-596e-aaa1-cfc32b39285b","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"fc3c9a40-787b-d823-1738-0c80477cb43c","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Work in Batches\n\nLoop controller — releases 10 item(s) per pass. Output 2 (loop) processes the batch, output 1 (done) fires after the last batch.\n\nPorts: ①→ Aggregate Batch Results · ②→ Process Batch Item","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"062521fd-a6b0-8d02-b690-4725acfa63d0","name":"Note: Work in Batches"},{"parameters":{"content":"### Process Batch Item\n\nPOST https://api.example.com/v1/emails — retries 3× with backoff on failure.\n\nPorts: ①→ Respect Rate Limits · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1000],"id":"9cc44601-7eee-18a3-15c2-d384b03bc32d","name":"Note: Process Batch Item"},{"parameters":{"content":"### Respect Rate Limits\n\nPauses 2 seconds — spacing calls to respect rate limits.\n\nNext: Work in Batches","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"65ce1d16-12b7-5de0-967b-c3cb08efce43","name":"Note: Respect Rate Limits"},{"parameters":{"content":"### Aggregate Batch Results\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Mark Completed in Airtable","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"0549e47c-e18a-83e9-fc95-6a2f0d15a3a7","name":"Note: Aggregate Batch Results"},{"parameters":{"content":"### Mark Completed in Airtable\n\nairtable — `upsert` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"497aee14-e820-8bcd-4fbe-2f6f064e6324","name":"Note: Mark Completed in Airtable"},{"parameters":{"content":"### Load Previous Snapshot\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"05458a17-0e6b-0fa8-df0b-f3831d059d9b","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"1467d19f-3202-5112-729e-c0df4ec6da6d","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"1610db04-dd6c-bd6c-cb36-3c98686c2665","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"5d817500-8326-ac63-0429-4531e4a7462e","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"0cd2854d-fdfb-ca75-80c7-534d887d67f3","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"5282e37f-15f3-7031-fb58-88e7bb219515","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"75a9f759-b5f6-0ce4-8502-cd069fc97714","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"2e64141c-719a-1781-c724-8c1d018d75be","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"0a6808e5-dae4-a762-9336-2c60b38710f0","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Telegram · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"61aed6bb-bb68-fdc7-0636-3c29e84c179b","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Telegram\n\ntelegram — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"449684c4-5e22-1b27-acf0-f48c66d08570","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"efec5ca3-e915-414f-f4fe-311f83b5f371","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"7d624ecd-ab1a-9298-ea82-75f62d156249","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nairtable — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"bfb4cd43-de20-1e30-b1ad-a5bc7685f005","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Follow up open deals with Airtable and Telegram automatically\n\n**Pattern:** Reminders & Follow-ups · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nFollow up open deals with Airtable and Telegram automatically. It runs automatically on a schedule.\n\n## Why it exists\nManual inbox triage is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Read Pending Queue (Google Sheets) → Required Fields Present? → Work in Batches → Aggregate Batch Results → Mark Completed in Airtable → Load Previous Snapshot → …\n\n## Use it for\n- Teams that want to reminders & follow-ups without manual effort\n- Anyone automating inbox triage in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Runs 24/7 in the background\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2 / service account; Slack OAuth2; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"538ff653-d0ec-17a6-5ff4-a7eaa35a23a5","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"3936cafd-08c4-35a7-55b9-46fe632ede08","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"84b39f77-1923-6e5d-f17f-af41da3cc105","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"1172c5df-0e98-2bcf-1baa-d7e4451570f0","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your inbox triage process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"c6073b06-6f81-5cbf-ce07-63c34fb3a6c6","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Read Pending Queue (Google Sheets)","type":"main","index":0}]]},"Read Pending Queue (Google Sheets)":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Work in Batches","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Work in Batches":{"main":[[{"node":"Aggregate Batch Results","type":"main","index":0}],[{"node":"Process Batch Item","type":"main","index":0}]]},"Process Batch Item":{"main":[[{"node":"Respect Rate Limits","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Respect Rate Limits":{"main":[[{"node":"Work in Batches","type":"main","index":0}]]},"Aggregate Batch Results":{"main":[[{"node":"Mark Completed in Airtable","type":"main","index":0}]]},"Mark Completed in Airtable":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint