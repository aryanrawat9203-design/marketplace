          "conditions": [
            {
              "id": "a0b9300b-d354-452d-bf3f-82f5e904aeb0",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "c8fb655d-44a6-49d4-8abf-736804752a6c",
