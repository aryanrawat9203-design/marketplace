ryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3618,400],"id":"aa6c542b-a81b-43e1-93d1-6e163590ba6e","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3b7051f7-be92-41e9-b71c-0b408410ec49","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"32767050-edb5-4869-bd32-651020f9fb84","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,400],"id":"1e559e95-9b10-4a66-87b2-48ec40b054c2","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"b7a4db1d-a408-4bdb-9f87-2a0b8883f716","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"73bb2ab0-9870-49cf-b74e-ed2f44e26b66","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"de686eb0-e985-4ba3-a63b-21f295ee12ac","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"746da50e-f486-4d76-9da4-259caeadce56","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4590,400],"id":"fdc7a123-74a8-4787-90b1-4613c709a3b8","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=✅ Follow up open deals with Airtable and Discord in re