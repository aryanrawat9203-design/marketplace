prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"2efc3e13-55f5-4b9d-9d75-92ef5daeeede","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4266,400],"id":"97781f09-8041-4753-a7e1-a1dd426b11da","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4590,400],"id":"1e3bf269-e5ac-4e4a-b095-73d528b07488","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"c3e721cc-69f5-48eb-90e2-22e945ba80f3","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"dc0549ca-fdea-42ca-9655-0a4f7aadd126","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"076455db-dcbc-4067-bf4a-09c463a28a6f","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"26107778-94ac-472a-9b5f-f1ac1c658b47","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"7639c58e-fca9-4a75-95ef-118d72cf00cd","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":