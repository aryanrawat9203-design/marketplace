] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"ac5736cc-1104-42ce-b7a6-e221185fcd3f","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"1ff77879-bb18-4cf2-93e8-4e10c9fd4c07","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"d99be89d-6377-49a2-96c6-4f36dfb7120a","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"b6c544eb-eeba-4d7d-a43f-a586ca6616a9","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"8a816b42-2eb5-4255-a41e-d7931676bd72","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8b7b3a1e-3991-4b1b-bb76-ac6095c0026f","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"5a372061-bbfc-4737-80c2-cfe92655479c","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,400],"id":"4aa14559-5db3-4fde-8907-a4684ff9729b","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onErr