      "typeVersion": 1.2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "bf41fe8d-f60c-4497-98a9-5d7b5ff050ac",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "78d1627e-4540-4157-abb7-de0b2e6aaf29",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "74c734b9-9415-42d9-a56a-fccf38ef70f4",
