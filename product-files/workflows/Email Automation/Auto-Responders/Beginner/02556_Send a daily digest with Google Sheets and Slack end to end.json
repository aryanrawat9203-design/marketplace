{
  "name": "Send a daily digest with Google Sheets and Slack end to end",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1,
              "triggerAtHour": 6
            }
          ]
        }
      },
      "id": "88e6f8ab-903d-4cfe-981d-a26fb6d6934c",
      "name": "Schedule Trigger",
