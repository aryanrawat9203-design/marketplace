{"name":"Onboard trial users with Notion and Slack without manual work","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":9,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"4a68d218-4d84-435b-b4ba-dcd0ba75099a","name":"Daily Schedule"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"400a89e0-331c-4bff-81ce-e67fe6d5ec88","name":"Normalize Email Payload"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b45cb880-d84b-48e1-8c15-dcf59bdecd07","leftValue":"={{ ($json.score ?? 50) >= 50 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"8f6dfdfe-0777-41e4-81a6-e1603da6f126","name":"Segment Audience"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Hi {{ $json.name || 'there' }}, here's how to get started…","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,160],"id":"4c3215cf-16ea-48fe-a77c-be6cf097c244","name":"Step 1 — Welcome (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1026,760],"id":"55452638-76b5-41be-9d9b-f3f77ae20700","name":"Tag for Slow Nurture","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":3,"unit":"days"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1350,400],"id":"91ab89b3-6c85-4dac-b5b2-c91518a8bec9","name":"Wait Before Step 2","webhookId":"33308625-18cd-4840-af05-6e0a7639f915"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7dfb1af7-d049-4d70-95ea-4cdaf8b758a7","leftValue":"={{ $json.status }}","rightValue":"converted","operator":{"type":"string","operation":"notEquals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1674,400],"id":"da892ea1-469f-40e0-9e09-a4facd5d4fb7","name":"Converted Already?"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Quick tip for {{ $json.company || 'your team' }} — see what others automate.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1998,160],"id":"584030bd-2657-4477-b312-773ba1300bbf","name":"Step 2 — Value Nudge (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2322,760],"id":"ec2cb359-f5be-48de-a51f-32a6b2a65542","name":"Mark Converted — Stop Drip","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,400],"id":"a2877e8b-2a49-42d1-92f1-ec7f0d6cd4b7","name":"Update Drip Status","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2970,400],"id":"5661d14f-53cf-4071-8902-4894bc3c93ac","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d1914524-a7c7-4ade-b0a2-5e3bd01effd4","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"62745578-419d-4649-afd7-ef1e22bf9e23","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3294,400],"id":"b0eb2c89-1f91-4143-9e86-0ac366cb0e88","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3618,400],"id":"d71b9f8a-95c6-4693-a6b1-df641132ee00","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3942,400],"id":"a695f4a0-55fa-4286-979e-0df9f9538fa0","name":"Compute Drift vs Snapshot"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"1db11232-fad7-4e91-832b-49c42f66228e","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4590,400],"id":"f2e625e2-0f54-4b5f-8831-0a58830cabc0","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"5e524414-aa93-43e8-ac2b-a09d054e4545","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"55ef1089-2852-41c2-84ce-c4bf025188e3","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"423ecd00-fcda-46dd-89ff-863bb01383a5","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"477f16d4-df6e-449a-baf9-c8f398d84ebc","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"05b5464d-9c59-42f1-8ad1-7ac9c3cc89d9","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"ecaea06b-c8e7-41da-a0ae-2366fb71b71b","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5886,400],"id":"8da30106-0e6e-4844-9d18-dbc994853ee7","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Onboard trial users with Notion and Slack without manual work — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6210,400],"id":"c122c70d-2da2-40d5-b2f0-46c17f1df60f","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d31d1f5b-e9f0-4301-be73-4f3435bca081","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"99eeda90-bee1-40c1-8f3b-1649246513fb","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"5c3f7