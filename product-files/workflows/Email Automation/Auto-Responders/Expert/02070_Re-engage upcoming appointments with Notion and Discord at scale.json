-48ecb20f8274","name":"Send Confirmation (Discord)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=That slot is taken — here are 3 nearby openings.","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[1674,760],"id":"c50274bb-d5e9-4b7a-9bdd-b0bd1a7fd51c","name":"Propose Alternative Slots","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":1,"unit":"hours"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[2646,400],"id":"077971d6-793b-46d9-9b2c-bec5563683dd","name":"Hold Until Reminder Time","webhookId":"6f12fb9b-0e2b-46f2-802f-ae0900d81965"},{"parameters":{"authentication":"webhook","content":"=⏰ Reminder: your session starts soon.","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[2970,400],"id":"1fae4019-ab7b-4ffa-91a8-30fc82b1283b","name":"Send Reminder (Discord)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3294,400],"id":"b01d5c77-9dc0-4688-879a-ffce7ed4f510","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3618,400],"id":"ebc9c336-cea7-4d1b-b22d-fea1b6148a74","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3942,400],"id":"f4b28d8d-a72c-4df6-bd4f-e39a453d701f","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4266,400],"id":"dac512b0-27b8-44ad-ab0b-7246350beadd","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4590,400],"id":"9a7bfca2-2b7e-4902-afee-78a363795411","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"404c24ab-bdaf-4ad6-8297-d57825e37a51","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"771bbcb0-c08a-4a33-b4c3-db02d5613713","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"587ac0a6-7d81-4388-babf-df7840e6582d","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5238,400],"id":"95681e4f-ffed-4a75-ab89-773051533c60","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"01670690-419c-4e09-8fc6-664b77102aff","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"a4cde1b9-372e-4ca9-8047-47bb66c419ad","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"59efc6df-6623-4e40-ba85-05f43f4767f1","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"244af7b0-27ce-42a2-b780-5b96f8aaea2a","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"35bade36-fa7f-46ff-b38e-146afdbb757b","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6210,400],"id":"7e214979-1cdf-4d5d-9d2f-1bb302260a37","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Re-engage upcoming appointments with Notion and Discord at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6534,400],"id":"84d07c56-e701-40b7-a14f-5be3bec57a02","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"82ab1485-a4dc-401d-bd72-82e49ec66de6","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"753ea435-6948-4c90-8d4e-a45198f2512f","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"ed524587-59a6-4571-8d2e-2d2259c4c45a","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"14d8c0e6-4509-4e6a-9857-0d4196b7649c","name":"Capture Failure Context"},{"parameters":{"authentication":"webhook","content":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[6210,1420],"id":"d06354e5-5fe0-4800-82e3-d1f11e305e59","name":"Escalate Failure to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6534,1420],"id":"8a2609f2-1975-4e22-893c-35d3d40adf28","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 7:00. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Emails","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"2f3ca0dc-e062-7d66-f1c6-db442a54b81c","name":"Note: Daily Schedule"},{"parameters":{"content":"### Keep Valid Emails\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Slot Free?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"47221216-8089-3e87-eb27-55639c8e2300","name":"Note: Keep Valid Emails"},{"parameters":{"content":"### Slot Free?\n\nTwo-way gate on `={{ $items().length === 0 || !$json.id }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Record Booking · ②→ Propose Alternative Slots","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"adb3fd70-f7c9-8a15-f4ee-93dc304a0f22","name":"Note: Slot Free?"},{"parameters":{"content":"### Record Booking\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Confirmation (Discord) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,280],"id":"5765b743-f066-a8c5-0438-a98932625bf0","name":"Note: Record Booking"},{"parameters":{"content":"### Send Confirmation (Discord)\n\ndiscord — `action` operation against the connected account.\n\nPorts: ①→ Hold Until Reminder Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,280],"id":"3996b006-9316-430c-16a9-219c6f775299","name":"Note: Send Confirmation (Discord)"},{"parameters":{"content":"### Propose Alternative Slots\n\ndiscord — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,880],"id":"ff8f1692-1dfa-99d2-aacd-fca0c673f981","name":"Note: Propose Alternative Slots"},{"parameters":{"content":"### Hold Until Reminder Time\n\nPauses 1 hours — spacing calls to respect rate limits.\n\nNext: Send Reminder (Discord)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"c2ca22f7-7006-140b-50e4-526772cfcbb5","name":"Note: Hold Until Reminder Time"},{"parameters":{"content":"### Send Reminder (Discord)\n\ndiscord — `action` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"a4991008-6bdf-1e9d-458a-dad17d98ab94","name":"Note: Send Reminder (Discord)"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"5f3a0c3c-864c-fb02-6815-b02bcad6320a","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"80cd67bb-ac63-6a8a-7c32-289a0f70ef33","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"d92bc607-dda8-8f6f-3e16-2e00c6b636ff","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"35e9c97c-d132-9f18-5ba2-2f6822414b9b","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"3d81d793-8203-804f-ce50-8d0048047024","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"29743378-86e7-7f44-2f83-e7f669d60a83","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"8dc290ef-0350-0a1e-d831-fe27dce564d1","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"e35dc191-88e8-8cdb-090e-b23d8a1e81e1","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"9af15cea-6734-c577-885e-dc5384abe3b9","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"36916452-8070-c9b5-7d29-67f7ac60efbd","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"92c2d5b8-1d99-e96d-c5ac-676219e250e4","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Discord","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"000747f7-d369-8185-2d10-5ca4bf91fc45","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Discord\n\ndiscord — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Discord webhook URL","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"dbae3d38-9865-e547-3ce3-11915623a9ee","name":"Note: Escalate Failure to Discord"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"852f6dab-a3d8-1dc9-66ed-c9f6b0d4b09c","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Re-engage upcoming appointments with Notion and Discord at scale\n\n**Pattern:** Reminders & Follow-ups · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nRe-engage upcoming appointments with Notion and Discord at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual auto-responders is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Keep Valid Emails → Slot Free? → Record Booking → Send Confirmation (Discord) → Hold Until Reminder Time → Send Reminder (Discord) → …\n\n## Use it for\n- Teams that want to reminders & follow-ups without manual effort\n- Anyone automating auto-responders in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Saves hours of manual work each week\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Discord webhook URL; Google OAuth2 / service account; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"2df93cac-5de5-9814-4f01-905ad4cbcfab","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"e4b71c8d-cad1-b709-056c-5d13fa5a2889","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"07d9347f-e234-a32f-31fa-f31ff6f19927","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"3df7dea6-2010-a943-f4a9-fd63ebfcb008","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your auto-responders process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"1df2b7bf-e732-841b-70e7-f5cb2b6ec7f0","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Keep Valid Emails","type":"main","index":0}]]},"Keep Valid Emails":{"main":[[{"node":"Slot Free?","type":"main","index":0}]]},"Slot Free?":{"main":[[{"node":"Record Booking","type":"main","index":0}],[{"node":"Propose Alternative Slots","type":"main","index":0}]]},"Record Booking":{"main":[[{"node":"Send Confirmation (Discord)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Confirmation (Discord)":{"main":[[{"node":"Hold Until Reminder Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Until Reminder Time":{"main":[[{"node":"Send Reminder (Discord)","type":"main","index":0}]]},"Send Reminder (Discord)":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Discord","type":"main","index":0}]]},"Escalate Failure to Discord":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Propose Alternative Slots":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"1c53c49f-d0cb-46e7-87f6-e40156f43a27","id":"FDX02070"}