        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "name",
          "value": "#inbox-ops",
          "cachedResultName": "#inbox-ops"
        },
        "text": "={{ $json.html }}",
        "otherOptions": {}
      },
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [
        2620,
        400
