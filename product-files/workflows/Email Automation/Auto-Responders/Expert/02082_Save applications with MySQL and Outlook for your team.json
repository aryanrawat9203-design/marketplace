a":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"eecfccbd-f330-4915-8462-73effd5f05fb","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5dc3b2bf-07a7-4daa-912c-3210c1d6341b","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"eeb7bfe5-54fd-47d9-ad63-58a2d8148500","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"2e3c2ef5-cd40-4e4f-94bf-00ccbcc22507","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"449f61f5-4cfa-4edf-85a0-ae433f23402c","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"0f56036e-1ff0-4211-8193-ce567ad69ce0","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"df531ba8-cd31-4107-9db0-cb591774b812","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[4914,400],"id":"10e7bbbe-cfe0-4b40-99ec-a24e06f269e2","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=✅ Save applications with MySQL and Outlook for your team — run completed at {{ ","bodyContent":"=✅ Save applications with MySQL and Outlook for your team — run completed at {{ $now.toFormat('HH:mm') }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[5238,400],"id":"f0c333f0-9aba-4e43-a866-e3b45f64cd26","name":"Send Summary to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"