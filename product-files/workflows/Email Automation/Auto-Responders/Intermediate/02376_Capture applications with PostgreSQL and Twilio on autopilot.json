{"name":"Capture applications with PostgreSQL and Twilio on autopilot","nodes":[{"parameters":{"formTitle":"Capture applications with PostgreSQL and Twilio on autopilot","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"a4f0c472-1f1f-4b48-917f-d7077a3d8db1","name":"New Email Form Submission","webhookId":"36897124-35b9-49fc-9db7-2afdc76937e0"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"20a0b27c-2bf9-40e5-aee5-7ea8801ec184","name":"Normalize Email Payload"},{"parameters":{"assignments":{"assignments":[{"id":"d631b9ea-d423-49b4-836a-09f502621c65","name":"requestId","value":"={{ $json.messageId || $execution.id }}","type":"string"},{"id":"4aa348d2-538a-40cd-8f4a-682629280e21","name":"summary","value":"={{ ($json.from || '').toString().slice(0, 200) }}","type":"string"},{"id":"ac21687a-c4e7-4011-b879-db210ab8a426","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"93e1cb74-9e48-48eb-9041-39dbce0557de","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions"