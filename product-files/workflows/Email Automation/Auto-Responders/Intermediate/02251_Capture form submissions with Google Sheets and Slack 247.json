{"name":"Capture form submissions with Google Sheets and Slack 24/7","nodes":[{"parameters":{"formTitle":"Capture form submissions with Google Sheets and Slack 24/7","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"cca58571-f3c9-47c8-9043-eb7e898dd1f7","name":"New Email Form Submission","webhookId":"f673ce43-8a5a-4fc7-80bd-b819e6070c6f"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"853bfc38-4a7f-46d6-aff0-989f8c98f109","name":"Normalize Email Payload"},{"parameters":{"assignments":{"assignments":[{"id":"d503c53e-1d5e-4a9a-adbd-b3810f4384ad","name":"requestId","value":"={{ $json.messageId || $execution.id }}","type":"string"},{"id":"20190ef3-a9b7-4666-a803-a208d6fffa5b","name":"summary","value":"={{ ($json.from || '').toString().slice(0, 200) }}","type":"string"},{"id":"71767ed9-6e37-47c7-a665-31cabe301fbc","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"0c35f320-8a7c-4309-8e08-6a258275c713","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}}