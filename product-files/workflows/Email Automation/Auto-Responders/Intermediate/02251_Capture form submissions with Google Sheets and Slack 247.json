{"name":"Capture form submissions with Google Sheets and Slack 24/7","nodes":[{"parameters":{"formTitle":"Capture form submissions with Google Sheets and Slack 24/7","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"21a8e615-9723-431f-8a4d-1dc11a2b7cae","name":"New Email Form Submission","webhookId":"c282620a-1dc0-46c2-a3fb-2ef0137e0476"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"50e9671e-0d42-4f9e-884b-82744248489e","name":"Normalize Email Payload"},{"parameters":{"assignments":{"assignments":[{"id":"ec639e10-1c55-4f3a-92c4-40e80ce46d8b","name":"requestId","value":"={{ $json.messageId || $execution.id }}","type":"string"},{"id":"1aa2e4c2-ff8a-4920-9f54-00bbafbbf66b","name":"summary","value":"={{ ($json.from || '').toString().slice(0, 200) }}","type":"string"},{"id":"30e37c77-241a-4a99-8574-ff1e07874226","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"85c28d5e-7069-4064-8192-2775e9eaa148","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}}