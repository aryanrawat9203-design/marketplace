hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"fc40d1e1-4e5c-44d1-b12f-5a9ca41ac799","name":"Compute Drift vs Snapshot"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4590,400],"id":"a7c9b376-a05f-4083-bf24-940285a95025","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"1c06f0a6-c953-4cfb-87b5-965a7cb09b76","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"76861516-0d8c-4898-af6a-0107214fd04d","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"049f2771-6e02-4d78-bd45-6234f82dcc9e","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"390c6c7e-4db9-412f-ab7a-4b964444a246","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6d0c0e91-1b5d-40c2-a2bd-c2c281df6358","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"4b2d332f-f620-4edb-98ef-f0e4bb7f8990","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"95615448-cae9-4986-95c0-4375f041217b","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVers