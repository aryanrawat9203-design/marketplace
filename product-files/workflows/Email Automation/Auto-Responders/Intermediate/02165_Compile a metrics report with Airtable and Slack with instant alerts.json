{"name":"Compile a metrics report with Airtable and Slack with instant alerts","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":8,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"1eb2708f-3b09-4f12-9645-63e0c197d4f5","name":"Daily Schedule"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/emails","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"427b26e3-1694-44bb-a8b9-9abef96db531","name":"Pull Fresh Items (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"receivedAt","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[378,400],"id":"1f1bd399-c3b8-47b0-a7af-90332c5bd26f","name":"Newest First"},{"parameters":{"maxItems":15},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"cc7ee953-bfde-42c7-ba9d-382860c2c64a","name":"Trim to Digest Size"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.chainSummarization","typeVersion":2,"position":[1026,400],"id":"b33ad60d-256d-40e0-9d7d-304317aa1ce3","name":"Summarize Content (AI)","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[1269,970],"id":"69907902-a44a-4878-aa6d-2e140ebef956","name":"OpenAI Chat Model"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"={{ $json.html || $json.response?.text || $json.text }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,400],"id":"7d0cdfb4-0ab8-47f6-9c2c-846f5407fac3","name":"Post Digest to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[1917,400],"id":"bd25f2ac-3c64-4963-965d-1dad20c9f0bd","name":"Archive Digest in Airtable","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2241,400],"id":"632dbd21-72c9-4d33-9c03-bfc190fef6e8","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2565,400],"id":"793b8e67-99a9-437d-9581-0801776a9d7b","name":"Compute Drift vs Snapshot"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2889,400],"id":"3c1d94d5-8a13-43d7-bf5d-a61477d08580","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3213,400],"id":"f76ab6c9-5a31-4392-b395-5e605668e765","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3537,400],"id":"8f50e618-2c9b-4bb8-bbd3-ab5fe207b967","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3861,400],"id":"93464969-fee5-47aa-98fa-3160fbc51724","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4185,400],"id":"29327616-ea44-4e73-8dfd-d59ea02d06e1","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4509,400],"id":"051687f7-554b-4a48-aad6-2440fef48fb2","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4833,400],"id":"c3cda43d-53b1-4d71-8804-e38e676c87f9","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"c0b816e4-6fca-4859-92eb-4e73e3d524a8","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"244097df-b1be-4bf8-8780-c3503717f673","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,400],"id":"8612a76f-9d3b-4b2b-8a20-cf5f30b58c25","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"d55b9ed9-26dc-4413-9cf2-cff4a989d1f9","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"190bc4d5-788f-47c0-8484-19ab1619ab1c","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"b64eb501-a868-49e6-8763-814f97bede26","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,400],"id":"e6f2c938-76fb-4f3e-bc0f-9642d9719cc0","name":"Summarize Run Stats"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[5805,400],"id":"7ab93262-81f2-4cc3-abbd-62adf1de19f5","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Compile a metrics report with Airtable and Slack with instant alerts — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6129,400],"id":"48cec984-d730-4dd8-bb86-5ee42ba0afe8","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"61e664d6-6665-46ca-a434-9b00663bffd8","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"56333f02-e3f7-4f67-bc82-c2b9d7a24963","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"46d4b9df-552b-4b86-bca6-268a3ab948cd","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,1420],"id":"98529da0-8b7a-4135-99a2-eb2c1cb342de","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,1420],"id":"cec7e6d7-94aa-436d-b9a7-e7e7b9d0278f","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Emails"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[6129,1420],"id":"898c82bf-f07e-482a-bb6f-f2b1b3f3646b","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 8:00. No input data; downstream nodes fetch what they need.\n\nNext: Pull Fresh Items (API)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"65fed03d-c721-83b1-6e46-6ddc584350e0","name":"Note: Daily Schedule"},{"parameters":{"content":"### Pull Fresh Items (API)\n\nGET https://api.example.com/v1/emails — retries 3× with backoff on failure.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"2be62fad-351c-4578-2f72-b4fca5713810","name":"Note: Pull Fresh Items (API)"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"291abbb9-33eb-404a-49ee-a7f0296cf675","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"158c1b30-8ae8-bf55-2359-fbee7ec447aa","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Post Digest to Slack · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"2f90b124-c40d-fef6-729b-bd4774a4af0f","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"9d9e1a3d-1bb5-227d-b93b-fc89980a1aeb","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Post Digest to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Archive Digest in Airtable · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"b5d002ed-799f-a286-24d8-2fb30b93fcdf","name":"Note: Post Digest to Slack"},{"parameters":{"content":"### Archive Digest in Airtable\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"0549b41a-f9c3-c275-68b7-ce531f683d16","name":"Note: Archive Digest in Airtable"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"2278bb48-52d6-f314-6cb6-68a541b73495","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"75623c43-0040-e57d-63e0-be89ce8f0f82","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"c002aea9-5c12-9be1-2380-4eec4619bc75","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"06a553c9-0ae1-13ea-c1b8-35d961d74722","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"529ccff6-cd15-bd81-dd58-0512ae5a9907","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"f1001b57-f701-6e96-9af6-c11e6b080c4d","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"88e7c406-de74-9519-118a-f24857f0570b","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"466cedbf-465b-ddc3-54e9-8e1f31a58ded","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"bb517fa5-51fb-9815-a1bb-14b4802a986d","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"5f5d9d09-3a95-47a7-3b4f-3b398531666d","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"0cf0b94f-7280-7474-734e-85e4195de425","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"b68922c8-43d8-4e47-e30c-c3a1fac42e12","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"1eaccd36-27cc-4286-f263-b3b20214b856","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"f91c6cd5-8fa1-4f92-4618-e71fdaf61a57","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,1540],"id":"d9b17c21-fd8e-75e0-e8e6-76196969b014","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nairtable — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,1540],"id":"093dc7d0-c0c1-4832-0481-bf097a720181","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Compile a metrics report with Airtable and Slack with instant alerts\n\n**Pattern:** Scheduled Digest · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nCompile a metrics report with Airtable and Slack with instant alerts. It runs automatically on a schedule.\n\n## Why it exists\nManual auto-responders is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Pull Fresh Items (API) → Newest First → Trim to Digest Size → Summarize Content (AI) → Post Digest to Slack → Archive Digest in Airtable → …\n\n## Use it for\n- Teams that want to scheduled digest without manual effort\n- Anyone automating auto-responders in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Standardizes the process every time\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2 / service account; OpenAI API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"37a30f51-b947-d247-9b2f-6ae16fbf4301","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"a4f1b201-25c2-62b4-7eb8-51c8b7316d2e","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"b598f625-c775-e717-daa0-3e717e41a9dd","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"d0d484aa-8e64-f76c-88b4-8167d51f06b4","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your auto-responders process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"04d9bf72-449f-b045-f89b-08fef8001407","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Pull Fresh Items (API)","type":"main","index":0}]]},"Pull Fresh Items (API)":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Post Digest to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Post Digest to Slack":{"main":[[{"node":"Archive Digest in Airtable","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Digest in Airtable":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"a38d6ac1-c69c-4db8-a832-16a1dbef052e","id":"FDX02165"}