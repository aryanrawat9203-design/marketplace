plicates","typeVersion":2,"position":[5886,400],"id":"eaa3d9ee-610d-4f6b-87fe-d42fa28ed86b","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6210,400],"id":"0a0c756b-88b5-4c32-bfc4-ccaf8410a80e","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"5e78e723-bdd7-4942-97e8-24ec90644499","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"96dd9374-bfdd-4e09-9110-562cdbac408b","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6534,400],"id":"51381721-3670-45b7-957a-bad4d977b12f","name":"Fold In Enrichment Fields"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"messageId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[6858,400],"id":"a75085d8-bf4a-489f-be0a-f5272cce851f","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"6e61216e-4022-4dbd-9079-7c02f8e6a55a","name":"pipeline","value":"Auto-Responders","type":"string"},{"id":"0f1eefb7-ace8-4737-9adc-a23c6c3c662a","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"99eae048-8d60-40e8-8232-9d68b47d1ac7","name":"Tag Pipeline Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"564c441c-dbf5-494e-8810-5d7a3abdeaae","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-b