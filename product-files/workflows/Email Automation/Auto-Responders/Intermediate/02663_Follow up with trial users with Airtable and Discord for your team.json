":"autoMapInputData","value":{},"matchingColumns":["messageId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2970,400],"id":"a4dc2a59-9822-4f0d-b179-6bdfbc1d5b21","name":"Update Drip Status","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 8:00. No input data; downstream nodes fetch what they need.\n\nNext: Segment Audience","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"1d99d305-b9ab-a9fe-57dc-5b7310af025d","name":"Note: Daily Schedule"},{"parameters":{"content":"### Segment Audience\n\nTwo-way gate on `={{ ($json.score ?? 50) >= 50 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 1 — Welcome (Discord) · ②→ Tag for Slow Nurture","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"c11e0a12-fd66-4983-2aa0-b06f04d7afbc","name":"Note: Segment Audience"},{"parameters":{"content":"### Step 1 — Welcome (Discord)\n\ndiscord — `action` operation against the connected account.\n\nNext: Wait Before Step 2\n\n↻ retries 3×/2s · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,280],"id":"e71b2313-61c2-09c9-1ddc-87a161fc0ba7","name":"Note: Step 1 — Welcome (Discord)"},{"parameters":{"content":"### Tag for Slow Nurture\n\nairtable — `upsert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,880],"id":"be893cab-0678-faff-466c-5b36f7650171","name":"Note: Tag for Slow Nurture"},{"parameters":{"content":"### Wait Before Step 2\n\nPauses 2 days — spacing calls to respect rate limits.\n\nNext: Converted Already?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"da7c0b6c-1ee8-97ed-2ae0-591810ad1fa6","name":"Note: Wait Before Step 2"},{"parameters":{"content":"### Converted Already?\n\nTwo-way gate on `={{ $json.status }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Step 2 — Value Nudge (Discord) · ②→ Mark Converted — Stop Drip","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"bf5245fa-da66-6f9b-ee8d-b593fe814e8e","name":"Note: Converted Already?"},{"parameters":{"content":"### Step 2 — Value Nudge (Discord)\n\ndiscord — `action` operation against the connected account.\n\nNext: Wait Before Final Step\n\n↻ retries 3×/2s · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"44cd54a9-18b3-e63c-c441-95db57497105","name":"Note: Step 2 — Value Nudge (Discord)"},{"parameters":{"content":"### Mark Converted — Stop Drip\n\nairtable — `upsert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"147d020f-8b2d-7f30-6596-20198f5eab33","name":"Note: Mark Converted — Stop Drip"},{"parameters":{"content":"### Wait Before Final Step\n\nPauses 3 days — spacing calls to respect rate limits.\n\nNext: Step 3 — Final Offer (Discord)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"19d8f72b-fd4f-3e18-b244-4642872415af","name":"Note: Wait Before Final Step"},{"parameters":{"content":"### Step 3 — Final Offer (Discord)\n\ndiscord — `action` operation against the connected account.\n\nNext: Update Drip Status\n\n↻ retries 3×/2s · 🔑 Discord webhook URL","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"8c4e9b26-fc80-13c8-5661-94a59c738073","name":"Note: Step 3 — Final Offer (Discord)"},{"parameters":{"content":"### Update Drip Status\n\nairtable — `upsert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"5c97a321-b122-9444-9702-4943ba37f159","name":"Note: Update Drip Status"},{"parameters":{"content":"# Follow up with trial users with Airtable and Discord for your team\n\n**Pattern:** Drip Sequence · **Level:** Foundation · **Trigger:** Scheduled\n\n## What it does\nFollow up with trial users with Airtable and Discord for your team. It runs automatically on a schedule.\n\n## Why it exists\nManual auto-responders is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Segment Audience → Step 1 — Welcome (Discord) → Wait Before Step 2 → Converted Already? → Step 2 — Value Nudge (Discord) → Wait Before Final Step → …\n\n## Use it for\n- Teams that want to drip sequence without manual effort\n- Anyone automating auto-responders in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Removes copy-paste errors\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Airtable PAT; Discord webhook URL.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"468f7973-d9c3-2793-fc39-613543018b10","name":"📘 Workflow Overview"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"04e2dc17-ca2a-22f1-8e13-c775c77dba3e","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your auto-responders process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"f5b72fc4-7d5a-151d-8fd3-d10efdedbca0","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Segment Audience","type":"main","index":0}]]},"Segment Audience":{"main":[[{"node":"Step 1 — Welcome (Discord)","type":"main","index":0}],[{"node":"Tag for Slow Nurture","type":"main","index":0}]]},"Step 1 — Welcome (Discord)":{"main":[[{"node":"Wait Before Step 2","type":"main","index":0}]]},"Wait Before Step 2":{"main":[[{"node":"Converted Already?","type":"main","index":0}]]},"Converted Already?":{"main":[[{"node":"Step 2 — Value Nudge (Discord)","type":"main","index":0}],[{"node":"Mark Converted — Stop Drip","type":"main","index":0}]]},"Step 2 — Value Nudge (Discord)":{"main":[[{"node":"Wait Before Final Step","type":"main","index":0}]]},"Wait Before Final Step":{"main":[[{"node":"Step 3 — Final Offer (Discord)","type":"main","index":0}]]},"Step 3 — Final Offer (Discord)":{"main":[[{"node":"Update Drip Status","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"55f6f2e5-bdc1-4e44-947d-0e039fea2091","id":"FDX02663"}