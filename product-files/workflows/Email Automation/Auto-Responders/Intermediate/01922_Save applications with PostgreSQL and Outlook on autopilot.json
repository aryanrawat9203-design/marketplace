{"name":"Save applications with PostgreSQL and Outlook on autopilot","nodes":[{"parameters":{"formTitle":"Save applications with PostgreSQL and Outlook on autopilot","formFields":{"values":[{"fieldLabel":"From","requiredField":true},{"fieldLabel":"Subject","requiredField":false},{"fieldLabel":"Receivedat","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"bd3702cc-0c26-4434-a150-8301e88c8586","name":"New Email Form Submission","webhookId":"37259e36-747b-46db-8cff-298be815d23e"},{"parameters":{"method":"GET","url":"={{ $json.fileUrl }}","options":{"timeout":30000,"response":{"response":{"responseFormat":"file"}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"e6a27869-160c-4274-a75c-44e4f56de9c0","name":"Download Source File","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"xlsx","options":{}},"type":"n8n-nodes-base.extractFromFile","typeVersion":1,"position":[378,400],"id":"7acf2139-f0fe-4308-87a8-3190832933ca","name":"Parse XLSX Contents"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming email records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    messageId: String(j.messageId ?? j.id ?? '').trim(),\n    from: typeof j.from === 'string' ? j.from.trim() : j.from ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"ec17ad11-1264-4ed2-9b5b-542ffe403690","name":"Clean & Reshape Rows"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8e8f8aff-29b0-4429-b9e7-391970a14e15","leftValue":"={{ $json.messageId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1026,400],"id":"0ba616ca-f76b-4328-a692-0a8ffa9830ac","name":"Rows Pass Validation?"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1350,880],"id":"37ecb019-8b72-403b-9998-1b59770a39fb","name":"Quarantine Bad Rows","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1674,400],"id":"6777fafc-954c-417a-b6ea-1cc3fec3c21d","name":"Load Rows into Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[1998,400],"id":"51cc0438-3146-4605-88e0-d300cee81b08","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO email_log (messageId, from, subject, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.messageId, $json.from, $json.subject ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2322,400],"id":"5b3037d4-f65f-426d-9a1e-d1eea2999806","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2646,400],"id":"053f6c3c-4a5f-455f-b72a-330bdf351b33","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2970,400],"id":"a607a6cc-33a4-4180-b110-e413c19e83e8","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3294,400],"id":"7b8e6867-2451-47d0-81a9-3f6f3dc00c6c","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"6a6e676d-eac4-4a75-a11c-7f0ab2e025e0","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c717d242-d9a1-4a42-ae63-b9a97a982a4a","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"b97dbb2b-38f5-43c0-a96b-45a96ec2c333","name":"Fold In Enrichment Fields"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Emails"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3942,400],"id":"6f1ba84f-904e-47a7-9f67-24515d45d337","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4266,400],"id":"75974105-357d-4deb-9071-bf744b0713e9","name":"Record Sub-workflow Result"},{"parameters":{"operation":"executeQuery","query":"SELECT * FROM emails WHERE updated_at > NOW() - INTERVAL '1 day' ORDER BY updated_at DESC;","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4590,400],"id":"d51c3a49-a3aa-446e-b20e-533dde615ef7","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"3fdce711-c026-467e-89ca-cbcdb3be4d3a","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5238,400],"id":"d4ebd095-37d9-48fc-8117-357fd5717ada","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"49b7f653-d413-4088-adc8-ca07b58bb674","name":"Persist Run Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"messageId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[5886,400],"id":"3ec8467d-4b9f-4357-ba3e-5463ec94b8c5","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"798d04c9-c719-4e63-b9f4-2747dd0763cb","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[6210,400],"id":"856186c0-b051-402e-b35f-47c48e1b0ba4","name":"Guard Non-Empty from"},{"parameters":{"assignments":{"assignments":[{"id":"2c1ce028-c250-4542-8f36-9d872f335bf3","name":"pipeline","value":"Auto-Responders","type":"string"},{"id":"3ef7fa93-f7f9-45a7-98b8-0ce956fd59fd","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6534,400],"id":"3434c048-a5d4-461d-9f65-d1d4bcc4cdfa","name":"Tag Pipeline Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"messageId","value":"={{ $json.messageId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6858,400],"id":"57d01164-3771-4970-bc81-775d445ac6d7","name":"Save Execution Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"receivedAt","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7182,400],"id":"810cbfe2-b46a-4dc6-aa46-f499af87a308","name":"Sort Emails Newest First"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7506,400],"id":"3e0bc128-afd9-4aab-b62e-a438112e7891","name":"Stamp Processing Time"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7830,400],"id":"a0d8dd96-9eea-4071-a049-c2e4d4840051","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"c0ae3185-d74f-4bf9-9d08-12f88633ba26","name":"runAt","value":"={{ $now.toISO(