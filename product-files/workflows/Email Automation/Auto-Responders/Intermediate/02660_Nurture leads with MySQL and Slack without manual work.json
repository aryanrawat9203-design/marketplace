{"name":"Nurture leads with MySQL and Slack without manual work","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[5],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"a4fa2cf6-61ca-4660-a422-478873f7a110","name":"Weekly Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"314f6f65-3122-42bb-b455-0e6b69b63aff","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"a15086be-0612-4e2c-9a5f-8ffabdbf75c8","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'from' on incoming email."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"c4d5a17b-d647-44ee-94fe-fc9d7e55653a","name":"Abort — Malformed Input"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each email 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.from) score += 20;\n  if (j.subject) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"8110b8a2-24fd-4e10-a84f-c606f8b24aa2","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"f79ef890-d910-45ee-8368-209028026eb7","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"238f70da-e9b2-4a21-845c-b8dc88b99299","leftValue":"={{ $json.score }}","rightValue":80,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"hot"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ab57c414-6baf-4e90-a075-ced6a1e15bf4","leftValue":"={{ $json.score }}","rightValue":50,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warm"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1026,400],"id":"73fa4fea-1c99-4a1a-9cd2-d76fab69256e","name":"Route by Heat"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"emails","cachedResultName":"emails"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[1350,-80],"id":"fbc48b85-71cb-4d52-9ad4-e934be2319f0","name":"Hot → MySQL + Instant Ping","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🔥 New hot lead {{ $json.email }} → {{ $json.owner }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1998,-80],"id":"97d88399-306a-4bc7-beaf-164369476895","name":"Notify Assigned Owner","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=Thanks for your interest — here's a quick-start guide.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2322,400],"id":"a6d92fbc-aab7-4754-bea4-e855b456f1a8","name":"Warm → Drip via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,880],"id":"f66a3a10-45d7-4890-8514-bf6f12317694","name":"Cold → Park in Nurture List","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3618,400],"id":"748c6a49-b497-41ad-97ce-140f9b379683","name":"Combine Lead Paths"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4914,400],"id":"047c747b-0f92-425d-b010-43d336decfb1","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"f7984816-bfc0-4779-9aab-30cd982c4905","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"4abc6339-d222-49c3-a2e3-57dcf52ac131","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"0f99c8f6-64a2-4d24-a43b-290a5a00dcee","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5562,400],"id":"276335ca-b952-40d0-a1ff-6e976091dd9a","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5886,400],"id":"9ade0556-8595-466a-890c-ed07161e2b82","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6210,400],"id":"8bbbcc8e-9bf2-4f25-a05c-f09ba23bbfcb","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6534,400],"id":"b9694d10-4ca6-46e7-b94f-294c638c3f9b","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"a1c579b8-2936-4686-92b9-3ba29645b5c5","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e7c5e2f0-aa05-4ebe-8a80-ef870daf6b17","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"b334be91-f18f-40c9-b45d-7ee05fca3c6c","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"8f2d0223-6662-408e-9b62-0322a7e11a19","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7182,400],"id":"c44f7a06-2810-499b-ba01-d3329aaad32e","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=✅ Nurture leads with MySQL and Slack without manual work — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7506,400],"id":"73ff5075-749c-48b9-85bf-58513f6d42a7","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"bf38bbaf-93c9-47ef-9474-8140ed5e18e5","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"640a9aba-f15b-4a62-aa43-04cdf2e2dc28","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e45f3a59-53e0-4ace-a5ac-c27c7ff6c20f","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,1420],"id":"94527266-9c20-487b-9c48-a450a691d016","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7182,1420],"id":"c03639fa-9001-49e2-9f1f-18ed3ffb797c","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7506,1420],"id":"5451fdb8-19a1-4ec4-818b-125b1e79d201","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"fecbe71b-ed2b-fdfd-5521-1e7ec1db8880","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.from }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Score the Lead · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"035a8082-2877-b7aa-388c-6c2e0893df06","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"001320ea-44f3-15c4-9e88-192379ba3c1a","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Score the Lead\n\nCustom JavaScript: Score each email 0-100 from simple heuristics\n\nNext: Assign Round-Robin Owner","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"558c59bc-53d8-59fd-58c6-7f6933e93b00","name":"Note: Score the Lead"},{"parameters":{"content":"### Assign Round-Robin Owner\n\nCustom JavaScript: Round-robin owner assignment\n\nNext: Route by Heat","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"f6c30013-1149-e352-dc8b-5d84da5dfebb","name":"Note: Assign Round-Robin Owner"},{"parameters":{"content":"### Route by Heat\n\nRoutes each item to one of 3 lanes: hot, warm + fallback.\n\nPorts: ①→ Hot → MySQL + Instant Ping · ②→ Warm → Drip via Slack · ③→ Cold → Park in Nurture List","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"2536e553-e686-c1ac-0d86-339f611d9af4","name":"Note: Route by Heat"},{"parameters":{"content":"### Hot → MySQL + Instant Ping\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Notify Assigned Owner · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,40],"id":"b175492c-02b5-25dd-7cd6-6f627d322b54","name":"Note: Hot → MySQL + Instant Ping"},{"parameters":{"content":"### Notify Assigned Owner\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,40],"id":"99755df8-e935-c737-7f37-b8231e19dea5","name":"Note: Notify Assigned Owner"},{"parameters":{"content":"### Warm → Drip via Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"067a17e4-8b0e-7092-365a-32764a050c90","name":"Note: Warm → Drip via Slack"},{"parameters":{"content":"### Cold → Park in Nurture List\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Combine Lead Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1000],"id":"8952aa3b-64b0-84b1-b95e-a7f8d053c899","name":"Note: Cold → Park in Nurture List"},{"parameters":{"content":"### Combine Lead Paths\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"f273d1bb-3db0-ea66-c5f9-4e92e03abf36","name":"Note: Combine Lead Paths"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"04c3dd65-bb07-7950-479c-65a696e33dc2","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"35e91a09-8a48-57a3-f8a5-5e5255daae3f","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"af0482f3-2140-0334-ed38-6b747c2826ab","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"6038b0c9-0674-31cc-a704-57a1d453c560","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"83e25d15-34ca-2b9c-8e36-0eeb7c595963","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"ec053ab5-b751-5310-9705-c5dcf0ca0d03","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"d317da79-f109-4497-9c27-7371e251c0b5","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"14c3b61b-f29c-6697-56a5-0b50d544519c","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"2ff5f784-35bf-ab3d-d93d-52832102a0b5","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,1540],"id":"64c3354c-d535-4355-61b7-869a3aae2d5e","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"114b42dc-f4c5-cdb1-6cb2-95ea54c5b1a2","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"be3ac941-6ef8-eb5f-531d-84b432938759","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Nurture leads with MySQL and Slack without manual work\n\n**Pattern:** Drip Sequence · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nNurture leads with MySQL and Slack without manual work. It runs automatically on a schedule.\n\n## Why it exists\nManual auto-responders is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Required Fields Present? → Score the Lead → Assign Round-Robin Owner → Route by Heat → Hot → MySQL + Instant Ping → Notify Assigned Owner → …\n\n## Use it for\n- Teams that want to drip sequence without manual effort\n- Anyone automating auto-responders in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Has retries and error handling built in\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; MySQL connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"44f62ec4-b87c-1436-7f4f-b253f177e9af","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"3f199a0c-2246-c798-679a-29bc948a93bc","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"f105e9e8-5fa4-592c-f60d-daa6fb06021b","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your auto-responders process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"383e1ca6-7345-970e-9637-acbcb33cbcea","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Score the Lead","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Score the Lead":{"main":[[{"node":"Assign Round-Robin Owner","type":"main","index":0}]]},"Assign Round-Robin Owner":{"main":[[{"node":"Route by Heat","type":"main","index":0}]]},"Hot → MySQL + Instant Ping":{"main":[[{"node":"Notify Assigned Owner","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Route by Heat":{"main":[[{"node":"Hot → MySQL + Instant Ping","type":"main","index":0}],[{"node":"Warm → Drip via Slack","type":"main","index":0}],[{"node":"Cold → Park in Nurture List","type":"main","index":0}]]},"Notify Assigned Owner":{"main":[[{"node":"Combine Lead Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Warm → Drip via Slack":{"main":[[{"node":"Combine Lead Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Cold → Park in Nurture List":{"main":[[{"node":"Combine Lead Paths","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Combine Lead Paths":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"9b3bd285-f7d5-48ed-8d4d-1de6bab65827","id":"FDX02660"}