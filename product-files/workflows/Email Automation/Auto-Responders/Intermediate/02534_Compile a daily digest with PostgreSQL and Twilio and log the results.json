          "conditions": [
            {
              "id": "f4fac1d1-24a9-42d8-b32d-989b64ea8c0d",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
