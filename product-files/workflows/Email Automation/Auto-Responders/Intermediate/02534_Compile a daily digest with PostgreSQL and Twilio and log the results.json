            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "e518a2f8-a703-4aba-aa60-3f4f793b5a82",
              "leftValue": "={{ $json.receivedAt || $now.toISO() }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
