<tr><td>${r.messageId ?? ''}</td><td>${r.from ?? ''}</td><td>${r.count ?? 1}</td></tr>`\n).join('');\nconst html = `<h2>Email digest</h2><table border=\"1\" cellpadding=\"4\">\n<tr><th>ID</th><th>from</th><th>Count</th></tr>${tr}</table>`;\nreturn [{ json: { html, rowCount: rows.length, generatedAt: new Date().toISOString() } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2322,400],"id":"be7ceb9d-8926-4548-a865-054afd911612","name":"Compose HTML Report"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"={{ $json.html }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2646,400],"id":"95bb833c-1a8e-4ba0-a86a-85b9cab68e96","name":"Send Report via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"messageId","value":"={{ $json.messageId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2970,400],"id":"44708a4e-34cd-447a-9096-39421c7c3f2f","name":"Save Execution Metadata"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[3294,400],"id":"27844e2c-e9fd-4b58-836c-be1fcc7c0ee4","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"bb71d9f6-4546-4230-bcb8-22f6d289121c","name":"pipeline","value":"Auto-Responders","type":"string"},{"id":"8fefba3c-618f-4c92-8d5b-0008ca957766","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"df1325ea-fec4-4e75-89bf-71bcef086ca2","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"messageId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3942,400],"id":"4b364586-b579-4490-b5e8-4e0dcef18dc5","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive