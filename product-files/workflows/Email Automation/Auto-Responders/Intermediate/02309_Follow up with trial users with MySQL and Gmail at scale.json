{"name":"Follow up with trial users with MySQL and Gmail at scale","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[5],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"b08c4b5c-a0cf-4f55-b8ee-a28202c4ff73","name":"Weekly Schedule"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[54,400],"id":"cf9d93dd-7e88-4bc1-831e-27888f54e2e7","name":"Read Pending Queue (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a5e5a72d-d26c-4042-89fb-8b2672bb32ce","leftValue":"={{ $json.messageId || $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[378,400],"id":"80611a91-c6fc-428a-895f-26d16f8dfdf6","name":"Keep Valid Emails"},{"parameters":{"batchSize":20,"options":{"reset":false}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[702,400],"id":"54dd7b95-3d4b-48ec-a5b4-bc603664c762","name":"Work in Batches"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/emails","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1026,880],"id":"5adc0444-3108-43f8-b4bb-2009f50b3e6b","name":"Process Batch Item","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"amount":2,"unit":"seconds"},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1674,880],"id":"2a51cbaa-b601-4