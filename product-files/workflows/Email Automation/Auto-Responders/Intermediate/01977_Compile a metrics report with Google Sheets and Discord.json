{"name":"Compile a metrics report with Google Sheets and Discord","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":9,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"b0a9a446-d429-40e3-886f-f1271a89588d","name":"Daily Schedule"},{"parameters":{"url":"https://news.example.com/feed.xml","options":{}},"type":"n8n-nodes-base.rssFeedRead","typeVersion":1.2,"position":[54,400],"id":"09af0019-b13f-40f8-87ce-4d070a39f5fe","name":"Read Source Feed","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.link }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"9c883c27-4ff9-4d28-bf13-c6c068811c05","name":"Skip Already-Seen Posts"},{"parameters":{"maxItems":5},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"8962531d-6fca-4264-8c54-3f0ef881f581","name":"Keep Top Stories"},{"parameters":{"promptType":"define","text":"=Rewrite this story as a punchy 3-sentence post for our audience:\n\n{{ $json.title }}\n{{ $json.contentSnippet || $json.content }}","options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"05186e1a-536d-4c59-ab15-d8fc8d1e4136","name":"Rewrite for Our Audience (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[1269,970],"id":"b2fd4b9e-17e2-49b1-bec9-a461c8d78688","name":"Google Gemini Chat Model"},{"parameters":{"authentication":"webhook","content":"={{ $json.text || $json.title }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[1593,160],"id":"a6e7e44a-b580-486f-8686-c2dc3682957b","name":"Publish to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"={{ $json.text || $json.title }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1917,640],"id":"ffe8a9d7-98a5-4720-aa1d-b1b56045fdce","name":"Publish to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2565,400],"id":"0147b13b-a835-4fdf-892c-cb2e89f8b037","name":"Confirm Cross-Post"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[3537,400],"id":"d4b50090-c992-4838-9a11-35dffee6e59e","name":"Log Published Posts (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per email (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.messageId, j.from].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3861,400],"id":"a0c5c92d-70e7-4d41-a2b5-c0879842c879","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4185,400],"id":"d48148c2-9d9d-4aaf-9984-770665710af8","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4509,400],"id":"da487384-4ab5-4f5f-81e5-63b2bbed203b","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4833,400],"id":"4915a4a5-9096-46c2-8818-74a7b0549c17","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.from }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5157,400],"id":"7e60fdc1-77ff-4725-be2a-907566d2648f","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"737e08d5-b139-4169-8fec-392c9c9691c0","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"7d9f7c9f-be7a-4379-bde9-6bac4e7c4249","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,400],"id":"7fe3738f-854e-4bd5-9e19-bbe7c08d96bd","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5805,400],"id":"207bd979-a7f1-455f-8008-9738227c41f4","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6129,400],"id":"3493868a-a5a4-46e7-9809-c79360f61270","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Emails"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[6453,400],"id":"1653c526-3298-4a2b-8210-50166501fbb8","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6777,400],"id":"c0ffa708-6473-4a77-84ef-b872fd3edb62","name":"Record Sub-workflow Result"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7101,400],"id":"8d2ffffe-654a-4055-9d4d-3282cfafa170","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7425,400],"id":"e5556f7e-c2bb-413e-974e-9dd9ec7dc3a6","name":"Compute Drift vs Snapshot"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d3e5a5ad-4e1e-4878-a4ae-8ed1ca5862af","leftValue":"={{ $json.from }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7749,400],"id":"97a43886-3624-484b-9f58-f76285b2e18c","name":"Guard Non-Empty from"},{"parameters":{"dataToSave":{"values":[{"key":"messageId","value":"={{ $json.messageId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8073,400],"id":"a70085ef-7e88-4b82-8728-83ad986b37ab","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[8397,400],"id":"38a4b58b-42c2-4781-8132-d4bda6146eb1","name":"Stamp Processing Time"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"receivedAt","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8721,400],"id":"8a3b90b9-6b6f-4d91-a019-53420523c858","name":"Sort Emails Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"a946db23-ab48-41c4-b103-db21f492c4bc","name":"pipeline","value":"Auto-Responders","type":"string"},{"id":"0d64b074-6c67-4013-8de3-fa8838d90aef","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9045,400],"id":"c27c7c80-79af-406f-8b28-03d32d7a8a52","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"7674c13e-c42d-45c8-888e-d9f7f4201598","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"00ea2446-3b8a-4e42-a623-3709c1aa50d5","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"0415fda8-4dec-452d-9895-f4421bc31dd9","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9369,400],"id":"6490fc9f-7316-42f8-8fc2-5412075173cc","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9693,400],"id":"9414b4c4-840f-40f5-8235-241b493dcf0e","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=✅ Compile a metrics report with Google Sheets and Discord — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[10017,400],"id":"15ad49f2-6498-4718-807a-941fbcfa69ca","name":"Send Summary to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"80092e9b-dc9d-4bb0-9016-f51806947037","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"0f2d38da-4a1b-4ddb-80e9-080bbf2db72f","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"818131f4-0b6d-4b18-bb55-c7a371d98108","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9369,1420],"id":"969eebfd-e71b-4c3a-b419-e0d930d646b2","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#inbox-ops","cachedResultName":"#inbox-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9693,1420],"id":"ab5d49b9-7258-4cb4-938a-68ccd726e301","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Email Database"},"title":"={{ $json.from || $json.messageId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[10017,1420],"id":"b8d64ad3-16de-4002-93f7-e9da8ab85a21","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 9:00. No input data; downstream nodes fetch what they need.\n\nNext: Read Source Feed","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"0223156c-a9eb-b21a-14df-9189c43f360c","name":"Note: Daily Schedule"},{"parameters":{"content":"### Read Source Feed\n\nPulls the RSS feed and emits one item per entry (title, link, content).\n\nPorts: ①→ Skip Already-Seen Posts · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"95248d56-d9f2-be1c-d148-c08f05c0b570","name":"Note: Read Source Feed"},{"parameters":{"content":"### Skip Already-Seen Posts\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Keep Top Stories","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"8e59e8b5-8f52-ca8c-9fe5-9fbf6a7d4f0f","name":"Note: Skip Already-Seen Posts"},{"parameters":{"content":"### Keep Top Stories\n\nCaps the stream at 5 items to protect downstream quotas.\n\nNext: Rewrite for Our Audience (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"565ef43b-b9c6-f34a-8d43-1a76c1ea11f4","name":"Note: Keep Top Stories"},{"parameters":{"content":"### Rewrite for Our Audience (AI)\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish to Discord, Publish to Slack · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"3839e303-dfc3-6c30-07cb-9852c6c357d5","name":"Note: Rewrite for Our Audience (AI)"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Rewrite for Our Audience (AI)** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"cff1c55d-ebdc-677d-d5d6-bbe4a05b0d6b","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Publish to Discord\n\ndiscord — `action` operation against the connected account.\n\nPorts: ①→ Confirm Cross-Post · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,280],"id":"3fca95cf-5a52-d044-fbfe-5fa256966bd8","name":"Note: Publish to Discord"},{"parameters":{"content":"### Publish to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Confirm Cross-Post · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,760],"id":"c845d83b-6040-ff04-7f93-24be93385510","name":"Note: Publish to Slack"},{"parameters":{"content":"### Confirm Cross-Post\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Log Published Posts (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"92b4f33f-21d2-2c3b-6d64-5705e019fbf6","name":"Note: Confirm Cross-Post"},{"parameters":{"content":"### Log Published Posts (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Fingerprint for Idempotency · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"6b03db5d-88bb-9336-1cf4-fc15f8fed7e7","name":"Note: Log Published Posts (Notion)"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per email (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"9d040b58-28cd-31cf-7ab4-e2cece1261f7","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"961e0f96-2cee-15cb-22a4-f5e3775b1693","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"dc719d5e-0882-b7fb-1a1a-14d0df0f3e63","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"6e6d0f8b-e859-13f7-f45d-5edafc9a37fc","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"5c3578a3-0c6f-17cc-0d2c-3a94de38e2ae","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"0cc99ed4-394f-0cb3-fa0a-6aaa05d91d4b","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"f2191494-0514-73c0-74c1-3c66dfde6a57","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Offload to Post-Process Sub-workflow · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"c268f635-5947-a7a8-26eb-4b8daa00d2d0","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"2608c4d8-45a7-50d0-935c-4514dd4a0fa1","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"fa43d64f-f015-c009-c016-539882174998","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"22909b35-4a5c-efb6-75e9-b911eb3082eb","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Guard Non-Empty from","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"c1b53ce5-1c84-09ba-59f1-2d001b218612","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Guard Non-Empty from\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"ea3fe204-f7ab-c930-3178-e08b1548c401","name":"Note: Guard Non-Empty from"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"2dfe1d83-3d55-8a1d-2587-b1f81944b252","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Sort Emails Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,520],"id":"d1c8a132-f425-13e7-baf8-a62502921bc2","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Sort Emails Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,520],"id":"96d80746-d0ea-f8a6-3c8b-1e4a2947c70c","name":"Note: Sort Emails Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,520],"id":"0ae1eac1-6ec1-a938-e57a-2e538c61df92","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9309,520],"id":"eb8fd80c-9282-67a2-40f0-5252bd047125","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Discord · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9633,520],"id":"f269c863-efc9-13ac-e0aa-78ff08ae6a6d","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Discord\n\ndiscord — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9957,520],"id":"9dd0273e-4c9e-dcaf-8ba5-5a06ae5b95d9","name":"Note: Send Summary to Discord"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9309,1540],"id":"c4849763-7e78-299d-5dea-f1934874d0dd","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9633,1540],"id":"74c826f9-1200-43bd-436b-f073afcb44ae","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9957,1540],"id":"9c07c68c-f68c-70d2-83b7-d22ef29c8cd7","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Compile a metrics report with Google Sheets and Discord\n\n**Pattern:** Scheduled Digest · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nCompile a metrics report with Google Sheets and Discord. It runs automatically on a schedule.\n\n## Why it exists\nManual auto-responders is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Read Source Feed → Skip Already-Seen Posts → Keep Top Stories → Rewrite for Our Audience (AI) → Publish to Discord → Confirm Cross-Post → …\n\n## Use it for\n- Teams that want to scheduled digest without manual effort\n- Anyone automating auto-responders in marketing\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Removes copy-paste errors\n- Improves response time\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Discord webhook URL; Google AI API key; Google OAuth2 / service account; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a29677a5-e556-2c22-5dfe-f23c8b2f4ae0","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"dc00a65c-e576-3754-6d15-895246dacff3","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"e63c1a3d-0ff3-745f-6db6-3686f733da1a","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"cfe6d584-8a24-4561-5eba-c1c6d930843f","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your auto-responders process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"832204d3-9cad-1d80-16e5-c31ce1304bfc","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Read Source Feed","type":"main","index":0}]]},"Read Source Feed":{"main":[[{"node":"Skip Already-Seen Posts","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Skip Already-Seen Posts":{"main":[[{"node":"Keep Top Stories","type":"main","index":0}]]},"Keep Top Stories":{"main":[[{"node":"Rewrite for Our Audience (AI)","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Rewrite for Our Audience (AI)","type":"ai_languageModel","index":0}]]},"Rewrite for Our Audience (AI)":{"main":[[{"node":"Publish to Discord","type":"main","index":0},{"node":"Publish to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Discord":{"main":[[{"node":"Confirm Cross-Post","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish to Slack":{"main":[[{"node":"Confirm Cross-Post","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Confirm Cross-Post":{"main":[[{"node":"Log Published Posts (Notion)","type":"main","index":0}]]},"Log Published Posts (Notion)":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Guard Non-Empty from","type":"main","index":0}]]},"Guard Non-Empty from":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Sort Emails Newest First","type":"main","index":0}]]},"Sort Emails Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Discord","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Discord":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"ef43bcb0-5411-43d0-ab02-d5fe6ff020b3","id":"FDX01977"}