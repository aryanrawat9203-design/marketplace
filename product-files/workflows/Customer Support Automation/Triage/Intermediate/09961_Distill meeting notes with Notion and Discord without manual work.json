{"name":"Distill meeting notes with Notion and Discord without manual work","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09961-ticket","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"8257c0f7-9aa7-49b5-806c-cbabfb9f2cbf","name":"Receive Inbound Webhook","webhookId":"6a6ce9d3-cb85-4d1f-9381-5cb78f2b3422"},{"parameters":{"assignments":{"assignments":[{"id":"051eabe4-107d-41a1-a6d5-6098bd13226f","name":"ticketId","value":"={{ $json.ticketId || $json.id || $execution.id }}","type":"string"},{"id":"7cceefda-4518-4ffb-9583-3e15cc1d12bc","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"c3933608-7d41-4095-b0cf-983c10ffa8f0","name":"Stamp & Shape Ticket"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ad6b1c55-3204-4e39-8120-c17f63908996","leftValue":"={{ $json.ticketId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"ab35196f-9bb6-4d66-a7ae-d6af2fbb9fa8","name":"Payload Valid?"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Ticket Database"},"title":"={{ $json.subject || $json.ticketId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[378,910],"id":"31630b79-1a70-44ee-8198-8f7a31f43be0","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"inputText":"={{ $json.subject || JSON.stringify($json) }}","categories":{"categories":[{"category":"Urgent","description":"Tickets that are urgent for the triage team."},{"category":"Routine","description":"Tickets that are routine for the triage team."},{"category":"FYI","description":"Tickets that are fyi for the tri