{"name":"Collect NPS responses with MySQL and Jira hands-free","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[5],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"fe3a2450-9479-43bf-824f-97fcf7fc8483","name":"Weekly Schedule"},{"parameters":{"operation":"select","table":{"__rl":true,"mode":"name","value":"tickets","cachedResultName":"tickets"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[54,130],"id":"24765b0e-b93b-4dcc-922c-9dd53c6432ff","name":"Gather from MySQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"select","table":{"__rl":true,"mode":"name","value":"tickets","cachedResultName":"tickets"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[378,640],"id":"9649ad8a-6c7b-43ed-a149-aa60875d10c6","name":"Gather from MySQL 2","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1026,400],"id":"a51b07e7-6ff3-4f44-a6aa-1d936b516bf7","name":"Blend Sources"},{"parameters":{"fieldsToSummarize":{"values":[{"aggregation":"count","field":"ticketId"}]},"fieldsToSplitBy":"priority","options":{}},"type":"n8n-nodes-base.summarize","typeVersion":1.1,"position":[1998,400],"id":"5c9f5595-0b37-432c-9494-db48ed08b05c","name":"Roll Up KPIs"},{"parameters":{"promptType":"define","text":"=Summarize these KPIs for leadership in 5 bullet points:\n{{ JSON.stringify($json) }}","options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[2322,400],"id":"0d4849e5-548e-408f-97bd-92058503cd52","name":"Write Executive Summary (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[2565,970],"id":"7f9efe88-7ca2-40fa-b186-bbe4aea57d45","name":"Anthropic Chat Model"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build an HTML digest table from the aggregated rows\nconst rows = $input.all().map(i => i.json);\nconst tr = rows.map(r =>\n  `<tr><td>${r.ticketId ?? ''}</td><td>${r.subject ?? ''}</td><td>${r.count ?? 1}</td></tr>`\n).join('');\nconst html = `<h2>Ticket digest</h2><table border=\"1\" cellpadding=\"4\">\n<tr><th>ID</th><th>subject</th><th>Count</th></tr>${tr}</table>`;\nreturn [{ json: { html, rowCount: rows.length, generatedAt: new Date().toISOString() } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2889,400],"id":"7cfe708a-dca4-47e9-b92e-dec3ff074a3e","name":"Compose HTML Report"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"={{ $json.html }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[3213,400],"id":"d9c191e6-6698-486c-8430-092964f4b089","name":"Send Report via Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3537,400],"id":"8658f157-266c-4b0c-8235-5b9da4e7fb36","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"18d65eee-6c63-483c-9e82-6f79ce861fd1","leftValue":"={{ $json.subject }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3861,400],"id":"2a26dc39-1589-4ad3-bd2e-7f3a193d2c6e","name":"Guard Non-Empty subject"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"customerEmail","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[4185,400],"id":"8438f3fe-5288-4f95-a164-72a0ae42d469","name":"Sort Tickets Newest First"},{"parameters":{"dataToSave":{"values":[{"key":"ticketId","value":"={{ $json.ticketId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4509,400],"id":"2606605c-5a5a-4d40-af8a-3bab4b420ab7","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"60b2fa29-1544-4d72-ae3f-e42ec88bf7eb","name":"pipeline","value":"Triage","type":"string"},{"id":"bdb47cea-e327-4a41-9485-eca0ce5eb127","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4833,400],"id":"90036042-25cb-4c97-aa45-b2f7d838c4a4","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"1f8dc5fb-f37b-4449-884a-b410b8a96ac6","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"acc9c372-9f8b-4292-8ff9-2dd054b3a273","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"999fd2c4-9642-4b7a-bdef-20eaba71dbf0","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,400],"id":"62043122-9dba-4b62-a815-5de23d557258","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"tickets","cachedResultName":"tickets"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[5481,400],"id":"2b41fc42-8d63-4f45-bc82-4c51b9ee2929","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#support","cachedResultName":"#support"},"text":"=✅ Collect NPS responses with MySQL and Jira hands-free — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,400],"id":"426bb188-a276-44ed-8b62-8cab3dd4f556","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"78f00f4e-5462-4a5a-8cd1-61be335c93f7","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"c9cb21ab-38a8-453b-a1b0-1277a1eef6ec","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"d14be379-f58a-4c89-a48c-87e268f5c5bc","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,1420],"id":"c3d5c7da-c2ff-43f4-b945-e5aa7cc88f5c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#support","cachedResultName":"#support"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5481,1420],"id":"acb98ac1-15de-4070-8d49-0926c4881c08","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Gather from MySQL","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"e9c496e5-b1c8-1fd3-9a1e-f74993a9dfbe","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Gather from MySQL\n\nmySql — `select` operation against the connected account.\n\nPorts: ①→ Blend Sources · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"864ca5c0-01f1-3de8-4905-800c0b2dbffa","name":"Note: Gather from MySQL"},{"parameters":{"content":"### Gather from MySQL 2\n\nmySql — `select` operation against the connected account.\n\nPorts: ①→ Blend Sources · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,760],"id":"ca2c87cf-02a9-6333-da42-e03fd73a44ae","name":"Note: Gather from MySQL 2"},{"parameters":{"content":"### Blend Sources\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Roll Up KPIs","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"4d48fab4-244a-3a3a-76e5-b758e1d3a14c","name":"Note: Blend Sources"},{"parameters":{"content":"### Roll Up KPIs\n\nGroup-by + aggregate (like a pivot table) — turns raw rows into KPI numbers.\n\nNext: Write Executive Summary (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"1975a681-2dea-d090-b693-228b37a735d4","name":"Note: Roll Up KPIs"},{"parameters":{"content":"### Write Executive Summary (AI)\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Compose HTML Report · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"ab8fdcf8-38eb-7803-e232-73283e0783cd","name":"Note: Write Executive Summary (AI)"},{"parameters":{"content":"### Anthropic Chat Model\n\nChat model powering the AI step (model: `claude-sonnet-4-5-20250929`). Swap providers here without rewiring.\n\nFeeds **Write Executive Summary (AI)** as `languageModel`\n\n🔑 Anthropic API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,1090],"id":"55b19273-f117-9b73-9672-362a798bc5d7","name":"Note: Anthropic Chat Model"},{"parameters":{"content":"### Compose HTML Report\n\nCustom JavaScript: Build an HTML digest table from the aggregated rows\n\nNext: Send Report via Telegram","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"26e9d1fe-58c2-67a4-3dd6-9888946dd0ab","name":"Note: Compose HTML Report"},{"parameters":{"content":"### Send Report via Telegram\n\ntelegram — `action` operation against the connected account.\n\nPorts: ①→ Stamp Processing Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"98561e57-9a81-943a-bbdb-e9d1625fb274","name":"Note: Send Report via Telegram"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Guard Non-Empty subject","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"baf1102e-5794-ce26-7712-94be9dc9aac2","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Guard Non-Empty subject\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Sort Tickets Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"7ba41b87-397f-4491-a3f6-e3263401b536","name":"Note: Guard Non-Empty subject"},{"parameters":{"content":"### Sort Tickets Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"3be310bd-c23e-79bf-327e-100df297c847","name":"Note: Sort Tickets Newest First"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"a3c43b0a-8fe0-a642-38cf-60c22b370ae4","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"7d48cac5-3a59-fcdd-ff03-ad1d46fe4584","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"6e98ab31-cef0-8fc3-89ac-67318b30293d","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"bcd1912f-5654-f283-a713-affb4cab9084","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"807ccbbf-1b5c-7d47-eaf0-d09d38c5ded1","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"fa3ea29e-161e-72ff-2e80-d2d73337f650","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"51fdb2bb-35b2-1439-bfd5-594dcec58726","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Collect NPS responses with MySQL and Jira hands-free\n\n**Pattern:** Survey & Feedback · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nCollect NPS responses with MySQL and Jira hands-free. It runs automatically on a schedule.\n\n## Why it exists\nManual triage is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Gather from MySQL → Blend Sources → Roll Up KPIs → Write Executive Summary (AI) → Compose HTML Report → Send Report via Telegram → …\n\n## Use it for\n- Teams that want to survey & feedback without manual effort\n- Anyone automating triage in customer support\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Standardizes the process every time\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: Anthropic API key; MySQL connection; Slack OAuth2; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"689ee57a-c178-7013-64dd-c1991e64f677","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"f39c579a-879f-261e-0ae3-e6b79fa991aa","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"e5830808-2486-fcb4-c18d-2e7e888ef275","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your triage process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"93acb123-b87c-c5b0-c5b2-3eedb74a0d05","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Gather from MySQL","type":"main","index":0},{"node":"Gather from MySQL 2","type":"main","index":0}]]},"Gather from MySQL":{"main":[[{"node":"Blend Sources","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Gather from MySQL 2":{"main":[[{"node":"Blend Sources","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Blend Sources":{"main":[[{"node":"Roll Up KPIs","type":"main","index":0}]]},"Roll Up KPIs":{"main":[[{"node":"Write Executive Summary (AI)","type":"main","index":0}]]},"Anthropic Chat Model":{"ai_languageModel":[[{"node":"Write Executive Summary (AI)","type":"ai_languageModel","index":0}]]},"Write Executive Summary (AI)":{"main":[[{"node":"Compose HTML Report","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compose HTML Report":{"main":[[{"node":"Send Report via Telegram","type":"main","index":0}]]},"Send Report via Telegram":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Guard Non-Empty subject","type":"main","index":0}]]},"Guard Non-Empty subject":{"main":[[{"node":"Sort Tickets Newest First","type":"main","index":0}]]},"Sort Tickets Newest First":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"b180aebd-5c5a-4724-92f2-538926c3772b","id":"FDX10011"}