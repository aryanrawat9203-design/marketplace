{"name":"Analyze NPS responses with Google Sheets and Jira without manual work","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":2}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"f989b572-6f83-40fe-9b39-2885d47e094c","name":"Hourly Schedule"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming ticket records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    ticketId: String(j.ticketId ?? j.id ?? '').trim(),\n    subject: typeof j.subject === 'string' ? j.subject.trim() : j.subject ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"0c435953-afc0-4d30-8af9-c337fe71fa44","name":"Normalize Ticket Payload"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Score each ticket 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.subject) score += 20;\n  if (j.priority) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"17d7150d-feb9-4799-941d-85fc233a1044","name":"Score the Lead"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"2de18fd3-a077-4c50-8e00-dd037a78bd26","name":"Assign Round-Robin Owner"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"bce91651-076e-4b07-aa9f