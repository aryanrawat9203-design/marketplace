nError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[945,970],"id":"6bdc1db0-92ea-48ce-a9a6-33cd30afaed2","name":"OpenRouter Chat Model"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#support","cachedResultName":"#support"},"text":"=😠 Negative ticket: {{ $json.subject }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1269,-80],"id":"29195adb-825b-41b5-ae11-34a91bb810bb","name":"Escalate Negative — Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"ticket","operation":"create","description":"={{ $json.subject }}","additionalFields":{}},"type":"n8n-nodes-base.zendesk","typeVersion":1,"position":[1917,-80],"id":"13609145-8ada-4fd3-88fa-b05b38e5c653","name":"Open Zendesk Ticket","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Ticket Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2241,400],"id":"a71b4dc3-66c3-4d4e-8867-e98d516cc1b2","name":"Log Neutral Feedback","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=💚 Positive feedback received: {{ $json.subject }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[2565,880],"id":"3e6e9a1d-cfe3-4963-9986-783e32f86bbd","name":"Thank the Sender","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-node