    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming ticket records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    ticketId: String(j.ticketId ?? j.id ?? '').trim(),\n    subject: typeof j.subject === 'string' ? j.subject.trim() : j.subject ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40,
        400
      ],
      "id": "0ccf2391-e26c-4545-b856-e120c4cef700",
      "name": "Normalize Ticket Payload"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Score each ticket 0-100 from simple heuristics\nreturn $input.all().map(item => {\n  const j = item.json;\n  let score = 50;\n  if (j.subject) score += 20;\n  if (j.priority) score += 15;\n  if ((j.source || '') === 'referral') score += 15;\n  return { json: { ...j, score: Math.min(100, score) } };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        400
      ],
      "id": "c65a3688-5ab8-46fd-b66a-0b5ef804c007",
      "name": "Score the Lead"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Round-robin owner assignment\nconst owners = ['ava@company.com', 'liam@company.com', 'mia@company.com'];\nreturn $input.all().map((item, i) => ({\n  json: { ...item.json, owner: owners[i % owners.length] },\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        400
      ],
      "id": "89676166-3a29-45fb-a72a-3637d265eb2c",
      "name": "Assign Round-Robin Owner"
    },
