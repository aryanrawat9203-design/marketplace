ypeVersion":2.2,"position":[4833,400],"id":"fc048344-bce6-4946-8a87-515b8c71b032","name":"Guard Non-Empty subject"},{"parameters":{"assignments":{"assignments":[{"id":"b4b7322e-9c49-4413-9943-fa5065ecd820","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"2b9b9081-993f-4ecd-baf5-9131d7400500","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"42436268-5bf4-4f66-8065-3339766abd42","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,400],"id":"ff7fd5c4-96ff-4eb5-9e89-ed9a31b500f7","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Ticket Database"},"title":"={{ $json.subject || $json.ticketId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5481,400],"id":"c4a1a1c4-4307-491e-8288-9f904cf4573c","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Analyze customer feedback with Notion and Trello — run completed at {{ $now.t","message":"=✅ Analyze customer feedback with Notion and Trello — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[5805,400],"id":"088cce0d-26f1-4107-bc57-691dc552dc38","name":"Send Summary to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"09bfe77d-e673-4290-b43d-dcbe5c1dd187","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"be97dea8-18d2-4c0d-955f-17753a0e7b63","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"e0b9c6ba-4380-4315-9dc2-a975e0516b34","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,1420],"id":"d9941605-d706-4503-afa7-6210ccafc098","name":"Capture Failure Context"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[5481,1420],"id":"737bba1c-85a4-4216-978c-4ce840f66ff5","name":"Escalate Failure to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 6:00. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Tickets","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"9e552f1c-f933-7892-fd55-c36600c85d21","name":"Note: Daily Schedule"},{"parameters":{"content":"### Keep Valid Tickets\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Detect Sentiment","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"59266af7-89e4-fe0c-235b-7eb54af8549e","name":"Note: Keep Valid Tickets"},{"parameters":{"content":"### Detect Sentiment\n\nScores the text's sentiment; ports fire positive / neutral / negative.\n\nPorts: ①→ Escalate Negative — Gmail · ②→ Log Neutral Feedback, Capture Failure Context · ③→ Thank the Sender\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"25c19d5a-b308-57e4-bc41-e00c08d2a936","name":"Note: Detect Sentiment"},{"parameters":{"content":"### Anthropic Chat Model\n\nChat model powering the AI step (model: `claude-sonnet-4-5-20250929`). Swap providers here without rewiring.\n\nFeeds **Detect Sentiment** as `languageModel`\n\n🔑 Anthropic API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"a4bc2c0f-5672-fcdf-eae1-eeeeb383f355","name":"Note: Anthropic Chat Model"},{"parameters":{"content":"### Escalate Negative — Gmail\n\ngmail — `action` operation against the connected account.\n\nPorts: ①→ Collect All Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,40],"id":"5e08c00d-203a-18c8-8638-27829ba97c2f","name":"Note: Escalate Negative — Gmail"},{"parameters":{"content":"### Log Neutral Feedback\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Collect All Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,520],"id":"f67a4eab-4dec-2b53-7bab-80adeb03ddaf","name":"Note: Log Neutral Feedback"},{"parameters":{"content":"### Thank the Sender\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Collect All Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,1000],"id":"de1f6793-542d-6e3b-6446-748e5302525d","name":"Note: Thank the Sender"},{"parameters":{"content":"### Collect All Outcomes\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"8e5b8d05-4533-c04a-e04d-66e9f59041f6","name":"Note: Collect All Outcomes"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Sort Tickets Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"f1998b93-cc6e-be07-bc6c-ce9751f68e7d","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Sort Tickets Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"77dfd98f-2b1b-ef58-98ba-fd6b494fe9ae","name":"Note: Sort Tickets Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Guard Non-Empty subject","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"f24fece4-2b20-45ea-ddd5-f0a888fe6e05","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Guard Non-Empty subject\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"952c8044-6f7e-cbea-692c-30f07aef3ba9","name":"Note: Guard Non-Empty subject"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"f99418b6-7e79-3794-6cfc-673412e9d403","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Gmail · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"680773d3-bf78-da83-16ee-1ff7abd4f40d","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"563cee06-0f05-3061-7c13-d90a207f3166","name":"Note: Send Summary to Gmail"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Gmail","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"8bc34b0b-6cce-cccd-b0d8-70711a7e10b3","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"ec70cb78-c2c4-77e6-082b-ce2c959905f1","name":"Note: Escalate Failure to Gmail"},{"parameters":{"content":"# Analyze customer feedback with Notion and Trello\n\n**Pattern:** Survey & Feedback · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nAnalyze customer feedback with Notion and Trello. It runs automatically on a schedule.\n\n## Why it exists\nManual feedback is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Keep Valid Tickets → Detect Sentiment → Escalate Negative — Gmail → Collect All Outcomes → Stamp Processing Time → Sort Tickets Newest First → …\n\n## Use it for\n- Teams that want to survey & feedback without manual effort\n- Anyone automating feedback in customer support\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Saves hours of manual work each week\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Anthropic API key; Google OAuth2; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"a2e574b6-0cc1-8cb8-470d-f62154d32075","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"cbac1662-b0aa-c2f0-0687-ad899c8feedf","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"1031a604-a570-fca8-2f56-4aa4cd73108a","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your feedback process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"eac6a5d3-5cb7-3575-09f7-26df85ef308c","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Keep Valid Tickets","type":"main","index":0}]]},"Keep Valid Tickets":{"main":[[{"node":"Detect Sentiment","type":"main","index":0}]]},"Anthropic Chat Model":{"ai_languageModel":[[{"node":"Detect Sentiment","type":"ai_languageModel","index":0}]]},"Detect Sentiment":{"main":[[{"node":"Escalate Negative — Gmail","type":"main","index":0}],[{"node":"Log Neutral Feedback","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Thank the Sender","type":"main","index":0}]]},"Escalate Negative — Gmail":{"main":[[{"node":"Collect All Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Neutral Feedback":{"main":[[{"node":"Collect All Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Thank the Sender":{"main":[[{"node":"Collect All Outcomes","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Collect All Outcomes":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Sort Tickets Newest First","type":"main","index":0}]]},"Sort Tickets Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Guard Non-Empty subject","type":"main","index":0}]]},"Guard Non-Empty subject":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Gmail","type":"main","index":0}]]},"Send Summary to Gmail":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"953b361d-dadb-4833-87e0-06e5ab1aaf13","id":"FDX09923"}