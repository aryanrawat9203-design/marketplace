{"name":"Route requests with Telegram and Airtable end to end","nodes":[{"parameters":{"formTitle":"Route requests with Telegram and Airtable end to end","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Role","requiredField":false},{"fieldLabel":"Stage","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"6f56d551-b4b1-4d59-bb97-146b3b4c9aa5","name":"New Candidate Form Submission","webhookId":"16f3c659-f0db-4b3c-8611-cce4394007b7"},{"parameters":{"assignments":{"assignments":[{"id":"1a8bbb45-5016-4dbf-89ca-85bd9acefd7f","name":"candidateId","value":"={{ $json.candidateId || $json.id || $execution.id }}","type":"string"},{"id":"46bb59ff-8bad-4e90-91c4-bccea8d7b774","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"c3129231-c883-4728-a8bd-57e95650b95a","name":"Stamp & Shape Candidate"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8a6b4245-d968-4397-892b-9c0b0301ffeb","leftValue":"={{ $json.candidateId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"f2df1f75-9ca9-408a-8715-eec396cae936","name":"Payload Valid?"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"HR & Recruitment Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidates"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[378,910],"id":"6fbae806-a32c-4288-984a-e213bfeaf1b0","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d55aa962-680c-4dc4-97c8-660e0c8fcd85","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"auto-approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"auto-approve"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e52f5444-21e4-4a2e-ab48-062b7f7e68b2","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"needs-review","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"needs-review"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"84bcf9c2-6e78-40bc-a7e7-52ba8ed7b5f2","name":"Route by Work Type"},{"parameters":{"operation":"upsert","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"HR & Recruitment Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidates"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["candidateId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[1026,130],"id":"0842406d-0b74-4c18-976e-3c9f382b174f","name":"Process 'auto-approve' → Airtable","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🚀 Priority candidate handled: {{ $json.candidateId }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[1350,640],"id":"9e3372e6-a7b4-4689-b803-3f186e2b1a8b","name":"Fast-Track 'needs-review' + Alert","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"HR & Recruitment Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidates"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[1674,1150],"id":"f12a5796-49a0-485b-bf93-15552996329f","name":"Hold Unknown Types (DLQ)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"7699c18f-bc49-423b-bb1e-2f0d64ff2de8","name":"Merge Routed Work"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3294,400],"id":"f1427370-5af4-4e26-b62a-ce8ad81b42f8","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"HR & Recruitment Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidates"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3618,400],"id":"d149d1e4-669f-4467-8d1e-b39fbf3b1200","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3942,400],"id":"48a3cf34-10d3-42cb-b5b2-77a7a7f0bcc5","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a8d1e439-36a6-4f8c-a32d-80827c9a2120","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"90b28634-093e-4457-b00f-33d6cf24352f","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4266,400],"id":"cf91b667-0862-4724-9167-181ae8b3b691","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"search","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"HR & Recruitment Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidates"},"filterByFormula":"={LastModified} > DATEADD(NOW(), -1, 'days')","options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[4590,400],"id":"7d0d26df-219b-450e-9c3b-a7a0279343f6","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"b561702f-6007-409f-a037-b9991a1597fd","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5238,400],"id":"93176034-365f-4169-8b9e-15cff2ba546f","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"56fe6627-0d9c-4978-b60a-20da1f318e5e","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"c2af45c6-4c98-4355-9911-199f859602b7","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"244d8bd5-180e-4ed5-a996-f7321dc8aae2","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"c6b6a634-e4df-4344-b2b9-fe9178369f26","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,400],"id":"dfa34206-83dd-494d-8486-95235576b728","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidate Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,400],"id":"056383c8-7e57-48ae-afec-35617c3dd398","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Route requests with Telegram and Airtable end to end — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[6534,400],"id":"ed837059-c735-41a5-95be-73f9000387fd","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"352ba270-3a7e-4487-8c33-33302428eedf","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"11778bed-2a8d-4b44-9b75-58dd1553afd3","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"13d076ae-bfd7-4237-9139-9b91197ad2bc","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5886,1420],"id":"265b4804-d476-497f-826d-d10452c75aaf","name":"Capture Failure Context"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[6210,1420],"id":"34989561-c62c-4319-98ad-078478497992","name":"Escalate Failure to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"HR & Recruitment Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidates"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[6534,1420],"id":"0610f7d6-4292-4331-aebb-c0e3d3fce66e","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### New Candidate Form Submission\n\nServes an n8n-hosted form (Email, Role, Stage). Each submission becomes one execution.\n\nNext: Stamp & Shape Candidate","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"2aa33237-60ac-2c18-2925-4269459b389f","name":"Note: New Candidate Form Submission"},{"parameters":{"content":"### Stamp & Shape Candidate\n\nShapes the item: writes `candidateId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"444f2407-be9c-b32d-74bb-ea9f2e3a4346","name":"Note: Stamp & Shape Candidate"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.candidateId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Route by Work Type · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"bf5671f3-272f-c907-dbb1-e69b24b237f9","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\nCreates a new record in Airtable's 'Candidates' table.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"c943b99f-a7fb-42e3-d775-3cd7f616cc7c","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Route by Work Type\n\nRoutes each item to one of 3 lanes: auto-approve, needs-review + fallback.\n\nPorts: ①→ Process 'auto-approve' → Airtable · ②→ Fast-Track 'needs-review' + Alert · ③→ Hold Unknown Types (DLQ)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"b88b3878-9dce-1d6c-d1c3-9518db3c1e56","name":"Note: Route by Work Type"},{"parameters":{"content":"### Process 'auto-approve' → Airtable\n\nUpserts into Airtable's 'Candidates' table, matched on `candidateId` — safe to re-run without creating duplicates.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,250],"id":"618ff63e-a7cf-cbbf-0c8c-e8296fcc4db4","name":"Note: Process 'auto-approve' → Airtable"},{"parameters":{"content":"### Fast-Track 'needs-review' + Alert\n\nSends a Telegram message to the configured chat — the same bot can also receive replies, so this doubles as a two-way ops channel.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,760],"id":"44db4b04-c328-ff35-5dad-ac580b473c39","name":"Note: Fast-Track 'needs-review' + Alert"},{"parameters":{"content":"### Hold Unknown Types (DLQ)\n\nCreates a new record in Airtable's 'Candidates' table.\n\nPorts: ①→ Merge Routed Work · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1270],"id":"423bdb3d-87bd-bed7-47ff-5a2624827e11","name":"Note: Hold Unknown Types (DLQ)"},{"parameters":{"content":"### Merge Routed Work\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"1229847f-941d-fe6a-f22c-cafb40909a59","name":"Note: Merge Routed Work"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"397845c3-383b-7597-af00-242e63d60552","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nCreates a new record in Airtable's 'Candidates' table.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"bae95535-5f8c-3c6c-006a-3319e1a1f4ee","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"1c770c28-48be-ab93-d08f-cf1844475210","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"85fe5569-de0b-b06d-8e15-bba9fa1f98df","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\nSearches Airtable's 'Candidates' table by formula (`={LastModified} > DATEADD(NOW(), -1, 'days')`) for records the pipeline hasn't handled yet.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"ed9d9b4e-40f5-0c14-737b-e1f0906e9294","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"84c9ef88-59ad-1cbc-d7c1-53b30f083ba8","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"446d4fea-31bb-df11-ca2a-b893c77f8dd5","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"3898d391-cf22-751c-d1c9-ff105e1727e9","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"8b8567e7-02cd-75b0-55dc-bc8641158e51","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\nAppends a new row to 'Candidate Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Send Summary to Telegram · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"12444003-81e5-699b-7165-0acb3c6672f5","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Telegram\n\nSends a Telegram message to the configured chat — the same bot can also receive replies, so this doubles as a two-way ops channel.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"6145774c-d76f-d167-01c8-c927b9f6829b","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Telegram","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"20924f44-c281-644a-de26-efa200dc4db9","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Telegram\n\nSends a Telegram message to the configured chat — the same bot can also receive replies, so this doubles as a two-way ops channel.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Telegram bot token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"c42e5275-73a2-7528-4e20-34e7c42c149d","name":"Note: Escalate Failure to Telegram"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nCreates a new record in Airtable's 'Candidates' table.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,1540],"id":"30cd9bcc-031a-69c9-75b6-75b2a6c310c4","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Route requests with Telegram and Airtable end to end\n\n**Pattern:** Approval Workflow · **Level:** Production · **Trigger:** Form\n\n## What it does\nRoute requests with Telegram and Airtable end to end. It starts from a hosted form submission.\n\n## Why it exists\nManual time off is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nNew Candidate Form Submission → Stamp & Shape Candidate → Payload Valid? → Route by Work Type → Process 'auto-approve' → Airtable → Merge Routed Work → Serialize Run Output (CSV) → …\n\n## Use it for\n- Teams that want to approval workflow without manual effort\n- Anyone automating time off in human resources\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Runs 24/7 in the background\n- Standardizes the process every time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2 / service account; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"efac9f30-473e-d455-f4cf-7b315bc24386","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nUnrecognized work types are parked in a dead-letter lane instead of erroring the whole run or silently dropping the item — new event kinds will show up eventually, and this is where you'd notice one without losing it. One kind is deliberately routed through a sub-workflow to show how heavier per-type logic can be extracted without touching this router at all.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"2bb8d7de-4ba0-8aca-bde8-7790ae5be018","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAlready production-grade — deepen your understanding:\n\n1. Send a work-type value that matches no switch rule and confirm it lands in the dead-letter branch.\n2. Add a new work type and its own handling branch.\n3. Replace the direct-write branch with a sub-workflow call, matching the pattern already used for the first kind.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"82ce2d8f-ab99-1031-ac8c-88b57cbf2cba","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"cdcc09b0-35a8-6957-71b7-b60d8e35b95c","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your time off process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"cc5ef7f0-d94c-0b87-08af-1724cbb9b49f","name":"🛠 Customize me"}],"connections":{"New Candidate Form Submission":{"main":[[{"node":"Stamp & Shape Candidate","type":"main","index":0}]]},"Stamp & Shape Candidate":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Route by Work Type","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Route by Work Type":{"main":[[{"node":"Process 'auto-approve' → Airtable","type":"main","index":0}],[{"node":"Fast-Track 'needs-review' + Alert","type":"main","index":0}],[{"node":"Hold Unknown Types (DLQ)","type":"main","index":0}]]},"Process 'auto-approve' → Airtable":{"main":[[{"node":"Merge Routed Work","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fast-Track 'needs-review' + Alert":{"main":[[{"node":"Merge Routed Work","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold Unknown Types (DLQ)":{"main":[[{"node":"Merge Routed Work","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Routed Work":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Telegram","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Telegram","type":"main","index":0}]]},"Escalate Failure to Telegram":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Telegram":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"New Candidate Form Submission":[{"json":{"candidateId":"CAND-441","email":"sam.okafor@example.com","role":"Backend Engineer","stage":"Phone Screen"}},{"json":{"candidateId":"CAND-442","email":"priya.nair@example.com","role":"Product Designer","stage":"Final Interview"}}]},"versionId":"2e04ac0d-b1ec-4040-940b-74897d887389","id":"FDX10385"}