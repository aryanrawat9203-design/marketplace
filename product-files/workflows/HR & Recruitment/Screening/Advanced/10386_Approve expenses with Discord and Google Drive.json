< s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.candidateId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6858,400],"id":"d700472b-c312-4a8a-aa44-1f2f7a4ab2b0","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[7182,400],"id":"4bf6064e-58a5-4227-90bc-cac3c0dfaf6e","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7506,400],"id":"4c36c8ee-912f-4fe1-86ba-954441ec1d7b","name":"Stamp Processing Time"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7830,400],"id":"27d7f475-c829-4efd-81c8-49479d3b1d29","name":"Cap Batch Volume"},{"parameters":{"dataToSave":{"values":[{"key":"candidateId","value":"={{ $json.candidateId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8154,400],"id":"4b0e05a7-fc82-4f42-b76c-b175a6ac6699","name":"Save Execution Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"candidateId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8478,400],"id":"7ded361a-5994-4c8f-9b45-cc9dcf40a6f9","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a1894987-3bc3-4f47-a4c0-9cd53589e39f","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8802,400],"id