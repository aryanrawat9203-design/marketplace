{"name":"Route documents with Microsoft Teams and Google Sheets with instant alerts","nodes":[{"parameters":{"formTitle":"Route documents with Microsoft Teams and Google Sheets with ","formFields":{"values":[{"fieldLabel":"Email","requiredField":true},{"fieldLabel":"Role","requiredField":false},{"fieldLabel":"Stage","requiredField":false}]},"options":{"appendAttribution":false}},"type":"n8n-nodes-base.formTrigger","typeVersion":2.2,"position":[-270,400],"id":"be6f5c3c-fc3d-4949-b436-fc01fcdb9d1d","name":"New Candidate Form Submission","webhookId":"d7d32842-8cdc-47ec-b7b2-7ec6ff8df924"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming candidate records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    candidateId: String(j.candidateId ?? j.id ?? '').trim(),\n    email: typeof j.email === 'string' ? j.email.trim() : j.email ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"bd0273a9-6a6c-40af-b869-3a9fd124984b","name":"Normalize Candidate Payload"},{"parameters":{"assignments":{"assignments":[{"id":"ada8cc81-33ce-4c39-92d7-f822fdff7b93","name":"requestId","value":"={{ $json.candidateId || $execution.id }}","type":"string"},{"id":"3b13cc36-6e30-46ca-b494-9404880fa660","name":"summary","value":"={{ ($json.email || '').toString().slice(0, 200) }}","type":"string"},{"id":"2c33e744-4c68-41df-96fb-348bc1a14413","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"99c49c4c-baa2-4a55-ad36-e8deea65519a","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#hr","cachedResultName":"#hr"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,400],"id":"85ec9691-bfa4-45fe-a582-372f252dbd7f","name":"Request Approval via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resume":"webhook","httpMethod":"POST","options":{}},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1026,400],"id":"59f54fa5-3136-4a9c-bacd-4cf62468ee0f","name":"Hold for Decision","webhookId":"e4a976e7-c32a-44fd-ad17-20b054b85baf"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b1521d98-6e90-4b65-a6ef-1be77bff4021","leftValue":"={{ $json.body?.decision || $json.decision }}","rightValue":"approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"f29117b0-836a-4b2d-ab8c-1b24a678bf60","name":"Approved?"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/candidates","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1674,160],"id":"1f42dffd-1093-48f2-aedd-e7bcede47c5c","name":"Execute Approved Action (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#hr","cachedResultName":"#hr"},"text":"=❌ Request {{ $json.requestId }} was declined.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1998,760],"id":"4c66944a-32b2-4b56-a5b7-03ba04b57e73","name":"Record Decline + Notify Requester","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"fc8561d2-8731-4e73-bfc1-611cbcc20007","name":"Join Decision Paths"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per candidate (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.candidateId, j.email].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3618,400],"id":"e1a94601-66a1-4e2e-b8b4-3251bc2a6934","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3942,400],"id":"a0bb6ef3-21bf-41e0-8bce-fec666a85804","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4266,400],"id":"71c50723-9e28-41ef-bd96-9247f4558565","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"83ce2d67-8c36-4d86-bb5a-044934346ec0","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"ff21e50c-5794-487c-8ed4-45e827d187eb","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"65c56c50-1ee7-41b5-9d55-b779076f0a9b","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4914,400],"id":"1df9ca96-9e0b-4f3e-9e99-0738b45d639b","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidate Database"},"title":"={{ $json.email || $json.candidateId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5238,400],"id":"b6322853-c570-4cba-9ad0-0f385bfcdb08","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Candidate Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5562,400],"id":"ca94d0e2-1a11-4133-8678-61ce8d6fb68a","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5886,400],"id":"431f92b8-228e-468c-be70-d9cd7751b1f8","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Candidates"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[6210,400],"id":"79f66f1c-b664-48ca-942d-714d1b95cf4b","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6534,400],"id":"2e7c3793-b2c6-4585-aabc-c0f685d24ba0","name":"Record Sub-workflow Result"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6858,400],"id":"be33ed95-928c-4da8-9507-2e16aefd5b03","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7182,400],"id":"329252e9-50a0-4e0e-81e0-2ce3f848c4e7","name":"Persist Run Metadata"},{"parameters":{"dataToSave":{"values":[{"key":"candidateId","value":"={{ $json.candidateId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7506,400],"id":"dd0f8841-8581-45fe-a9b7-33b9d1312561","name":"Save Execution Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2ad38a67-bd96-4109-bd3f-653077d5ba54","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7830,400],"id":"e238fb40-fe39-4cf6-8c82-39f21394707c","name":"Guard Non-Empty email"},{"parameters":{"assignments":{"assignments":[{"id":"46de36c7-b7c7-4373-b9e8-deab6871cd84","name":"pipeline","value":"Onboarding","type":"string"},{"id":"0a5796cf-15d4-4851-b6a2-5dffbffc4024","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8154,400],"id":"83581198-00b8-4e51-85a9-3e621a5a46b5","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignm