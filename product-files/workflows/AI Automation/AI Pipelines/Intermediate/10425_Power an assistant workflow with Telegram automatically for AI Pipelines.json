{"name":"Power an assistant workflow with Telegram automatically for AI Pipelines","nodes":[{"parameters":{"httpMethod":"POST","path":"wf10425-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"ffb106ab-f8dd-46c9-93f0-9f40b1bb90f4","name":"Receive Inbound Webhook","webhookId":"0ffcfe9e-65ef-4a21-9ca6-08a66b8f72a8"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e14f750f-3b1e-48f8-9933-ff4c456b19d7","leftValue":"={{ $json.docId || $json.content }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"372cae42-602f-46ae-8232-c66254a83d68","name":"Keep Valid Documents"},{"parameters":{"assignments":{"assignments":[{"id":"2c2bfdb3-4f6c-428e-bc32-b240a73faf83","name":"assignment","value":"={{ $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"c2bd20f8-2020-4fba-a9de-fdde444a060c","name":"deadline","value":"={{ $now.plus({minutes: 5}).toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"d283f40c-15ef-4f82-ba45-c5ae1a5da6fc","name":"Frame the Assignment"},{"parameters":{"promptType":"define","text":"={{ $json.assignment }}","options":{"systemMessage":"You are the coordinator for a ai pipelines pipeline. Break the request into sub-tasks, delegate each to the matching specialist tool, then merge results into one coherent answer. Never call the same specialist twice for one request.","maxIterations":10},"hasOutputParser":true},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"9f06b02b-2f6e-4652-942d-bf2d44f1dea6","name":"Coordinator Agent","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-l