{"name":"Summarize documents with MySQL and Telegram in real time","nodes":[{"parameters":{"httpMethod":"POST","path":"wf10455-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"a859a355-40e5-4b59-bade-c3d1b096cf8f","name":"Receive Inbound Webhook","webhookId":"5dddf94d-b2fd-4e17-b40a-0685facb27c6"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/documents","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"39c51af1-e186-47d9-a20e-7e3adedfc25d","name":"Pull Fresh Items (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"confidence","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[378,400],"id":"7b52020d-0e46-4bd2-9121-4f9e3ae8a113","name":"Newest First"},{"parameters":{"maxItems":15},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"d93466c5-bde9-4f3e-8f79-a0590212b9fe","name":"Trim to Digest Size"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.chainSummarization","typeVersion":2,"position":[1026,400],"id":"10c85ed3-5f1f-45e8-9842-9234be889443","name":"Summarize Content (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[1269,970],"id":"0c90b3c1-5b50-472e-8fbf-2071fd5ecd8b","name":"OpenRouter Chat Model"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"={{ $json.html || $json.response?.text || $json.text }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[1593,400],"id":"ccb41244-14ca-4b3a-b506-9a269178f28a","name":"Post Digest to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[1917,400],"id":"1f7b5cf2-9ff1-4eb5-9fa0-73dc880c7834","name":"Archive Digest in MySQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[2241,400],"id":"d6f5202b-8179-49de-9e8c-e006a8737c9c","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.content || $json.docId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[2565,400],"id":"5c492628-a935-436c-9e0a-b1962d5613ca","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[2889,400],"id":"0f95255e-5374-4d38-ad94-879783e80d12","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3213,400],"id":"c08b9a62-ef38-41da-be06-659d5914ae9d","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.content }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3537,400],"id":"bdebaba2-0524-40ff-a87f-26e49b675e30","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e54178ff-7818-4677-9ef1-275530bb1b75","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"1afa0dba-914d-4c6f-a511-cc6e96076290","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3861,400],"id":"adfed8ac-e8d7-464f-aae7-a7393e432aa2","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per document (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.docId, j.content].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4185,400],"id":"4a44d433-7422-4897-aa95-3fb6925c600c","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4509,400],"id":"b2d892c1-ad82-470c-8c23-48680f2ab276","name":"Drop Already-Processed Items"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Documents"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[4833,400],"id":"21300c42-8e11-4230-9e4a-61da059bcbdc","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5157,400],"id":"50bf8df6-083b-40dc-b1b6-1d0df0fa5149","name":"Record Sub-workflow Result"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5481,400],"id":"a4472a2a-6ce8-4186-89cb-934084cac39c","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5805,400],"id":"1fecff8f-3761-4c19-a9a3-014fadc120b9","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6129,400],"id":"bf1445be-be47-4593-b6c7-1f0f450dfb5b","name":"Stamp Processing Time"},{"parameters":{"dataToSave":{"values":[{"key":"docId","value":"={{ $json.docId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6453,400],"id":"ae797b6e-ce83-4a40-9983-308331564839","name":"Save Execution Metadata"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[6777,400],"id":"0a4be668-e3d4-4ce6-803f-ed5cb3e64a6d","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"cdf28cc3-c3a8-410c-91c0-76ced2ffca3c","name":"pipeline","value":"AI Pipelines","type":"string"},{"id":"23dee2ff-65cd-41e7-9139-4ec7928f0dab","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7101,400],"id":"0802f30b-861e-49b1-8b78-fc5283432c98","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"docId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7425,400],"id":"22be34cc-fcf8-4552-acf2-913eba11e374","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"395da4ce-33bf-4e39-88cd-46a0a48ebf91","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"99e31c04-6b3f-45ac-a2c3-1d86b63ca167","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8e1d9ab7-61d0-4b2b-8b08-c3b15cee0588","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7749,400],"id":"af0be4c9-7f1c-4407-8048-aa04f1a8044b","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[8073,400],"id":"a138241c-feda-4bea-b50d-e4f0d5350de2","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Summarize documents with MySQL and Telegram in real time — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[8397,400],"id":"37d574bf-b24a-4d30-bc78-764bc7a5c317","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"85b199a5-71cd-43f9-8e90-1704caa27c35","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"6ab89e63-5140-4bbb-be46-f73638109dc4","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"48914adc-dc99-4ddb-937d-8e21bf335bf2","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7749,1420],"id":"0bb92d00-98e0-4307-b0e0-136afede509c","name":"Capture Failure Context"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[8073,1420],"id":"aaacccc1-d5a2-47da-a946-53c9eb3a7688","name":"Escalate Failure to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[8397,1420],"id":"01af5df5-9eab-4dae-9362-fedcca41187f","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf10455-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Pull Fresh Items (API)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"f2342041-929e-5c51-d9a6-e120539eb39b","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Pull Fresh Items (API)\n\nGET https://api.example.com/v1/documents — retries 3× with backoff on failure.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"24289a55-66f9-5e91-71e0-a1154bed3e80","name":"Note: Pull Fresh Items (API)"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"a8c571df-ea60-c4a4-fe5d-e4e30d756dec","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"303a2480-f5a5-b07c-f0fa-ff4edf55e5fe","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Post Digest to Telegram · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"ccec46ef-a1a9-02aa-5030-6d9c5c2f2a7a","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### OpenRouter Chat Model\n\nChat model powering the AI step (model: `anthropic/claude-sonnet-4.5`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 OpenRouter API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"b88792ee-fabc-64cb-b1f0-cc9a34beb733","name":"Note: OpenRouter Chat Model"},{"parameters":{"content":"### Post Digest to Telegram\n\ntelegram — `action` operation against the connected account.\n\nPorts: ①→ Archive Digest in MySQL · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"1819e9f8-fe4e-934b-7502-74bd56e5aff4","name":"Note: Post Digest to Telegram"},{"parameters":{"content":"### Archive Digest in MySQL\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Serialize Run Output (CSV) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"6deece85-f74c-aa71-e62b-8c7b9e1f9f4b","name":"Note: Archive Digest in MySQL"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"5f30c7b3-958b-7fa5-bffa-a4bf5bc655d7","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"f85fc8c1-873b-bf77-967e-e53dd87aeb89","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"e85078d0-6f87-a4e6-2522-0903eb1dd24b","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"a74e8d8e-67da-dc3d-139a-4a9c5ef01b44","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"f2a79bdb-e186-7368-a0a6-6c552f316c26","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"0a9e3c6f-e3f2-94a4-9d53-09e2d82d4b5b","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per document (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"39f9d6f2-48dd-ba84-ce00-006c194c7b3a","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"38c10ff6-2572-c14e-e2e9-f58aee98f608","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"5edf6269-2599-1a5c-d2bc-6dabd4a7921b","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"d63bb87b-44bc-14a0-2cf9-5c2afc340131","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Load Previous Snapshot\n\nnotion — `getAll` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"70055e4b-0fb3-e6b9-9306-41d8e5464311","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"51ac5d70-d0ee-9473-d5da-66264c622646","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"b25d9bf0-88fc-a476-2e2a-ce3259e9a2ae","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"7aa2422d-3d34-dc32-1a94-c8c47001b4e3","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"2bcd517b-9dbe-b1db-fc2b-cbc59d85ab26","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"90e018ff-d1e9-3087-3d1a-78c3342a5a86","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"e28be329-0c7a-2acb-fbd2-69da2ba5b671","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"b82319b4-c1ab-ba07-e6da-3d7c408e0c40","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Telegram · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"a7f73a70-fb80-1d8e-319d-eb7c29a99dd9","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Telegram\n\ntelegram — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,520],"id":"57a998dc-ae68-db79-999f-96025872bb1d","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Telegram","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,1540],"id":"c1b2f0fb-703d-a397-f3f2-cd78aa44c33c","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Telegram\n\ntelegram — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Telegram bot token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,1540],"id":"f4cb8f36-3485-d122-f0e3-71365877ec42","name":"Note: Escalate Failure to Telegram"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nmySql — `insert` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 MySQL connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,1540],"id":"d74ce908-1899-f6dd-c40e-8a63723e7c1f","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Summarize documents with MySQL and Telegram in real time\n\n**Pattern:** AI Summarize & Route · **Level:** Architect · **Trigger:** Webhook\n\n## What it does\nSummarize documents with MySQL and Telegram in real time. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual ai pipelines is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Pull Fresh Items (API) → Newest First → Trim to Digest Size → Summarize Content (AI) → Post Digest to Telegram → Archive Digest in MySQL → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating ai pipelines in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Removes copy-paste errors\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; MySQL connection; Notion integration token; OpenRouter API key; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"abecbfef-f458-aced-6474-73c04593f19e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"7f6fb2f5-7ce5-b4f0-bf3c-5ff291187391","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"fda87647-92f6-50a8-94dd-61d8c3d2d9a1","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"0843211a-5db3-b8f5-b280-e337ce775794","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your ai pipelines process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"36849525-424c-79af-0dfd-b2362ce5c0f1","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Pull Fresh Items (API)","type":"main","index":0}]]},"Pull Fresh Items (API)":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"OpenRouter Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Post Digest to Telegram","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Post Digest to Telegram":{"main":[[{"node":"Archive Digest in MySQL","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Digest in MySQL":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Telegram","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Telegram","type":"main","index":0}]]},"Escalate Failure to Telegram":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Telegram":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"d589c55a-e905-4f4a-89df-5d6bc99b7949","id":"FDX10455"}