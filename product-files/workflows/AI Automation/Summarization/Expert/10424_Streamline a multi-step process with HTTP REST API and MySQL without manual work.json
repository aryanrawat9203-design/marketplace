{"name":"Streamline a multi-step process with HTTP / REST API and MySQL without manual work","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":7,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"55d1c3a7-4504-4568-9bb4-b9783ccf2be1","name":"Daily Schedule"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[54,400],"id":"c1805a22-5d0a-4346-9067-7eb58f146690","name":"Read Pending Queue (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"7a099ac9-01b4-46d0-a18c-88afd7b2e9c6","name":"docId","value":"={{ $json.docId || $json.id || $execution.id }}","type":"string"},{"id":"0bc77b49-4573-42d4-abc6-de990f222477","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"9cd58c83-4c54-4c72-ba40-8c54e60ce814","name":"Stamp & Shape Document"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d1c4f925-11ec-48fc-9b75-9082e8b91e33","leftValue":"={{ $json.docId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[702,400],"id":"6d3138bc-6d1c-4c66-aee0-ccf1f882dd78","name":"Payload Valid?"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[702,910],"id":"9af1b8c8-7820-4735-967b-ad7bdef79b43","name":"Recor