odes-base.set","typeVersion":3.4,"position":[3861,400],"id":"937b0039-dda0-4ef9-bbd4-de834bc02341","name":"Tag Pipeline Metadata"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[4185,400],"id":"cabcfec9-f95d-48a5-8aa8-c65ac88113df","name":"Cap Batch Volume"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4509,400],"id":"14cf6eb8-830d-4c46-945f-9539eba539c5","name":"Stamp Processing Time"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"docId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[4833,400],"id":"49690439-090e-4bf7-8d2f-5ec91c89742e","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"622d9595-c6d3-42f6-87f2-624b3d8e1274","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"fae2a13c-d9d0-4f3b-9604-044340dfb326","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"ae5c599c-80db-49cf-b9a1-93ab8cddf16d","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,400],"id":"c3433a2f-792b-4e20-a943-2369904e3712","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[5481,400],"id":"b46fd645-89a4-4d5f-8889-a96eb1b971e4","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=✅ Digest meeting notes with MySQL and Telegram with instant alerts — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,400],"id":"f1fe050d-2042-4348-a772-08b37cd59ca2","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"bb9a0689-e74e-4e55-9734-bc0dc3396091","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"9d2ba810-a222-45f9-92e0-426f51a9aec6","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"dc2390ab-917c-40c3-9d0b-c768ea173d73","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,1420],"id":"292ff0c1-6847-4265-bcd2-7ff221896854","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#ai-ops","cachedResultName":"#ai-ops"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5481,1420],"id":"3f438c9a-776a-4672-a28f-4461e019c440","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf10429-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Keep Valid Documents","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"17d4a45c-3194-bb22-00ee-3470ad2b866d","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Keep Valid Documents\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Classify with AI","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"6c5a4963-bd78-c988-2000-ddd1052888de","name":"Note: Keep Valid Documents"},{"parameters":{"content":"### Classify with AI\n\nLLM classification into: Action Needed, Reference, Ignore (+fallback). Output port order matches this list.\n\nPorts: ①→ Store as Action Needed · ②→ Store as Reference, Capture Failure Context · ③→ Store as Ignore · ④→ Alert Slack — Other\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"483370dc-f700-859a-09e6-9fb74e7fee16","name":"Note: Classify with AI"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Classify with AI** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"2ff745a3-ada8-c3fa-c5de-1b29d2f0ea97","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Store as Action Needed\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,40],"id":"38b06a93-50f4-4816-e59f-79d477db52bf","name":"Note: Store as Action Needed"},{"parameters":{"content":"### Store as Reference\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,490],"id":"04fee9c8-91ea-d88a-f7cb-56a25327b625","name":"Note: Store as Reference"},{"parameters":{"content":"### Store as Ignore\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,940],"id":"3f26947a-7eab-3e99-4f9a-59a41e174648","name":"Note: Store as Ignore"},{"parameters":{"content":"### Alert Slack — Other\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,1390],"id":"0d12c20b-dd19-ffb2-4183-319e3b52699a","name":"Note: Alert Slack — Other"},{"parameters":{"content":"### Reunite Branches\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"35e92a10-0034-8291-ccfc-4be8b92480a4","name":"Note: Reunite Branches"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"1157c178-66b8-052c-3d6b-c9c4a5296b0c","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"3cd6b814-3f3a-afe4-d3ca-de063d0c7dc7","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"a2c70b3e-c76a-45fb-5aba-bb99661ce801","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"b943be14-99f7-ad22-2263-8d2c68e20db3","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"5b358793-a94b-164c-571d-c59c90a6b9e2","name":"Note: Align Field Names"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"923c801a-f156-9d7c-dc59-322208b52c02","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"8d260eb1-9611-380a-547b-8624279fc056","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"abd0e9ff-f317-309b-b8f5-dca0008e4618","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"9449b9f3-b349-8249-aada-6a263b45fe3a","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"87c94075-bf0e-5ae1-8173-d2ed551e8bb4","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Digest meeting notes with MySQL and Telegram with instant alerts\n\n**Pattern:** AI Summarize & Route · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nDigest meeting notes with MySQL and Telegram with instant alerts. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual routing is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Keep Valid Documents → Classify with AI → Store as Action Needed → Reunite Branches → Save Execution Metadata → Tag Pipeline Metadata → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating routing in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Saves hours of manual work each week\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: MySQL connection; OpenAI API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"cadb3d69-e2d6-5c1b-d758-ddea3a857f93","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"251722ea-ceaf-81d3-e14b-eb790da33101","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"83f3c36f-1152-e6e7-520b-0c91374e2916","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"92f3f792-f0d9-ab69-df93-95a3287f4ed6","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your routing process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-500],"id":"3aeca437-113a-c555-4dc9-e755a86b8b30","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Keep Valid Documents","type":"main","index":0}]]},"Keep Valid Documents":{"main":[[{"node":"Classify with AI","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Classify with AI","type":"ai_languageModel","index":0}]]},"Classify with AI":{"main":[[{"node":"Store as Action Needed","type":"main","index":0}],[{"node":"Store as Reference","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Store as Ignore","type":"main","index":0}],[{"node":"Alert Slack — Other","type":"main","index":0}]]},"Store as Action Needed":{"main":[[{"node":"Reunite Branches","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Reference":{"main":[[{"node":"Reunite Branches","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Ignore":{"main":[[{"node":"Reunite Branches","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Alert Slack — Other":{"main":[[{"node":"Reunite Branches","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Reunite Branches":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"720faccd-3463-4fd9-bdb7-312e60163cdd","id":"FDX10429"}