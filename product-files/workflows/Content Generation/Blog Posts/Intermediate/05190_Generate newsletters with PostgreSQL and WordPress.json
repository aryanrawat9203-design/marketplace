{"name":"Generate newsletters with PostgreSQL and WordPress","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":4}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"3acaeb0a-5900-4c4f-9c68-b7a6961437cb","name":"Hourly Schedule"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/drafts","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"2cdf3111-6672-40db-8030-3c12763ea2ca","name":"Pull Fresh Items (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"tone","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[378,400],"id":"67701ebc-3049-4e9e-9f9a-1c0f494f925f","name":"Newest First"},{"parameters":{"maxItems":15},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[702,400],"id":"69a84e3a-634d-4d0f-9f25-9dddbcab81d5","name":"Trim to Digest Size"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.chainSummarization","typeVersion":2,"position":[1026,400],"id":"979b1cc6-9bf7-40b6-92b2-29dec6744135","name":"Summarize Content (AI)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[1269,970],"id":"cac28d23-eed0-4f99-81d2-21267b230640","name":"Google Gemini Chat Model"},{"parameters":{"mode":"markdownToHtml","markdown":"={{ $json.response?.text || $json.text }}","options":{}},"type":"n8n-nodes-base.markdown","typeVersion":1,"position":[1593,400],"id":"61bc991c-c352-4eb2-9acd-458c304d105c","name":"Render as HTML"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"={{ $json.html || $json.response?.text || $json.text }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1917,400],"id":"a9203275-2c10-4d52-a844-47b9adc98567","name":"Post Digest to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2241,400],"id":"3df832eb-5b5c-47ff-8988-de6a524a1ddc","name":"Archive Digest in PostgreSQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Drafts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[2565,400],"id":"5f94cab6-9d5b-4275-92ca-ff514b305205","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[2889,400],"id":"b8dcdcd9-5863-41e4-9447-e2f187ff4de3","name":"Record Sub-workflow Result"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per draft (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.draftId, j.topic].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3213,400],"id":"b70f27f5-a278-4909-a2a7-7de533b382a0","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[3537,400],"id":"883e8c17-2108-415b-be30-9b80739ab747","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.topic }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3861,400],"id":"fc334cd8-d346-45e1-a059-948e57777859","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"cabebc80-1606-4280-94ba-e57f34501f33","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"ee44e358-8b21-48f6-9def-8317d60391ca","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4185,400],"id":"d1edb389-8520-4284-8280-c0b4ada6aa97","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4509,400],"id":"d905cce9-9b3b-4e59-93f0-1209da2b3303","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4833,400],"id":"443a7012-238a-4b2f-a47e-5ba8a2d429c4","name":"Persist Run Metadata"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5157,400],"id":"ff595807-feef-4d1b-a08f-e8a9db9950bb","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5481,400],"id":"faa43dd9-4ded-4a65-bf23-5c0d0440081b","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5805,400],"id":"38748b62-8a28-4f34-94af-9bebc35ffb76","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6129,400],"id":"3b49e358-2ecb-42f7-86ec-d06dc0cd2960","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[6453,400],"id":"0c70cd11-6721-4d69-8c00-406986983ba4","name":"Cap Batch Volume"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[6777,400],"id":"562ec4cd-5a85-4315-8965-e8e2cb3443b4","name":"Stamp Processing Time"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"draftId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[7101,400],"id":"490fd9a1-6ca4-4e9f-9549-aaa6a85222cb","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"draftId","value":"={{ $json.draftId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7425,400],"id":"a7ad4c09-ea9e-4734-a0fe-b4a5cb01cbeb","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"908f4823-4267-430e-a993-062080421b9e","name":"pipeline","value":"Blog Posts","type":"string"},{"id":"393acbdb-10d2-4567-8b43-80858cc1883e","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7749,400],"id":"c02d1758-3e3c-4191-9f9a-dd5e67d3ed6f","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"tone","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8073,400],"id":"95affdb5-a0fb-454d-9a80-a2309e8755d5","name":"Sort Drafts Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"20fe05b8-5f70-468f-8e15-edf85b29aaa5","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"7b092f50-a496-4eb2-b2c3-07789e0a7ca4","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"d5026a42-f778-461d-b721-c5aeb464d74b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8397,400],"id":"971bd5e8-cf3b-40ec-83f1-8aef83807373","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[8721,400],"id":"ab8d0cdf-c722-450c-b8ed-70da92007220","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Generate newsletters with PostgreSQL and WordPress — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9045,400],"id":"13dd8ee2-2691-4550-88ee-e28ba2d91e2f","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"bbd02b2e-9eb7-482c-9cfc-ad40e1f7994d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"1aa1e584-56e9-4757-bcbd-c1164a960b14","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"d90e3981-893a-49a4-8af8-33748aec11fd","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8397,1420],"id":"e6373676-1399-4d4e-93de-85b13f923aa6","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8721,1420],"id":"a2c0203c-08cf-42fe-9dc5-97c4f18b260e","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[9045,1420],"id":"c9c1f8b8-3c7f-4746-8e41-5c3ee1317495","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 4 h. No input data; downstream nodes fetch what they need.\n\nNext: Pull Fresh Items (API)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"22877aba-17d7-ab95-fea1-dd6850cb6048","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Pull Fresh Items (API)\n\nGET https://api.example.com/v1/drafts — retries 3× with backoff on failure.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"1813fe27-8094-9c2e-cf30-4d955c89149f","name":"Note: Pull Fresh Items (API)"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"60f4107c-eba6-0c37-0989-f37b8824eb66","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"5d2124c5-0f3e-18c7-2f37-a15ea9360830","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Render as HTML · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"7e4605df-2d61-abd7-9e28-4f7af7e68796","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"bc2383d6-8142-4aea-239f-4ecb572fb58c","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Render as HTML\n\nConverts markdown to HTML for rich rendering in email/CMS.\n\nNext: Post Digest to Slack","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"9a2c9f26-3159-e504-af4d-b636d95d0e89","name":"Note: Render as HTML"},{"parameters":{"content":"### Post Digest to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Archive Digest in PostgreSQL · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"b2e477ea-d994-d6e5-34fd-61174c30d54e","name":"Note: Post Digest to Slack"},{"parameters":{"content":"### Archive Digest in PostgreSQL\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Offload to Post-Process Sub-workflow · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"cdc98599-e1cc-ce67-72d9-b27d413922aa","name":"Note: Archive Digest in PostgreSQL"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"1b1718c5-09f8-16d9-fd17-9570452e420c","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"628494ee-6fb5-d47d-a32b-c0bd73ff067a","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per draft (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"ecea045a-e4a2-56d9-c500-b9f826834851","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"294d1fc8-eff1-7117-9f7a-e68f8338d98e","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"9a65a770-df8d-f1f7-c7e9-ad369e22b66d","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"e1387354-9d27-bb79-e87d-60ce76eae1e5","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"a4da6285-2b8c-527e-9544-130746f6f55d","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"7327c629-d3ba-c227-a5f4-4a2a282f6c6e","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"2a26a791-eedf-22f3-d3d6-526a357358ff","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"b4b029f6-90ba-4e54-0878-29992cae3e44","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"e63ec257-1d16-baba-16fe-756b7ee4d0c5","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Cap Batch Volume · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"291958f0-2592-2516-6a20-e67411820f8c","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"897d3dbc-da25-14b9-28cd-00410b23f2ca","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"4d1e3dfb-fea2-3908-5498-22e3428a6692","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"9a34a785-9f6a-21d5-83f3-316a43e8bcf3","name":"Note: Align Field Names"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"b5868574-c3cb-7796-2049-a8f3e30112a8","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Drafts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7689,520],"id":"86f05587-0238-ccfb-890d-4b3812dd9da4","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Drafts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8013,520],"id":"2bc01524-00a5-9bdf-b15f-b7ef0abc60a8","name":"Note: Sort Drafts Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,520],"id":"094d21e3-8e44-4035-d303-4ec3835dcc78","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,520],"id":"1aaccd09-d5e5-4d8d-7cff-10c622a57b84","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,520],"id":"5cbfa4b1-802d-bb0b-b82a-7c8f3bda6150","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8337,1540],"id":"ead9f1a4-72cf-03c0-5eff-4d3641484bfb","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8661,1540],"id":"b985e050-6ee6-3b1b-5e73-fa94c86f6927","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8985,1540],"id":"10be00a6-0d01-52c7-c49b-7d9719703553","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Generate newsletters with PostgreSQL and WordPress\n\n**Pattern:** Content Generation · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nGenerate newsletters with PostgreSQL and WordPress. It runs automatically on a schedule.\n\n## Why it exists\nManual blog posts is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Pull Fresh Items (API) → Newest First → Trim to Digest Size → Summarize Content (AI) → Render as HTML → Post Digest to Slack → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating blog posts in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Has retries and error handling built in\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google AI API key; Google OAuth2 / service account; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"b6598dc6-8ede-bb9b-3446-7e32a8a1221f","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"74383f4b-8ac0-ceef-6615-0a98eff49f4b","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"4bb8bc91-6e93-8035-81c3-bd8409258e3f","name":"🤖 AI cluster"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"db3debae-0eb9-8587-8539-2d5f0b999275","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your blog posts process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"c28ec007-6d6a-b4ba-1229-a5096314a033","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Pull Fresh Items (API)","type":"main","index":0}]]},"Pull Fresh Items (API)":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Render as HTML","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Render as HTML":{"main":[[{"node":"Post Digest to Slack","type":"main","index":0}]]},"Post Digest to Slack":{"main":[[{"node":"Archive Digest in PostgreSQL","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Digest in PostgreSQL":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Drafts Newest First","type":"main","index":0}]]},"Sort Drafts Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"75af5cf2-842f-4e55-8b72-0bfe710594e4","id":"FDX05190"}