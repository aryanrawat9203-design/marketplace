{"name":"Summarize meeting notes with Google Sheets and Gmail and log the results","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05497-draft","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"5e318b7b-8f04-4bbb-8ae0-553a26129ea5","name":"Receive Inbound Webhook","webhookId":"c210e4ab-4041-40b0-bbcb-6eb8ca140e59"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fcb2ff70-14cc-4002-b5e0-96c720ab1ed7","leftValue":"={{ $json.draftId || $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"a9b0bdb0-fea6-4f47-bb58-a5b1f419f9b5","name":"Keep Valid Drafts"},{"parameters":{"inputText":"={{ $json.topic || JSON.stringify($json) }}","categories":{"categories":[{"category":"Urgent","description":"Drafts that are urgent for the blog posts team."},{"category":"Routine","description":"Drafts that are routine for the blog posts team."},{"category":"FYI","description":"Drafts that are fyi for the blog posts team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"c93bd6c0-544b-430d-bf22-ac2d4f1dbd8f","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[621,970],"id":"8195834e-08bb-440e-973f-c7f52be0f589","name":"Groq Chat Model"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[945,-80],"id":"9e900fce-f694-4d56-924f-eefde070c286","name":"Store as Urgent","retryOnFail":true,"maxTries":3,"waitBe