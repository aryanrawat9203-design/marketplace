odel"},{"parameters":{"promptType":"define","text":"=Improve this draft without changing facts:\n\n{{ $json.text }}","messages":{"messageValues":[{"message":"You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1269,400],"id":"38c2be2c-2102-416c-ae52-21ba94449425","name":"Refine with AI Editor","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[1512,970],"id":"1cec90bc-eb8b-4cbc-a83c-3a13d4e1b56c","name":"OpenRouter Editor Model"},{"parameters":{"title":"={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}","additionalFields":{"content":"={{ $json.html || $json.text }}","status":"draft"}},"type":"n8n-nodes-base.wordpress","typeVersion":1,"position":[1836,400],"id":"7f127ea5-b498-4bd9-a494-fb6505103efe","name":"Publish Draft to WordPress","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"draftId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[2160,400],"id":"3b6c43a2-a963-4eff-ae7d-6b5cd4cc4de4","name":"Align Field Names"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"88e6cbc8-8ace-49a9-97d4-8215e3346910","leftValue":"={{ $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[2484,400],"id":"b1599ab9-150b-4df7-a8cd-736db6e92d83","name":"Guard Non-Empty topic"},{"parameters":{"assignments":{"assignments":[{"id":"5ce145e3-0d52-4701-a1de-c0c66651cec4","name":"pipeline","value":"Blog Posts","type":"string"},{"id":"