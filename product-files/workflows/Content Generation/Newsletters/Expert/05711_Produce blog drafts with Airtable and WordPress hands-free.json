:{"__rl":true,"mode":"list","value":"","cachedResultName":"Drafts"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3550,400],"id":"0ff4d52b-097c-4dcb-834a-2ba80c547372","name":"Append Audit Row (Airtable)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Produce blog drafts with Airtable and WordPress hands-free — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3874,400],"id":"0a5e5ed8-bda9-4e95-8307-d0d23e53c441","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"259bd42a-4844-42a7-ae8a-3ca3b522323d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"8b45573c-b6ee-43f0-b9ab-d0f116d14bc7","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"b0d4506e-b866-498e-b373-4236dc3d6ca3","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3226,1420],"id":"bb9927c6-fad8-47f3-8f2e-a6c61397460c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3550,1420],"id":"8d016d81-ba1f-49a5-99a6-9f8518d3a68a","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"a2fe5bbe-0d1c-36ad-4815-3587bf4308d7","name":"Note: Daily Schedule"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.topic }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Frame the Assignment · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"f264ae95-a0aa-7dad-9fc6-28532481adf1","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"03fdf629-2d05-ec3c-a2f2-071b1c881642","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Frame the Assignment\n\nShapes the item: writes `assignment`, `deadline`. Keeps the schema explicit between stages.\n\nNext: Coordinator Agent","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"85765d6a-33e9-c3cc-9520-76ea9a0148f8","name":"Note: Frame the Assignment"},{"parameters":{"content":"### Coordinator Agent\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Unpack Sections · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"95ff7f82-f794-b23b-a1f5-0f9b32ee8736","name":"Note: Coordinator Agent"},{"parameters":{"content":"### Anthropic Chat Model\n\nChat model powering the AI step (model: `claude-sonnet-4-5-20250929`). Swap providers here without rewiring.\n\nFeeds **Coordinator Agent** as `languageModel`\n\n🔑 Anthropic API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"74d3300b-e808-c2a2-fe20-1ce698134174","name":"Note: Anthropic Chat Model"},{"parameters":{"content":"### Research Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[804,1510],"id":"06aea368-f66f-9651-64b2-0cdb59eb1cd5","name":"Note: Research Specialist (Sub-workflow)"},{"parameters":{"content":"### Draft Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1060,1750],"id":"3daffba7-6af5-fd15-46e7-be6f12c2c422","name":"Note: Draft Specialist (Sub-workflow)"},{"parameters":{"content":"### Enforce Result Schema\n\nForces the agent's answer into the JSON schema below — downstream nodes rely on this exact shape.\n\nFeeds **Coordinator Agent** as `outputParser`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1222,1090],"id":"e3434652-c896-6019-8f24-b7cb672411a7","name":"Note: Enforce Result Schema"},{"parameters":{"content":"### Unpack Sections\n\nExplodes the `output.sections` array into one item per element.\n\nNext: Persist Deliverable to Airtable","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1546,520],"id":"9c22e352-8b08-f284-8cec-dcd1f445e6e0","name":"Note: Unpack Sections"},{"parameters":{"content":"### Persist Deliverable to Airtable\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Guard Non-Empty topic · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1870,520],"id":"add3e997-6c2a-d881-7cdd-157b40a3449f","name":"Note: Persist Deliverable to Airtable"},{"parameters":{"content":"### Guard Non-Empty topic\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2194,520],"id":"634de31b-2df1-a897-0778-e5b80e2cdee8","name":"Note: Guard Non-Empty topic"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Sort Drafts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2518,520],"id":"0f805eed-431c-fdbc-c207-a0d76d153409","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Sort Drafts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2842,520],"id":"f2411249-b144-e968-95bb-f9fc66a4f5cf","name":"Note: Sort Drafts Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3166,520],"id":"2b93d8ea-b392-b4fe-0955-ae96d12420cb","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3490,520],"id":"2f569feb-b03a-bb2d-d482-2a80fe92fc48","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3814,520],"id":"8585e4ac-aafb-b956-e164-ee2bdeb7b13d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3166,1540],"id":"b4b1af0c-5398-7139-6d07-66c45618e0dc","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3490,1540],"id":"319f50f4-d9be-5ed0-54f8-a2db6b102cc3","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Produce blog drafts with Airtable and WordPress hands-free\n\n**Pattern:** Content Generation · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nProduce blog drafts with Airtable and WordPress hands-free. It runs automatically on a schedule.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Required Fields Present? → Frame the Assignment → Coordinator Agent → Unpack Sections → Persist Deliverable to Airtable → Guard Non-Empty topic → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating newsletters in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Runs 24/7 in the background\n- Improves response time\n\n## Before first run\nConnect credentials: Airtable PAT; Anthropic API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"3d9f1221-9548-c0a8-2659-e8cff27145e5","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"81769a35-4fd1-c002-4d40-fa4ddf083171","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"59fbea99-c288-c227-9904-b439ab4c4d8b","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"ead68db3-e636-c18b-ccbc-16538f39c052","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Frame the Assignment","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Frame the Assignment":{"main":[[{"node":"Coordinator Agent","type":"main","index":0}]]},"Anthropic Chat Model":{"ai_languageModel":[[{"node":"Coordinator Agent","type":"ai_languageModel","index":0}]]},"Research Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Draft Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Enforce Result Schema":{"ai_outputParser":[[{"node":"Coordinator Agent","type":"ai_outputParser","index":0}]]},"Coordinator Agent":{"main":[[{"node":"Unpack Sections","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Unpack Sections":{"main":[[{"node":"Persist Deliverable to Airtable","type":"main","index":0}]]},"Persist Deliverable to Airtable":{"main":[[{"node":"Guard Non-Empty topic","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Guard Non-Empty topic":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Sort Drafts Newest First","type":"main","index":0}]]},"Sort Drafts Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"88e09b46-b0f3-4f06-9abd-5621dd38a576","id":"FDX05711"}