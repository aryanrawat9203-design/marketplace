— never invent draft details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"f0bc8ab0-1556-4107-8009-7e6d404682a8","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[945,970],"id":"afdb5eb4-51f4-4348-b488-16fb82ee9cf9","name":"OpenRouter Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[945,1390],"id":"64d85abe-16a8-414f-aa14-66cd17ad7671","name":"Search Reference Wiki"},{"parameters":{"name":"score_helper","description":"Compute a quality score for a draft record.","jsCode":"const j = JSON.parse(query);\nreturn String((j.signals || []).length * 10);"},"type":"@n8n/n8n-nodes-langchain.toolCode","typeVersion":1.3,"position":[1174,1390],"id":"6b374e3e-b3d3-4b44-b7e3-97775dbae52d","name":"Custom Logic Tool"},{"parameters":{"assignments":{"assignments":[{"id":"4aab0cef-67f0-4e31-beae-d8b81afe9a9b","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"abafc697-d008-4bab-968f-19907aada669","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1498,400],"id":"654189de-c241-4c18-90c4-72ab88f16d60","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"96917fbc-7fa7-4e9a-b519-d54e6026d23e","leftValue":"={{ $json.confidence }}","rightValue":"high","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1822,400],"id":"9f73abc4-14c9-4129-a4e7-169716d6462e","name":"Confident Enough?"},{