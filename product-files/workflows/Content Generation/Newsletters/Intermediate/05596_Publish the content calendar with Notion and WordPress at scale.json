{"name":"Publish the content calendar with Notion and WordPress at scale","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":9,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"b2c78aae-f5ac-48c3-8342-ca980db530e4","name":"Daily Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e94d3142-7db9-4b63-9a6d-9d737c38309b","leftValue":"={{ $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"78927d75-1bbc-4ea7-95af-baaca696c13d","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'topic' on incoming draft."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"85c81eeb-78df-474e-a7dd-1cfa5f7ac3c6","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"11e0a540-7486-4bcf-b72f-b0e20aafe693","name":"brief","value":"={{ $json.topic || $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"f5a88ef4-2a87-4777-98fb-75100268ac07","name":"tone","value":"={{ $json.tone || 'professional' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"7139ba8a-dcbf-413d-8791-f5cb4efb2354","name":"Build the Brief"},{"parameters":{"promptType":"define","text":"=Write {{ $json.tone }} content for: {{ $json.brief }}","messages":{"messageValues":[{"message":"You write production-quality newsletters content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[702,400],"id":"f8d2ad17-c32e-4e45-a80a-695b67920fe9","name":"Draft with AI Writer","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[945,970],"id":"2d60ac24-4432-4bc3-854d-7ec36ee12c5b","name":"Google Gemini Writer Model"},{"parameters":{"promptType":"define","text":"=Improve this draft without changing facts:\n\n{{ $json.text }}","messages":{"messageValues":[{"message":"You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1269,400],"id":"b4eedef8-a4b1-4a06-94cb-f04000af2145","name":"Refine with AI Editor","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[1512,970],"id":"5f6befd7-9906-46d0-b038-4ff79fdd553d","name":"Google Gemini Editor Model"},{"parameters":{"title":"={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}","additionalFields":{"content":"={{ $json.html || $json.text }}","status":"draft"}},"type":"n8n-nodes-base.wordpress","typeVersion":1,"position":[1836,400],"id":"fc187454-03b7-4369-9293-a62f20d492f4","name":"Publish Draft to WordPress","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[2160,400],"id":"39d674cb-9880-473a-ad8a-00368e486d99","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2484,400],"id":"bd779124-a850-4457-bfc8-ad8a7bf08626","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.topic }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2808,400],"id":"8e58b13b-6289-4f5d-8b68-5adfacfd558d","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"5fe04f44-bfd4-4785-ae78-ce373577cbee","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"9891e3d6-18e6-46ec-9c36-1b0d2878cadd","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3132,400],"id":"cc0a2b6f-5d0a-47f7-a896-79a2c966fde5","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3456,400],"id":"e894ef23-7ebd-4844-8c68-ecf697117d90","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3780,400],"id":"948fcb44-a733-43d4-86df-a86505fff4d2","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4104,400],"id":"5f561a6f-c233-4321-9e43-66e53f7185c4","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4428,400],"id":"a8b546c3-b2c2-4eec-ab5e-9b6aaed33862","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"56ad49ec-0a2c-465f-b8b7-893fbcc04d40","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"6d5588e2-fc25-414a-96af-a6fd9f6a75ee","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"d6309ca7-1603-4bf9-90ac-945a2b962284","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4752,400],"id":"7dfaf197-5202-4724-b89f-058a9e549486","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5076,400],"id":"10663719-3231-4b89-85de-d89082f55ddf","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Publish the content calendar with Notion and WordPress at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5400,400],"id":"197dfd7c-ef8b-4954-91e6-c23b1fb5e5e6","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"c65b4f02-ef8c-4bd3-9640-dae2d4731094","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"dc247933-8872-4855-89f7-27b29d7477e1","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"84763624-7f9c-4f46-88ab-31595c3d7395","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4752,1420],"id":"ce272406-f18e-4103-964a-a6b5d5e0e3f8","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5076,1420],"id":"1bcc78cb-87e8-48e6-9c2d-2e66d1799c7b","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5400,1420],"id":"01c76292-9708-455f-a3a7-c6c43419d518","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 9:00. No input data; downstream nodes fetch what they need.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"53cbc6ea-85f4-0d36-25ec-c1d59ba153c4","name":"Note: Daily Schedule"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.topic }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Build the Brief · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"f9dda9b9-4909-8e48-8433-fb6e2d3dab63","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"bed2974c-9ed4-5e2b-0063-9637b581d5c1","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Build the Brief\n\nShapes the item: writes `brief`, `tone`. Keeps the schema explicit between stages.\n\nNext: Draft with AI Writer","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"2eba7813-2d96-d870-f851-f1cd9943587c","name":"Note: Build the Brief"},{"parameters":{"content":"### Draft with AI Writer\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Refine with AI Editor · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"a10c0e7c-c1f1-359d-6fd3-5a9cff5fe2cc","name":"Note: Draft with AI Writer"},{"parameters":{"content":"### Google Gemini Writer Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Draft with AI Writer** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"f15f1e16-9e32-0980-bc39-dfe60642039a","name":"Note: Google Gemini Writer Model"},{"parameters":{"content":"### Refine with AI Editor\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish Draft to WordPress · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,520],"id":"f79e978b-25ed-4d52-9a5c-2084fcd82ddb","name":"Note: Refine with AI Editor"},{"parameters":{"content":"### Google Gemini Editor Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Refine with AI Editor** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1452,1090],"id":"26319b90-4789-cef2-717f-a8aab017b74c","name":"Note: Google Gemini Editor Model"},{"parameters":{"content":"### Publish Draft to WordPress\n\nwordpress — `action` operation against the connected account.\n\nPorts: ①→ Serialize Run Output (CSV) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 WordPress credentials","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,520],"id":"8e26e98b-e462-bee3-c1ce-41cf2ebaccd4","name":"Note: Publish Draft to WordPress"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2100,520],"id":"e35101b2-cbc4-0c03-fda4-f97d952b9ca2","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2424,520],"id":"fd1aca93-81ef-94c8-0e46-cce28a05206c","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2748,520],"id":"c5035aa5-f522-9094-47b0-b9ff043c4952","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3072,520],"id":"349b35a8-6915-f755-9118-062fa2fc88bf","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,520],"id":"4c5d09d1-0036-8a25-306b-50bea8c35e9d","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,520],"id":"b33ea435-3504-259a-50c7-3d171fdaf730","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4044,520],"id":"286b5557-8c41-4126-a680-90c485854059","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4368,520],"id":"d0059583-75b1-cb02-1d8f-650f032b51a5","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,520],"id":"d88d60ce-c04f-ae4e-9af8-ee8d48ce89cd","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,520],"id":"c66811f4-a4b7-c8a3-2577-fbe46cce4f57","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5340,520],"id":"bce1bb16-5a88-635d-1423-9a90145f046e","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,1540],"id":"1ed5ac32-e8b8-7fab-8794-e6cd515e7455","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,1540],"id":"5e26c318-cef5-110d-9bfc-19edf2db8e34","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5340,1540],"id":"169b461b-4dce-c66e-1c69-1263099ed4b4","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Publish the content calendar with Notion and WordPress at scale\n\n**Pattern:** Social Scheduler · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nPublish the content calendar with Notion and WordPress at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Required Fields Present? → Build the Brief → Draft with AI Writer → Refine with AI Editor → Publish Draft to WordPress → Serialize Run Output (CSV) → …\n\n## Use it for\n- Teams that want to social scheduler without manual effort\n- Anyone automating newsletters in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Standardizes the process every time\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google AI API key; Google OAuth2 / service account; Slack OAuth2; WordPress credentials.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"6f9218a1-0393-ce48-82b9-684de811c31a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"8c46ba11-99d9-6a1e-ebb9-c41dee78536f","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"ab2289e8-8313-ba8e-ba77-f840263afefe","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"22a77f99-6ba2-846a-7088-9c27f5eefd38","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Build the Brief","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Build the Brief":{"main":[[{"node":"Draft with AI Writer","type":"main","index":0}]]},"Google Gemini Writer Model":{"ai_languageModel":[[{"node":"Draft with AI Writer","type":"ai_languageModel","index":0}]]},"Draft with AI Writer":{"main":[[{"node":"Refine with AI Editor","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Google Gemini Editor Model":{"ai_languageModel":[[{"node":"Refine with AI Editor","type":"ai_languageModel","index":0}]]},"Refine with AI Editor":{"main":[[{"node":"Publish Draft to WordPress","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish Draft to WordPress":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift 