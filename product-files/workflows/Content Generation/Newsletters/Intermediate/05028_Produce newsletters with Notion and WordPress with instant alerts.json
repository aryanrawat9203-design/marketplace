{
  "name": "Produce newsletters with Notion and WordPress with instant alerts",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "triggerAtDay": [
                5
              ],
              "triggerAtHour": 9
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -200,
        400
      ],
      "id": "471890b9-6c94-4bac-9cfd-60c4a2919eea",
      "name": "Weekly Schedule"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "4a4db9c7-8077-445a-9eef-2bb71d541652",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "d2793374-2201-4655-b5f7-73fa660c5387",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        40,
        400
      ],
      "id": "63b1c249-ae30-49f8-b549-624462085d3c",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality newsletters content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        280,
        400
      ],
      "id": "c7ba0a01-91cf-43dd-a574-4f1bd9f6aa0a",
      "name": "Draft with AI Writer"
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        460,
        590
      ],
      "id": "3aa58b33-6b4a-41ae-a67a-dceeef6a64f6",
      "name": "Groq Writer Model"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Improve this draft without changing facts:\n\n{{ $json.text }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        700,
        400
      ],
      "id": "3e24af75-bc40-47fc-b31b-b51f7d9dd77c",
      "name": "Refine with AI Editor"
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        880,
        590
      ],
      "id": "6514beda-b4d8-404c-b245-eb43bfbc0733",
      "name": "Groq Editor Model"
    },
    {
      "parameters": {
        "mode": "markdownToHtml",
        "markdown": "={{ $json.text }}",
        "options": {}
      },
      "type": "n8n-nodes-base.markdown",
      "typeVersion": 1,
      "position": [
        1120,
        400
      ],
      "id": "42487639-202d-4ff4-9173-066ca42bcf6e",
      "name": "Convert to HTML"
    },
    {
      "parameters": {
        "title": "={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}",
        "additionalFields": {
          "content": "={{ $json.html || $json.text }}",
          "status": "draft"
        }
      },
      "type": "n8n-nodes-base.wordpress",
      "typeVersion": 1,
      "position": [
        1360,
        400
      ],
      "id": "3a4e166e-edbf-4f52-b84e-ccd86927e4ef",
      "name": "Publish Draft to WordPress",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
