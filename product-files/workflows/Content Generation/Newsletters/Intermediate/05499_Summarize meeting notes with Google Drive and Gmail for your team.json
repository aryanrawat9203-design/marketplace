nt","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[945,970],"id":"d2682b91-2fa3-4047-befc-c91f41c86314","name":"Groq Chat Model"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=😠 Negative draft: {{ $json.topic }}","message":"=😠 Negative draft: {{ $json.topic }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1269,-80],"id":"ac7575d5-68d2-4aaf-a0ca-a254efface5b","name":"Escalate Negative — Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1593,400],"id":"0cbe62e0-0daa-4767-8df1-b7bb58133fa4","name":"Log Neutral Feedback","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=💚 Positive feedback received: {{ $json.topic }}","message":"=💚 Positive feedback received: {{ $json.topic }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1917,880],"id":"136e115a-29f5-44d6-8849-3db73cff264b","name":"Thank the Sender","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2889,400],"id":"0c6c2c0f-bb86-43f1-8655-364d547549db","name":"Collect All Outcomes"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $j