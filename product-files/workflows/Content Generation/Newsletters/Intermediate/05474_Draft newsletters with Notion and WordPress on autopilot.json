 Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3334,400],"id":"8b547846-626e-4ef1-a906-f5848cd8e96f","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3658,400],"id":"66cf2c6d-a2c8-43d9-94de-688795206fe6","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"fe865954-7e52-4d04-a44a-ea3b87b320e5","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"d8968065-1640-48cc-b78c-cc5e6040ae07","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"8ac67449-3282-485c-beeb-75bebefd138d","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3982,400],"id":"40c21959-ce5a-4ad7-8239-f5ffbdb7653b","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4306,400],"id":"2fd6c086-4d44-4c16-9da2-6aa54c573381","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Draft newsletters with Notion and WordPress on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4630,400],"id":"f5be0532-2b32-43c6-946c-8b97d711c32e","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"c4a80742-e86a-4105-b84d-ae32ea654473","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"60d2f328-852f-42a1-b828-1fa770c7e9ef","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"225e6e16-5bb5-4ad9-af66-a41f434163a4","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3982,1420],"id":"eefcf159-3a76-422c-a63d-253009bc7b17","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4306,1420],"id":"281b2ec6-7e72-425f-8236-2dc74dd5acf6","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[4630,1420],"id":"dbaab416-516d-4f1c-b512-8fe3c31584cd","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 17:00. No input data; downstream nodes fetch what they need.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"694289a8-324b-c138-1161-840589c3846c","name":"Note: Daily Schedule"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.topic }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Frame the Assignment · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"b47533e0-25a9-820a-dedb-c89a19635687","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"d79e99a4-2c21-a081-d9ca-b537ff559122","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Frame the Assignment\n\nShapes the item: writes `assignment`, `deadline`. Keeps the schema explicit between stages.\n\nNext: Coordinator Agent","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"29feb7e0-b0a2-679f-042e-cd3fd4ff940f","name":"Note: Frame the Assignment"},{"parameters":{"content":"### Coordinator Agent\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Unpack Sections · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"20e2e682-787d-f39f-be0d-071db0765208","name":"Note: Coordinator Agent"},{"parameters":{"content":"### Anthropic Chat Model\n\nChat model powering the AI step (model: `claude-sonnet-4-5-20250929`). Swap providers here without rewiring.\n\nFeeds **Coordinator Agent** as `languageModel`\n\n🔑 Anthropic API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"633046e5-74d8-4e05-e4e3-e7e502722b1f","name":"Note: Anthropic Chat Model"},{"parameters":{"content":"### Research Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[804,1510],"id":"8b779847-8eb7-062c-0898-d3d6a202cf71","name":"Note: Research Specialist (Sub-workflow)"},{"parameters":{"content":"### Draft Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1060,1750],"id":"1fb7dfed-d1b2-52f2-4527-3a5fec5a9bdf","name":"Note: Draft Specialist (Sub-workflow)"},{"parameters":{"content":"### Review Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1492,1510],"id":"b12a6b90-cab7-9873-f691-66bcfcf92623","name":"Note: Review Specialist (Sub-workflow)"},{"parameters":{"content":"### Enforce Result Schema\n\nForces the agent's answer into the JSON schema below — downstream nodes rely on this exact shape.\n\nFeeds **Coordinator Agent** as `outputParser`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1654,1090],"id":"ea6866bb-393b-7b9f-9188-e74f774eb7fc","name":"Note: Enforce Result Schema"},{"parameters":{"content":"### Unpack Sections\n\nExplodes the `output.sections` array into one item per element.\n\nNext: Persist Deliverable to Notion","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1978,520],"id":"1c3a7470-3481-2c43-50a5-149a266d52cd","name":"Note: Unpack Sections"},{"parameters":{"content":"### Persist Deliverable to Notion\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2302,520],"id":"c4ad287a-ca76-9572-bde4-4e65b1a2459f","name":"Note: Persist Deliverable to Notion"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2626,520],"id":"814e0abf-17db-5dbf-098e-a925d49fee90","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2950,520],"id":"a13d0804-5a0d-6a7d-8a31-e56fa58ae69b","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3274,520],"id":"ee45a720-8487-603d-7244-03ab3ca02102","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3598,520],"id":"a618d10c-07cf-0c7b-1062-b9192cab77a3","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3922,520],"id":"e96e5b05-4ba8-8ca4-42bb-3156ec1c0c7a","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4246,520],"id":"e51e61f7-8407-d59d-b4ff-49048dd4885e","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4570,520],"id":"bc7a3017-6653-d74b-12f4-c644cfdd663d","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3922,1540],"id":"fe2c976c-1152-ffaa-c21b-8b8fce5bb8e0","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4246,1540],"id":"fefb18c3-adbb-24cc-5f96-2a9645695ef0","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4570,1540],"id":"3e188655-952e-5618-7c7b-d6d94b40f311","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Draft newsletters with Notion and WordPress on autopilot\n\n**Pattern:** Content Generation · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nDraft newsletters with Notion and WordPress on autopilot. It runs automatically on a schedule.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Required Fields Present? → Frame the Assignment → Coordinator Agent → Unpack Sections → Persist Deliverable to Notion → Load Previous Snapshot → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating newsletters in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Keeps your systems in sync\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Anthropic API key; Google OAuth2 / service account; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"970803cb-25c8-9434-a363-462467a46a41","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"719c406c-95ac-f3d9-7573-75bd122854d6","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"c687012d-5203-ffd0-2661-7aac13e6086d","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"ead32d2e-d1d8-86bd-f671-d683c952e0d7","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Frame the Assignment","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"Frame the Assignment":{"main":[[{"node":"Coordinator Agent","type":"main","index":0}]]},"Anthropic Chat Model":{"ai_languageModel":[[{"node":"Coordinator Agent","type":"ai_languageModel","index":0}]]},"Research Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Draft Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Review Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Enforce Result Schema":{"ai_outputParser":[[{"node":"Coordinator Agent","type":"ai_outputParser","index":0}]]},"Coordinator Agent":{"main":[[{"node":"Unpack Sections","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Unpack Sections":{"main":[[{"node":"Persist Deliverable to Notion","type":"main","index":0}]]},"Persist Deliverable to Notion":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"f8311587-eef8-4659-a802-92eab9c80496","id":"FDX05474"}