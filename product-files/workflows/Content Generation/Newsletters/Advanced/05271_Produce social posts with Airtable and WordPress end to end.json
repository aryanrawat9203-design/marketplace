    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming draft records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    draftId: String(j.draftId ?? j.id ?? '').trim(),\n    topic: typeof j.topic === 'string' ? j.topic.trim() : j.topic ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40,
        400
      ],
      "id": "03856057-36a1-4ec0-aa05-9a20bd6663d2",
      "name": "Normalize Draft Payload"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "10ff5330-e4b7-42d1-879f-b5ea673ac8ae",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "c6df3558-1884-456d-aa97-12392b2ffe76",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        280,
        400
      ],
      "id": "420399a1-3918-4ba3-96a1-bea1b5eba2b9",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality newsletters content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
