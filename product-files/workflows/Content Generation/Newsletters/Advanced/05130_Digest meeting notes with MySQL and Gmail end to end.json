":"={{ $json.email || 'ops@company.com' }}","subject":"=🙋 Low-confidence answer needs review: {{ $json.answer }}","message":"=🙋 Low-confidence answer needs review: {{ $json.answer }}","options":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2605,760],"id":"1c36168a-e445-44a9-b780-6f0d2dcff4b7","name":"Escalate to Human Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3253,400],"id":"16f4ec4a-4a2a-4b53-ad13-0e1a577b4c81","name":"Join Outcomes"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4225,400],"id":"96133365-15b9-4bf6-a641-e2b644fcc319","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4549,400],"id":"68f0ce54-0e29-4e47-936d-62c4cd045ce8","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Drafts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[4873,400],"id":"8d532891-4c3d-41c2-892e-0b4ff570cd23","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5197,400],"id":"05b62ab3-ba71-40c4-a571-0644b0d60cdb","name":"Record Sub-workflow Result"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5521,400],"id":"4a0de888-0494-4432-8701-bea979e6df22","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5845,400],"id":"5a3eeb9f-187a-4573-9d8c-74b7ac71019a","name":"Persist Run Metadata"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[6169,400],"id":"80c58c8c-9626-4889-965a-1acc58bf4884","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6493,400],"id":"f54ed2d7-21f5-4724-b6bf-c4fd353321fd","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.topic }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6817,400],"id":"9eec05ad-2203-405e-8847-1b398f325175","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"02cc18c3-41d2-4601-a685-9948fa25307a","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"42b95646-7daa-464f-956e-0907b49abef0","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7141,400],"id":"0ebc4ae0-0fda-4229-a6cd-1b9ab811953f","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per draft (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.draftId, j.topic].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7465,400],"id":"a9b4e89b-84d9-4749-8f63-0e9dac0ec4b3","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[7789,400],"id":"dc6e345a-617f-46ca-93d8-269f0ac2ed04","name":"Drop Already-Processed Items"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"tone","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8113,400],"id":"4a01e693-ef69-4526-9dc2-2bae9bf9ec3d","name":"Sort Drafts Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"d5bf44a5-c763-4a76-8a52-972adf4bb429","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c7cda329-1225-47de-9611-73302d64dc3a","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"79a0c657-e74a-4b7b-be90-89eca611e650","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8437,400],"id":"ecef36b8-9711-4277-bdc1-d3cb64ba04fa","name":"Summarize Run Stats"},{"parameters":{"operation":"insert","table":{"__rl":true,"mode":"name","value":"drafts","cachedResultName":"drafts"},"dataMode":"autoMapInputData","options":{}},"type":"n8n-nodes-base.mySql","typeVersion":2.4,"position":[8761,400],"id":"12b38419-f1ef-401f-a260-0cd42001665a","name":"Append Audit Row (MySQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=✅ Digest meeting notes with MySQL and Gmail end to end — run completed at {{ $n","message":"=✅ Digest meeting notes with MySQL and Gmail end to end — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[9085,400],"id":"023cc338-5762-4d1b-9420-06c8fcb94be7","name":"Send Summary to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"3c9e3492-b068-4cef-bd63-6b61e581dfbc","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"6f83c8a0-f531-4879-b15d-b6ca5c2ac994","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"c0177dbd-cf91-4011-99f4-d44d1a9c26f7","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8437,1420],"id":"a668d881-f1d8-4467-bd94-3b17b04ee46b","name":"Capture Failure Context"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[8761,1420],"id":"7a1ed932-9dae-46ca-a7c3-08225741e828","name":"Escalate Failure to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9085,1420],"id":"661a78d6-6957-488e-815e-138d100f9a4b","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf05130-draft`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Keep Valid Drafts","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"7337c9cf-ced2-aa34-e517-26b2c2928b3a","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Keep Valid Drafts\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Reason & Act (AI Agent)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"84e92bcc-94de-9a4e-fc75-8e3523cdb3a8","name":"Note: Keep Valid Drafts"},{"parameters":{"content":"### Reason & Act (AI Agent)\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Shape Agent Output · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"81f5a37d-de87-8c88-2db6-0e7907b952cf","name":"Note: Reason & Act (AI Agent)"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Reason & Act (AI Agent)** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"514ea65f-7da1-d539-c2b9-78ab86ab019f","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Search Reference Wiki\n\nReference lookup tool for general-knowledge questions.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1510],"id":"8e7f1b0c-9e4d-dfb8-fce3-df74d49657db","name":"Note: Search Reference Wiki"},{"parameters":{"content":"### Run Calculations\n\nMath tool — keeps arithmetic exact instead of letting the LLM guess.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[790,1750],"id":"b17e562f-c34a-449c-ed55-45810894e24c","name":"Note: Run Calculations"},{"parameters":{"content":"### Custom Logic Tool\n\nDeterministic code helper the agent can invoke for exact computation.\n\nFeeds **Reason & Act (AI Agent)** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1249,1510],"id":"ae87a5dc-4fcc-a313-93da-dc5ae1aa14f4","name":"Note: Custom Logic Tool"},{"parameters":{"content":"### Conversation Memory\n\nConversation memory keyed by session — the bot remembers earlier turns for each user separately.\n\nFeeds **Reason & Act (AI Agent)** as `memory`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1006,1090],"id":"05f2be4f-e01b-29f4-a1f8-744c366e9227","name":"Note: Conversation Memory"},{"parameters":{"content":"### Shape Agent Output\n\nShapes the item: writes `answer`, `confidence`. Keeps the schema explicit between stages.\n\nNext: Confident Enough?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1573,520],"id":"ab5e29f1-f987-343c-3bdd-d02fae67ebd1","name":"Note: Shape Agent Output"},{"parameters":{"content":"### Confident Enough?\n\nTwo-way gate on `={{ $json.confidence }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Deliver Answer + Log to MySQL · ②→ Escalate to Human Queue","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1897,520],"id":"64ee2d0b-5455-0bad-bbb3-041e447929ff","name":"Note: Confident Enough?"},{"parameters":{"content":"### Deliver Answer + Log to MySQL\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2221,280],"id":"723cb7bc-2da5-8a47-817f-ce80823959e0","name":"Note: Deliver Answer + Log to MySQL"},{"parameters":{"content":"### Escalate to Human Queue\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Join Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2545,880],"id":"aa0c7e63-3a96-b5ae-510f-4a4c02b9f591","name":"Note: Escalate to Human Queue"},{"parameters":{"content":"### Join Outcomes\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3193,520],"id":"a9605469-c4dc-1fed-e12a-78f4087af075","name":"Note: Join Outcomes"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4165,520],"id":"4f34642c-11c3-14fd-f0a3-2186da77bc42","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4489,520],"id":"657a9311-0c61-346a-be5e-d300c9a1cb30","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4813,520],"id":"bca9588a-3d6d-5d35-58b1-e03ba6b7f865","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5137,520],"id":"241b6b6a-3e6e-49af-ae21-8c63226b6a22","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5461,520],"id":"ec70f335-f6fe-8ace-a9ed-ddf58c887615","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5785,520],"id":"46628859-d847-b69a-bb05-aa8ab7ed8ac9","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6109,520],"id":"8c9d064e-5807-cf16-438d-787c8ddadd17","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6433,520],"id":"5c4d9ffd-48d7-5daa-ec9d-8e3d19435dae","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6757,520],"id":"7ce8eb6c-da47-3b4b-f789-7f52ff28c802","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7081,520],"id":"fd32270e-9917-fb38-2c91-5bfec623f55f","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per draft (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7405,520],"id":"09cdc2b9-3d44-8cbf-dfdc-7546f8355fda","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Sort Drafts Newest First","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7729,520],"id":"b77b2533-879d-32ed-da58-621ee0f5ae8c","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Sort Drafts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8053,520],"id":"21ff9755-73c4-58ed-a19c-97425dc135f9","name":"Note: Sort Drafts Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (MySQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8377,520],"id":"1f2b90de-4cc4-eef6-79b9-dc10c29cf3e1","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (MySQL)\n\nmySql — `insert` operation against the connected account.\n\nPorts: ①→ Send Summary to Gmail · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 MySQL connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8701,520],"id":"c0ba6716-89de-353b-cc6f-6f3ff3df91fb","name":"Note: Append Audit Row (MySQL)"},{"parameters":{"content":"### Send Summary to Gmail\n\ngmail — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9025,520],"id":"13ea43e8-d750-dce3-b74b-e443c3276d90","name":"Note: Send Summary to Gmail"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Gmail","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8377,1540],"id":"4d08b1c1-7b92-29b0-eb8a-b00a86e49be4","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Gmail\n\ngmail — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Google OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8701,1540],"id":"a3ffd0e7-fe39-165d-06ef-5abc01211a66","name":"Note: Escalate Failure to Gmail"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9025,1540],"id":"cbf6eca4-9d12-25bc-dbf3-c7363496cf98","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Digest meeting notes with MySQL and Gmail end to end\n\n**Pattern:** AI Summarize & Route · **Level:** Architect · **Trigger:** Webhook\n\n## What it does\nDigest meeting notes with MySQL and Gmail end to end. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual newsletters is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Keep Valid Drafts → Reason & Act (AI Agent) → Shape Agent Output → Confident Enough? → Deliver Answer + Log to MySQL → Join Outcomes → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating newsletters in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Keeps your systems in sync\n- Runs 24/7 in the background\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2; Google OAuth2 / service account; MySQL connection; Notion integration token; OpenAI API key.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"c97e9946-f8fc-6961-d34e-124e2bc03b2c","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"25a99bb9-36c6-221f-1be5-67edd42dce45","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"c54967e4-2cf5-e034-1aaf-5b0dbc9a11f9","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"8c9f6dd4-96e3-f30c-6525-39fd09a72dd5","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your newsletters process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"07708ae3-20de-a9eb-2812-d34939063cb3","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Keep Valid Drafts","type":"main","index":0}]]},"Keep Valid Drafts":{"main":[[{"node":"Reason & Act (AI Agent)","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Reason & Act (AI Agent)","type":"ai_languageModel","index":0}]]},"Search Reference Wiki":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Run Calculations":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Custom Logic Tool":{"ai_tool":[[{"node":"Reason & Act (AI Agent)","type":"ai_tool","index":0}]]},"Conversation Memory":{"ai_memory":[[{"node":"Reason & Act (AI Agent)","type":"ai_memory","index":0}]]},"Reason & Act (AI Agent)":{"main":[[{"node":"Shape Agent Output","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Shape Agent Output":{"main":[[{"node":"Confident Enough?","type":"main","index":0}]]},"Confident Enough?":{"main":[[{"node":"Deliver Answer + Log to MySQL","type":"main","index":0}],[{"node":"Escalate to Human Queue","type":"main","index":0}]]},"Deliver Answer + Log to MySQL":{"main":[[{"node":"Join Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Escalate to Human Queue":{"main":[[{"node":"Join Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Outcomes":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Sort Drafts Newest First","type":"main","index":0}]]},"Sort Drafts Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (MySQL)","type":"main","index":0}]]},"Append Audit Row (MySQL)":{"main":[[{"node":"Send Summary to Gmail","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Gmail","type":"main","index":0}]]},"Escalate Failure to Gmail":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Gmail":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"c706967c-6761-4774-93d5-8b8dca2cf750","id":"FDX05130"}