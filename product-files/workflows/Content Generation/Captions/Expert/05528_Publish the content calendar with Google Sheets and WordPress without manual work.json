b66551-b2e7-4a50-86f3-0ed8bafd3831","name":"Hold for Decision","webhookId":"d55b02ec-b819-4e75-b08b-7caa0c222d55"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"dec89a8e-62de-464f-8c47-aef5f54b933a","leftValue":"={{ $json.body?.decision || $json.decision }}","rightValue":"approve","operator":{"type":"string","operation":"equals"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1350,400],"id":"fe998d2d-5834-4b7d-aa4c-eced521ecafa","name":"Approved?"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/drafts","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1674,160],"id":"d78b03af-5ad9-4203-a86c-666895e168aa","name":"Execute Approved Action (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=❌ Request {{ $json.requestId }} was declined.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1998,760],"id":"23652984-e8a4-4436-b062-0901736f9408","name":"Record Decline + Notify Requester","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"d0edcd91-57b1-49f1-88a9-145b460519e2","name":"Join Decision Paths"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.topic }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3618,400],"id":"70b81281-2201-4332-a9cb-ae49939272ef","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"7cc01370-d70a-4186-a1bb-f37dce3d3cb5","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"bb05dac5-b46e-4ad8-aaad-a3a59889cd97","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3942,400],"id":"0a790f8d-39d3-402d-9166-a80202e34c00","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per draft (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.draftId, j.topic].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4266,400],"id":"2086f997-c354-4ce1-ba46-1fb237c79aff","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4590,400],"id":"08a370dc-c256-4abb-931b-057db9d8d00d","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4914,400],"id":"1b8b6e85-1d29-44f6-993e-54bd791fa115","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5238,400],"id":"e5b023c3-dbc3-4af8-9d40-f5435a4057b7","name":"Persist Run Metadata"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Drafts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5562,400],"id":"6faa2ded-db17-4e4c-ad96-d598faa486d2","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5886,400],"id":"c2e9753c-3ee3-40dc-ab0e-9890f6b7a1e8","name":"Record Sub-workflow Result"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[6210,400],"id":"23013a6c-31ed-47d5-b6c5-74aee9415234","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6534,400],"id":"a03f233a-aacd-4c62-a548-21b444d6a989","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[6858,400],"id":"5c706840-c8be-43c8-a873-912f47a56ee5","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7182,400],"id":"a6141154-d620-4c52-8f6c-d755be22b94b","name":"Compute Drift vs Snapshot"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"6320fc2f-8718-4c5a-a982-800b9770138f","leftValue":"={{ $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7506,400],"id":"b3b5d357-fe61-4755-91ac-5438f1c7d5bf","name":"Guard Non-Empty topic"},{"parameters":{"assignments":{"assignments":[{"id":"47042328-4056-4049-a25d-bef76f5fd32f","name":"pipeline","value":"Captions","type":"string"},{"id":"a248b2f0-5e9b-40c4-806c-c294d1ec6607","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7830,400],"id":"e629dfb1-a6e2-4639-bec1-f641be91d207","name":"Tag Pipeline Metadata"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8154,400],"id":"e150398c-409e-4536-a30b-fd7100ab3a8c","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"tone","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8478,400],"id":"e4459231-faa2-4d1b-8427-477c5dbfc3f5","name":"Sort Drafts Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"d259d2a7-2bea-4cd6-800a-b27d6fa09e4b","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f3eb0dca-97c7-4007-a10e-da5972748528","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"16f428dc-0b7e-4eb7-9ed0-9f74e43ac7b1","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8802,400],"id":"81d2b6f2-7cb1-4689-bffc-65f366026035","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9126,400],"id":"7c9191cd-39f7-4104-853b-94802e138a7d","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Publish the content calendar with Google Sheets and WordPress without  — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9450,400],"id":"079f2852-68e5-454e-88ae-e0ef0136b155","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b34b4bcf-c24e-48c9-9e3b-bbd4d9bfb368","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"dc8d7479-d425-4138-a558-fb2213db26b9","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"fc1e8735-54a1-48f0-b9f5-c5cefcd344a7","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8802,1420],"id":"366a1994-4aee-4fac-a4f2-452c13612cdd","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9126,1420],"id":"cf2ddf76-fbaf-4fce-8961-473882db66ac","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9450,1420],"id":"5d589b63-6629-43cb-85e6-e8f232599aa8","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 6 h. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Drafts","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"02aef1ec-93ed-0412-dee0-aaa479da4fa9","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Keep Valid Drafts\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Prepare Approval Packet","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"bc2832eb-bd22-b688-31a9-8316cfab3275","name":"Note: Keep Valid Drafts"},{"parameters":{"content":"### Prepare Approval Packet\n\nShapes the item: writes `requestId`, `summary`, `requestedBy`. Keeps the schema explicit between stages.\n\nNext: Request Approval via Slack","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"b369dc65-d85d-d3ee-28f0-71d606315f4a","name":"Note: Prepare Approval Packet"},{"parameters":{"content":"### Request Approval via Slack\n\nPosts a message to Slack (`#content`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nPorts: ①→ Hold for Decision · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"a5214c19-4f45-d66f-e4f6-c98359d6312e","name":"Note: Request Approval via Slack"},{"parameters":{"content":"### Hold for Decision\n\nPauses the execution until the resume webhook is called — this is the approval/HITL gate.\n\nNext: Approved?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"f944488d-221a-a626-88d6-9ffb9371d4a0","name":"Note: Hold for Decision"},{"parameters":{"content":"### Approved?\n\nTwo-way gate on `={{ $json.body?.decision || $json.decision }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Execute Approved Action (API) · ②→ Record Decline + Notify Requester","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"f10f1a93-9669-6bdd-d02a-e080d5fa96cb","name":"Note: Approved?"},{"parameters":{"content":"### Execute Approved Action (API)\n\nPOST https://api.example.com/v1/drafts — retries 3× with backoff on failure.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,280],"id":"d6749873-1e9e-c07b-d972-51b251a37f47","name":"Note: Execute Approved Action (API)"},{"parameters":{"content":"### Record Decline + Notify Requester\n\nPosts a message to Slack (`#content`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nPorts: ①→ Join Decision Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,880],"id":"319bdb4e-4c9d-7d33-1469-3d34f6761a57","name":"Note: Record Decline + Notify Requester"},{"parameters":{"content":"### Join Decision Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"24f20906-346f-ec93-31ac-f8f2c7c8216a","name":"Note: Join Decision Paths"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"ee176166-96e3-f259-74fc-97273ce24ab0","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"c131b684-8342-9d95-8af5-0414b229ed0f","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per draft (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"66c304f8-b9b6-3ffe-8ff4-fc3f6d416d2b","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"c7a4a390-006b-7299-2464-efa8b5d57310","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"26aeabcc-44e6-eebc-7681-815e71d4d65f","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"3e730733-394a-950e-ac88-8b833828da33","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"f4c1030f-6c5f-37f6-cc20-110d0118cee0","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"3c45378e-7e99-2d15-0bc5-8225926ec6ed","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"c340e4a2-87d2-5bf5-29e3-9b93af609ef5","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"bb1d2865-490f-5e3d-bdcf-fc4aa477aa18","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Load Previous Snapshot\n\nPulls every page from the Notion database — fine for small datasets; add a filter if the database grows large.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"999be3b6-d4a4-0601-7571-cfa6dfa8c4a2","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Guard Non-Empty topic","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"da79eccd-c745-bae0-dfd8-49b165b971b3","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Guard Non-Empty topic\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"0c91f7b6-305a-54ed-b64c-2ff71589534b","name":"Note: Guard Non-Empty topic"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"3988f2ca-fafb-877e-560e-8c6fda67db17","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Sort Drafts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"cb437361-96b1-ecac-6121-1376833a0b8b","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Sort Drafts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"06b481bd-1b1a-efc0-6dc2-d229648fefeb","name":"Note: Sort Drafts Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"1e102b16-12c3-8c56-7b6b-4f183826163f","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,520],"id":"bcb7eded-3722-434d-ea2e-96e4cce49e24","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#content`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,520],"id":"70035478-f242-9910-780f-6267bf70ce04","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,1540],"id":"7834bbf2-5058-c405-3a56-5df773d323f0","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nPosts a message to Slack (`#content`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,1540],"id":"5071c6b8-ec6c-2ade-e0e7-b51f0c12d5c9","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,1540],"id":"7bc425c9-39d6-eabc-b6c2-b3c74c7e42f5","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Publish the content calendar with Google Sheets and WordPress without manual work\n\n**Pattern:** Social Scheduler · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nPublish the content calendar with Google Sheets and WordPress without manual work. It runs automatically on a schedule.\n\n## Why it exists\nManual captions is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Keep Valid Drafts → Prepare Approval Packet → Request Approval via Slack → Hold for Decision → Approved? → Execute Approved Action (API) → …\n\n## Use it for\n- Teams that want to social scheduler without manual effort\n- Anyone automating captions in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Has retries and error handling built in\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"6a30ede1-c53a-0fdd-dceb-f64d2a20f295","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe workflow pauses on a Wait node configured to resume via webhook — n8n's actual human-in-the-loop primitive, not a polling loop. The resume URL is embedded directly in the approval message so approving is one click, and the paused execution burns no compute for however long the decision takes.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"faf1cfa7-0f93-0238-8717-57817c0b3bf1","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAbout as deep as this pattern goes — extend it:\n\n1. Add a timeout to the Wait node so unanswered approvals auto-decline after N hours.\n2. Change the approval channel and confirm the resume link still works.\n3. Add a third outcome (e.g. 'needs changes') alongside approve/decline.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"e27ac4df-992e-7b3f-f84b-57975f20d9ea","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"687ee0d8-ec7a-e35f-0303-d7f375173ddf","name":"🛟 Error handling & retries"},{"parameters":{"content":"## ⏱ Rate limiting\n\nWork is batched and spaced with Wait so provider quotas aren't tripped. If you hit 429s, lower the batch size or raise the wait — throughput drops, reliability rises.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"986732ae-d029-644a-2091-01ce6424711a","name":"⏱ Rate limiting"},{"parameters":{"content":"## 🙋 Human in the loop\n\nThe workflow pauses at the Wait node until a human posts a decision to the resume URL (included in the approval message). Approve → the action executes; anything else → recorded as declined. No timeout is set by default — add one under the Wait node's options if approvals go stale.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"e4e9b094-3e0c-9336-5e1c-bf91a1487e6d","name":"🙋 Human in the loop"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your captions process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"6e45cdf5-93d4-b1f8-d585-f4d48802bb93","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Keep Valid Drafts","type":"main","index":0}]]},"Keep Valid Drafts":{"main":[[{"node":"Prepare Approval Packet","type":"main","index":0}]]},"Prepare Approval Packet":{"main":[[{"node":"Request Approval via Slack","type":"main","index":0}]]},"Request Approval via Slack":{"main":[[{"node":"Hold for Decision","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Hold for Decision":{"main":[[{"node":"Approved?","type":"main","index":0}]]},"Approved?":{"main":[[{"node":"Execute Approved Action (API)","type":"main","index":0}],[{"node":"Record Decline + Notify Requester","type":"main","index":0}]]},"Execute Approved Action (API)":{"main":[[{"node":"Join Decision Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Decline + Notify Requester":{"main":[[{"node":"Join Decision Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Join Decision Paths":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Guard Non-Empty topic","type":"main","index":0}]]},"Guard Non-Empty topic":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Sort Drafts Newest First","type":"main","index":0}]]},"Sort Drafts Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Hourly Schedule":[{"json":{"draftId":"DR-2201","topic":"5 automation tips for small teams","audience":"SMB owners","tone":"friendly"}},{"json":{"draftId":"DR-2202","topic":"Product update: v2.4 release notes","audience":"existing customers","tone":"professional"}}]},"versionId":"1cb30ba5-2769-4622-8731-875b461ca06c","id":"FDX05528"}