s":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3874,400],"id":"68dd2e07-0cce-4110-ba0c-851fafa84e40","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"150e1c14-054a-4300-87fe-2b4570a102e0","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"55356fba-2a07-4e42-beec-3b2a89394d72","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"246f0a1e-07e6-4c1d-a5d4-7057b54c3d0a","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4198,400],"id":"be09dcfb-a589-4273-97c8-9c6b42a9f34f","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4522,400],"id":"62209640-a818-4a0e-8b0c-4ab943d82a6e","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Draft social posts with PostgreSQL and WordPress at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4846,400],"id":"aebbc4a5-dfad-4a02-9b95-d74a48dfa657","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"ce76f0bb-36d2-4da8-b82f-93020b0058e0","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"ace42751-7d32-42bb-a898-86b865f02dfd","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"2ae2ad0c-6c9a-4e8d-b361-4a6ca3b5d1ce","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4198,1420],"id":"7755c8e9-19b0-4a18-b8b3-b616430ebc1b","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4522,1420],"id":"82e4ea0d-a923-4565-8b89-3e558d37c431","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4846,1420],"id":"71ad9975-dca7-4865-ab19-7682f00f93e8","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 4 h. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Drafts","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"922103b9-41a0-3407-1346-cb45c440f522","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Keep Valid Drafts\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Frame the Assignment","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"52062257-20bc-28c0-4ad1-3609fc1f4e1e","name":"Note: Keep Valid Drafts"},{"parameters":{"content":"### Frame the Assignment\n\nShapes the item: writes `assignment`, `deadline`. Keeps the schema explicit between stages.\n\nNext: Coordinator Agent","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"c6ff069b-58e9-7c00-6277-85494261b2a4","name":"Note: Frame the Assignment"},{"parameters":{"content":"### Coordinator Agent\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Unpack Sections · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"228b09e9-ee9a-0959-6a62-609a210e7f6e","name":"Note: Coordinator Agent"},{"parameters":{"content":"### Google Gemini Chat Model\n\nChat model powering the AI step (model: `models/gemini-2.5-flash`). Swap providers here without rewiring.\n\nFeeds **Coordinator Agent** as `languageModel`\n\n🔑 Google AI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"fe266e51-3eba-07ee-e250-2e42ca9b8a96","name":"Note: Google Gemini Chat Model"},{"parameters":{"content":"### Research Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[804,1510],"id":"7be0ddbe-a469-48de-6e4d-92528e156b3a","name":"Note: Research Specialist (Sub-workflow)"},{"parameters":{"content":"### Draft Specialist (Sub-workflow)\n\nSpecialist sub-workflow exposed as a callable tool — one narrow capability per tool.\n\nFeeds **Coordinator Agent** as `tool`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1060,1750],"id":"d529954d-5020-5ae1-6b81-a27e157e7675","name":"Note: Draft Specialist (Sub-workflow)"},{"parameters":{"content":"### Enforce Result Schema\n\nForces the agent's answer into the JSON schema below — downstream nodes rely on this exact shape.\n\nFeeds **Coordinator Agent** as `outputParser`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1222,1090],"id":"236b68d2-54e5-1405-736b-cc8e692c62b0","name":"Note: Enforce Result Schema"},{"parameters":{"content":"### Unpack Sections\n\nExplodes the `output.sections` array into one item per element.\n\nNext: Persist Deliverable to Google Sheets","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1546,520],"id":"0a12aabc-8649-d00e-6ddd-1049a1e6bba9","name":"Note: Unpack Sections"},{"parameters":{"content":"### Persist Deliverable to Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1870,520],"id":"6aca8d4a-7211-02cc-201e-fd5a118f7e8e","name":"Note: Persist Deliverable to Google Sheets"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2194,520],"id":"d87fb9f3-c99b-89bb-0427-9c3316697f95","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2518,520],"id":"e6dcbdaf-b5a2-9654-5d56-01095bb4c41f","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2842,520],"id":"0de6c26b-87ed-7bf5-cb0c-73a8ddb06454","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3166,520],"id":"00c2e881-082f-2be7-01a9-a698e3f3d521","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3490,520],"id":"a88a36cb-52e8-6dc5-eb3d-d0d5d9f17e3d","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3814,520],"id":"d4a01324-55a6-7bea-63fe-21c1132844d7","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4138,520],"id":"65a7c4e5-43f7-927f-e219-61a5c10b3661","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4462,520],"id":"2f80eca0-c583-1a91-5bea-fbbac1ee4ce7","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4786,520],"id":"1a61e0e2-d7f8-29c9-e133-7becbdef45ca","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4138,1540],"id":"c660f301-6b9c-6c20-6845-c8de1b250ca8","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4462,1540],"id":"8888a953-17a4-3ebe-8fec-eb89e3d3a22c","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\npostgres — `executeQuery` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Postgres connection","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4786,1540],"id":"42ae7ba2-0856-1717-f270-ac768328d899","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Draft social posts with PostgreSQL and WordPress at scale\n\n**Pattern:** Content Generation · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nDraft social posts with PostgreSQL and WordPress at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual captions is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Keep Valid Drafts → Frame the Assignment → Coordinator Agent → Unpack Sections → Persist Deliverable to Google Sheets → Stamp Completion Time → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating captions in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Improves response time\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google AI API key; Google OAuth2 / service account; Postgres connection; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"1aa750b0-6069-0952-6aba-36d5a59425ae","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"2c80e763-1ec4-c10c-86e2-42404b1909f7","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"9d2c77ea-50e6-efd3-f8d6-26e178442eb3","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your captions process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"b3736ca5-734e-49d7-1d76-27612864b7c1","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Keep Valid Drafts","type":"main","index":0}]]},"Keep Valid Drafts":{"main":[[{"node":"Frame the Assignment","type":"main","index":0}]]},"Frame the Assignment":{"main":[[{"node":"Coordinator Agent","type":"main","index":0}]]},"Google Gemini Chat Model":{"ai_languageModel":[[{"node":"Coordinator Agent","type":"ai_languageModel","index":0}]]},"Research Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Draft Specialist (Sub-workflow)":{"ai_tool":[[{"node":"Coordinator Agent","type":"ai_tool","index":0}]]},"Enforce Result Schema":{"ai_outputParser":[[{"node":"Coordinator Agent","type":"ai_outputParser","index":0}]]},"Coordinator Agent":{"main":[[{"node":"Unpack Sections","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Unpack Sections":{"main":[[{"node":"Persist Deliverable to Google Sheets","type":"main","index":0}]]},"Persist Deliverable to Google Sheets":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"2a7193b5-c2c6-45b0-9328-9a2bbf010fd8","id":"FDX05730"}