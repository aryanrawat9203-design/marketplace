              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "812b84f8-de5f-46e9-a605-fc4308590de4",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        40,
        400
      ],
      "id": "9bdf7af7-766c-44de-a065-7856face4ce5",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality captions content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        280,
        400
      ],
      "id": "1108e91c-c363-4555-86e7-a11be429f10c",
      "name": "Draft with AI Writer"
    },
    {
      "parameters": {
        "model": "claude-sonnet-4-5-20250929",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        460,
        590
      ],
      "id": "99cb467c-9ca2-4883-bf94-36bc1df2d788",
      "name": "Anthropic Writer Model"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Improve this draft without changing facts:\n\n{{ $json.text }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        700,
        400
      ],
      "id": "4c3d6253-57ed-447a-90a3-afbac7c26031",
      "name": "Refine with AI Editor"
    },
    {
      "parameters": {
        "model": "claude-sonnet-4-5-20250929",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        880,
        590
      ],
      "id": "b961bd5b-5944-421e-a3d9-bfeefd3c21d0",
      "name": "Anthropic Editor Model"
    },
    {
      "parameters": {
        "title": "={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}",
        "additionalFields": {
          "content": "={{ $json.html || $json.text }}",
          "status": "draft"
        }
      },
      "type": "n8n-nodes-base.wordpress",
      "typeVersion": 1,
      "position": [
        1120,
        400
      ],
      "id": "629f4795-84de-486a-b0c5-0a33a62692e8",
      "name": "Publish Draft to WordPress",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
