w)"},{"parameters":{"description":"Delegate review sub-tasks for a draft to the Review specialist workflow.","workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Review Specialist"},"workflowInputs":{"mappingMode":"defineBelow","value":{},"matchingColumns":[],"schema":[],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[1876,1390],"id":"03adfa42-2118-4288-a697-3ca8b3b0e5a8","name":"Review Specialist (Sub-workflow)"},{"parameters":{"jsonSchemaExample":"{\n  \"summary\": \"string\",\n  \"sections\": [\"string\"],\n  \"status\": \"complete\"\n}"},"type":"@n8n/n8n-nodes-langchain.outputParserStructured","typeVersion":1.3,"position":[2038,970],"id":"dcf8be44-8cf6-4112-8f44-b528a984bd81","name":"Enforce Result Schema"},{"parameters":{"fieldToSplitOut":"output.sections","options":{}},"type":"n8n-nodes-base.splitOut","typeVersion":1,"position":[2362,400],"id":"b79a57f4-77ed-41bd-b334-3d2173415fb9","name":"Unpack Sections"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Content Generation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Drafts"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[2686,400],"id":"fff19c57-66ff-4e8c-b43d-589edc086408","name":"Persist Deliverable to Airtable","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3010,400],"id":"520e3b08-8f0b-4da1-89a9-debf22d471de","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Content Generation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Drafts"}