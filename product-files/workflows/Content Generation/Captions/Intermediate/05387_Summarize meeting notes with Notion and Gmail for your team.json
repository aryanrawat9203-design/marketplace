{"name":"Summarize meeting notes with Notion and Gmail for your team","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05387-draft","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"7d82fcbc-c24d-40bd-9fbd-c25fe897c630","name":"Receive Inbound Webhook","webhookId":"2b56d7a4-ca74-49f3-b55b-4cda3e576849"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming draft records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    draftId: String(j.draftId ?? j.id ?? '').trim(),\n    topic: typeof j.topic === 'string' ? j.topic.trim() : j.topic ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"2f3edbbe-cddc-4a91-8cbc-0cc6260cd57e","name":"Normalize Draft Payload"},{"parameters":{"inputText":"={{ $json.topic || JSON.stringify($json) }}","categories":{"categories":[{"category":"Urgent","description":"Drafts that are urgent for the captions team."},{"category":"Routine","description":"Drafts that are routine for the captions team."},{"category":"FYI","description":"Drafts that are fyi for the captions team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"2297d8f2-5bab-4141-9f03-c81676c984c4","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[621,970],"id":"8e656009-284b-4f4c-9634-b92217486028","name":"OpenAI Chat Model"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"