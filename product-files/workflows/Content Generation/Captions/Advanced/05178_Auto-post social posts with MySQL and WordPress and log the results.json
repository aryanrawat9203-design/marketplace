{"name":"Auto-post social posts with MySQL and WordPress and log the results","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":6,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"8d68f2ef-48df-4ca6-9dd7-7148d05194ac","name":"Daily Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"60224f94-082c-414e-b457-4014accae458","leftValue":"={{ $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"6d7cc532-88e6-4a4f-a4df-7243832436f0","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'topic' on incoming draft."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"cc7e3ecb-0fb3-4851-aefa-608f8f51990c","name":"Abort — Malformed Input"},{"parameters":{"assignments":{"assignments":[{"id":"63f3f616-cb06-414f-a070-76dd6f375b38","name":"requestId","value":"={{ $json.draftId || $execution.id }}","type":"string"},{"id":"845ff2e3-0ac9-42ee-b2b1-755e60e6fa73","name":"summary","value":"={{ ($json.topic || '').toString().slice(0, 200) }}","type":"string"},{"id":"cfef9fe6-1f21-49d3-b473-b323dd6f4330","name":"requestedBy","value":"={{ $json.email || 'system' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"44fa2302-2e10-4b00-8631-fcd7bd1abe83","name":"Prepare Approval Packet"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🟡 Approval needed for {{ $json.summary }} — resume link: {{ $execution.resumeUrl }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[702,400],"id":"f4732f94-f2ff-4126-a5b6-f16b159dbd29","name":"Request App