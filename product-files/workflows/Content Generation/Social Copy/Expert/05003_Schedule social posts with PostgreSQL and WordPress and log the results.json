{
  "name": "Schedule social posts with PostgreSQL and WordPress and log the results",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "triggerAtHour": 9,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -200,
        400
      ],
      "id": "78ba6684-8ac1-4bab-afbd-bb88101ef08c",
      "name": "Daily Schedule"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming draft records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    draftId: String(j.draftId ?? j.id ?? '').trim(),\n    topic: typeof j.topic === 'string' ? j.topic.trim() : j.topic ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40,
        400
      ],
      "id": "7b82c577-5e50-48e3-857e-ffd32041a863",
      "name": "Normalize Draft Payload"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "867e3dc4-f86e-49b3-9b92-9a1909b1455c",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "491ab175-7044-4b26-b498-de3fc1b6f028",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        280,
        400
      ],
      "id": "df9bb061-9cef-46ad-8009-1db202acfaff",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality social copy content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        520,
        400
      ],
      "id": "ef81e1f5-9150-4b84-8a90-be10f6851340",
      "name": "Draft with AI Writer",
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "model": "models/gemini-2.5-flash",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [
        700,
        590
      ],
      "id": "45858d7b-f9fd-48a8-af5e-50607c4a2d4a",
      "name": "Google Gemini Writer Model"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Improve this draft without changing facts:\n\n{{ $json.text }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        940,
        400
      ],
      "id": "658102a6-a7e2-41e0-b56a-702c924a3662",
