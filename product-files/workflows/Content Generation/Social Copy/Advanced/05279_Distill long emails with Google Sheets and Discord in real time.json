ta before answering — never invent draft details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"74dd6d1c-abda-4a86-a6b2-aba189b69bda","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[945,970],"id":"d35d733d-bc6a-400c-87f9-0640d4daf47e","name":"Anthropic Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[945,1390],"id":"da4e0d6f-5b2b-46c7-87d5-2b52f084d088","name":"Run Calculations"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolThink","typeVersion":1,"position":[1174,1390],"id":"799eca5c-551b-44b2-8595-4f423d68368b","name":"Think It Through"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[1633,1390],"id":"7ba421a0-fd9c-4b3b-8a17-e1830500f863","name":"Search Reference Wiki"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $json.sessionId || $execution.id }}","contextWindowLength":12},"type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.3,"position":[1390,970],"id":"13c7f7a9-5c22-48b6-8583-497b9bd09401","name":"Conversation Memory"},{"parameters":{"assignments":{"assignments":[{"id":"cde5e0e3-676b-44fa-ae95-c883b0e67673","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"3d4a5944-51eb-4de1-83ef-e5381c32d7c5","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1957,400],"id":"63034935-90f0-4293-8865-6be8fe9a260d","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[