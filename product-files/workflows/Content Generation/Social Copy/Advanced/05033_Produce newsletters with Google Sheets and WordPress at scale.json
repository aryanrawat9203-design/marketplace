rameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"895b51cf-783b-4417-a102-49b1bd318724","leftValue":"={{ $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3861,400],"id":"a3df9ef8-63de-4339-854e-f54ca77c099a","name":"Guard Non-Empty topic"},{"parameters":{"assignments":{"assignments":[{"id":"b6d507d8-32ca-4234-8011-01afde9fdd9b","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"690bc0bd-3d65-46cb-a0ee-d2b873e39119","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"5e8dd19e-fc7e-473e-aac6-19c9d38fc8dd","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4185,400],"id":"e8154542-b778-41f1-8f3b-b92d1fd27293","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4509,400],"id":"c887e514-20af-4aa8-b991-1f26ea4ce972","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Produce newsletters with Google Sheets and WordPress at scale — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4833,400],"id":"e7c728dd-197f-4df4-bf8b-bedf27cc91e4","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4218d910-c3f8-4e38-b265-2cc4858cafd8","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"427464a0-c8ca-4fae-9f85-42b9348628bc","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"3bc09cb8-a9fc-41e7-8ffe-daa647519603","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4185,1420],"id":"b720e74f-48fc-4dc8-b0fc-6a3636860140","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4509,1420],"id":"87842227-492f-472a-880e-8ec564b1acf8","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Hourly Schedule\n\nStarts the workflow on a timer — every 1 h. No input data; downstream nodes fetch what they need.\n\nNext: Read Recent from Google Sheets","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"075c2271-5fd4-529a-dcf7-3712f8b1b957","name":"Note: Hourly Schedule"},{"parameters":{"content":"### Read Recent from Google Sheets\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"2f404b97-44a8-d16b-f2ef-1ac149a752d3","name":"Note: Read Recent from Google Sheets"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"0a173808-4c77-bdca-6fc9-d719874e03e4","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"e157ffbc-5ad4-791c-b37e-359ab0fabb1f","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Render as HTML · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"626e60ef-be4a-ed49-ee0f-0b32a1aae7f2","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"454b7378-efb3-6eea-6833-383f6e220024","name":"Note: Groq Chat Model"},{"parameters":{"content":"### Render as HTML\n\nConverts markdown to HTML for rich rendering in email/CMS.\n\nNext: Post Digest to Slack","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"c83a9ebf-7a06-b240-41b3-958b8479eaa0","name":"Note: Render as HTML"},{"parameters":{"content":"### Post Digest to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Archive Digest in Google Sheets · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"377be486-8cd6-2a88-17b2-984fb6c29ee9","name":"Note: Post Digest to Slack"},{"parameters":{"content":"### Archive Digest in Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Stamp Processing Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"140e9d4e-bf79-3e96-638c-b25c496eabe3","name":"Note: Archive Digest in Google Sheets"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"005afe34-62fe-ed3c-d634-490f19593c62","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Drafts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"b131416c-95b8-a734-4c7f-d95d09dd9deb","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Drafts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"31ef746a-5046-ade4-7c9c-3951ed9aa50f","name":"Note: Sort Drafts Newest First"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Guard Non-Empty topic","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"183fd48a-1a03-3883-001d-73fd9cb2324a","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Guard Non-Empty topic\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"9f82d897-1d63-76ae-4e65-bc0ba1b56102","name":"Note: Guard Non-Empty topic"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"c6006eb0-9d36-e4ae-34f3-748387ac0993","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"408f89b0-2fbd-8dec-1e8f-329bde553975","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"b35e39d8-63a7-5615-78f4-89a8f116dc2e","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,1540],"id":"0a37691f-ddd6-ae05-65d4-92100cb86cb2","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,1540],"id":"5912f495-cd7a-48e3-5d9b-f35b6bd1bca8","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Produce newsletters with Google Sheets and WordPress at scale\n\n**Pattern:** Content Generation · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nProduce newsletters with Google Sheets and WordPress at scale. It runs automatically on a schedule.\n\n## Why it exists\nManual social copy is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nHourly Schedule → Read Recent from Google Sheets → Newest First → Trim to Digest Size → Summarize Content (AI) → Render as HTML → Post Digest to Slack → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating social copy in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Removes copy-paste errors\n- Has retries and error handling built in\n- Improves response time\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Groq API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"007dc30a-67d0-a288-26f2-8bd5151b684e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"9ba1b2df-10c0-d843-ff77-f7a293ef558e","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"e065eb36-69be-7cee-ec04-6e7e6c61a70d","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your social copy process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"a38b4f1f-a543-978e-cf5e-cd8d44119132","name":"🛠 Customize me"}],"connections":{"Hourly Schedule":{"main":[[{"node":"Read Recent from Google Sheets","type":"main","index":0}]]},"Read Recent from Google Sheets":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Render as HTML","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Render as HTML":{"main":[[{"node":"Post Digest to Slack","type":"main","index":0}]]},"Post Digest to Slack":{"main":[[{"node":"Archive Digest in Google Sheets","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Digest in Google Sheets":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Drafts Newest First","type":"main","index":0}]]},"Sort Drafts Newest First":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Guard Non-Empty topic","type":"main","index":0}]]},"Guard Non-Empty topic":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"ca3ffe4c-761e-4d5f-9280-3b3af0dde44b","id":"FDX05033"}