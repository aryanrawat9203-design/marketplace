      "name": "Drop Already-Processed Items"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM drafts WHERE updated_at > NOW() - INTERVAL '1 day' ORDER BY updated_at DESC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
