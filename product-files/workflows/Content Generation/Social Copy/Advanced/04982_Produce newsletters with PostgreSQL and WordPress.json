{"name":"Produce newsletters with PostgreSQL and WordPress","nodes":[{"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":9,"triggerAtMinute":0}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"579cbfc5-382a-4f94-949a-23fa42b04723","name":"Daily Schedule"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e2f8c393-a76c-4f85-a765-75abd30c73cc","leftValue":"={{ $json.draftId || $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"9421100e-50e2-4244-a8f1-b71922734162","name":"Keep Valid Drafts"},{"parameters":{"assignments":{"assignments":[{"id":"89bbf2b8-c998-4ec5-82a8-d90dec2cfac1","name":"brief","value":"={{ $json.topic || $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"bcfab1b5-e0b7-4beb-875d-9220b68981e8","name":"tone","value":"={{ $json.tone || 'professional' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[378,400],"id":"a9799e83-d53a-45b8-8698-4f51d4e2a4be","name":"Build the Brief"},{"parameters":{"promptType":"define","text":"=Write {{ $json.tone }} content for: {{ $json.brief }}","messages":{"messageValues":[{"message":"You write production-quality social copy content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[702,400],"id":"af6ee195-72dd-4881-aff1-0d72ffb67c5d","name":"Draft with AI Writer","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[945,970],"id":"144f3e0d-dd51-4fb8-b87c-39b93078e398","name":"Groq Writer Model"},{"parameters":{"promptType":"define","text":"=Improve this draft without changing facts:\n\n{{ $json.text }}","messages":{"messageValues":[{"message":"You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1269,400],"id":"9bcbab7a-8823-4153-a798-b2376383e5ea","name":"Refine with AI Editor","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[1512,970],"id":"fc062d1f-f409-4c07-a8e9-f9ffe78a0e3c","name":"Groq Editor Model"},{"parameters":{"mode":"markdownToHtml","markdown":"={{ $json.text }}","options":{}},"type":"n8n-nodes-base.markdown","typeVersion":1,"position":[1836,400],"id":"67e9b0a4-65bd-472a-ac78-e6d38885e6b8","name":"Convert to HTML"},{"parameters":{"title":"={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}","additionalFields":{"content":"={{ $json.html || $json.text }}","status":"draft"}},"type":"n8n-nodes-base.wordpress","typeVersion":1,"position":[2160,400],"id":"c907231c-441c-4e8c-8368-5328977d9dbc","name":"Publish Draft to WordPress","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"draftId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[2484,400],"id":"5e68e34e-47d0-4a33-8491-a17891efa47e","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"8a0f6d5e-59be-4617-9125-31817632fbf4","name":"pipeline","value":"Social Copy","type":"string"},{"id":"0bcaeb73-5809-4d09-aa19-75e77269b347","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2808,400],"id":"12313d53-9bc5-4f49-ba5d-a140aee6f1c1","name":"Tag Pipeline Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3132,400],"id":"d4a4b744-91e7-4069-842c-10b56c03f924","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"0e12e674-876d-4134-863a-b09acd55100f","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"fdbc0504-d451-42bd-8c37-593d73a182a7","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"468a6ed3-289c-434f-b1ca-14857e448ccc","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3456,400],"id":"030dc1d6-a0d8-46f7-82a1-759930e457b9","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[3780,400],"id":"67c6a01c-13cb-4ebf-9c38-55e96ab078ef","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Produce newsletters with PostgreSQL and WordPress — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4104,400],"id":"94ffa877-7984-41e6-9eae-50fbae3e64b9","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"800390fb-7ea1-44b3-9e8e-4f1d327d08e5","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"e65550e7-7cd8-49d1-9366-2435049b9a7d","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"97ecf70d-e305-4a38-af51-eefe5c60054c","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3456,1420],"id":"5016b544-e30a-4daf-986a-da78282bd8ac","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3780,1420],"id":"fdb0a806-3b30-4c60-90c0-ea053563676d","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Daily Schedule\n\nStarts the workflow on a timer — daily at 9:00. No input data; downstream nodes fetch what they need.\n\nNext: Keep Valid Drafts","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"4cd6d0cc-e907-fdc9-fa5f-caf2b31a3c32","name":"Note: Daily Schedule"},{"parameters":{"content":"### Keep Valid Drafts\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Build the Brief","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"933f3b54-815a-b706-ba53-0e3f5f4d2c0d","name":"Note: Keep Valid Drafts"},{"parameters":{"content":"### Build the Brief\n\nShapes the item: writes `brief`, `tone`. Keeps the schema explicit between stages.\n\nNext: Draft with AI Writer","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"7aa84e68-c98d-cbd1-b7b8-5d246853c0db","name":"Note: Build the Brief"},{"parameters":{"content":"### Draft with AI Writer\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Refine with AI Editor · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"6bc6c8e2-e431-1c58-bd4c-0d0dd057899f","name":"Note: Draft with AI Writer"},{"parameters":{"content":"### Groq Writer Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Draft with AI Writer** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,1090],"id":"c599f6e6-0cca-c8fe-3fcc-64902ccdf102","name":"Note: Groq Writer Model"},{"parameters":{"content":"### Refine with AI Editor\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Convert to HTML · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,520],"id":"70a93138-22d4-6c2a-afff-1987cfced195","name":"Note: Refine with AI Editor"},{"parameters":{"content":"### Groq Editor Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Refine with AI Editor** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1452,1090],"id":"4777e584-a336-d01e-52c3-5b663455eb6e","name":"Note: Groq Editor Model"},{"parameters":{"content":"### Convert to HTML\n\nConverts markdown to HTML for rich rendering in email/CMS.\n\nNext: Publish Draft to WordPress","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,520],"id":"a9a12904-7d8b-10cf-7649-931b6799fb37","name":"Note: Convert to HTML"},{"parameters":{"content":"### Publish Draft to WordPress\n\nwordpress — `action` operation against the connected account.\n\nPorts: ①→ Align Field Names · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 WordPress credentials","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2100,520],"id":"e6df2aed-d307-7e5a-50fc-3d68a58f8f44","name":"Note: Publish Draft to WordPress"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2424,520],"id":"386eede8-e234-a7d6-5beb-1065d541482b","name":"Note: Align Field Names"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2748,520],"id":"e30e4572-6265-c2e1-8f7f-7db89a4d3d11","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3072,520],"id":"e30270ae-8dc2-d210-7190-15fbccd127c0","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,520],"id":"2bafdab8-0d57-a4dd-2e4f-b0e45724f4d2","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,520],"id":"98b2cc06-1373-7308-b68e-c667a06e72b3","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4044,520],"id":"eda171d3-02cc-0e6d-828c-9f42ffd21f5e","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,1540],"id":"f714dc83-7958-6119-034e-66327afc816b","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,1540],"id":"fdcabc78-496c-1725-32e7-5fcca26980d6","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Produce newsletters with PostgreSQL and WordPress\n\n**Pattern:** Content Generation · **Level:** Advanced · **Trigger:** Scheduled\n\n## What it does\nProduce newsletters with PostgreSQL and WordPress. It runs automatically on a schedule.\n\n## Why it exists\nManual social copy is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nDaily Schedule → Keep Valid Drafts → Build the Brief → Draft with AI Writer → Refine with AI Editor → Convert to HTML → Publish Draft to WordPress → …\n\n## Use it for\n- Teams that want to content generation without manual effort\n- Anyone automating social copy in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Standardizes the process every time\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: Groq API key; Postgres connection; Slack OAuth2; WordPress credentials.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"d02ed2b6-602f-83ed-e7df-294ad45e7dba","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"392bb17b-8cb1-e05e-6512-b613185eda73","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"e30bd72b-20fc-2591-7b28-679c97c12718","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your social copy process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"1083066e-7f5d-7ae5-a9de-6db5926771c4","name":"🛠 Customize me"}],"connections":{"Daily Schedule":{"main":[[{"node":"Keep Valid Drafts","type":"main","index":0}]]},"Keep Valid Drafts":{"main":[[{"node":"Build the Brief","type":"main","index":0}]]},"Build the Brief":{"main":[[{"node":"Draft with AI Writer","type":"main","index":0}]]},"Groq Writer Model":{"ai_languageModel":[[{"node":"Draft with AI Writer","type":"ai_languageModel","index":0}]]},"Draft with AI Writer":{"main":[[{"node":"Refine with AI Editor","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Groq Editor Model":{"ai_languageModel":[[{"node":"Refine with AI Editor","type":"ai_languageModel","index":0}]]},"Refine with AI Editor":{"main":[[{"node":"Convert to HTML","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Convert to HTML":{"main":[[{"node":"Publish Draft to WordPress","type":"main","index":0}]]},"Publish Draft to WordPress":{"main":[[{"node":"Align Field Names","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"a246aaf6-2802-4e22-81a8-3329f8227fd9","id":"FDX04982"}