{
  "name": "Produce newsletters with PostgreSQL and WordPress",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "triggerAtHour": 9,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -200,
        400
      ],
      "id": "f03572c0-a3ed-4887-8f21-c59149d3fff7",
      "name": "Daily Schedule"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "2145fa12-b14d-4e75-bcd1-a1dca23f2860",
              "leftValue": "={{ $json.draftId || $json.topic }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [
        40,
        400
      ],
      "id": "84c5dc4a-bbe7-4890-8774-f92463b0979f",
      "name": "Keep Valid Drafts"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "34e4a0fa-3066-4aa3-9ce0-0ea54d67ac3c",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "7a8b2dd3-4838-4d72-b8bc-bfabbb8739e9",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        280,
        400
      ],
      "id": "8fb8d4ea-21ab-4acb-abc8-38abec13b819",
      "name": "Build the Brief"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write {{ $json.tone }} content for: {{ $json.brief }}",
        "messages": {
          "messageValues": [
            {
              "message": "You write production-quality social copy content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        520,
        400
      ],
      "id": "b02ea045-7b0e-46f1-8e7d-d9dd591e61e2",
      "name": "Draft with AI Writer",
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        700,
        590
      ],
      "id": "2cbc0a14-1081-42ed-a05f-205e894c1a7c",
      "name": "Groq Writer Model"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Improve this draft without changing facts:\n\n{{ $json.text }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        940,
        400
      ],
      "id": "99d9eed0-4650-4fd0-a7bc-cd8a0100702c",
      "name": "Refine with AI Editor",
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        1120,
        590
      ],
      "id": "394502f0-c347-494d-ab26-8813422c2341",
      "name": "Groq Editor Model"
    },
    {
      "parameters": {
        "mode": "markdownToHtml",
        "markdown": "={{ $json.text }}",
        "options": {}
      },
      "type": "n8n-nodes-base.markdown",
      "typeVersion": 1,
      "position": [
        1360,
        400
      ],
      "id": "8bb184ef-54fc-4f19-bf83-9ef9ca77971e",
      "name": "Convert to HTML"
    },
    {
      "parameters": {
        "title": "={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}",
        "additionalFields": {
          "content": "={{ $json.html || $json.text }}",
          "status": "draft"
        }
      },
      "type": "n8n-nodes-base.wordpress",
      "typeVersion": 1,
      "position": [
        1600,
        400
      ],
      "id": "ec563c77-da07-412d-91fb-db8b3809627f",
      "name": "Publish Draft to WordPress",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "keys": {
          "key": [
            {
              "currentKey": "id",
              "newKey": "draftId"
            }
          ]
        },
        "additionalOptions": {}
      },
      "type": "n8n-nodes-base.renameKeys",
      "typeVersion": 1,
      "position": [
