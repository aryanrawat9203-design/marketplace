]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[6777,400],"id":"4f8623e6-920e-4347-9a0e-b90025b695c7","name":"Sort Drafts Newest First"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7101,400],"id":"3ea621f6-3f29-4eb9-bf86-ac223d5e6d1a","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8cdd8126-7891-457f-8f37-c597a8b640d1","leftValue":"={{ $json.topic }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[7425,400],"id":"fae4db54-ed36-490f-84e4-9bf0fe14633d","name":"Guard Non-Empty topic"},{"parameters":{"assignments":{"assignments":[{"id":"d8f785aa-f72f-4bb3-9a99-9ab7d49bc508","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"0fc1c1a0-fada-4bea-a6ed-8a1c2ff1d252","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9626dbc4-f707-4fda-8e10-64cfe3790e7a","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7749,400],"id":"578ff1f3-f28b-4598-95e7-6c884c411d69","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"title":"={{ $json.topic || $json.draftId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8073,400],"id":"8cda0a8c-ea6c-49ec-8ae7-5a4613f185af","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Draft blog drafts with Airtable and WordPress 