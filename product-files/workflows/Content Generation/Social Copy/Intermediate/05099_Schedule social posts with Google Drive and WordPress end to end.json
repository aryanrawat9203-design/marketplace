      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        880,
        590
      ],
      "id": "a0ed4224-c271-4c58-b370-490de4cc24a3",
      "name": "Groq Editor Model"
    },
    {
      "parameters": {
        "title": "={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}",
        "additionalFields": {
          "content": "={{ $json.html || $json.text }}",
