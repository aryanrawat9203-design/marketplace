Fail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Digest long emails with Google Sheets and Outlook 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,400],"id":"cfb6546e-81e4-429b-b6da-55712f66f091","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"e601998b-8b75-4dcd-8a5e-9e463f7f9031","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"632bfe77-8507-4930-8c46-350bcb754af0","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"003be752-9aa5-4cb8-a570-4a53cb80e8c2","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5157,1420],"id":"4a25cf74-ff0e-42fc-b3db-236e3559ded5","name":"Capture Failure Context"},{"parameters":{"subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","bodyContent":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[5481,1420],"id":"5cd659d6-6359-4ec3-a1ac-adaa70e3e8c9","name":"Escalate Failure to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf05659-draft`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Collect Raw Text","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"6f552199-576e-430e-364b-6bbe30faa957","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Collect Raw Text\n\nShapes the item: writes `content`. Keeps the schema explicit between stages.\n\nNext: Extract Structured Fields","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"0db1a42e-d83b-4926-d87b-6e059a07368a","name":"Note: Collect Raw Text"},{"parameters":{"content":"### Extract Structured Fields\n\nPulls structured fields (draftId, topic, audience) out of free text using a strict extraction prompt.\n\nPorts: ①→ All Required Fields Found? · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"0839b5f1-bc66-0506-217b-5e66e53ea8c8","name":"Note: Extract Structured Fields"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Extract Structured Fields** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"83573a62-a456-43da-6927-fb7028fe13b7","name":"Note: Groq Chat Model"},{"parameters":{"content":"### All Required Fields Found?\n\nTwo-way gate on `={{ $json.output?.draftId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Upsert into Google Sheets · ②→ Queue for Manual Review","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,520],"id":"03a65829-3161-9e3a-36a7-0bf36bd0abcb","name":"Note: All Required Fields Found?"},{"parameters":{"content":"### Upsert into Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Merge Review Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,280],"id":"e195fe41-141e-2a60-9bae-f1456f14d05c","name":"Note: Upsert into Google Sheets"},{"parameters":{"content":"### Queue for Manual Review\n\nmicrosoftOutlook — `action` operation against the connected account.\n\nPorts: ①→ Merge Review Paths · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Microsoft OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,880],"id":"e0d9ad3b-8cc1-ce03-50d7-889f202a0dd0","name":"Note: Queue for Manual Review"},{"parameters":{"content":"### Merge Review Paths\n\nRejoins 2 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"79cfbc3b-d5c1-e5fd-c19d-d3c65b76d4f5","name":"Note: Merge Review Paths"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Guard Non-Empty topic","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"594c1697-d6a3-f85e-5967-2f92fd511151","name":"Note: Align Field Names"},{"parameters":{"content":"### Guard Non-Empty topic\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"682ba94c-83c4-b103-b012-607aeddd0ae6","name":"Note: Guard Non-Empty topic"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Drafts Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"b266b1bc-e6f8-9e6b-a054-a5ed64877b67","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Drafts Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"cdb8397f-adfb-e0e7-a49c-d297ffa62f28","name":"Note: Sort Drafts Newest First"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"f4b0388e-95ff-861a-39a1-1656a9f012c9","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"053a1358-c6eb-405e-69c3-909e04590d02","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"718feba6-fd84-6428-70fb-409490b88422","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"69d7a0b0-d0dd-1be2-36be-58aba411e852","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"baa3a061-7298-bf1c-eab9-0b93d575fb55","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Outlook","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,1540],"id":"c5d96ae2-d93a-2418-f6ea-ccf2720f99f2","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Outlook\n\nmicrosoftOutlook — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Microsoft OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"9ebf5b8e-71bf-4534-e75a-4389c9545184","name":"Note: Escalate Failure to Outlook"},{"parameters":{"content":"# Digest long emails with Google Sheets and Outlook 24/7\n\n**Pattern:** AI Summarize & Route · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nDigest long emails with Google Sheets and Outlook 24/7. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual social copy is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Collect Raw Text → Extract Structured Fields → All Required Fields Found? → Upsert into Google Sheets → Merge Review Paths → Align Field Names → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating social copy in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Scales without extra headcount\n- Saves hours of manual work each week\n\n## Before first run\nConnect credentials: Google OAuth2 / service account; Groq API key; Microsoft OAuth2; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"4ab853b6-dca9-41d0-38d2-a2bdeabda22e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"66c3cd21-80a3-9c54-a865-942be228c0e0","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"f7d882da-5392-73c3-d4d2-65cfa7c18836","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"7e6ce3aa-3e5a-9b6f-190b-a5104d25dd7c","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your social copy process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"172aa7d0-2ad0-e913-b47b-610e3714543b","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Collect Raw Text","type":"main","index":0}]]},"Collect Raw Text":{"main":[[{"node":"Extract Structured Fields","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Extract Structured Fields","type":"ai_languageModel","index":0}]]},"Extract Structured Fields":{"main":[[{"node":"All Required Fields Found?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"All Required Fields Found?":{"main":[[{"node":"Upsert into Google Sheets","type":"main","index":0}],[{"node":"Queue for Manual Review","type":"main","index":0}]]},"Upsert into Google Sheets":{"main":[[{"node":"Merge Review Paths","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Queue for Manual Review":{"main":[[{"node":"Merge Review Paths","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Review Paths":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Guard Non-Empty topic","type":"main","index":0}]]},"Guard Non-Empty topic":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Drafts Newest First","type":"main","index":0}]]},"Sort Drafts Newest First":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Outlook","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"4f0c0031-3da8-4c1d-869d-331f84a4f965","id":"FDX05659"}