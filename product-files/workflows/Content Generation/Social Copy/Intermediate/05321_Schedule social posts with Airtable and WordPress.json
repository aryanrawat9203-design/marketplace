{"name":"Schedule social posts with Airtable and WordPress","nodes":[{"parameters":{"rule":{"interval":[{"field":"weeks","triggerAtDay":[1],"triggerAtHour":9}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"2704bbb2-0d2e-48ba-ad83-84f6aebb0f3b","name":"Weekly Schedule"},{"parameters":{"assignments":{"assignments":[{"id":"a335e9cb-a5e0-4c51-817a-7e27829b2572","name":"draftId","value":"={{ $json.draftId || $json.id || $execution.id }}","type":"string"},{"id":"fbbab54b-1944-4eeb-a921-d1ab4e3b91bd","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"ba041fcb-ce8d-4618-bbe6-743bc494aedf","name":"Stamp & Shape Draft"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f98d2f64-2cbc-4cac-9dd7-c97c134b6969","leftValue":"={{ $json.draftId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"675177b7-6858-4303-a053-6a2e536484f3","name":"Payload Valid?"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Content Generation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Drafts"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"ccfc9894-c4dd-4478-8b88-b3909015d754","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"assignments":{"assignments":[{"id":"a584fe8b-b59c-44c9-943a-4b10a9fae599","name":"brief","value":"={{ $json.topic || $json.chatInput || JSON.stringify($json) }}","type":"string"},{"id":"23ad3ef7-565b-4ba8-be91-97784b6cd96d","name":"tone","value":"={{ $json.tone || 'professional' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[702,400],"id":"31d7801a-ce68-4ee8-8891-af419795abd8","name":"Build the Brief"},{"parameters":{"promptType":"define","text":"=Write {{ $json.tone }} content for: {{ $json.brief }}","messages":{"messageValues":[{"message":"You write production-quality social copy content. Follow the brief exactly, match the requested tone, and return clean markdown with a title line. No preamble, no explanations."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1026,400],"id":"e3e9c9eb-a6c1-4d39-9430-c7a5c02d419a","name":"Draft with AI Writer","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[1269,970],"id":"660262b9-6668-4552-9ad0-d8f44f8a5abe","name":"Groq Writer Model"},{"parameters":{"promptType":"define","text":"=Improve this draft without changing facts:\n\n{{ $json.text }}","messages":{"messageValues":[{"message":"You are a strict editor. Check the draft for factual gaps, tone mismatches and weak openings. Return the improved draft only — do not describe your changes."}]},"options":{}},"type":"@n8n/n8n-nodes-langchain.chainLlm","typeVersion":1.7,"position":[1593,400],"id":"02fc23a4-69c9-4075-9da7-c05d3a5e07ba","name":"Refine with AI Editor","onError":"continueErrorOutput"},{"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGroq","typeVersion":1,"position":[1836,970],"id":"dbed37d1-4cbf-4e79-a339-9364b02b3b36","name":"Groq Editor Model"},{"parameters":{"title":"={{ ($json.text || '').split('\\n')[0].slice(0, 80) }}","additionalFields":{"content":"={{ $json.html || $json.text }}","status":"draft"}},"type":"n8n-nodes-base.wordpress","typeVersion":1,"position":[2160,400],"id":"a3db5cfa-6864-4a1a-855c-92076bed63ca","name":"Publish Draft to WordPress","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[2484,400],"id":"63761f5b-5852-45f6-858e-09bfb1feb890","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2808,400],"id":"52d28387-ce5c-4d06-b9e7-b3d48f0da0f7","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.topic }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3132,400],"id":"f55c1123-70d8-4ba0-808e-084ac94f7cd5","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"83105e62-3488-45fb-9e47-4c80697c376d","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"8ff1aaed-6427-4988-a269-d4bd0ded1088","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3456,400],"id":"7287da9f-dae1-4141-9515-430f24dcce07","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"search","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Content Generation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Drafts"},"filterByFormula":"={LastModified} > DATEADD(NOW(), -1, 'days')","options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[3780,400],"id":"359f1ea3-683b-47e5-8df7-d0d246293187","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4104,400],"id":"63c69fc6-c97f-45ad-a1df-9598347b131d","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"6fe90e1c-792b-4f60-b1b5-bb1f52db89a9","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"181f6e55-f4ae-480d-ba88-29260de9bacf","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"9dfca9ee-3c34-4b57-8724-279c5677bab9","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4428,400],"id":"a986d37a-072c-4dc2-b854-32a5d6658ecc","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4752,400],"id":"93fe2cb1-1ebf-4060-a55d-7f44b2693654","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=✅ Schedule social posts with Airtable and WordPress — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5076,400],"id":"ec06c464-1b9e-4f4e-98f6-d94fdfcb2f5d","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"51498941-a157-4c2a-a7c7-235c56758452","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"eeeabe81-78e1-4df6-9cbe-f627ecfe8549","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"b1774e11-e105-47a3-a1a5-54e0c0a9516b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4428,1420],"id":"e0d06204-9ff5-4d3e-9209-27aa4b223c30","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4752,1420],"id":"9b637ab4-1e1b-4a5b-a91b-82aff289e781","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Content Generation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Drafts"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[5076,1420],"id":"4c41dcd0-b1b7-4d35-9748-7d2c21d7258c","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Weekly Schedule\n\nStarts the workflow on a timer — weekly. No input data; downstream nodes fetch what they need.\n\nNext: Stamp & Shape Draft","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"2fc78f86-5a8c-32a0-c752-bb50e7259a86","name":"Note: Weekly Schedule"},{"parameters":{"content":"### Stamp & Shape Draft\n\nShapes the item: writes `draftId`, `receivedAt`. Keeps the schema explicit between stages.\n\nNext: Payload Valid?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"fa119844-aa9f-a177-1110-d0171e3b1f95","name":"Note: Stamp & Shape Draft"},{"parameters":{"content":"### Payload Valid?\n\nTwo-way gate on `={{ $json.draftId }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Build the Brief · ②→ Record Rejected Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"227e0730-8c9f-e3c0-bca7-3995dd83ca7e","name":"Note: Payload Valid?"},{"parameters":{"content":"### Record Rejected Input\n\ngoogleSheets — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,1030],"id":"0c0bd828-0b3a-308a-9568-d63190a4a2d0","name":"Note: Record Rejected Input"},{"parameters":{"content":"### Build the Brief\n\nShapes the item: writes `brief`, `tone`. Keeps the schema explicit between stages.\n\nNext: Draft with AI Writer","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"a30df4a6-40c1-0f32-d266-a2e2b9c87486","name":"Note: Build the Brief"},{"parameters":{"content":"### Draft with AI Writer\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Refine with AI Editor · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"0ad30db5-1806-de1d-f38d-a941ba1a0549","name":"Note: Draft with AI Writer"},{"parameters":{"content":"### Groq Writer Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Draft with AI Writer** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"7d61f8db-98eb-97b0-bfcb-0280b33d834f","name":"Note: Groq Writer Model"},{"parameters":{"content":"### Refine with AI Editor\n\nSingle fixed LLM step (no tool choice) — cheaper and more predictable than an agent.\n\nPorts: ①→ Publish Draft to WordPress · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"81bcc57f-bc03-7469-f558-313d903c36ad","name":"Note: Refine with AI Editor"},{"parameters":{"content":"### Groq Editor Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Refine with AI Editor** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,1090],"id":"a4006557-b264-6dd2-4c21-aba25a796924","name":"Note: Groq Editor Model"},{"parameters":{"content":"### Publish Draft to WordPress\n\nwordpress — `action` operation against the connected account.\n\nPorts: ①→ Serialize Run Output (CSV) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 WordPress credentials","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2100,520],"id":"aa38a46d-06b9-3dd6-ebec-708f4a929422","name":"Note: Publish Draft to WordPress"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2424,520],"id":"f7dd60ff-4983-e4bf-0a7f-081f29836699","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Enrich with Reference Data · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2748,520],"id":"f3e3d771-2385-b319-79f2-0cb906aad923","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3072,520],"id":"220dac12-b0c2-f50b-a806-2ced584b2800","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3396,520],"id":"ba3aea8f-e3f7-3bae-43d1-0481e228e8bc","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3720,520],"id":"410aa2c6-6309-6254-7729-dfd73986a45c","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4044,520],"id":"119491c3-c30d-8fe0-63c8-6d308d1e62b3","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4368,520],"id":"cb89af9c-f724-8f34-bd42-65da6ab6d55f","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,520],"id":"8715708e-14dc-11e8-ae5c-419eed8c2b23","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,520],"id":"aedd62da-bb28-0581-98ae-c7c24643bd46","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4368,1540],"id":"dc4cba68-e871-84a2-946e-eeed91d0ab87","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4692,1540],"id":"9db59b35-4d02-735b-2167-555e3124367d","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nairtable — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Airtable PAT","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5016,1540],"id":"5dbf3e4a-42c0-73e2-7dd6-0050f7ee43e0","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Schedule social posts with Airtable and WordPress\n\n**Pattern:** Social Scheduler · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nSchedule social posts with Airtable and WordPress. It runs automatically on a schedule.\n\n## Why it exists\nManual social copy is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nWeekly Schedule → Stamp & Shape Draft → Payload Valid? → Build the Brief → Draft with AI Writer → Refine with AI Editor → Publish Draft to WordPress → …\n\n## Use it for\n- Teams that want to social scheduler without manual effort\n- Anyone automating social copy in content creation\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Scales without extra headcount\n- Runs 24/7 in the background\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Google OAuth2 / service account; Groq API key; Slack OAuth2; WordPress credentials.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"467f43c0-2df4-52f9-4a0c-58e6beb225ea","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"7514883a-ea0f-20a9-a63d-210934c3f355","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"2ea35d86-21d4-52b0-ab0c-ef7418feaac8","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your social copy process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"a56712eb-5328-be39-d01a-b6390cc3d6ce","name":"🛠 Customize me"}],"connections":{"Weekly Schedule":{"main":[[{"node":"Stamp & Shape Draft","type":"main","index":0}]]},"Stamp & Shape Draft":{"main":[[{"node":"Payload Valid?","type":"main","index":0}]]},"Payload Valid?":{"main":[[{"node":"Build the Brief","type":"main","index":0}],[{"node":"Record Rejected Input","type":"main","index":0}]]},"Build the Brief":{"main":[[{"node":"Draft with AI Writer","type":"main","index":0}]]},"Groq Writer Model":{"ai_languageModel":[[{"node":"Draft with AI Writer","type":"ai_languageModel","index":0}]]},"Draft with AI Writer":{"main":[[{"node":"Refine with AI Editor","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Groq Editor Model":{"ai_languageModel":[[{"node":"Refine with AI Editor","type":"ai_languageModel","index":0}]]},"Refine with AI Editor":{"main":[[{"node":"Publish Draft to WordPress","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Publish Draft to WordPress":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","