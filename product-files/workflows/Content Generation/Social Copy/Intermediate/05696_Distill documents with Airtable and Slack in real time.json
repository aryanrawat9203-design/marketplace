{"name":"Distill documents with Airtable and Slack in real time","nodes":[{"parameters":{"httpMethod":"POST","path":"wf05696-draft","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"6890df34-29ce-437e-92c4-694ae2decf17","name":"Receive Inbound Webhook","webhookId":"c7d13084-ae75-453f-9622-1f76df627804"},{"parameters":{"assignments":{"assignments":[{"id":"f6b8c4ed-c02b-4fc8-98ec-311a981e29ff","name":"draftId","value":"={{ $json.draftId || $json.id || $execution.id }}","type":"string"},{"id":"8b26d219-8e23-46d0-b6d2-0e496b7f3ec5","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"e6abdd75-fda8-4ec3-bfb2-001e3778d5cd","name":"Stamp & Shape Draft"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7d00b5ff-fd64-440a-9f22-7b13a9a65919","leftValue":"={{ $json.draftId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"f30c1dd9-7cfe-485a-a560-3c5a050dd362","name":"Payload Valid?"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"Content Generation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Drafts"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[378,910],"id":"79b251ad-f1e5-4b92-84a3-07e3a490a871","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"inputText":"={{ $json.topic || JSON.stringify($json) }}","categories":{"categories":[{"category":"Action Needed","description":"Drafts that are action needed for the social copy team."},{"category":"Reference","description":"Drafts that are re