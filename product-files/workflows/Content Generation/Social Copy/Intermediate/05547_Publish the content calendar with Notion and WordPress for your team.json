      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize incoming draft records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    draftId: String(j.draftId ?? j.id ?? '').trim(),\n    topic: typeof j.topic === 'string' ? j.topic.trim() : j.topic ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40,
        400
      ],
      "id": "6562605c-5c4e-462e-930d-cee574535167",
      "name": "Normalize Draft Payload"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "c95861df-d954-412d-8d65-66182c26330e",
              "name": "brief",
              "value": "={{ $json.topic || $json.chatInput || JSON.stringify($json) }}",
              "type": "string"
            },
            {
              "id": "51b97cc0-6f88-4093-9f82-ab1481b4334a",
              "name": "tone",
              "value": "={{ $json.tone || 'professional' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
