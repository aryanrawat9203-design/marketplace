s that are reference for the social copy team."},{"category":"Ignore","description":"Drafts that are ignore for the social copy team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[702,400],"id":"6f90a58b-9ff3-4ba9-b7c2-a3492b36b16d","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[945,970],"id":"8c00a2e9-b5f9-4c5d-820a-7ec8dab2d26e","name":"OpenRouter Chat Model"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1269,-80],"id":"676adf15-377a-4d9d-aba6-6fc6c6eda153","name":"Store as Action Needed","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1593,370],"id":"db6fed7a-99ad-47b6-a2c2-130fc71155cd","name":"Store as Reference","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1917,820],"id":"d9f409d5-4309-4991-80e4-9d81cda1bb73","name":"Store as Ignore","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#content","cachedResultName":"#content"},"text":"=[Other] {{ $json.topic }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[2241,1270],"id":"c5bc80ca-181b-4c31-bd8f-7e9c126d201e","name":"Alert Slack — Other","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2889,400],"id":"8d681a0c-1f0f-4895-884e-b9cfcaab2939","name":"Reunite Branches"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.topic }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3861,400],"id":"1313fe37-a134-472f-b0f0-adc0261c4c67","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"20c61adc-852b-4aac-a87c-1daaf9c6728b","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c2988086-0c66-4892-b8fc-6d69774501d5","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4185,400],"id":"e47fab56-0c67-47e8-9a0d-b88fc79737a1","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4509,400],"id":"6b12e9ab-3736-4e6a-9008-dab299a78701","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4833,400],"id":"ede64917-4bf6-4af9-bb20-dacfed540033","name":"Persist Run Metadata"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Draft Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5157,400],"id":"63d23328-7cd4-4187-9b74-3e5b02884f33","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5481,400],"id":"95527e37-19b1-41e1-8683-c7cac8d825a5","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Drafts"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5805,400],"id":"bffa9e7d-960e-43f6-b729-c3330609a193","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6129,400],"id":"e323c281-4126-490d-951f-b5f276662dfd","name":"Record Sub-workflow Result"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per draft (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.draftId, j.topic].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6453,400],"id":"a46ec070-e799-44a5-9cbd-1ab23b9920a3","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6777,400],"id":"d7fe68ac-4442-4af2-a210-d600b8a872be","name":"Drop Already-Processed Items"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[7101,400],"id":"62c197b7-4553-4373-af73-b03660a41916","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO draft_log (draftId, topic, audience, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.draftId, $json.topic, $json.audience ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[7425,400],"id":"77b3643b-6ecc-47d2-9678-f9630cf19a78","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7749,400],"id":"bbb62c8b-7713-4d40-97d5-1dccaf74d331","name":"Stamp Processing Time"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"tone","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8073,400],"id":"93651ef5-0444-4b45-ba7e-d8eb1142923d","name":"Sort Drafts Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"7cef097f-4a94-439e-aeb5-af6e6e93a315","name":"runAt","value"