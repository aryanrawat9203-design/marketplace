ringify($json).slice(0,200) }}","type":"string"},{"id":"87f8600a-c03a-4121-85d9-e75b76b06d72","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3537,1420],"id":"82d7a41b-5937-4718-97e8-dad66220c6d4","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[3861,1420],"id":"804c30ee-fa4e-4fe7-a3b0-66b3e4b5bb21","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf06958-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Read Recent from Airtable","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"6ecbb344-e627-34ae-2901-ca008531a6db","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Read Recent from Airtable\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"2a65bf3e-abad-6426-6397-d214227e2ec8","name":"Note: Read Recent from Airtable"},{"parameters":{"content":"### Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Trim to Digest Size","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"ef0ff3ce-cbf5-a2ac-f0f1-b3949527f625","name":"Note: Newest First"},{"parameters":{"content":"### Trim to Digest Size\n\nCaps the stream at 15 items to protect downstream quotas.\n\nNext: Summarize Content (AI)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"f3e196d3-e47a-e3ee-ca01-ad0d8b08d92e","name":"Note: Trim to Digest Size"},{"parameters":{"content":"### Summarize Content (AI)\n\nMap-reduce summarization chain — handles long content without blowing the context window.\n\nPorts: ①→ Post Digest to Slack · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"fa28040c-900c-43f0-c09c-605dbb881df0","name":"Note: Summarize Content (AI)"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Summarize Content (AI)** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1090],"id":"d27d58c6-8fef-f107-4a57-0a27a5559198","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Post Digest to Slack\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Archive Digest in Airtable · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"ffa21019-993b-298a-3c9a-9e6277ebdb3e","name":"Note: Post Digest to Slack"},{"parameters":{"content":"### Archive Digest in Airtable\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Guard Non-Empty title · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"24864c67-bd17-6f8b-a83f-57d902b1db75","name":"Note: Archive Digest in Airtable"},{"parameters":{"content":"### Guard Non-Empty title\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"1f66fe1b-e6de-dcad-c1c6-4497e10f2b8a","name":"Note: Guard Non-Empty title"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Sort Documents Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"e2422e63-5cd3-638a-c861-8a5c123f9ead","name":"Note: Align Field Names"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"3726c6f0-731d-7991-7bbf-f5cfaa71a25a","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"5dec1469-8362-1581-b6d5-f38bb40ea1a8","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Airtable)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"395d3594-90ae-34d8-9ae4-f801ee01cc2a","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Airtable)\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"c595c10e-e8bb-81de-c99a-c7a035920945","name":"Note: Append Audit Row (Airtable)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"95c1705e-4b44-e824-56c3-c2ede2170288","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,1540],"id":"54e973e5-6dba-82b6-31b6-7835f3c4bb83","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,1540],"id":"7883efd1-6c1a-94a0-c5a0-9c08c4cdd321","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Distill long emails with Airtable and Slack automatically\n\n**Pattern:** AI Summarize & Route · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nDistill long emails with Airtable and Slack automatically. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual embeddings is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Read Recent from Airtable → Newest First → Trim to Digest Size → Summarize Content (AI) → Post Digest to Slack → Archive Digest in Airtable → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating embeddings in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Removes copy-paste errors\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: Airtable PAT; OpenAI API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"51fb0590-b619-0dcc-ff44-d2bc170f2d97","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"77b89887-c6be-f799-02b7-e1226a79e83e","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"1e47096e-afda-31c5-b8fa-8aaa4f09cce5","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"0717a4e2-4619-caa9-7cdc-38718e791a67","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your embeddings process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"5f1193dc-45ef-e1cc-801d-219dc593bc1a","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Read Recent from Airtable","type":"main","index":0}]]},"Read Recent from Airtable":{"main":[[{"node":"Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Newest First":{"main":[[{"node":"Trim to Digest Size","type":"main","index":0}]]},"Trim to Digest Size":{"main":[[{"node":"Summarize Content (AI)","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Summarize Content (AI)","type":"ai_languageModel","index":0}]]},"Summarize Content (AI)":{"main":[[{"node":"Post Digest to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Post Digest to Slack":{"main":[[{"node":"Archive Digest in Airtable","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Digest in Airtable":{"main":[[{"node":"Guard Non-Empty title","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Guard Non-Empty title":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Airtable)","type":"main","index":0}]]},"Append Audit Row (Airtable)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"84f3b6b8-7777-4cb6-a17f-1b385c82f1f0","id":"FDX06958"}