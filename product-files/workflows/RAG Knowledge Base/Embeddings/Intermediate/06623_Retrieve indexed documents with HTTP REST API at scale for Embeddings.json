{"name":"Retrieve indexed documents with HTTP / REST API at scale for Embeddings","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06623-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"19db41b8-0dc4-430e-bb80-2fa8714c2f23","name":"Receive Inbound Webhook","webhookId":"a0f681f3-92eb-4298-b47b-97294986ab2d"},{"parameters":{"assignments":{"assignments":[{"id":"4eb5d738-c8ff-4609-80ac-09a5513d8ade","name":"docId","value":"={{ $json.docId || $json.id || $execution.id }}","type":"string"},{"id":"657ff56e-b8de-40fa-833d-bf27d1aa0592","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"925032d5-5c65-4308-bbc1-2ed46ea5403d","name":"Stamp & Shape Document"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8d0dfdf9-a40f-41a4-9a16-3211b0c14704","leftValue":"={{ $json.docId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"3502a2ff-3181-4074-959d-aecb3456a184","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"c682ddbd-253b-42ee-9345-9cff505c8542","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.title || JSON.stringify($json) }}","options":{"systemMessage":"You are a embeddings specialist for the rag / knowledge base team. Use the attached tools to look up real data before answering — never invent document details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"499bab12-6b82-46d3-952e-beee5322b5b2","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[945,970],"id":"f4d52e8c-c21d-486f-810c-0d589b4ccb07","name":"Google Gemini Chat Model"},{"parameters":{"toolDescription":"Fetch live document data from the internal REST API by id or query.","url":"https://api.example.com/v1/documents","options":{}},"type":"@n8n/n8n-nodes-langchain.toolHttpRequest","typeVersion":1.1,"position":[945,1390],"id":"5886ff49-012b-4787-b5e3-7cf6bed97dc9","name":"Lookup API Data"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[1174,1390],"id":"8d4c8e0d-2d96-4340-a8f1-a3419d2966fe","name":"Search Reference Wiki"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolThink","typeVersion":1,"position":[1633,1390],"id":"74630cf6-b9d9-4c3a-bebd-60bb492a25a4","name":"Think It Through"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $json.sessionId || $execution.id }}","contextWindowLength":12},"type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.3,"position":[1390,970],"id":"0251bf55-ca83-4cec-95b0-57892a047898","name":"Conversation Memory"},{"parameters":{"assignments":{"assignments":[{"id":"3912ffc1-c307-42ca-8651-2539ceda238d","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"effe0d53-f11b-4dfb-92a0-d8cc2fd15e3a","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1957,400],"id":"c936c588-3070-4fb9-b1cc-b1f45a93