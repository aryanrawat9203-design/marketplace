equired Fields Found?"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["docId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1269,160],"id":"65d1d08f-bc30-45a5-b332-990e28998f16","name":"Upsert into Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=✍️ Extraction incomplete for {{ $json.fileName || 'document' }} — please review","bodyContent":"=✍️ Extraction incomplete for {{ $json.fileName || 'document' }} — please review.","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,760],"id":"ddde5f20-f4ca-4273-bb08-38bcde872a6d","name":"Queue for Manual Review","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2241,400],"id":"0ef364ff-c504-4d19-925d-4f9e2d5ed452","name":"Merge Review Paths"},{"parameters":{"assignments":{"assignments":[{"id":"629710bc-4cff-4e4d-bb3f-375652f65612","name":"pipeline","value":"Embeddings","type":"string"},{"id":"5cf04d11-fdbb-46b1-a383-50ad32a1e199","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3213,400],"id":"1af8ea27-d510-4d80-ba3b-1df7dabb2835","name":"Tag Pipeline Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3537,400],"id":"315baa2a-9d16-42d1-a194-529c2c85c804","name":"Stamp Processing Time"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.lim