{"name":"Distill long emails with Google Drive and Telegram without manual work","nodes":[{"parameters":{"updates":["message"],"additionalFields":{}},"type":"n8n-nodes-base.telegramTrigger","typeVersion":1.2,"position":[-270,400],"id":"8797bb5e-cc41-4318-9004-aa1f33b40953","name":"On Telegram Event","webhookId":"d652b48c-1815-48ab-ac7e-fd661807173e"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming document records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    docId: String(j.docId ?? j.id ?? '').trim(),\n    title: typeof j.title === 'string' ? j.title.trim() : j.title ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"28b435fb-57cd-4bb1-87eb-d19be77df2c9","name":"Normalize Document Payload"},{"parameters":{"inputText":"={{ $json.title || JSON.stringify($json) }}","categories":{"categories":[{"category":"Action Needed","description":"Documents that are action needed for the embeddings team."},{"category":"Reference","description":"Documents that are reference for the embeddings team."},{"category":"Ignore","description":"Documents that are ignore for the embeddings team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"a245fc55-8659-4713-a844-bc11eb46f677","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[621,970],"id":"48ec816c-aab6-4a21-a7fb-823878ee1b2c","name":"Google Gemini Chat Model"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"m