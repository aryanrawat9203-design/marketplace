rrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2565,400],"id":"788bd95e-b870-4d14-8cb8-adfd16935c65","name":"Reunite Branches"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.title }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3537,400],"id":"1077564c-63f3-404c-969e-247dd76daf99","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a8d6b523-d263-4977-80b7-f53284eaad4d","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"39899659-a9e1-499e-9f10-7ec2244213ff","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3861,400],"id":"c3267e5c-d135-4bbe-9f0a-4e4e5549c952","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4185,400],"id":"c4ca9672-84d5-4a01-bdb7-d2faf99063f1","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4509,400],"id":"8d8cc8bc-0ace-454d-a9f3-6dcee1879800","name":"Persist Run Metadata"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4833,400],"id":"017250a7-7ef6-4fae-96f5-53424bb33177","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5157,400],"id":"b6083ac8-7b32-49c1-a473-76e11ca0e27c","name":"Compute Drift vs Snapshot"},{"parameters":{"assignments":{"assignments":[{"id":"61b2814e-5adf-453e-b078-01b75e9fb42e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"df4ec67a-f61d-4d7d-97bc-0fff52268868","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"a8ee410f-3f05-4df2-802e-cd5474e0c80a","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,400],"id":"fdabe883-6224-4c6a-b113-2da6ddaf5d96","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5805,400],"id":"cfd00ed3-86a4-418f-9e22-5e59287e005b","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=✅ Summarize meeting notes with Notion and Slack and log the results — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[6129,400],"id":"c987e361-5e72-4fd7-aa7e-675fb12cf4e8","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"b0d4ec92-ba6e-4b1e-9e7d-00bb1e1be009","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"085d3165-7220-4f44-b821-36cac9da6ed0","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"a2df3324-ed11-42f3-a712-3bf8cca54818","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,1420],"id":"d0da06b6-7db6-4bdc-a671-54b74935eefe","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5805,1420],"id":"993baa35-744a-4ef5-b9f1-30f1e65d6050","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6129,1420],"id":"0876d938-9c81-40ad-b284-c7a131569f47","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf06706-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Required Fields Present?","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"c45f7dde-c018-f322-65d1-0dbd769b2ff3","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Required Fields Present?\n\nTwo-way gate on `={{ $json.title }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Classify with AI · ②→ Abort — Malformed Input","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"c468b7bd-e59b-a932-1702-6d81333b95b8","name":"Note: Required Fields Present?"},{"parameters":{"content":"### Abort — Malformed Input\n\nFails fast with a clear message; triggers the error workflow instead of processing bad data.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,1030],"id":"397e1e1a-d3f3-1193-6b72-86a4ed9f9ebe","name":"Note: Abort — Malformed Input"},{"parameters":{"content":"### Classify with AI\n\nLLM classification into: Action Needed, Reference, Ignore (+fallback). Output port order matches this list.\n\nPorts: ①→ Store as Action Needed · ②→ Store as Reference, Capture Failure Context · ③→ Store as Ignore · ④→ Alert Slack — Other\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"1b46941a-38de-4a5a-b33d-f087c9c28ffd","name":"Note: Classify with AI"},{"parameters":{"content":"### OpenAI Chat Model\n\nChat model powering the AI step (model: `gpt-4o-mini`). Swap providers here without rewiring.\n\nFeeds **Classify with AI** as `languageModel`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"f6a25be0-ca8d-a6c0-68ca-cd0e65b39f62","name":"Note: OpenAI Chat Model"},{"parameters":{"content":"### Store as Action Needed\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[885,40],"id":"7ed7635a-820b-8336-a19d-6d53b16888bc","name":"Note: Store as Action Needed"},{"parameters":{"content":"### Store as Reference\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,490],"id":"063e3da6-291b-ee16-cc37-7fe250ac6a6d","name":"Note: Store as Reference"},{"parameters":{"content":"### Store as Ignore\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,940],"id":"e3d76cb2-2420-4e2e-9526-4a88803a520e","name":"Note: Store as Ignore"},{"parameters":{"content":"### Alert Slack — Other\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Reunite Branches · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,1390],"id":"da9c728f-0e3b-7994-03fd-473cdf9a7231","name":"Note: Alert Slack — Other"},{"parameters":{"content":"### Reunite Branches\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"37b0ca4d-b391-e27c-f8a6-c610b101da15","name":"Note: Reunite Branches"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"21babf14-19e0-bab3-43d2-7668ca886dd1","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"2bbf2775-7e0a-2d88-04ce-337c776cb214","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"ed6f21aa-e7b5-60f6-9f07-be62cade5541","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"31d9b796-d65d-5a57-992e-e37627a4793b","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"0807d14b-71c4-2b01-c63e-bde034e7a883","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"db08e78e-efe0-5992-a927-64d10ec4c174","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"4f2735c0-9723-2bca-e68b-45ae7730d813","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"25c2951a-6e61-2e29-434d-f44decb5ea1f","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"3c7a534d-1a57-056a-180d-9c2b03e0dfd5","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,1540],"id":"3ec0d7e9-6a9a-a5e9-cee0-88b8dc678e61","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,1540],"id":"65ec349e-d00d-fa00-86d0-3584ae42d30c","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,1540],"id":"44384a9c-90fb-9f96-4314-2b73ed68b83c","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Summarize meeting notes with Notion and Slack and log the results\n\n**Pattern:** AI Summarize & Route · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nSummarize meeting notes with Notion and Slack and log the results. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual embeddings is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Required Fields Present? → Classify with AI → Store as Action Needed → Reunite Branches → Enrich with Reference Data → Fold In Enrichment Fields → …\n\n## Use it for\n- Teams that want to ai summarize & route without manual effort\n- Anyone automating embeddings in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Runs 24/7 in the background\n- Has retries and error handling built in\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; OpenAI API key; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"3fad8304-3d0c-e2cf-aa39-3a18755d209a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"5e270163-3120-87a0-cedf-de5c811b79e1","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"4d764051-61c0-69b7-db13-cd1b871cbfd1","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"41cb862d-4d3a-b59d-7fa7-584cf97eab57","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your embeddings process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-500],"id":"874c8c81-c443-e4a6-ec9e-ea9275102ab2","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Required Fields Present?","type":"main","index":0}]]},"Required Fields Present?":{"main":[[{"node":"Classify with AI","type":"main","index":0}],[{"node":"Abort — Malformed Input","type":"main","index":0}]]},"OpenAI Chat Model":{"ai_languageModel":[[{"node":"Classify with AI","type":"ai_languageModel","index":0}]]},"Classify with AI":{"main":[[{"node":"Store as Action Needed","type":"main","index":0}],[{"node":"Store as Reference","type":"main","index":0},{"node":"Capture Failure Context","type":"main","index":0}],[{"node":"Store as Ignore","type":"main","index":0}],[{"node":"Alert Slack — Other","type":"main","index":0}]]},"Store as Action Needed":{"main":[[{"node":"Reunite Branches","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Reference":{"main":[[{"node":"Reunite Branches","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Store as Ignore":{"main":[[{"node":"Reunite Branches","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Alert Slack — Other":{"main":[[{"node":"Reunite Branches","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Reunite Branches":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"9a0dc6db-4914-4f56-833c-82477693d3f6","id":"FDX06706"}