{"name":"Summarize meeting notes with Notion and Slack and log the results","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06706-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"2ea9335d-aece-4235-b308-6110ec0543a0","name":"Receive Inbound Webhook","webhookId":"41c3106c-0975-4514-9b5f-cb3b944f7a9a"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8682ad36-a747-4458-bbca-cc06f2369728","leftValue":"={{ $json.title }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[54,400],"id":"379b34cd-55de-46c4-b8d4-9076546039dc","name":"Required Fields Present?"},{"parameters":{"errorType":"errorMessage","errorMessage":"Missing required field 'title' on incoming document."},"type":"n8n-nodes-base.stopAndError","typeVersion":1,"position":[54,910],"id":"34677787-50ae-41ec-a7e5-85c71d902044","name":"Abort — Malformed Input"},{"parameters":{"inputText":"={{ $json.title || JSON.stringify($json) }}","categories":{"categories":[{"category":"Action Needed","description":"Documents that are action needed for the embeddings team."},{"category":"Reference","description":"Documents that are reference for the embeddings team."},{"category":"Ignore","description":"Documents that are ignore for the embeddings team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"e4ce4ef1-4562-4ea8-85cf-a725286e61cb","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[621,970],"id":"2c326208-6dad-441b-96f0-8baf30047c99","name":"OpenAI Chat Model"},{"parameters":{"operation":"append","documentI