{"name":"Digest long emails with MySQL and Microsoft Teams 24/7","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06765-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"b2990a5b-5d2f-4ab2-9495-177f52b3861d","name":"Receive Inbound Webhook","webhookId":"548da334-4ac1-45e5-b8ea-51c5371e5ac2"},{"parameters":{"assignments":{"assignments":[{"id":"b47cfe91-af3d-486f-8e27-3d9279590d9c","name":"content","value":"={{ $json.body?.text || $json.content || JSON.stringify($json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"35ccccfb-b0ac-411b-a1c5-fac4f4275cdb","name":"Collect Raw Text"},{"parameters":{"text":"={{ $json.text || $json.content }}","attributes":{"attributes":[{"name":"docId","description":"The docId of this document.","required":true},{"name":"title","description":"The title of this document.","required":true},{"name":"sourceUrl","description":"The sourceUrl of this document.","required":false}]},"options":{"systemPromptTemplate":"You are a precise extraction engine. Only extract values present in the text."}},"type":"@n8n/n8n-nodes-langchain.informationExtractor","typeVersion":1,"position":[378,400],"id":"cddabdc9-e7a7-4d6a-bf52-cb56a41f99cc","name":"Extract Structured Fields","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[621,970],"id":"93b2e427-1d33-47cc-8cd8-d78cfa55bbe9","name":"Google Gemini Chat Model"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4fbf8d35-deaf-4439-bea3-05cc570b5c31","leftValue":"={{ $json.output?.docId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[945,400],"id":"b8128e93-b101-4cac-bd33-bd0d81ecc881","n