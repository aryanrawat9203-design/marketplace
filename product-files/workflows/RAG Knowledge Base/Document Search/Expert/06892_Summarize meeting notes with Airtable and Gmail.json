nce-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6777,400],"id":"cffe4c6f-2c93-48e0-a956-f416c7b17336","name":"Fold In Enrichment Fields"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[7101,400],"id":"1d8e8d6e-f40b-4208-8135-a424db7ec27f","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"chunkCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[7425,400],"id":"edc85b0f-ab1c-4c23-881c-bb99ead45325","name":"Sort Documents Newest First"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7749,400],"id":"70e7dfc8-5725-44d2-9f87-ba5ecc9a736d","name":"Stamp Processing Time"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"38c768c1-643e-411c-a0d1-c905f8153da7","leftValue":"={{ $json.title }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8073,400],"id":"2cece914-1e36-44f6-a6fd-3380f0173123","name":"Guard Non-Empty title"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"docId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8397,400],"id":"dfc4d1d7-536c-415f-b2c4-eec31c66478e","name":"Align Field Names"},{"parameters":{"assignments":{"assignments":[{"id":"7dcc84de-97f7-4264-bb78-697250925a77","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"de08dc04-f205-451b-a254-26c03d33472e","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"5d586745-4e5b-435e-ab9b-870f775ec747","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8721,400],"id":"6d1cdf