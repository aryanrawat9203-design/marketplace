schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1917,820],"id":"5e86e5c9-0d63-4024-a7eb-416b33a24859","name":"Store as Ignore","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=[Other] {{ $json.title }}","bodyContent":"=[Other] {{ $json.title }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[2241,1270],"id":"02df37b3-0984-4de2-ae02-ed536101b663","name":"Alert Outlook — Other","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2889,400],"id":"bec3b8bc-0e64-4c84-8730-926ee7f26782","name":"Reunite Branches"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"chunkCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3861,400],"id":"95cfbab8-a352-43a5-9e53-4e728867607a","name":"Sort Documents Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"d03f0f75-ae8a-460b-8037-ffd926f75e95","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"d2b7eb5c-08b7-49bd-aa80-96ed77bbd4f3","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"eedfba4e-92b7-4e64-805e-ccf4e15059f0","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4185,400],"id":"272fe6bf-9f41-4b08-a1ff-fb100155b178","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets