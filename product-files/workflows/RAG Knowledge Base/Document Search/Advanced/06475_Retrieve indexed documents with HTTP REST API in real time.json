{"name":"Retrieve indexed documents with HTTP / REST API in real time","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06475-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"bbcae13c-c937-41c7-b8bb-4c2588d1e4b2","name":"Receive Inbound Webhook","webhookId":"8e57bed2-cfe4-4a46-9251-3670f3d7e6e9"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/documents","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"dd9dfb28-a83b-40a4-ae1a-0cfb28560ca4","name":"List Changed Docs (API)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"compare":"selectedFields","fieldsToCompare":"docId","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[378,400],"id":"2786d5cb-16d7-4d83-a221-73f97cb6dd72","name":"Remove Duplicate Documents"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Attach chunk-level metadata before embedding\nreturn $input.all().map((item, i) => ({\n  json: {\n    ...item.json,\n    chunkIndex: i,\n    sourceUrl: item.json.sourceUrl || item.json.url || 'internal',\n    ingestedAt: new Date().toISOString(),\n  },\n}));"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[702,400],"id":"8f6390bb-d26e-4669-8eae-8f801a230804","name":"Attach Chunk Metadata"},{"parameters":{"tableName":{"__rl":true,"mode":"name","value":"documents","cachedResultName":"documents"},"mode":"insert","options":{}},"type":"@n8n/n8n-nodes-langchain.vectorStoreSupabase","typeVersion":1.3,"position":[1026,400],"id":"55612d90-a2ac-4d5c-8448-88d42c298fef","name":"Insert into Vector Store","onError":"continueErrorOutput"},{"parameters":{"options":{"metadata":{"metadataValues":[{"name":"sourceUrl","value":"={{ $json.sourceUrl }}"}]}}},"type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","typeVersion":1,"position":[1026,970],"id":"b16159dd-0c3d-403b-9b70-de5f19636ddb","name":"Prepare Documents"},{"parameters":{"chunkSize":1200,"chunkOverlap":120,"options":{}},"type":"@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter","typeVersion":1,"position":[1026,1480],"id":"dbaca477-683f-4972-a4ac-cc97312be559","name":"Chunk with Overlap"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.embeddingsOpenAi","typeVersion":1.2,"position":[1269,970],"id":"bcf840e9-a55d-4a07-ab43-03bb7e9a9746","name":"Document Embeddings"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregate","typeVersion":1,"position":[1593,400],"id":"5fe401b2-42c3-46e4-81be-af62efb06c4c","name":"Count Indexed Chunks"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.title }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1917,400],"id":"cd7ab18a-35cd-411b-b915-f4a01d7e20b4","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"a4137929-92b7-480a-a711-569eb9067a0a","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"06f05d5a-5eaa-4b9f-93db-0b9b143cf85b","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2241,400],"id":"5e0ed572-38c8-4c31-a042-8baf6465461e","name":"Fold In Enrichment Fields"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per document (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.docId, j.title].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2565,400],"id":"43f3ab79-54a8-45d4-bd36-efee1edc318f","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2889,400],"id":"41bd2677-21b1-4efc-ab03-c529042273b8","name":"Drop Already-Processed Items"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Documents"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[3213,400],"id":"2748d5f5-61de-4464-b659-faed39ffbdb0","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3537,400],"id":"d38e8149-928d-4295-943f-f232e1641a91","name":"Record Sub-workflow Result"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[3861,400],"id":"cb0322d3-7d6c-42ac-9803-9d8698aaae16","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4185,400],"id":"8c6ecc76-55e4-4e6a-879c-b4d2b9c8a6e3","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4509,400],"id":"e721f19d-8b58-4768-bea7-f91b6aad3a7e","name":"Serialize Run Output (CSV)"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.title || $json.docId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[4833,400],"id":"c77e1d4c-446f-443f-a6a6-c9300a021b97","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5157,400],"id":"f7a78514-927c-4fb5-a101-f80ced474b82","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5481,400],"id":"330f37fa-7189-4659-a04a-e96a81c4864a","name":"Persist Run Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5805,400],"id":"a163c876-e19a-45ee-818c-22e4679f6352","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"382f65c5-e94c-4e6c-9860-282b55fbb4d4","name":"pipeline","value":"Document Search","type":"string"},{"id":"68c0e755-bf7d-4b89-a11e-0a80742c70c0","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6129,400],"id":"7d5f0a6b-cc26-4a07-8b4d-5bf981d3ca4c","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"chunkCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[6453,400],"id":"2a005e48-bec9-4dea-91c9-48b1db1a351a","name":"Sort Documents Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"b8d4913a-b560-4717-b71c-f29b1557324b","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"7f6146c9-2e98-4903-a8da-433374dae43b","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"1ab39e5d-9566-4c32-b7d5-29f75b019463","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6777,400],"id":"4fd29854-dda8-49da-8b53-10a8b36d16bc","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.title || $json.docId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[7101,400],"id":"7475ad40-e225-4613-a13c-87dcfa4b55a3","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=✅ Retrieve indexed documents with HTTP / REST API in real time — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7425,400],"id":"1e6c40f3-fbc0-4c3d-8c8b-dd038974536d","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"1e6acece-8ce0-4b51-990f-8e89674082ea","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"90e3bf5e-2ad0-4b60-8fc2-1189a2974de6","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"30da307b-d2dc-473c-a40b-03e3a5528e0b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6777,1420],"id":"3808bf36-9180-4b2d-9d61-ed09bcceb6a6","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7101,1420],"id":"9ec2e0a7-83ad-488d-9965-c30de898126b","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.title || $json.docId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[7425,1420],"id":"11a714e1-1f49-4417-b333-8b96cc38def5","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf06475-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: List Changed Docs (API)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"34e6b280-1ed7-389a-d56e-0960d743ce04","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### List Changed Docs (API)\n\nGET https://api.example.com/v1/documents — retries 3× with backoff on failure.\n\nPorts: ①→ Remove Duplicate Documents · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"f4520c46-062a-3482-ddcf-6f470c169e18","name":"Note: List Changed Docs (API)"},{"parameters":{"content":"### Remove Duplicate Documents\n\nDrops duplicates within this run (compared on `docId`).\n\nNext: Attach Chunk Metadata","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"3d3fb88e-12a1-df54-d13f-cd2bf4ef701a","name":"Note: Remove Duplicate Documents"},{"parameters":{"content":"### Attach Chunk Metadata\n\nCustom JavaScript: Attach chunk-level metadata before embedding\n\nNext: Insert into Vector Store","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"30c5349c-0d63-e650-5cf0-14d8bf4f01a7","name":"Note: Attach Chunk Metadata"},{"parameters":{"content":"### Insert into Vector Store\n\nWrites embedded chunks into the vector index.\n\nPorts: ①→ Count Indexed Chunks · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail · 🔑 Supabase URL + service key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"7aab5135-02ff-45e2-872f-6e7b1aa46ffa","name":"Note: Insert into Vector Store"},{"parameters":{"content":"### Prepare Documents\n\nWraps incoming items as documents (with metadata) for the vector store.\n\nFeeds **Insert into Vector Store** as `document`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1090],"id":"08d5b6b3-4392-d6a4-80bb-7cfb1d9374be","name":"Note: Prepare Documents"},{"parameters":{"content":"### Chunk with Overlap\n\nChunks documents (~1200 chars, 120 overlap) so retrieval hits stay focused.\n\nFeeds **Prepare Documents** as `textSplitter`","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1600],"id":"e64d717e-5984-afd2-a3f6-0e45835e6e37","name":"Note: Chunk with Overlap"},{"parameters":{"content":"### Document Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Insert into Vector Store** as `embedding`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1209,1810],"id":"d6528841-46c0-d6ed-a407-1839cb43339d","name":"Note: Document Embeddings"},{"parameters":{"content":"### Count Indexed Chunks\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1533,520],"id":"095e964d-3d41-9661-fd29-a83f6d71505f","name":"Note: Count Indexed Chunks"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1857,520],"id":"d8d81954-170d-db0e-4f87-31d42fe47a55","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2181,520],"id":"437b5581-027a-c7a5-800d-0aab48b79e8f","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per document (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2505,520],"id":"308d54ec-2e1a-ff22-2e10-4469ef51050f","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2829,520],"id":"ac10c7d8-c8bf-4f95-e879-c439c3aee87c","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3153,520],"id":"6dbc2247-fdfe-9898-5d77-16f3bcbe94b2","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3477,520],"id":"c9288fb3-c1ad-d3fe-4285-c1f0de84da2f","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Load Previous Snapshot\n\nnotion — `getAll` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3801,520],"id":"df6e5dd8-45f0-c4ad-9a24-c3b83bb3c622","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4125,520],"id":"1a96df60-3573-97dc-7fae-99ed6ec6cbba","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4449,520],"id":"d498a441-79de-abda-c723-739d551e9bf3","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4773,520],"id":"a5428b3a-e5d6-55cd-3c20-dbba373cd50f","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5097,520],"id":"b3000645-18a1-946a-8909-26fc67ea953c","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5421,520],"id":"363dbd46-4621-822d-079a-69bab111e71f","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5745,520],"id":"b78ef330-99b7-3c1d-6d59-52cba82b8451","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Documents Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6069,520],"id":"c771e859-b7f9-8fbf-e4cf-406b0121f060","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6393,520],"id":"9d59c486-fc09-529e-2301-e684b441cc81","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,520],"id":"ee3e782f-58cf-92c8-042d-543cc5c9f77c","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,520],"id":"1a948c67-a25f-4e68-8af2-a98fed898b03","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,520],"id":"3335f5e3-ac59-0f85-7e66-d41b9d74823a","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6717,1540],"id":"cfe2986c-2cc0-1de9-1afa-8f0dc61687f6","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7041,1540],"id":"7b09109d-2b7b-6b31-380c-55c3b690efb6","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7365,1540],"id":"09f7bafa-f541-a8e3-8557-bf72e59e72a4","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Retrieve indexed documents with HTTP / REST API in real time\n\n**Pattern:** RAG Pipeline · **Level:** Architect · **Trigger:** Webhook\n\n## What it does\nRetrieve indexed documents with HTTP / REST API in real time. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual document search is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → List Changed Docs (API) → Remove Duplicate Documents → Attach Chunk Metadata → Insert into Vector Store → Count Indexed Chunks → Enrich with Reference Data → …\n\n## Use it for\n- Teams that want to rag pipeline without manual effort\n- Anyone automating document search in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Improves response time\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Notion integration token; OpenAI API key; Slack OAuth2; Supabase URL + service key.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"6172ff71-19a6-13d2-a362-88032c0ff11e","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-20],"id":"0d2850e5-dd3b-9d3f-b238-99c381c8b81c","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-20],"id":"444555e2-b0f0-8461-4721-bbe3d8418dbc","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-20],"id":"1b93fcb3-a9c6-613d-c2ed-79470cab3d02","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your document search process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-20],"id":"0abbbc70-c65b-16e2-2017-2685c629b5c6","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"List Changed Docs (API)","type":"main","index":0}]]},"List Changed Docs (API)":{"main":[[{"node":"Remove Duplicate Documents","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Remove Duplicate Documents":{"main":[[{"node":"Attach Chunk Metadata","type":"main","index":0}]]},"Attach Chunk Metadata":{"main":[[{"node":"Insert into Vector Store","type":"main","index":0}]]},"Prepare Documents":{"ai_document":[[{"node":"Insert into Vector Store","type":"ai_document","index":0}]]},"Chunk with Overlap":{"ai_textSplitter":[[{"node":"Prepare Documents","type":"ai_textSplitter","index":0}]]},"Document Embeddings":{"ai_embedding":[[{"node":"Insert into Vector Store","type":"ai_embedding","index":0}]]},"Insert into Vector Store":{"main":[[{"node":"Count Indexed Chunks","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count Indexed Chunks":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"ca80481e-3948-48ce-bf47-b6e7fe325e78","id":"FDX06475"}