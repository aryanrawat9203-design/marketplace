oes not contain the answer, say so and set needsHuman=true.","maxIterations":6}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"4db69b5e-ad3f-40d8-9175-44d954fa839f","name":"Answer from Knowledge Base","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[945,970],"id":"96c9d1d5-9c68-4a0e-9bc7-6886ea6b3811","name":"Google Gemini Chat Model"},{"parameters":{"qdrantCollection":{"__rl":true,"mode":"list","value":"","cachedResultName":"kb_main"},"mode":"retrieve-as-tool","topK":5,"toolDescription":"Semantic search over the q&a knowledge base. Always call this before answering factual document questions."},"type":"@n8n/n8n-nodes-langchain.vectorStoreQdrant","typeVersion":1,"position":[999,1390],"id":"7eaea08e-512a-42b2-a7ef-4d6c3ccabc94","name":"Knowledge Base Retriever"},{"parameters":{"options":{}},"type":"@n8n/n8n-nodes-langchain.embeddingsGoogleGemini","typeVersion":1,"position":[1053,1900],"id":"801b60ea-4a85-4116-866c-767921fc7435","name":"Query Embeddings"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.rerankerCohere","typeVersion":1,"position":[1336,1900],"id":"fb25c830-e4d6-448e-b4e6-dd9c44772f80","name":"Rerank Retrieved Chunks"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"55d5ceee-5174-47e6-8647-a66dc54a6c89","leftValue":"={{ !($json.output || '').includes('needsHuman') }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[1660,400],"id":"7e5f7447-9db3-47be-a04d-dc57bdf704a0","name":"Grounded Answer Found?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"answer\": $json.output } }}","options":{}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[1984,160],"id":"17e7f609-c796-4859