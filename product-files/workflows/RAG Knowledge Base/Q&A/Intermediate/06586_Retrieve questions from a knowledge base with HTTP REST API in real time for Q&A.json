{"name":"Retrieve questions from a knowledge base with HTTP / REST API in real time for Q&A","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06586-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"edb0679d-c372-4a08-a551-ced2f5985143","name":"Receive Inbound Webhook","webhookId":"e1ce69e2-a8ff-44e1-aa37-55724f7ed5b0"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7b004473-16e7-4d80-b1e9-ef74703406de","leftValue":"={{ $json.docId || $json.title }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"df3eafe8-d602-41f8-b720-a07ffa887c7e","name":"Keep Valid Documents"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.title || JSON.stringify($json) }}","options":{"systemMessage":"You are a q&a specialist for the rag / knowledge base team. Use the attached tools to look up real data before answering — never invent document details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"75df884c-fd3b-4b52-84e1-ecf6dff74fa1","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[621,970],"id":"637ea5af-95e0-4029-bd93-93eb0d7c98e3","name":"OpenAI Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[621,1390],"id":"97d6c69a-b923-445d-8b8a-80ab47f65365","name":"Run Calculations"},{"parameters":{"toolDescription":"Fetch live document data from the internal REST API by id or query.","url":"https: