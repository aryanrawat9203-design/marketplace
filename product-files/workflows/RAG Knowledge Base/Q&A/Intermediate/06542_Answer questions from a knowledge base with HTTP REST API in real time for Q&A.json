ook up real data before answering — never invent document details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"e3d7f189-b54b-4b71-9823-9151611b4b9b","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[945,970],"id":"fb76d454-0fec-4c56-9e31-54a8cd6c816b","name":"Google Gemini Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[945,1390],"id":"e1e26ef9-0a0b-4b23-9da0-cfda971379f5","name":"Run Calculations"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[1174,1390],"id":"95e78d63-9a7b-4471-bba0-9484bfc6bdf1","name":"Search Reference Wiki"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolThink","typeVersion":1,"position":[1633,1390],"id":"d7276e04-8904-492e-8605-05d1d7df58e9","name":"Think It Through"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $json.sessionId || $execution.id }}","contextWindowLength":12},"type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.3,"position":[1390,970],"id":"58e0bb00-81a1-4fc8-afe5-2213a736544f","name":"Conversation Memory"},{"parameters":{"assignments":{"assignments":[{"id":"b9dcbc37-7f7d-462e-b032-e783bb5a7459","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"6548bd16-10a2-455f-843e-301387c14479","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'high' : 'low' }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1957,400],"id":"00492daa-b40a-4d64-ad5b-f250c99fb1f9","name":"Shape Agent Output"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version