{"name":"Retrieve questions from a knowledge base with HTTP / REST API without manual work for Q&A","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06643-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"3b57c490-cc7c-4588-8a86-88bff1ae6ca9","name":"Receive Inbound Webhook","webhookId":"481e5c8a-769f-4684-91b0-b05b8940d942"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"61f934d3-2a62-4771-8a02-2e772a477f04","leftValue":"={{ $json.docId || $json.title }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"ff382d7b-08f9-41ed-b62c-e68dbacb0274","name":"Keep Valid Documents"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.title || JSON.stringify($json) }}","options":{"systemMessage":"You are a q&a specialist for the rag / knowledge base team. Use the attached tools to look up real data before answering — never invent document details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"21a87f1e-c2e6-4404-948b-769876ab010c","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[621,970],"id":"d3598f38-bbc3-4ecc-82ff-8d9d86a10039","name":"OpenAI Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[621,1390],"id":"ef3435db-7f20-48ca-ad42-e33af605de2c","name":"Search Reference Wiki"},{"parameters":{"toolDescription":"Fetch live document data from the internal REST API by id or query.","u