a1-4ebd-a89f-e0dd7e58bf7e","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8788,1420],"id":"6d03d33f-f02f-4418-934b-653c2b48da7c","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[9112,1420],"id":"aeaaa350-bbe5-428c-ab03-12c09c82aae9","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.title || $json.docId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9436,1420],"id":"3735e8e2-b281-461d-92cd-aa9a83000926","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf06856-document`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Keep Valid Documents","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d32742c2-31fb-0d12-f8c7-a2a2b121e8aa","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Keep Valid Documents\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Answer from Knowledge Base","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"466e3f0a-14f3-ee6b-b726-62f1b1fb8d1f","name":"Note: Keep Valid Documents"},{"parameters":{"content":"### Answer from Knowledge Base\n\nThe AI brain: reads the input, decides which attached tools to call (and in what order), then composes the answer.\n\nPorts: ①→ Grounded Answer Found? · ②→ Capture Failure Context\n\n⚠ failures exit via the error rail","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"81eaad16-6f97-cf46-931b-fcf627508e2d","name":"Note: Answer from Knowledge Base"},{"parameters":{"content":"### Groq Chat Model\n\nChat model powering the AI step (model: `llama-3.3-70b-versatile`). Swap providers here without rewiring.\n\nFeeds **Answer from Knowledge Base** as `languageModel`\n\n🔑 Groq API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[561,1090],"id":"dcda8f6d-75f5-2e16-b8fe-1e7995a18115","name":"Note: Groq Chat Model"},{"parameters":{"content":"### Knowledge Base Retriever\n\nExposes the vector index to the agent as a semantic-search tool.\n\nFeeds **Answer from Knowledge Base** as `tool`\n\n🔑 Pinecone API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[615,1510],"id":"fa8ffd4f-f8df-cfbd-9381-b897f9a00b94","name":"Note: Knowledge Base Retriever"},{"parameters":{"content":"### Query Embeddings\n\nEmbedding model — MUST be the same model for indexing and querying, or retrieval quality collapses.\n\nFeeds **Knowledge Base Retriever** as `embedding`\n\n🔑 OpenAI API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[669,2020],"id":"21845c46-6b71-e087-9ff9-d6b26bb7735e","name":"Note: Query Embeddings"},{"parameters":{"content":"### Rerank Retrieved Chunks\n\nRe-scores retrieved chunks so only the most relevant reach the model.\n\nFeeds **Knowledge Base Retriever** as `reranker`\n\n🔑 Cohere API key","width":280,"height":232,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[952,2020],"id":"faa5769f-8801-0068-a398-369926109712","name":"Note: Rerank Retrieved Chunks"},{"parameters":{"content":"### Grounded Answer Found?\n\nTwo-way gate on `={{ !($json.output || '').includes('needsHuman') }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Return Answer (HTTP 200) · ②→ Log Knowledge Gap","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1276,520],"id":"3ca65270-d56c-1f62-1949-576f82aa48e0","name":"Note: Grounded Answer Found?"},{"parameters":{"content":"### Return Answer (HTTP 200)\n\nSends the HTTP 200 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1600,280],"id":"baf4c8a8-c882-fcbd-c1ed-ee4cb87d5e48","name":"Note: Return Answer (HTTP 200)"},{"parameters":{"content":"### Log Knowledge Gap\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Flag Gap to KB Owners · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1924,880],"id":"62395a38-9b7b-7186-293e-268de12305c6","name":"Note: Log Knowledge Gap"},{"parameters":{"content":"### Flag Gap to KB Owners\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2572,880],"id":"b60362e9-689d-354f-bb3b-7e0afee9d4ae","name":"Note: Flag Gap to KB Owners"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3544,520],"id":"c62de651-ce22-4f51-d163-757ca9813f3e","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3868,520],"id":"bad774d8-1701-b73d-046e-198753efbf84","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4192,520],"id":"552b36e5-fed5-9cb1-181e-f642c0337a46","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4516,520],"id":"6226c0c0-d455-d4a3-b213-30e3bcfcd92c","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4840,520],"id":"41fe6a89-e425-bc2f-3d0d-fa87209900e3","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Offload to Post-Process Sub-workflow","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5164,520],"id":"9f14011c-c833-beaa-4628-cb7b7b9d87f7","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5488,520],"id":"909c5552-3063-5808-aa50-e6867f41595d","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5812,520],"id":"2957ad99-161e-53eb-efc5-180ee12c8d77","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per document (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6136,520],"id":"d33f5e95-9333-8447-0296-1b2a0259afe3","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6460,520],"id":"d50dfb57-91c4-783a-c714-34003fef7f88","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6784,520],"id":"6fa1a639-371b-11ba-925c-34f815af1610","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Sort Documents Newest First · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7108,520],"id":"ef2d8543-430e-c295-a743-0e28dff0e5d0","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Sort Documents Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Guard Non-Empty title","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7432,520],"id":"404110d8-3e5e-da1d-ddc0-9313ea33e960","name":"Note: Sort Documents Newest First"},{"parameters":{"content":"### Guard Non-Empty title\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7756,520],"id":"20062dbe-5571-21ab-b467-843aacfed2da","name":"Note: Guard Non-Empty title"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8080,520],"id":"98802901-f1ea-4ad1-db72-5f5c6473823a","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8404,520],"id":"36e1a881-1ab2-e404-211e-7b3be170f400","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8728,520],"id":"4bb0f80b-0d26-1cfc-b109-81d9183813a7","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9052,520],"id":"9b005fe3-6a44-5fd8-06ef-228f123983e5","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9376,520],"id":"e7748d92-e6a1-dc0b-416b-c23b0e82c5f3","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8728,1540],"id":"91d76a55-7432-b2a3-707f-b44b4794b6e3","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9052,1540],"id":"0c7e462f-66eb-8847-b626-4551c0081c66","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9376,1540],"id":"874a40dd-ed12-d968-d5f6-74b634b5bdde","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Query questions from a knowledge base with HTTP / REST API in real time for Q&A\n\n**Pattern:** RAG Pipeline · **Level:** Architect · **Trigger:** Webhook\n\n## What it does\nQuery questions from a knowledge base with HTTP / REST API in real time for Q&A. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual q&a is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Keep Valid Documents → Answer from Knowledge Base → Grounded Answer Found? → Return Answer (HTTP 200) → Stamp Completion Time → Persist Run Metadata → …\n\n## Use it for\n- Teams that want to rag pipeline without manual effort\n- Anyone automating q&a in ai\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Saves hours of manual work each week\n- Runs 24/7 in the background\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Cohere API key; Google OAuth2 / service account; Groq API key; Notion integration token; OpenAI API key.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"294532f6-d04c-1fcf-e5a8-e12604ee69b0","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-260],"id":"c88751bb-c756-2542-dc47-dc07c2f652ce","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-260],"id":"ef977e8b-b9cf-49e8-e9dc-19c5f05c5a3d","name":"🔐 Security"},{"parameters":{"content":"## 🤖 AI cluster\n\nPurple nodes form one AI unit: the root node orchestrates, sub-nodes plug in via typed ports (model / memory / tools / parser). Swap the chat model without rewiring anything else. Costs scale with tokens — keep prompts lean and cap iterations.","width":360,"height":260,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-260],"id":"da36a6a3-58d7-8194-94a5-86de3830c4ca","name":"🤖 AI cluster"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your q&a process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-260],"id":"94710671-7bdd-9df3-0c2e-dfaa2a52271b","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Keep Valid Documents","type":"main","index":0}]]},"Keep Valid Documents":{"main":[[{"node":"Answer from Knowledge Base","type":"main","index":0}]]},"Groq Chat Model":{"ai_languageModel":[[{"node":"Answer from Knowledge Base","type":"ai_languageModel","index":0}]]},"Knowledge Base Retriever":{"ai_tool":[[{"node":"Answer from Knowledge Base","type":"ai_tool","index":0}]]},"Query Embeddings":{"ai_embedding":[[{"node":"Knowledge Base Retriever","type":"ai_embedding","index":0}]]},"Rerank Retrieved Chunks":{"ai_reranker":[[{"node":"Knowledge Base Retriever","type":"ai_reranker","index":0}]]},"Answer from Knowledge Base":{"main":[[{"node":"Grounded Answer Found?","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Grounded Answer Found?":{"main":[[{"node":"Return Answer (HTTP 200)","type":"main","index":0}],[{"node":"Log Knowledge Gap","type":"main","index":0}]]},"Log Knowledge Gap":{"main":[[{"node":"Flag Gap to KB Owners","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Return Answer (HTTP 200)":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Sort Documents Newest First","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Sort Documents Newest First":{"main":[[{"node":"Guard Non-Empty title","type":"main","index":0}]]},"Guard Non-Empty title":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"9e8c687b-2d08-4860-8fb8-070c0e374040","id":"FDX06856"}