$items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4833,400],"id":"d0402d24-7ed4-4af6-a032-cb9cb8877bd9","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.title }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5157,400],"id":"cc791e22-d637-4670-b9c3-56ecc3d88615","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"352e6f8d-5703-4f9f-b069-60f8523b3741","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"b63d0dd2-585e-4e98-97e3-5b75a356ac3b","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5481,400],"id":"e0bc9324-6d9b-49f2-9d78-a5234e30e768","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[5805,400],"id":"1188b8df-4b18-4455-ac96-f3e7634f5016","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"upload","name":"=run-{{ $now.toFormat('yyyyLLdd-HHmm') }}.csv","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Archives"},"options":{}},"type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[6129,400],"id":"222ccf93-f91f-4f63-86c6-b837fc777ede","name":"Archive Copy to Google Drive","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"chunkCount","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[6453,400],"id":"d4578451-c5e0-4f18-87c2-96e61543aa41","name":"Sort Documents Newest First"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[6777,400],"id":"b7b4a3fe-f503-47b3-8020-86ae0331ce43","name":"Cap Batch Volume"},{"parameters":{"dataToSave":{"values":[{"key":"docId","value":"={{ $json.docId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7101,400],"id":"69e967e2-6c19-4c3b-bb47-8ec0af4d45b4","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7425,400],"id":"77a32f81-78d7-4a2e-88df-e96079ffb818","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"3a82f994-3ba6-40c3-a5ab-49a20bc9df18","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"475b3290-1609-4aca-ad67-7e844bf2d943","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"18d89839-1ef8-42d2-87da-3e371772875e","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7749,400],"id":"356fbe11-2b4f-4639-9839-74e1b67c12f4","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Database"},"title":"={{ $json.title || $json.docId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8073,400],"id":"69f49c79-84c7-47d3-98b0-51ced5e29596","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=✅ Summarize documents with Google Drive and Slack without manual work — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[8397,400],