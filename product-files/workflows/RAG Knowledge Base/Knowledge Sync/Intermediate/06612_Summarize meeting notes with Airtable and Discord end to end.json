{"name":"Summarize meeting notes with Airtable and Discord end to end","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06612-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"2d3d94f0-82f9-474b-a279-8a22fe8c227e","name":"Receive Inbound Webhook","webhookId":"000761e1-fd9d-462a-9034-76374afae50a"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Normalize incoming document records to a stable schema\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  out.push({ json: {\n    docId: String(j.docId ?? j.id ?? '').trim(),\n    title: typeof j.title === 'string' ? j.title.trim() : j.title ?? null,\n    source: j.source ?? 'api',\n    receivedAt: new Date().toISOString(),\n  } });\n}\nreturn out;"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[54,400],"id":"6d3948a9-ec75-486d-ad40-527ba3e6dcfa","name":"Normalize Document Payload"},{"parameters":{"inputText":"={{ $json.title || JSON.stringify($json) }}","categories":{"categories":[{"category":"Action Needed","description":"Documents that are action needed for the knowledge sync team."},{"category":"Reference","description":"Documents that are reference for the knowledge sync team."},{"category":"Ignore","description":"Documents that are ignore for the knowledge sync team."}]},"options":{"fallback":"other"}},"type":"@n8n/n8n-nodes-langchain.textClassifier","typeVersion":1,"position":[378,400],"id":"2549d333-6a12-4994-879f-c2b1a09a35e8","name":"Classify with AI","onError":"continueErrorOutput"},{"parameters":{"model":"anthropic/claude-sonnet-4.5","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","typeVersion":1,"position":[621,970],"id":"c0ab88ae-a9ea-4b7b-9554-b0a74a96e1ab","name":"OpenRouter Chat Model"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"RAG / Knowledge Base Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Documents"},"