l data before answering — never invent document details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[702,400],"id":"c0bdd1c0-15c7-4036-9335-7627446b76a0","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"claude-sonnet-4-5-20250929","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[945,970],"id":"48fae428-7dca-48f1-a9a5-464a50078e40","name":"Anthropic Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolThink","typeVersion":1,"position":[945,1390],"id":"d35562ff-c5df-4e6b-b733-314ae532d87a","name":"Think It Through"},{"parameters":{"toolDescription":"Fetch live document data from the internal REST API by id or query.","url":"https://api.example.com/v1/documents","options":{}},"type":"@n8n/n8n-nodes-langchain.toolHttpRequest","typeVersion":1.1,"position":[1174,1390],"id":"8b848475-9476-4826-914b-6cd01b3627f2","name":"Lookup API Data"},{"parameters":{"name":"score_helper","description":"Compute a quality score for a document record.","jsCode":"const j = JSON.parse(query);\nreturn String((j.signals || []).length * 10);"},"type":"@n8n/n8n-nodes-langchain.toolCode","typeVersion":1.3,"position":[1633,1390],"id":"93ac9b17-b9b1-4c3f-b82c-7d4b04b0988b","name":"Custom Logic Tool"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $json.sessionId || $execution.id }}","contextWindowLength":12},"type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.3,"position":[1390,970],"id":"448002ca-b7b7-40cf-b73b-e35a61fc6205","name":"Conversation Memory"},{"parameters":{"assignments":{"assignments":[{"id":"744a34c7-7372-4ac4-adfd-215cc5bf92dd","name":"answer","value":"={{ $json.output }}","type":"string"},{"id":"8d75c8be-3f8a-4d2d-a499-52486d5783e0","name":"confidence","value":"={{ $json.output && $json.output.length > 40 ? 'hig