{"name":"Digest meeting notes with PostgreSQL and Slack 24/7","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06698-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"4abf5439-9ad2-44ff-9aba-043faafd15c8","name":"Receive Inbound Webhook","webhookId":"c0df3e64-022f-40bc-bf90-fe5224d31a3c"},{"parameters":{"assignments":{"assignments":[{"id":"f678471f-8ba5-41e4-8910-bc9f73345593","name":"content","value":"={{ $json.body?.text || $json.content || JSON.stringify($json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"d94129c7-3f55-41a8-8f96-beacb80c5580","name":"Collect Raw Text"},{"parameters":{"text":"={{ $json.text || $json.content }}","attributes":{"attributes":[{"name":"docId","description":"The docId of this document.","required":true},{"name":"title","description":"The title of this document.","required":true},{"name":"sourceUrl","description":"The sourceUrl of this document.","required":false}]},"options":{"systemPromptTemplate":"You are a precise extraction engine. Only extract values present in the text."}},"type":"@n8n/n8n-nodes-langchain.informationExtractor","typeVersion":1,"position":[378,400],"id":"69e42c24-af1a-465c-82a1-b4999bf12566","name":"Extract Structured Fields","onError":"continueErrorOutput"},{"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o-mini","cachedResultName":"gpt-4o-mini"},"options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[621,970],"id":"90c1d48a-6d6b-4c74-9819-279aa29fb681","name":"OpenAI Chat Model"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"da27fd4d-949a-4dc3-816a-745930639be5","leftValue":"={{ $json.output?.docId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[945,400],"id":"322c78a5-634b-41f0-8626-56ce94063b8e","name":"All Required Fields Found?"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["docId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1269,160],"id":"b007542a-ef50-479a-9d3c-ce478dbf0f7d","name":"Upsert into Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#knowledge","cachedResultName":"#knowledge"},"text":"=✍️ Extraction incomplete for {{ $json.fileName || 'document' }} — please review.","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1593,760],"id":"a1ff1c43-ec7d-473c-b48a-ab3debd7959a","name":"Queue for Manual Review","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":2},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2241,400],"id":"4644c9d3-82e7-4b0f-ab7a-6802e7e0202b","name":"Merge Review Paths"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Document Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3213,400],"id":"ea55fe60-5b92-4ec0-ae29-fe7a756ae2db","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3537,400],"id":"dca4c79c-51b3-4557-a769-9c90b7783fc4","name":"Compute Drift vs Snapshot"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per document (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.docId, j.title].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3861,400],"id":"57d1d15d-d18a-4d51-b791-34a2867c1df5","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[4185,400],"id":"7dd49a5b-1ab0-494a-93b2-b0cef2998be1","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.title }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[4509,400],"id":"f181f064-2e6e-42a7-82bc-2705f8139a49","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"92f3d686-c62b-4ce0-8590-d66e53f47a7a","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"40184a99-2ed5-47e6-9406-93cb492a3cb9","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4833,400],"id":"10d30462-2ecb-433b-8114-eeefcab8e872","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5157,400],"id":"0675aa29-8958-45ae-84fd-82744b2bd95f","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5481,400],"id":"8ff0b999-feaf-468c-9a1f-c0a882439e5f","name":"Persist Run Metadata"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Documents"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5805,400],"id":"5502bab4-15c8-47fa-badc-0fbcee46ea7e","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6129,400],"id":"38506848-a91d-4a56-81d5-9e081303675b","name":"Record Sub-workflow Result"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[6453,400],"id":"619a6776-53a4-4bda-8a86-cd108a8d4ad0","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO document_log (docId, title, sourceUrl, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.docId, $json.title, $json.sourceUrl ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"