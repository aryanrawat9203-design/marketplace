{"name":"Answer questions from a knowledge base with HTTP / REST API hands-free for Knowledge Sync (06721)","nodes":[{"parameters":{"httpMethod":"POST","path":"wf06721-document","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"2be9492d-0b1a-4136-8f83-34e8ffb5b06d","name":"Receive Inbound Webhook","webhookId":"90746428-1bfc-4f51-9652-6d43a59d3e63"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"08656b10-f7f7-4c5b-ba1f-824518970e74","leftValue":"={{ $json.docId || $json.title }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[54,400],"id":"b7c3df6c-ab1b-43b6-a5eb-7da86bf08eaa","name":"Keep Valid Documents"},{"parameters":{"promptType":"define","text":"={{ $json.chatInput || $json.title || JSON.stringify($json) }}","options":{"systemMessage":"You are a knowledge sync specialist for the rag / knowledge base team. Use the attached tools to look up real data before answering — never invent document details. Keep answers under 150 words, cite which tool you used, and escalate anything you cannot verify.","maxIterations":8}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":2.2,"position":[378,400],"id":"be7d57bc-ad42-47f9-b358-3b588e5e5bde","name":"Reason & Act (AI Agent)","onError":"continueErrorOutput"},{"parameters":{"model":"models/gemini-2.5-flash","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[621,970],"id":"688e02f9-3512-462a-8167-7c0a1a94f998","name":"Google Gemini Chat Model"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolCalculator","typeVersion":1,"position":[621,1390],"id":"f8d9538d-6178-4965-9603-ff2127e474c3","name":"Run Calculations"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.toolWikipedia","typeVersion":1,"position":[850,1390],"id":"27f45005-0d35-416b-ae69-e42