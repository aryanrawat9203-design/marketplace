;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[8154,400],"id":"71554374-2213-4b2a-866e-6bce37137210","name":"Compute Drift vs Snapshot"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"symbol"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8478,400],"id":"c0dc91cc-cfb0-4230-a4f3-dac0217d270e","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"symbol","value":"={{ $json.symbol }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8802,400],"id":"451af402-585f-4190-a987-b4743da63767","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[9126,400],"id":"f709d1c7-79c6-48df-b055-a305898d16c6","name":"Stamp Processing Time"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[9450,400],"id":"51be953c-6e27-4d19-abab-b0abae748744","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"volume","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[9774,400],"id":"9b8f4c0e-df73-4bc1-a2cd-47d5e3058182","name":"Sort Assets Newest First"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7ce041bc-0d8e-4011-813d-f1aaa8a35efe","leftValue":"={{ $json.price }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[10098,400],"id":"c6f25d14-d570-4ae0-8c39-b2220ad7e1dc","name":"Guard Non-Empty price"},{"parameters":{"assignments":{"assignments":[{"id":"31157622-30b8-4e50-aa80-92826fede1fb","name":"runAt","value":"={{ $now.toISO() }}","type":"s