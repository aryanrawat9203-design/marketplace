;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[8154,400],"id":"460fae7a-fa88-41fa-b3d6-e4d66a7e1772","name":"Compute Drift vs Snapshot"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"symbol"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[8478,400],"id":"b0e54d05-453d-4cf5-9ce6-f7b72fca11b5","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"symbol","value":"={{ $json.symbol }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8802,400],"id":"9395bf56-64b4-4b00-90c8-ae17d7e9cadf","name":"Save Execution Metadata"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[9126,400],"id":"b4c818fb-6a9f-4810-b88a-bee2534eb1eb","name":"Stamp Processing Time"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[9450,400],"id":"114bbecb-9a19-4bec-bbea-721fd8c779c3","name":"Cap Batch Volume"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"volume","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[9774,400],"id":"4c89f314-2166-4b34-ad06-e4c81b71bbf4","name":"Sort Assets Newest First"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"68c8f6d1-14f9-431a-9d57-19896f9c1703","leftValue":"={{ $json.price }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[10098,400],"id":"faaa13f2-c5ee-4be4-b67c-f440dd03caf4","name":"Guard Non-Empty price"},{"parameters":{"assignments":{"assignments":[{"id":"a9255af2-2866-40a9-bc80-277491ac77cb","name":"runAt","value":"={{ $now.toISO() }}","type":"s