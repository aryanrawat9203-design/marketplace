              "type": "string"
            },
            {
              "id": "48167ae6-2995-4405-8854-862850d01d5e",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "136aeecd-4c79-4163-aef0-6cbcc893f1be",
