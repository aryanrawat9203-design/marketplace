    {
      "parameters": {
        "url": "https://data.example.org/latest.json",
        "options": {}
      },
      "id": "8a5cfc25-ecf4-4d70-8722-eccdfe8b2200",
      "name": "Fetch Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        800,
        300
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
