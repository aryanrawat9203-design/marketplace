              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "55071a38-ec99-454d-a891-6d9355d01952",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "7bb9d91e-9b87-47b9-8e5c-f35c06fccfdf",
