      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        1280,
        520
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "41488451-b2c8-4cf4-9611-5958424c998e",
              "leftValue": "={{ $json.signalStrength }}",
              "rightValue": "0.7",
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "23045a1f-45d1-403f-b190-faebf08c2571",
