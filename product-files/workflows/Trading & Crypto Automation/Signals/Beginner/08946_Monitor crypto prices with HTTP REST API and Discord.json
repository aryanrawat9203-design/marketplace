              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "659ac90e-8154-4b49-8cfe-4b8ea1d740d9",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "c47a17f7-ee8b-4de7-987d-9d1d4e4baeb0",
