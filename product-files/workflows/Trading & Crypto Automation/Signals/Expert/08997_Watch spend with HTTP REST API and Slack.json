              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "ac19aca2-71ef-4090-9081-b1680153151c",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "a5428911-0be1-45fe-839d-9fb5e01c1c40",
