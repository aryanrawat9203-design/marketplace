{"name":"Monitor a key metric with HTTP / REST API and Outlook automatically","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":30}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"05654bf6-4fd2-4ac9-9f77-3f40bbf1e325","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/assets","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"b47194d1-b540-4ff9-b0fd-aa5a59d1fd0e","name":"Fetch Current Metrics","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compute a simple moving average and momentum signal\nconst items = $input.all().map(i => i.json);\nconst closes = items.map(j => Number(j.price)).filter(n => !isNaN(n));\nconst sma = closes.slice(-20).reduce((a, b) => a + b, 0) / Math.min(20, closes.length);\nconst last = closes[closes.length - 1];\nconst momentum = closes.length > 5 ? last - closes[closes.length - 6] : 0;\nreturn [{ json: { sma20: Math.round(sma * 100) / 100, last, momentum, signal: last > sma && momentum > 0 ? 'bullish' : 'neutral' } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"02c90d6d-2012-4451-8b51-53fd16dc75c1","name":"Compute Severity Signals"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1e791629-b58e-4949-9dd2-91de8071a459","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":40,"operator":{"type":"number","operation":"lt"}}],"combinator":"and"},"renameOutput":true,"outputKey":"info"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":