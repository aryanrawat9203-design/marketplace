ue,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"9f73da34-dcac-4b25-af93-15e827a88d0a","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5562,400],"id":"1d3ec127-46ef-419b-a34b-5e6081f338ec","name":"Compute Drift vs Snapshot"},{"parameters":{"workflowId":{"__rl":true,"mode":"list","value":"","cachedResultName":"lib: Post-Process Assets"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[5886,400],"id":"9cdaba6e-f740-413d-a8eb-cbf925390b0d","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[6210,400],"id":"e5fe2d32-9a43-4467-8a05-dcabbf5a209e","name":"Record Sub-workflow Result"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.price }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6534,400],"id":"867589bb-41b2-4e41-a319-6afd4f0e8f65","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"851c8ea8-366c-4345-90f7-971fcbb4bb5f","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e6321028-4925-4f53-9238-ed553570d89d","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"5efab089-baca-4342-b382-4afa0dfea797","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[7182,400],"id":"2d1b1ead-d564-455a-9ac1-4f10d6cbbbe3","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7506,400],"id":"f6fc64ae-5689-4a06-ad5e-8f36b3ec29da","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per asset (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.symbol, j.price].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7830,400],"id":"e1e00452-21a9-4d82-9c69-b66b02096967","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[8154,400],"id":"cae609b3-e3fb-4d39-adf1-2315501201c3","name":"Drop Already-Processed Items"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[8478,400],"id":"792a4fdb-9ee7-45a0-98ae-82ea2609a5df","name":"Stamp Processing Time"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[8802,400],"id":"d98f72df-422f-4dce-b393-454e446d4e3b","name":"Cap Batch Volume"},{"parameters":{"dataToSave":{"values":[{"key":"symbol","value":"={{ $json.symbol }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[9126,400],"id":"10e919a0-6c41-484b-8de4-9ecf2e103c8b","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"5736b478-c6e9-4395-8187-bfda5d2d8d5e","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f9c78361-d525-4a0a-8543-8e8b4684d988","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"51d0ee07-7c55-4960-a655-657a267aa057","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9450,400],"id":"18eaf265-7fc5-4ac1-b453-bd8a9bc40dfd","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Database"},"title":"={{ $json.price || $json.symbol }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[9774,400],"id":"dba52690-758b-4aa0-9476-525d92e5a498","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#trading","cachedResultName":"