            {
              "id": "d2d89add-c1b5-4e4c-afd5-6ac53bfa5997",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "ee7cbe3d-3a3c-44a6-b253-7d3a8b853c6d",
