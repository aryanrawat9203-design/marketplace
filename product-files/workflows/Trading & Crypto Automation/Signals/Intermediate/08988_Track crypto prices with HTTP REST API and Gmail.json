      "typeVersion": 2.2,
      "position": [
        1040,
        300
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "sendTo": "={{ $json.email }}",
        "subject": "Automated update",
        "message": "={{ $json.summary }}",
        "options": {}
      },
      "id": "eaad7fe3-d944-4577-9112-81ea559f4d25",
