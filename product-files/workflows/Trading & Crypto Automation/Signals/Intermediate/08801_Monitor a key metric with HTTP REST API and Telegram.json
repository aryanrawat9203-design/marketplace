    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "f6c4e2d7-0661-4114-b508-121d3a2b3c69",
              "name": "receivedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "7dd740ff-884d-44ac-8c17-7f4937bac698",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "61307057-53d5-4336-8030-80130a132802",
      "name": "Validate Input",
