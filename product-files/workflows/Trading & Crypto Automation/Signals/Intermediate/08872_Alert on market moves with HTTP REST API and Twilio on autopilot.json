{"name":"Alert on market moves with HTTP / REST API and Twilio on autopilot","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":10}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"a17655ec-a658-4aa7-9b47-bf10671c79f5","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/assets","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"534e081e-6be9-4436-afac-9a12c8d86c09","name":"Fetch Current Metrics","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compute a simple moving average and momentum signal\nconst items = $input.all().map(i => i.json);\nconst closes = items.map(j => Number(j.price)).filter(n => !isNaN(n));\nconst sma = closes.slice(-20).reduce((a, b) => a + b, 0) / Math.min(20, closes.length);\nconst last = closes[closes.length - 1];\nconst momentum = closes.length > 5 ? last - closes[closes.length - 6] : 0;\nreturn [{ json: { sma20: Math.round(sma * 100) / 100, last, momentum, signal: last > sma && momentum > 0 ? 'bullish' : 'neutral' } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"a405037e-b1e4-4817-867b-8b8bf6100c77","name":"Compute Severity Signals"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"89a37a4d-44bf-423a-af8d-37bf4d263c85","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":40,"operator":{"type":"number","operation":"lt"}}],"combinator":"and"},"renameOutput":true,"outputKey":"info"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"36bcf665-f098-47c1-85ad-71b18d1477dc","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":70,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warning"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"390f5930-9551-40f4-a2b9-7d72e7094399","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":90,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"critical"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"0bbc75e0-529c-4aab-8481-632084254a54","name":"Grade Severity Tier"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,-80],"id":"d972bb4a-7b3c-4cfa-855e-4a540a21bbb5","name":"Just Record (Info)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🟠 Warning tier reached: {{ $json.symbol }} at {{ $json.score ?? $json.last }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[1350,400],"id":"2221b2dd-34d4-4118-a607-52d5b89cebd6","name":"Warn Channel (Twilio)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#trading","cachedResultName":"#trading"},"text":"=🔴 CRITICAL: {{ $json.symbol }} breached threshold — act now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"5582c0e4-8fd8-4b1b-ae88-bb9f6d67251e","name":"Page Urgently (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1998,1360],"id":"635fbfe4-ba01-4f13-997e-8faf362f5983","name":"Archive Unscored","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"87906b63-aef7-4914-82bd-2ea857411da1","name":"Merge Tier Outcomes"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[3618,400],"id":"fec342f6-8c2b-49fa-ad39-5c6ebe36d924","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[3942,400],"id":"f739fb8d-3de9-4ff4-8edc-32263e88fdaa","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4266,400],"id":"56ac54dd-bb8a-4784-b924-365b94118866","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4590,400],"id":"d7b6a0ba-a8c8-4772-9295-9b7e148af0ee","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per asset (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.symbol, j.price].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"4f221f5e-e719-4964-ad09-cd17dfbb2565","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[5238,400],"id":"d7a7919f-8c0a-41d3-8454-6ca63e9eb13a","name":"Drop Already-Processed Items"},{"parameters":{"assignments":{"assignments":[{"id":"80c74691-6c77-4c5c-ab32-db0fcdc2e115","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5c5b7014-b381-468b-a87b-9babd5dd818e","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"6bcff532-5710-4dea-a04d-093406e911f5","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"4e2c055e-c481-492f-bbf8-9c13e9b62dc5","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"64a234ca-2e1e-4821-99e8-f7485331e491","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Alert on market moves with HTTP / REST API and Twilio on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[6210,400],"id":"5d4d6a92-6f45-4412-b259-335d53cb9ac2","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"d406662d-b72f-4052-86e0-582a20eea84f","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"1f094083-1afc-477e-a0fb-a186be5b5f06","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"9ba2ca87-ec0d-4656-9bd8-185bbba1e31f","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,1420],"id":"42b27742-4715-49a0-a6d4-bc997fc591ce","name":"Capture Failure Context"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5886,1420],"id":"a5cf00b6-610d-450b-ae94-141d87349c40","name":"Escalate Failure to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[6210,1420],"id":"194730d2-67be-4903-bfd6-b317109fe70e","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Every Few Minutes\n\nStarts the workflow on a timer — every 10 min. No input data; downstream nodes fetch what they need.\n\nNext: Fetch Current Metrics","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"c1209689-96bb-e9e5-fa6b-5bc7d022ae97","name":"Note: Every Few Minutes"},{"parameters":{"content":"### Fetch Current Metrics\n\nGET https://api.example.com/v1/assets — retries 3× with backoff on failure.\n\nPorts: ①→ Compute Severity Signals · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"5a6fb559-32e1-ff26-a438-d8d2fe7ebb29","name":"Note: Fetch Current Metrics"},{"parameters":{"content":"### Compute Severity Signals\n\nCustom JavaScript: Compute a simple moving average and momentum signal\n\nNext: Grade Severity Tier","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"4d875671-459e-80ed-dda8-1b54d24f72eb","name":"Note: Compute Severity Signals"},{"parameters":{"content":"### Grade Severity Tier\n\nRoutes each item to one of 4 lanes: info, warning, critical + fallback.\n\nPorts: ①→ Just Record (Info) · ②→ Warn Channel (Twilio) · ③→ Page Urgently (Slack) · ④→ Archive Unscored","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"b9c68e92-8e35-8409-7326-3c9dbfde5c79","name":"Note: Grade Severity Tier"},{"parameters":{"content":"### Just Record (Info)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,40],"id":"3e5965e7-d632-4794-8ee4-07173e98990e","name":"Note: Just Record (Info)"},{"parameters":{"content":"### Warn Channel (Twilio)\n\ntwilio — `action` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"ad7ad728-64d8-6944-19a5-9aaa61469a27","name":"Note: Warn Channel (Twilio)"},{"parameters":{"content":"### Page Urgently (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"11ce31b9-cb95-d189-0ec4-9624fe691f4f","name":"Note: Page Urgently (Slack)"},{"parameters":{"content":"### Archive Unscored\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,1480],"id":"e967a1e5-ed42-b15e-61cb-f7bc11fb74e6","name":"Note: Archive Unscored"},{"parameters":{"content":"### Merge Tier Outcomes\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"aa6c0ed7-4b6c-7459-a884-94b0159ba453","name":"Note: Merge Tier Outcomes"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"be42142b-2ce3-03a8-a1c1-395a6ddb867d","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Stamp Completion Time · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"6c8874e4-eb8b-0e4e-56db-17359c8ed023","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"59487e0b-68bc-4f20-aae6-0d8e96742599","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"619669ef-d7a8-fb35-44a7-e3192c16cbfc","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per asset (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"6abf6f45-66fd-0879-95cc-c2d1c1a6d6cf","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"1482bac5-e5e6-368d-e9f5-b0da64f965f8","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"eaf44f5c-6db2-a18b-4e01-d2960798a30e","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"6f8f00eb-8fa2-b6e7-522a-4d276c226d97","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Twilio\n\ntwilio — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"03f50581-6e85-a97d-7c5d-b466d74238f0","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Twilio","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"a5d74e53-eb46-4ae4-0e59-b04f6e25b967","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Twilio\n\ntwilio — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Twilio SID + token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,1540],"id":"f34dc95c-da91-a8ef-fe12-0a2a6541644d","name":"Note: Escalate Failure to Twilio"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,1540],"id":"6950c10f-aa8f-8e5c-5976-be2d5bd53447","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Alert on market moves with HTTP / REST API and Twilio on autopilot\n\n**Pattern:** Trading Alert · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nAlert on market moves with HTTP / REST API and Twilio on autopilot. It runs automatically on a schedule.\n\n## Why it exists\nManual signals is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nEvery Few Minutes → Fetch Current Metrics → Compute Severity Signals → Grade Severity Tier → Just Record (Info) → Merge Tier Outcomes → Serialize Run Output (CSV) → …\n\n## Use it for\n- Teams that want to trading alert without manual effort\n- Anyone automating signals in finance\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Improves response time\n- Scales without extra headcount\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Slack OAuth2; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"9b22ead5-eb19-e961-02fb-14221be748a9","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"31884639-ea04-251f-7064-aeee1f209e5c","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"e9a1ce1b-e534-7227-2c49-6633077473e8","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your signals process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"cca52df6-a417-9170-bdd2-60cf74404581","name":"🛠 Customize me"}],"connections":{"Every Few Minutes":{"main":[[{"node":"Fetch Current Metrics","type":"main","index":0}]]},"Fetch Current Metrics":{"main":[[{"node":"Compute Severity Signals","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Severity Signals":{"main":[[{"node":"Grade Severity Tier","type":"main","index":0}]]},"Grade Severity Tier":{"main":[[{"node":"Just Record (Info)","type":"main","index":0}],[{"no