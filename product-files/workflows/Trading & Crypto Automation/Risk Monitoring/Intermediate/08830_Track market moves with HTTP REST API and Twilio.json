          "conditions": [
            {
              "id": "00606273-c937-4e05-911e-6116ba202c8c",
              "leftValue": "={{ $json.isValid !== false }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
