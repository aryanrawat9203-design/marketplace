              "type": "string"
            },
            {
              "id": "cc36336b-38b8-4ec9-9c88-6e4bcff22ba9",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "2b1207ac-cedf-4960-925d-e6b4d1a89b75",
