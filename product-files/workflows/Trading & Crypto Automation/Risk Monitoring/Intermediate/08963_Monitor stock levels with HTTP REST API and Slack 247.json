          "combinator": "and",
          "conditions": [
            {
              "id": "58385186-a0d0-4a4e-9b53-450e9c222f78",
              "leftValue": "={{ $json.category }}",
              "rightValue": "paid",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "e899bb0f-e988-412f-a24b-0089d816ed7b",
