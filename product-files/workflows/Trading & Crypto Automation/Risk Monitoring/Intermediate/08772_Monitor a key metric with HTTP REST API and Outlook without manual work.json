            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "5c89414b-8b6a-4ca6-849a-8d1fbb451d75",
              "leftValue": "={{ $json.receivedAt || $now.toISO() }}",
