    {
      "parameters": {},
      "id": "58fb59c1-0741-4841-8061-d7fc868be052",
      "name": "Log Invalid Input",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        780,
        500
