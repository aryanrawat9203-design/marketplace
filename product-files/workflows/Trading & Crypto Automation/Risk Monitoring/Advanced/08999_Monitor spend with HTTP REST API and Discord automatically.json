    "Fetch Data": {
      "main": [
        [
          {
            "node": "Route on Condition",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Route on Condition": {
      "main": [
        [
          {
            "node": "Send Discord Message",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
