          "combinator": "and",
          "conditions": [
            {
              "id": "14bca1fa-033e-48c3-8311-3a84bff3275f",
              "leftValue": "={{ $json.priority }}",
              "rightValue": "paid",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "a9ce667b-ae51-46be-8318-175263b4fb97",
      "name": "Route on Condition",
