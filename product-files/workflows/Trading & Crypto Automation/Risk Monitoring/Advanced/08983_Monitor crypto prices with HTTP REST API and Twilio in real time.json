              "type": "string"
            },
            {
              "id": "32baf61b-e052-4dea-abd2-0d8f8a950d0c",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "c5172801-b414-40fd-8200-a0c14f290a6f",
      "name": "Validate Input",
