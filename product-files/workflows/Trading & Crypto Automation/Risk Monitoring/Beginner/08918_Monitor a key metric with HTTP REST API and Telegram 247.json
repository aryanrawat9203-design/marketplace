      "waitBetweenTries": 2000
    },
    {
      "parameters": {},
      "id": "28342a6c-9c83-47b1-a5ac-8feb97e45887",
      "name": "Skip (No Action)",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        1280,
        500
      ]
    },
    {
      "parameters": {
