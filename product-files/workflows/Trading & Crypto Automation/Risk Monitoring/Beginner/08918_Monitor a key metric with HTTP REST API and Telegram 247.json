{"name":"Monitor a key metric with HTTP / REST API and Telegram 24/7","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":10}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"02fa455c-5ff2-49f1-ab3c-6785ffd500b7","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://service-a.example.com/healthz","options":{"timeout":10000,"response":{"response":{"fullResponse":true,"neverError":true}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,130],"id":"cd4ea9c4-e175-4ab4-86c3-5c792ed92cd6","name":"Probe Endpoint A","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"method":"GET","url":"https://service-b.example.com/healthz","options":{"timeout":10000,"response":{"response":{"fullResponse":true,"neverError":true}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[378,640],"id":"04c29aad-9357-4e86-8fc4-150d3d4542d8","name":"Probe Endpoint B","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"method":"GET","url":"https://service-c.example.com/healthz","options":{"timeout":10000,"response":{"response":{"fullResponse":true,"neverError":true}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[702,1150],"id":"7b0135fc-967e-4647-af9f-c4cca1948bba","name":"Probe Endpoint C","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1350,400],"id":"3b291d3b-1caa-40b2-9b7c-25cc67664a5d","name":"Combine Probe Results"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"37e21df5-99b6-406c-a6c7-fa44e99e1de5","leftValue":"={{ ($json.statusCode || 200) < 400 }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[2322,400],"id":"8a9df3f5-c66d-454d-9f4e-1052969d67b5","name":"All Healthy?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,160],"id":"9da73fb2-0ae6-4a1d-bb3e-58db76c46d6b","name":"Record Uptime Metric","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.url || 'probe' }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[2970,760],"id":"68b01075-3266-4fde-b71b-077e4724c915","name":"Already Alerted? (State Check)"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#trading","cachedResultName":"#trading"},"text":"=🔴 Health check failed: {{ $json.url || 'endpoint' }} → {{ $json.statusCode }}","otherOptions":{}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[3618,760],"id":"6f478352-6a00-40bb-a11a-72c8f3a213ff","name":"Page On-Call via Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4590,400],"id":"7d7dc361-3d93-452a-818a-2410abc2d8ea","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[4914,400],"id":"f2a821f2-3dbb-44f7-af33-211ffb4e2759","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"completedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[5238,400],"id":"e7b6265f-a310-4c9b-8ecd-94e4f9ec3c8b","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[5562,400],"id":"e48337a6-19cb-45b0-8e14-1f7a9efcfcb6","name":"Persist Run Metadata"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per asset (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.symbol, j.price].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[5886,400],"id":"e74972c0-ad68-41eb-b995-e2f58580a312","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[6210,400],"id":"7c0a28fb-f560-4518-a3cc-e8c648a14049","name":"Drop Already-Processed Items"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.price }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[6534,400],"id":"8b5a12c7-6ce5-4e53-98ec-de23aa3bf593","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"8d18ed37-9db6-4303-913a-c980ae3976b0","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"e2db1796-1df7-41a6-8c67-bd0a0469d829","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[6858,400],"id":"effa9f41-2018-48a3-9b77-0744be0df40a","name":"Fold In Enrichment Fields"},{"parameters":{"assignments":{"assignments":[{"id":"0ba13113-4853-4635-98dd-659680d52a9a","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"445d18a2-6ec0-4425-9a57-1074d3b0a419","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"3a033586-9bab-4a70-ad76-cd8bf484503d","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"e526a795-d1e4-4022-a9de-36e57441ff39","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7506,400],"id":"c0ae62b5-69f0-41bf-9b60-c84b86678e11","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Monitor a key metric with HTTP / REST API and Telegram 24/7 — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[7830,400],"id":"f14f3cfb-7c62-4779-a3eb-eecb3bb7ff35","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"af22380b-6ade-4586-9e39-c670aa63bebb","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"db1e2c3b-ecc3-4ba8-bfb0-d2d72b5d3eec","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"75d90e0a-3e5e-494d-a28b-f296f824a996","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,1420],"id":"7a2d489a-cf5b-495f-8b9d-466083963fc8","name":"Capture Failure Context"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[7506,1420],"id":"25b27cc6-d3e2-4f3c-8a9c-10f5edfee7c7","name":"Escalate Failure to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7830,1420],"id":"c4fa83b9-8f7e-411b-88e7-c29f16f4a97d","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Every Few Minutes\n\nStarts the workflow on a timer — every 10 min. No input data; downstream nodes fetch what they need.\n\nNext: Probe Endpoint A","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"c6a9de3c-d281-21b6-0968-dd96e678fb93","name":"Note: Every Few Minutes"},{"parameters":{"content":"### Probe Endpoint A\n\nGET https://service-a.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"4ed9505a-f7b1-45f0-40a8-66ab70dd7a77","name":"Note: Probe Endpoint A"},{"parameters":{"content":"### Probe Endpoint B\n\nGET https://service-b.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,760],"id":"44219799-c017-b676-c092-e54b36adab78","name":"Note: Probe Endpoint B"},{"parameters":{"content":"### Probe Endpoint C\n\nGET https://service-c.example.com/healthz — retries 3× with backoff on failure.\n\nNext: Combine Probe Results\n\n↻ retries 3×/2s · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1270],"id":"77f75879-af95-eab0-1361-c56963a1a6a9","name":"Note: Probe Endpoint C"},{"parameters":{"content":"### Combine Probe Results\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: All Healthy?","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"1806e1e1-6466-4180-d98c-138824e06e3d","name":"Note: Combine Probe Results"},{"parameters":{"content":"### All Healthy?\n\nTwo-way gate on `={{ ($json.statusCode || 200) < 400 }}`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Record Uptime Metric · ②→ Already Alerted? (State Check)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"140684fe-0be3-16cc-a277-47a6036b33c8","name":"Note: All Healthy?"},{"parameters":{"content":"### Record Uptime Metric\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Load Previous Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,280],"id":"ed209bd5-3e53-b61d-48aa-c0a12638f429","name":"Note: Record Uptime Metric"},{"parameters":{"content":"### Already Alerted? (State Check)\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Page On-Call via Slack","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,880],"id":"30787751-14c7-e1e4-9529-6e7f26392f31","name":"Note: Already Alerted? (State Check)"},{"parameters":{"content":"### Page On-Call via Slack\n\ntelegram — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,880],"id":"0741bd61-358e-7166-b96c-cae9606f6e99","name":"Note: Page On-Call via Slack"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"b721cf51-388b-8dfd-8cb3-1d151d96e1d6","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"bc183682-8787-0ffc-3216-7586261788e1","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"af816984-1dc1-846b-49e9-5bddc792534c","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"259fc761-56e9-8c38-bbf7-960637ec0fce","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per asset (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"67c33960-11c5-c9ff-fa80-48a368054ed1","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"309e838a-cf9d-760f-e113-d621dd0e23cc","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"52bf9b47-b07a-bd2e-d8b8-74a5c86a2fb1","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"93c3891d-6b60-8307-1e3e-ce685390c288","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"9425ef93-bc00-56b6-004a-46f2ef438e33","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Telegram · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"181bd342-9f81-1e5d-37a0-d25bd6c1fdd4","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Telegram\n\ntelegram — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"6502773f-f11a-d93a-a655-84f2928d9a4b","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Telegram","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"4eb4e894-150a-0e8a-20e2-666733a2f4d5","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Telegram\n\ntelegram — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Telegram bot token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"ae76bb37-97cc-ec3a-aaa5-f98bf105db76","name":"Note: Escalate Failure to Telegram"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,1540],"id":"3788ac55-0ef3-bfb4-235e-173408bace00","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Monitor a key metric with HTTP / REST API and Telegram 24/7\n\n**Pattern:** Threshold Monitoring · **Level:** Production · **Trigger:** Scheduled\n\n## What it does\nMonitor a key metric with HTTP / REST API and Telegram 24/7. It runs automatically on a schedule.\n\n## Why it exists\nManual risk monitoring is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nEvery Few Minutes → Probe Endpoint A → Combine Probe Results → All Healthy? → Record Uptime Metric → Load Previous Snapshot → Compute Drift vs Snapshot → …\n\n## Use it for\n- Teams that want to threshold monitoring without manual effort\n- Anyone automating risk monitoring in finance\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Responds in seconds\n- Keeps your systems in sync\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"73f92747-bc3d-bb17-6f66-df1af55b0f86","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"c10018a2-8aba-827d-2599-387b2bab7ebd","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"e36c5b5d-1bab-b153-b2d1-48dd04e50532","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your risk monitoring process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"f293afbd-cab4-42a0-2515-4dac9ba7cd12","name":"🛠 Customize me"}],"connections":{"Every Few Minutes":{"main":[[{"node":"Probe Endpoint A","type":"main","index":0},{"node":"Probe Endpoint B","type":"main","index":0},{"node":"Probe Endpoint C","type":"main","index":0}]]},"Probe Endpoint A":{"main":[[{"node":"Combine Probe Results","type":"main","index":0}]]},"Probe Endpoint B":{"main":[[{"node":"Combine Probe Results","type":"main","index":1}]]},"Probe Endpoint C":{"main":[[{"node":"Combine Probe Results","type":"main","index":2}]]},"Combine Probe Results":{"main":[[{"node":"All Healthy?","type":"main","index":0}]]},"All Healthy?":{"main":[[{"node":"Record Uptime Metric","type":"main","index":0}],[{"node":"Already Alerted? (State Check)","type":"main","index":0}]]},"Already Alerted? (State Check)":{"main":[[{"node":"Page On-Call via Slack","type":"main","index":0}]]},"Record Uptime Metric":{"main":[[{"node":"Load Previous Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Telegram","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Telegram","type":"main","index":0}]]},"Escalate Failure to Telegram":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Page On-Call via Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Send Summary to Telegram":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"cdbf6813-b04f-4f2a-b2b0-a39fb4f8cd60","id":"FDX08918"}