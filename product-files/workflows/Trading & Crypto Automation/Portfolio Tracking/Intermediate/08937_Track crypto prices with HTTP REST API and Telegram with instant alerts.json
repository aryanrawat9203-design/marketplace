        300
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "71f01aeb-5d3c-4ada-8a68-454d18461bf5",
              "leftValue": "={{ $json.category }}",
              "rightValue": "paid",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "1bef4f90-6dd2-4e05-a0d9-496fe2fe7d8c",
      "name": "Route on Condition",
