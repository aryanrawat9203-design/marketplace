            {
              "id": "6481312f-9630-40c4-a2ec-641cb501b381",
              "leftValue": "={{ $json.status }}",
              "rightValue": "new",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "377b9235-b32c-416c-92b5-df87ca94b539",
