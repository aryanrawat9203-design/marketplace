{"name":"Monitor stock levels with HTTP / REST API and Telegram with instant alerts","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":10}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"d2bb71b7-9e9d-4c89-b9b1-8f18f0a21e72","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/assets","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"03241abc-6f52-4b18-a274-cb5c4bd7849b","name":"Fetch Current Metrics","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compute a simple moving average and momentum signal\nconst items = $input.all().map(i => i.json);\nconst closes = items.map(j => Number(j.price)).filter(n => !isNaN(n));\nconst sma = closes.slice(-20).reduce((a, b) => a + b, 0) / Math.min(20, closes.length);\nconst last = closes[closes.length - 1];\nconst momentum = closes.length > 5 ? last - closes[closes.length - 6] : 0;\nreturn [{ json: { sma20: Math.round(sma * 100) / 100, last, momentum, signal: last > sma && momentum > 0 ? 'bullish' : 'neutral' } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"06d59508-7647-4160-966f-972d92f7b7a4","name":"Compute Severity Signals"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"525ef5f5-f2ff-4ab0-86af-bebdd3bd385d","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":40,"operator":{"type":"number","operation":"lt"}}],"combinator":"and"},"renameOutput":true,"outputKey":"info"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fcd66c36-bd68-4fce-8871-0d5cec1ae546","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":70,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warning"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"bd982039-46e3-49e1-b402-1625890f7cae","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":90,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"critical"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"a6dd69ba-2eaa-42f8-9aeb-e03717681091","name":"Grade Severity Tier"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,-80],"id":"36a62d6e-3dce-401c-a9b9-f5b7a11ac19c","name":"Just Record (Info)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#trading","cachedResultName":"#trading"},"text":"=🟠 Warning tier reached: {{ $json.symbol }} at {{ $json.score ?? $json.last }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1350,400],"id":"4e0cf57c-1576-4a98-a90f-4c25c8dd4d92","name":"Warn Channel (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🔴 CRITICAL: {{ $json.symbol }} breached threshold — act now","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegr