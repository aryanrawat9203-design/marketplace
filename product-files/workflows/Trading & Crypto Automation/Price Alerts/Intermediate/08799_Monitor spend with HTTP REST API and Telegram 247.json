            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "eb5181bf-6e8a-460e-ace3-bcd33614c20a",
              "leftValue": "={{ $json.receivedAt || $now.toISO() }}",
              "rightValue": "",
