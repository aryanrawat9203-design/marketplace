              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "66e3495c-2062-4a1e-994c-158063419dae",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "30042da4-ab10-4d07-a08c-863fa93a6f68",
