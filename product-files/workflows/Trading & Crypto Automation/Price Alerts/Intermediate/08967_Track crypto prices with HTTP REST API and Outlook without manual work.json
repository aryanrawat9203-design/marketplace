            {
              "id": "ccb3c257-f55f-4679-8364-41bade6c5456",
              "leftValue": "={{ $json.amount }}",
              "rightValue": "open",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "0c52f051-a750-4656-aeae-6535075982e5",
