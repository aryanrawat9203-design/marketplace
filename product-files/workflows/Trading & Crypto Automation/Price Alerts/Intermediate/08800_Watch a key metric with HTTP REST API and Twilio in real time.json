"lib: Post-Process Assets"},"options":{"waitForSubWorkflow":true}},"type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[6858,400],"id":"12b277af-62f9-4981-bcee-9255132ed4e4","name":"Offload to Post-Process Sub-workflow","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"dataToSave":{"values":[{"key":"subflowStatus","value":"={{ $json.status || 'done' }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[7182,400],"id":"8829806e-df83-40e0-b196-0e91f257e9b4","name":"Record Sub-workflow Result"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[7506,400],"id":"c9b4e7f2-5dfc-4615-ba47-954e4c7349b8","name":"Load Previous Snapshot 2","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[7830,400],"id":"db3bf284-8a60-4917-a933-e4ed2a993742","name":"Compute Drift vs Snapshot"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Build a stable idempotency key per asset (djb2 hash, no deps)\nfunction hash(s) {\n  let h = 5381;\n  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;\n  return h.toString(16);\n}\nreturn $input.all().map(item => {\n  const j = item.json;\n  return { json: { ...j, idempotencyKey: hash([j.symbol, j.price].join('|')) } };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[8154,400],"id":"3f91b3ad-44cd-4117-8d3a-dc76ea7271de","name":"Fingerprint for Idempotency"},{"parameters":{"operation":"removeItemsSeenInPreviousExecutions","logic":"removeItemsWithAlreadySeenKeyValues","dedupeValue":"={{ $json.idempotencyKey }}","options":{}},"type":"n8n-nodes-base.removeDuplicates","typeVersion":2,"position":[8478,400],"id":"bd504b32-246e-49cb-bcb8-3d108a9756c1","name":"Drop Already-Processed Items"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"volume","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[8802,400],"id":"fb1b3689-534e-4ecb-a2e5-3c55a9992726","name":"Sort Assets Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"5c0ed8c7-f4da-4724-884b-afbb0b47013e","name":"pipeline","value":"Price Alerts","type":"string"},{"id":"79c17286-04f8-4283-95f7-841ce9699234","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9126,400],"id":"09c3e040-5a3b-4db3-bab8-71fb72918d13","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"symbol"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[9450,400],"id":"f7fb4a1f-7044-4671-84dd-80e1a542023a","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"symbol","value":"={{ $json.symbol }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[9774,400],"id":"3ab51566-4432-47f4-9cfe-6bfad740f8ed","name":"Save Execution Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"7abd8860-e1e8-461a-8172-6c130680c5eb","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"c78458fd-63c6-4239-8461-b8931ce61e34","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"590f1c15-0ecb-4ba0-9f72-a9df43a7ef96","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[10098,400],"id":"d21d10db-bdc9-46d0-a110-87ecac6a2621","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Database"},"title":"={{ $json.price || $json.symbol }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[10422,400],"id":"26a5f0d6-2eb9-4125-915a-265687b3de34","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#trading","cachedResultName":"#trading"},"text":"=✅ Watch a key metric with HTTP / REST API and Twilio in real time — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[10746,400],"id":"7f14d09b-72fa-468a-b171-908216b6c223","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"ea1c8936-a970-48db-b682-a2bdaa69aa3d","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a1be93c6-ff31-4d34-80aa-a26c9ce6e17f","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"f18ce1d2-0b2a-4f3c-a989-fdb6d5ed312b","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[10098,1420],"id":"4dc0fcc8-6586-4a5e-9dc2-cb034dc2a238","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#trading","cachedResultName":"#trading"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[10422,1420],"id":"d73374f2-42e9-49c7-b80c-8e674ca5566a","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Database"},"title":"={{ $json.price || $json.symbol }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[10746,1420],"id":"a65ec7df-3fb7-4a8a-bb9b-8df1ceaa664f","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Every Few Minutes\n\nStarts the workflow on a timer — every 5 min. No input data; downstream nodes fetch what they need.\n\nNext: Fetch Target Page","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"8dcf3182-28df-d31c-015d-eca4b4589b8a","name":"Note: Every Few Minutes"},{"parameters":{"content":"### Fetch Target Page\n\nGET https://example-market.com/assets — retries 3× with backoff on failure.\n\nPorts: ①→ Extract Listings (CSS) · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"51d7a66a-3fc9-e39c-97e9-af1879627c9c","name":"Note: Fetch Target Page"},{"parameters":{"content":"### Extract Listings (CSS)\n\nExtracts structured values from raw HTML via CSS selectors.\n\nNext: Rows from Arrays","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"912ed066-8641-e19a-b5de-5fb3083b5747","name":"Note: Extract Listings (CSS)"},{"parameters":{"content":"### Rows from Arrays\n\nCustom JavaScript: Zip parallel arrays into one item per listing\n\nNext: Diff vs Last Run","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"2ccb1098-5a53-528a-8279-2b916a53028e","name":"Note: Rows from Arrays"},{"parameters":{"content":"### Load Previous Snapshot\n\nnotion — `getAll` operation against the connected account.\n\nPorts: ①→ Diff vs Last Run · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,1030],"id":"569b29cd-cf94-0afb-44cb-378b0672f729","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Diff vs Last Run\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Alert New Findings · ③→ Update Changed Rows · ④→ Write Fresh Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"9e7f1eb7-b511-2ad2-af97-08ccb5142ee9","name":"Note: Diff vs Last Run"},{"parameters":{"content":"### Alert New Findings\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,40],"id":"799bc45e-a72e-f94f-2fb2-860e77a62c8e","name":"Note: Alert New Findings"},{"parameters":{"content":"### Update Changed Rows\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,580],"id":"cd0c9420-c426-13a8-0022-567d4ac81ec8","name":"Note: Update Changed Rows"},{"parameters":{"content":"### Write Fresh Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Merge Diff Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,1090],"id":"879375dd-aece-7ab8-c219-bdf90be685aa","name":"Note: Write Fresh Snapshot"},{"parameters":{"content":"### Merge Diff Outcomes\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"4b1189f4-329a-1ec0-9790-40d8b02f394a","name":"Note: Merge Diff Outcomes"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"163419d5-6f67-9d0d-8aa3-ba55d2e23582","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"e8a9c6c0-15b1-da7b-4de5-70fa025f0f16","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"1352b41f-ad2c-66f6-074a-79d24956ba9b","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"809210f3-db18-d9ef-959d-8185db2b5b2c","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"d1a465cf-526c-da83-3466-f5317d01879a","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Offload to Post-Process Sub-workflow · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"8825f5b4-3b2b-90ad-a152-761aedf2433e","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Offload to Post-Process Sub-workflow\n\nDelegates to a reusable sub-workflow (single-responsibility building block) and waits for its result.\n\nPorts: ①→ Record Sub-workflow Result · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"3f8778bd-efac-5a9f-0d8f-c4913abf8dba","name":"Note: Offload to Post-Process Sub-workflow"},{"parameters":{"content":"### Record Sub-workflow Result\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Load Previous Snapshot 2","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"527203da-84a5-acaa-d36d-f032db0261a3","name":"Note: Record Sub-workflow Result"},{"parameters":{"content":"### Load Previous Snapshot 2\n\nnotion — `getAll` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"9ef6a69a-1f6e-500e-0934-b4cfb84efb26","name":"Note: Load Previous Snapshot 2"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Fingerprint for Idempotency","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"9ce4fd49-28a0-25b3-d31f-6e2e7a4a07ec","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Fingerprint for Idempotency\n\nCustom JavaScript: Build a stable idempotency key per asset (djb2 hash, no deps)\n\nNext: Drop Already-Processed Items","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8094,520],"id":"69f62a59-4197-9add-587e-665156bcdbb7","name":"Note: Fingerprint for Idempotency"},{"parameters":{"content":"### Drop Already-Processed Items\n\nCross-execution dedupe: remembers keys it has processed before and drops repeats — the idempotency guard.\n\nNext: Sort Assets Newest First","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8418,520],"id":"8183d960-b6a3-a1c1-ea02-1515c58930c1","name":"Note: Drop Already-Processed Items"},{"parameters":{"content":"### Sort Assets Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[8742,520],"id":"642a7673-489b-904c-dd18-a3f0f30fed49","name":"Note: Sort Assets Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9066,520],"id":"8ec58c31-16b0-b1f6-18be-3b43471de9e7","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9390,520],"id":"9dbccea9-fafa-5e8d-b714-171560ecdd16","name":"Note: Align Field Names"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[9714,520],"id":"78b422be-d9ec-246f-2dca-ab5d25532f0e","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10038,520],"id":"ef60146c-15b6-9a9c-7dff-d315ce886fb9","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nnotion — `create` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10362,520],"id":"48860b3d-e582-d79d-798a-185debe03685","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10686,520],"id":"b63e8af1-6790-4cef-58a4-8bbf71aee632","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10038,1540],"id":"a88ef922-238f-f34d-7f6a-b249bb4c12a9","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10362,1540],"id":"fd14d47f-6a46-1a38-7a19-59a8b093aced","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nnotion — `create` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Notion integration token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[10686,1540],"id":"dc00d66b-9e00-60dc-c8af-8353d34f187a","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Watch a key metric with HTTP / REST API and Twilio in real time\n\n**Pattern:** Threshold Monitoring · **Level:** Architect · **Trigger:** Scheduled\n\n## What it does\nWatch a key metric with HTTP / REST API and Twilio in real time. It runs automatically on a schedule.\n\n## Why it exists\nManual price alerts is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nEvery Few Minutes → Fetch Target Page → Extract Listings (CSS) → Rows from Arrays → Diff vs Last Run → Alert New Findings → Merge Diff Outcomes → …\n\n## Use it for\n- Teams that want to threshold monitoring without manual effort\n- Anyone automating price alerts in finance\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Saves hours of manual work each week\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Notion integration token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"1fd122c4-1f77-b549-e141-986c01e7b7cf","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"c30acdf4-f753-b7db-7bc3-364d427296d5","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"442fefe3-2fe1-a93f-c926-8d9f4c3d2f6e","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your price alerts process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-500],"id":"062baf2b-ff80-3d39-997e-42c54e289319","name":"🛠 Customize me"}],"connections":{"Every Few Minutes":{"main":[[{"node":"Fetch Target Page","type":"main","index":0},{"node":"Load Previous Snapshot","type":"main","index":0}]]},"Fetch Target Page":{"main":[[{"node":"Extract Listings (CSS)","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Extract Listings (CSS)":{"main":[[{"node":"Rows from Arrays","type":"main","index":0}]]},"Rows from Arrays":{"main":[[{"node":"Diff vs Last Run","type":"main","index":0}]]},"Load Previous Snapshot":{"main":[[{"node":"Diff vs Last Run","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff vs Last Run":{"main":[[{"node":"Alert New Findings","type":"main","index":0}],[],[{"node":"Update Changed Rows","type":"main","index":0}],[{"node":"Write Fresh Snapshot","type":"main","index":0}]]},"Alert New Findings":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Update Changed Rows":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Write Fresh Snapshot":{"main":[[{"node":"Merge Diff Outcomes","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Diff Outcomes":{"main":[[{"node":"Stamp Completion Time","type":"main","index":0}]]},"Stamp Completion Time":{"main":[[{"node":"Persist Run Metadata","type":"main","index":0}]]},"Persist Run Metadata":{"main":[[{"node":"Enrich with Reference Data","type":"main","index":0}]]},"Enrich with Reference Data":{"main":[[{"node":"Fold In Enrichment Fields","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Fold In Enrichment Fields":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Offload to Post-Process Sub-workflow","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Offload to Post-Process Sub-workflow":{"main":[[{"node":"Record Sub-workflow Result","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Record Sub-workflow Result":{"main":[[{"node":"Load Previous Snapshot 2","type":"main","index":0}]]},"Load Previous Snapshot 2":{"main":[[{"node":"Compute Drift vs Snapshot","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Drift vs Snapshot":{"main":[[{"node":"Fingerprint for Idempotency","type":"main","index":0}]]},"Fingerprint for Idempotency":{"main":[[{"node":"Drop Already-Processed Items","type":"main","index":0}]]},"Drop Already-Processed Items":{"main":[[{"node":"Sort Assets Newest First","type":"main","index":0}]]},"Sort Assets Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Escalate Failure to Slack":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"133870d4-ff72-46cf-8eeb-312025a84429","id":"FDX08800"}