            {
              "id": "05ce9b55-0274-48db-bdfe-ae8fa6163796",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "c0f54506-2592-4dcc-bfad-d9ae6e8cc91e",
