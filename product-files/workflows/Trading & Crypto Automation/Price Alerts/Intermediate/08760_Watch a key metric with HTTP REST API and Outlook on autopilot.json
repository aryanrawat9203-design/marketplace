              "type": "string"
            },
            {
              "id": "47b80cd1-bac2-4624-a0f9-8390dec25f38",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "f5201b4c-cd26-499d-8fbf-9abb62cb0e4f",
