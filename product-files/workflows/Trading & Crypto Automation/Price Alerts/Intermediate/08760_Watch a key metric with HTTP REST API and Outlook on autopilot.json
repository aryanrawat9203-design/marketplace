              "rightValue": "high",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "658ded07-b709-4c63-9316-4f9e1309a09b",
      "name": "Route on Condition",
