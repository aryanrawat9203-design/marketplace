{"name":"Monitor stock levels with HTTP / REST API and Telegram","nodes":[{"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":10}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-270,400],"id":"3843eeb9-5153-4d22-94e2-d2ebd35c6a49","name":"Every Few Minutes"},{"parameters":{"method":"GET","url":"https://api.example.com/v1/assets","options":{"timeout":20000},"sendQuery":true,"queryParameters":{"parameters":[{"name":"updated_since","value":"={{ $now.minus({hours: 6}).toISO() }}"},{"name":"limit","value":"100"}]}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[54,400],"id":"d8c964e1-6d46-4cc8-98cf-9f216e5223ba","name":"Fetch Current Metrics","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compute a simple moving average and momentum signal\nconst items = $input.all().map(i => i.json);\nconst closes = items.map(j => Number(j.price)).filter(n => !isNaN(n));\nconst sma = closes.slice(-20).reduce((a, b) => a + b, 0) / Math.min(20, closes.length);\nconst last = closes[closes.length - 1];\nconst momentum = closes.length > 5 ? last - closes[closes.length - 6] : 0;\nreturn [{ json: { sma20: Math.round(sma * 100) / 100, last, momentum, signal: last > sma && momentum > 0 ? 'bullish' : 'neutral' } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[378,400],"id":"a2a784a0-eefe-4e7b-8c8f-420c646763ef","name":"Compute Severity Signals"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"d8fe6c77-d113-4008-8557-63e5292f0278","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":40,"operator":{"type":"number","operation":"lt"}}],"combinator":"and"},"renameOutput":true,"outputKey":"info"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"bca84227-2411-4d9d-8a1f-97f7285f1bd0","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":70,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"warning"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"4abaa261-9784-45c0-a515-7f022c550796","leftValue":"={{ $json.score ?? $json.momentum ?? 0 }}","rightValue":90,"operator":{"type":"number","operation":"gte"}}],"combinator":"and"},"renameOutput":true,"outputKey":"critical"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"5b8dbd3e-8437-4214-8dd5-239a97c5a07d","name":"Grade Severity Tier"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,-80],"id":"466cb35a-3735-41f3-b240-14202504f7d8","name":"Just Record (Info)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🟠 Warning tier reached: {{ $json.symbol }} at {{ $json.score ?? $json.last }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[1350,400],"id":"d3e57423-8603-473b-a49f-05b9e39c9983","name":"Warn Channel (Telegram)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#trading","cachedResultName":"#trading"},"text":"=🔴 CRITICAL: {{ $json.symbol }} breached threshold — act now","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[1674,880],"id":"9012ed1a-2f57-4d8b-b098-8aded3373aab","name":"Page Urgently (Slack)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Asset Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1998,1360],"id":"fbae0cf5-40c9-4018-84f5-6a3d4b725c1e","name":"Archive Unscored","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":4},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2646,400],"id":"24ddf703-71bd-4847-89a4-e9e15542c736","name":"Merge Tier Outcomes"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"symbol"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3618,400],"id":"0ea3acdc-5070-4a01-8902-3b8292b50ceb","name":"Align Field Names"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3942,400],"id":"f36bbd29-84f5-4e92-a632-c8c16ffe76f7","name":"Stamp Processing Time"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Monitor stock levels with HTTP / REST API and Telegram — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[4266,400],"id":"d4fe7724-a808-4297-9380-784b3adbdf9a","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"676f9def-d478-45b7-a858-40eccc9652f1","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"80a0b948-8b7e-4608-85aa-6f833c9cee1c","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"3efd2b93-57ee-4144-aa73-692027c8ed33","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,1420],"id":"bbd49b96-6a5b-40f1-89c7-9557e498fd8d","name":"Capture Failure Context"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[3942,1420],"id":"d80a2d23-af0a-460d-b137-076bd9bb3df4","name":"Escalate Failure to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Every Few Minutes\n\nStarts the workflow on a timer — every 10 min. No input data; downstream nodes fetch what they need.\n\nNext: Fetch Current Metrics","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"601c5a64-7507-83e3-d946-c79a6ddde6f2","name":"Note: Every Few Minutes"},{"parameters":{"content":"### Fetch Current Metrics\n\nGET https://api.example.com/v1/assets — retries 3× with backoff on failure.\n\nPorts: ①→ Compute Severity Signals · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"e05c8018-7d76-f9ed-488d-01d41f5dd1cf","name":"Note: Fetch Current Metrics"},{"parameters":{"content":"### Compute Severity Signals\n\nCustom JavaScript: Compute a simple moving average and momentum signal\n\nNext: Grade Severity Tier","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"fb5975cb-57df-421f-6117-8cdaa803831f","name":"Note: Compute Severity Signals"},{"parameters":{"content":"### Grade Severity Tier\n\nRoutes each item to one of 4 lanes: info, warning, critical + fallback.\n\nPorts: ①→ Just Record (Info) · ②→ Warn Channel (Telegram) · ③→ Page Urgently (Slack) · ④→ Archive Unscored","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"71229e5e-4864-fa86-14b8-07dd26ab9d6f","name":"Note: Grade Severity Tier"},{"parameters":{"content":"### Just Record (Info)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,40],"id":"2c825415-cdf4-3a90-14e4-846aca038ae7","name":"Note: Just Record (Info)"},{"parameters":{"content":"### Warn Channel (Telegram)\n\ntelegram — `action` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"58da4e67-6783-7d07-b5df-0bb9bd09f5f7","name":"Note: Warn Channel (Telegram)"},{"parameters":{"content":"### Page Urgently (Slack)\n\nslack — `action` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1000],"id":"80c35276-2175-1168-6dac-e2843dd51f0b","name":"Note: Page Urgently (Slack)"},{"parameters":{"content":"### Archive Unscored\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Merge Tier Outcomes · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,1480],"id":"39edb81d-6f82-fc76-c0b3-be4a06baa666","name":"Note: Archive Unscored"},{"parameters":{"content":"### Merge Tier Outcomes\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,520],"id":"94d246ed-c0df-6fd2-7893-f287f5f64a4f","name":"Note: Merge Tier Outcomes"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"43c24a10-12a0-6fc6-0b95-8f503353c405","name":"Note: Align Field Names"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Send Summary to Telegram","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"ac8bf9ab-a496-a930-b1de-37d561ac18b1","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Send Summary to Telegram\n\ntelegram — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"d4c25e32-8f64-7ec7-36b7-0dc6b0f790d1","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Telegram","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,1540],"id":"98ae27d0-2648-0048-f862-8e36ce24537f","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Telegram\n\ntelegram — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Telegram bot token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,1540],"id":"eb3aac32-263d-f040-929a-c3dcc01c487f","name":"Note: Escalate Failure to Telegram"},{"parameters":{"content":"# Monitor stock levels with HTTP / REST API and Telegram\n\n**Pattern:** Threshold Monitoring · **Level:** Core · **Trigger:** Scheduled\n\n## What it does\nMonitor stock levels with HTTP / REST API and Telegram. It runs automatically on a schedule.\n\n## Why it exists\nManual price alerts is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nEvery Few Minutes → Fetch Current Metrics → Compute Severity Signals → Grade Severity Tier → Just Record (Info) → Merge Tier Outcomes → Align Field Names → …\n\n## Use it for\n- Teams that want to threshold monitoring without manual effort\n- Anyone automating price alerts in finance\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Has retries and error handling built in\n- Improves response time\n- Responds in seconds\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Slack OAuth2; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"7558b6a2-19dd-68bc-49ff-a81088de755a","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-500],"id":"0fda0068-81bc-caad-7f20-3e2e956eada3","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your price alerts process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-500],"id":"304a8a1b-6cdb-e80d-adb2-1578e4b61768","name":"🛠 Customize me"}],"connections":{"Every Few Minutes":{"main":[[{"node":"Fetch Current Metrics","type":"main","index":0}]]},"Fetch Current Metrics":{"main":[[{"node":"Compute Severity Signals","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Compute Severity Signals":{"main":[[{"node":"Grade Severity Tier","type":"main","index":0}]]},"Grade Severity Tier":{"main":[[{"node":"Just Record (Info)","type":"main","index":0}],[{"node":"Warn Channel (Telegram)","type":"main","index":0}],[{"node":"Page Urgently (Slack)","type":"main","index":0}],[{"node":"Archive Unscored","type":"main","index":0}]]},"Just Record (Info)":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Warn Channel (Telegram)":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Page Urgently (Slack)":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Archive Unscored":{"main":[[{"node":"Merge Tier Outcomes","type":"main","index":3}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Merge Tier Outcomes":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Send Summary to Telegram","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Telegram","type":"main","index":0}]]},"Send Summary to Telegram":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"d5f7191a-fe61-43e0-8f75-c299fa35b013","id":"FDX08908"}