              "type": "string"
            },
            {
              "id": "d5ec449d-0cda-4c19-819c-e912c97a48ce",
              "name": "isValid",
              "value": "={{ $json ? true : false }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
      },
      "id": "1e1c6490-5520-4cff-bf9c-a7036be70bca",
