            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "6142a284-a3c1-4c6d-894b-99db944238e2",
              "leftValue": "={{ $json.category }}",
              "rightValue": "high",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "fa123e33-3a6f-4f6e-9618-4d129b0976ac",
      "name": "Route on Condition",
