des-base.switch","typeVersion":3.2,"position":[702,400],"id":"ae5e1197-8c14-4268-bdbd-225206ff27ba","name":"Route by Event Kind"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO orders (orderId, email, total, updated_at)\nVALUES ($1, $2, $3, NOW())\nON CONFLICT (orderId) DO UPDATE SET updated_at = NOW();","options":{"queryReplacement":"={{ [ $json.orderId, $json.email, $json.total ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1026,130],"id":"5dbf9a76-98e3-4bc9-b7b9-fcbad01b178b","name":"Handle 'order.paid' → PostgreSQL","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{},"type":"n8n-nodes-base.shopify","typeVersion":1,"position":[1350,640],"id":"852425e3-5b66-4ee5-9b1c-31d33f53ab86","name":"Handle 'order.cancelled' → Shopify","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO order_log (orderId, email, total, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.orderId, $json.email, $json.total ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1674,1150],"id":"efd52bd9-b744-4606-9ea8-e33b25239549","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"eae6ebee-e91f-468b-aa44-d9e705cd523a","name":"Consolidate Handling"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[3294,400],"id":"f291b825-ada7-46b9-8194-d66dfc1bc592","name":"Stamp Processing Time"},{"parameters":{"assignments":{"assignments":[{"id":"37d06028-4d1a-4a1e-908c-d83fdd3a81af","name":"pipeline","value":"Inventory","type":"string"},{"id":"b5c0ff68-7721-44d0-9b91-d2c959ebbe91","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[3618,400],"id":"fb97c7de-4542-418a-bd4e-8fc9d09630c5","name":"Tag Pipeline Metadata"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"orderId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3942,400],"id":"1cde43b5-11a2-48a5-ba05-917c77aa2a88","name":"Align Field Names"},{"parameters":{"maxItems":50},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[4266,400],"id":"62d8dc39-ff74-46b2-98d3-a06fe52deb15","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"af4efa1e-03d9-4f73-b1ad-c26cb22569cd","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"f7982694-ba8b-484b-b3ec-d27369cdd6f4","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"4b99b5a6-17e0-4ae9-8999-ed41a431289b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,400],"id":"7265897a-85a6-4b5a-bf75-cb30dc5d6275","name":"Summarize Run Stats"},{"parameters":{"operation":"executeQuery","query":"INSERT INTO order_log (orderId, email, total, logged_at)\nVALUES ($1, $2, $3, NOW());","options":{"queryReplacement":"={{ [ $json.orderId, $json.email, $json.total ] }}"}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[4914,400],"id":"3f394edf-c747-4d90-8d3d-511104735505","name":"Append Audit Row (PostgreSQL)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#orders","cachedResultName":"#orders"},"text":"=✅ Route paid orders with Shopify and PostgreSQL — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5238,400],"id":"4876e6e7-2db2-48e2-96de-3e7961b57ad1","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"469d7cba-4f88-4f1c-8dcc-d329304342ad","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"b7f59273-c5be-4cb5-858e-a7d06ebf2ba6","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"0634fc4f-dde9-454d-a92b-c8e9e22ba16f","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4590,1420],"id":"056be33b-b63c-4d37-821a-d3dd921c46c3","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#orders","cachedResultName":"#orders"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[4914,1420],"id":"98b122e0-3fa3-4aa9-914b-07e9c9350dfd","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf09113-order`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Map to Canonical Schema","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"7c2eb66f-f267-80f5-4420-2d66c743b60b","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `orderId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Acknowledge Fast (HTTP 202)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"e7880c58-a0ed-89c8-5a6a-e3967aca37aa","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Acknowledge Fast (HTTP 202)\n\nSends the HTTP 202 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Route by Event Kind","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"7a95c2a7-09b9-f72b-e97d-236ee22afb32","name":"Note: Acknowledge Fast (HTTP 202)"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 3 lanes: order.paid, order.cancelled + fallback.\n\nPorts: ①→ Handle 'order.paid' → PostgreSQL · ②→ Handle 'order.cancelled' → Shopify · ③→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"58afb90f-23fa-9eaa-d5de-2b61d7354e15","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'order.paid' → PostgreSQL\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,250],"id":"9177f65d-bd55-073b-8b60-19cce7fd7cf7","name":"Note: Handle 'order.paid' → PostgreSQL"},{"parameters":{"content":"### Handle 'order.cancelled' → Shopify\n\nshopify — `action` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Shopify access token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,760],"id":"47085e85-c085-8cb2-c872-c5ca30dd9f6a","name":"Note: Handle 'order.cancelled' → Shopify"},{"parameters":{"content":"### Log Unrecognized Kind\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1270],"id":"9fb4ac27-9844-ff1f-95cc-9c8677b105d3","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"bdc3ab6b-8db2-1793-148c-a15cb2c33141","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"83d7b9b0-d447-e711-fa61-4da43828a77f","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"52f3705a-fe3f-44fc-67d6-d81d2a2d0faf","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"017a8398-b2ea-0a1a-e3bc-be2309634835","name":"Note: Align Field Names"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 50 items to protect downstream quotas.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"fc9d2d7d-0c13-3ac2-03fd-a558235fa939","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (PostgreSQL)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"1f9b7f2b-980a-1b8e-2bcf-f316301159df","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (PostgreSQL)\n\npostgres — `executeQuery` operation against the connected account.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Postgres connection","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"5183093b-4304-cc9b-b2a9-70ac704dba30","name":"Note: Append Audit Row (PostgreSQL)"},{"parameters":{"content":"### Send Summary to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"d365a446-d99b-e56e-1e1a-23e732fd2ede","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,1540],"id":"78584626-12e8-756f-764a-52e0353164cf","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"4ff2ade8-fa3e-35bf-3841-2b578171579e","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"# Route paid orders with Shopify and PostgreSQL\n\n**Pattern:** Order Fulfillment · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nRoute paid orders with Shopify and PostgreSQL. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual inventory is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Map to Canonical Schema → Acknowledge Fast (HTTP 202) → Route by Event Kind → Handle 'order.paid' → PostgreSQL → Consolidate Handling → Stamp Processing Time → …\n\n## Use it for\n- Teams that want to order fulfillment without manual effort\n- Anyone automating inventory in e-commerce\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Standardizes the process every time\n- Improves response time\n- Removes copy-paste errors\n\n## Before first run\nConnect credentials: Postgres connection; Shopify access token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"6d3c4998-d294-1c6d-820f-5ddecb9fc998","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"6c7e45c6-ab34-86ad-fab3-f534c41c83c9","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"f1dc93dd-8b49-7de4-9046-e44363f548ea","name":"🔐 Security"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your inventory process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"9acdec8a-77ac-0221-62e9-c193a6ab1d04","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Acknowledge Fast (HTTP 202)","type":"main","index":0}]]},"Acknowledge Fast (HTTP 202)":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'order.paid' → PostgreSQL","type":"main","index":0}],[{"node":"Handle 'order.cancelled' → Shopify","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'order.paid' → PostgreSQL":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'order.cancelled' → Shopify":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (PostgreSQL)","type":"main","index":0}]]},"Append Audit Row (PostgreSQL)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Slack","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1"},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{},"versionId":"c6eac1dd-db59-4ee9-919a-95e5a532f37c","id":"FDX09113"}