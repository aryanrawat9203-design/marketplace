{"name":"Broadcast the team on new events with Discord","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09218-order","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"e5a43481-6ccf-4bc4-b1ed-5a24594e0870","name":"Receive Inbound Webhook","webhookId":"4e667bf9-e177-4e5f-8270-8e8bff029046"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"dff81c0f-b8ff-4b33-ae2d-b34a4d12288d","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f033fdb1-e317-41e8-a0f7-d704b7a24d03","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"1c610e59-3bad-4798-8b96-0472cf874e35","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"4e33ab43-1305-4e23-ac9c-a42db80abe19","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"ddec2366-435b-4d95-8d6c-ef91e5cdec5e","name":"orderId","value":"={{ $json.body?.orderId || $json.body?.id }}","type":"string"},{"id":"e72a7baf-80fc-4560-83b5-a415dd467a8f","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"1fdf3720-6a06-4c3c-a559-c212f3eb0db8","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"2708c144-984e-4112-8bbf-1f8