{"name":"Fulfill paid orders with Shopify and Notion on autopilot","nodes":[{"parameters":{"topic":"orders/create"},"type":"n8n-nodes-base.shopifyTrigger","typeVersion":1,"position":[-270,400],"id":"9749245e-600c-4101-bf64-49986f0bb0fc","name":"On Shopify Event","webhookId":"2bcb2bd5-0b3f-425c-95b7-c20e177f7de6"},{"parameters":{"assignments":{"assignments":[{"id":"92240b12-6ed5-46e2-a459-9249544c7308","name":"orderId","value":"={{ $json.body?.orderId || $json.body?.id }}","type":"string"},{"id":"7e0172b1-4e40-4d89-91df-ec30a9e330d9","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"221144ea-f3a8-473f-ae2a-3b504bdf8fdb","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"b18a2ff3-936a-453b-b86f-d2d6d2766af0","name":"Map to Canonical Schema"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"1bcec89b-a00c-4faa-8330-39a18f202218","leftValue":"={{ $json.kind }}","rightValue":"order.paid","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"order.paid"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"e98ea6cc-ebf7-43de-9c5b-6809c788d502","leftValue":"={{ $json.kind }}","rightValue":"order.cancelled","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"order.cancelled"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[378,400],"id":"ba2d085d-32a2-488c-b294-4574993db5dc","name":"Route by Event Kind"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[702,130],"id":"a06ef2eb-c058-4b65-8ed1-5404d380af70","name":"Handle 'order.paid' → Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"order","operation":"update","orderId":"={{ $json.id || $json.orderId }}","options":{}},"type":"n8n-nodes-base.shopify","typeVersion":1,"position":[1026,640],"id":"d70b786c-d0b8-4883-ba03-a7e6abd06ef0","name":"Handle 'order.cancelled' → Shopify","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1350,1150],"id":"c3019b11-29f6-4864-a494-92e67eb267ac","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1998,400],"id":"50e31829-6551-4005-8fae-5a04ea5b3b65","name":"Consolidate Handling"},{"parameters":{"assignments":{"assignments":[{"id":"1ec92549-97ef-4ab4-9687-90b8f9e47e43","name":"pipeline","value":"Inventory","type":"string"},{"id":"32de1199-1ab1-43e5-9aa7-3e1f4693a0a4","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2970,400],"id":"57cadb90-ed3a-4790-8eaf-ca9d3d338bee","name":"Tag Pipeline Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[3294,400],"id":"61434aca-4ff5-43a5-adff-0f24d6efd06e","name":"Sort Orders Newest First"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"orderId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3618,400],"id":"19ae0f59-5edb-4849-a205-be4f73e50e2d","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"orderId","value":"={{ $json.orderId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3942,400],"id":"92e3a6b1-b275-4400-8ea5-0974515e5146","name":"Save Execution Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"ce65e682-1005-4c63-9bb7-041d80cfbf69","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[4266,400],"id":"595cc7c6-60bd-4beb-bdd9-9eb4cf1e61a2","name":"Guard Non-Empty email"},{"parameters":{"operation":"getCurrentDate","outputFieldName":"processedAt","options":{}},"type":"n8n-nodes-base.dateTime","typeVersion":2,"position":[4590,400],"id":"29690123-737d-4596-873e-a0d9e44a0077","name":"Stamp Processing Time"},{"parameters":{"maxItems":100},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[4914,400],"id":"6da6186f-3371-4aa4-be3b-ace84f4fcfd5","name":"Cap Batch Volume"},{"parameters":{"assignments":{"assignments":[{"id":"627c4864-c4c0-445a-8d28-0e9a3b658625","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"98c3612c-9314-46eb-aead-68d5230fa2f3","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"bf777558-97c2-45e1-bf81-817ad8ef3699","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"f8dc3413-16ff-462e-ab28-71dbedaf308c","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5562,400],"id":"b5c50baa-bcec-4da6-b93c-9585ea5ea517","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=✅ Fulfill paid orders with Shopify and Notion on autopilot — run completed at {{ $now.toFormat('HH:mm') }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[5886,400],"id":"28c4257c-90c9-41b6-ad42-f9da239f3664","name":"Send Summary to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"c813639a-7da4-401a-b1db-9b591c3db86c","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"152bb755-e1de-4fff-8490-4bcfa9667661","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"5e817e2a-dce7-4781-88c6-b53179cd2e08","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,1420],"id":"bca9569d-2601-4427-8b30-ba4008c6fc38","name":"Capture Failure Context"},{"parameters":{"chatId":"={{ $json.chatId || 'OPS_CHAT_ID' }}","text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","additionalFields":{"appendAttribution":false}},"type":"n8n-nodes-base.telegram","typeVersion":1.2,"position":[5562,1420],"id":"37142131-3bd4-4af6-a7f0-41997a0702c4","name":"Escalate Failure to Telegram","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### On Shopify Event\n\nNative push trigger — shopify calls this workflow the moment the event happens (no polling).\n\nNext: Map to Canonical Schema\n\n🔑 Shopify access token","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"b8416be7-3a6c-c7ed-6c06-8bf2ce5c3005","name":"Note: On Shopify Event"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `orderId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Route by Event Kind","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"c8ea65f8-7579-954c-63c4-8f770dc07045","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 3 lanes: order.paid, order.cancelled + fallback.\n\nPorts: ①→ Handle 'order.paid' → Notion · ②→ Handle 'order.cancelled' → Shopify · ③→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"a2661837-a78e-5c7c-b05e-8bdfc569ea4a","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'order.paid' → Notion\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,250],"id":"b55d308a-3dd8-5a6f-316c-0b14838ed45d","name":"Note: Handle 'order.paid' → Notion"},{"parameters":{"content":"### Handle 'order.cancelled' → Shopify\n\nWrites to Shopify (upserts the matching order/customer record) — the commerce system of record for this pipeline.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Shopify access token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,760],"id":"39642f38-a7bb-ac65-7329-25aaf18eec88","name":"Note: Handle 'order.cancelled' → Shopify"},{"parameters":{"content":"### Log Unrecognized Kind\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,1270],"id":"4a9aa389-40fc-e2fe-afd5-c43f8726527d","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,520],"id":"c096019b-8ec7-8034-f8a9-e1e9378d6f22","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Sort Orders Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,520],"id":"856c5894-07c6-cffa-d0f4-f78982a3aa6e","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Sort Orders Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"ae1c1b1c-ecb0-140c-e068-af5a2300077f","name":"Note: Sort Orders Newest First"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"15c92c51-c30a-08de-a77f-28f40c7b82b9","name":"Note: Align Field Names"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Guard Non-Empty email","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"16ff33c2-44c0-f576-9931-72f5117664d9","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Guard Non-Empty email\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Stamp Processing Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"1f7c9560-78ce-5dc1-1498-4ae5f7726309","name":"Note: Guard Non-Empty email"},{"parameters":{"content":"### Stamp Processing Time\n\nStamps `processedAt` with the current time for auditing.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"fe201a48-a533-0092-6c6c-2b0726c1348d","name":"Note: Stamp Processing Time"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 100 items to protect downstream quotas.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"7db4097a-c401-bb4d-ef1f-a6ea46377fff","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"bc5d83c9-c933-1dd0-3757-0bc570646aae","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Send Summary to Telegram · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"bbc4de73-6801-dc52-b794-851f4c28d433","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Telegram\n\nSends a Telegram message to the configured chat — the same bot can also receive replies, so this doubles as a two-way ops channel.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Telegram bot token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"17dba5a2-0ea0-820f-1b62-b0b59fdc61d3","name":"Note: Send Summary to Telegram"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Telegram","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"32d0630c-6d32-3ded-f874-e67435c5734b","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Telegram\n\nSends a Telegram message to the configured chat — the same bot can also receive replies, so this doubles as a two-way ops channel.\n\n↻ retries 3×/2s · 🔑 Telegram bot token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"fd5c77f8-db8d-a28a-716d-2d34caf21560","name":"Note: Escalate Failure to Telegram"},{"parameters":{"content":"# Fulfill paid orders with Shopify and Notion on autopilot\n\n**Pattern:** Order Fulfillment · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nFulfill paid orders with Shopify and Notion on autopilot. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual inventory is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nOn Shopify Event → Map to Canonical Schema → Route by Event Kind → Handle 'order.paid' → Notion → Consolidate Handling → Tag Pipeline Metadata → Sort Orders Newest First → …\n\n## Use it for\n- Teams that want to order fulfillment without manual effort\n- Anyone automating inventory in e-commerce\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Scales without extra headcount\n- Standardizes the process every time\n\n## Before first run\nConnect credentials: Notion integration token; Shopify access token; Telegram bot token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"c5f59220-1728-8a30-f0b3-90fab5992fdb","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe optional HMAC check runs before any business logic touches the payload — bad signatures are rejected at the door rather than after work has already been done with untrusted data. Acking fast (HTTP 202) and doing the real work after the response is what stops the sender's webhook delivery from timing out and re-delivering the same event.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"1d68ef75-f835-35b3-5c2f-c7a2d527e657","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nYou've got the basics covered — push further:\n\n1. Turn on signature verification and trace what a tampered payload does at the 'Signature Valid?' gate.\n2. Add a new event kind to the switch and give it its own handler.\n3. Remove the fast-ack step and observe how response time changes under a slow downstream write.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"920fc906-113c-6dee-865c-e8c4dde8fbb9","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"1320b0e8-a981-a494-58da-6274f5910a50","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your inventory process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"6ce60004-8283-21d3-dbb0-98254c93e211","name":"🛠 Customize me"}],"connections":{"On Shopify Event":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'order.paid' → Notion","type":"main","index":0}],[{"node":"Handle 'order.cancelled' → Shopify","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'order.paid' → Notion":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'order.cancelled' → Shopify":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Sort Orders Newest First","type":"main","index":0}]]},"Sort Orders Newest First":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Guard Non-Empty email","type":"main","index":0}]]},"Guard Non-Empty email":{"main":[[{"node":"Stamp Processing Time","type":"main","index":0}]]},"Stamp Processing Time":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Telegram","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Telegram","type":"main","index":0}]]},"Send Summary to Telegram":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"On Shopify Event":[{"json":{"orderId":"ORD-55211","email":"chris.owusu@example.com","total":129.99,"status":"paid"}},{"json":{"orderId":"ORD-55212","email":"nina.silva@example.com","total":64.5,"status":"pending"}}]},"versionId":"bd71db53-c018-428e-bd2a-21eeb6a2d93d","id":"FDX09112"}