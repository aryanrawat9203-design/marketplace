type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"b2327b7d-dd12-4fb9-b01b-442b36346119","name":"Route by Event Kind"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["orderId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1026,130],"id":"ce04278a-c9fc-4530-8d7c-aa9bafaa4223","name":"Handle 'order.paid' → Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{},"type":"n8n-nodes-base.shopify","typeVersion":1,"position":[1350,640],"id":"42a241ff-83e0-4600-951a-e6503c7ed5e6","name":"Handle 'order.cancelled' → Shopify","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1674,1150],"id":"b92e69e8-a8c9-4e13-9ead-5f1af092d729","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"093c8d9c-a921-4206-94e7-b9bdf397f5c1","name":"Consolidate Handling"},{"parameters":{"dataToSave":{"values":[{"key":"orderId","value":"={{ $json.orderId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3294,400],"id":"c5594237-6f69-4f2b-9ca4-95bda7f60c56","name":"Save Execution Metadata"},{"parameters":{"conditions