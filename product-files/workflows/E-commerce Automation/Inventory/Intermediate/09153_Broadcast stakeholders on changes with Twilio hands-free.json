{"name":"Broadcast stakeholders on changes with Twilio hands-free","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09153-order","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"c5033fcc-2de3-4a33-bb65-770b8fcddbd3","name":"Receive Inbound Webhook","webhookId":"5b4810e9-08d9-4848-8298-a42fb3f8b83e"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"3ffdcc61-38df-4b41-92c9-40463d851b19","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"7d20df19-57bb-40c8-8695-38ffbf4ebe08","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"2abd1270-e87e-4698-acc5-b33fbcfb1acf","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"ea365055-ac61-4fe9-8c00-059d4bd26194","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"17171389-0084-45c3-a9ac-1296300a7e70","name":"orderId","value":"={{ $json.body?.orderId || $json.body?.id }}","type":"string"},{"id":"320a9b59-7a98-4ca9-818f-85abd46eef88","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"19ab265e-dfc9-4d0f-adfe-a54b0caf72c0","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"03bbe565-dd71-4539-817e-1b5e96abb421","name":"Map to Canonical Schema"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"accepted\": true, \"id\": $json.orderId } }}","options":{"responseCode":202}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[1350,400],"id":"a02e4aae-7e81-4b4a-9aee-6b0fae4acef4","name":"Acknowledge Fast (HTTP 202)"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0e5258a1-091c-4960-81d3-1f7fa00ca21a","leftValue":"={{ $json.kind }}","rightValue":"created","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"created"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b8fa7723-d03d-40be-9536-d01930cab143","leftValue":"={{ $json.kind }}","rightValue":"updated","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"updated"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1674,400],"id":"400405d4-1476-4377-a9bc-ce8f9519cd2d","name":"Route by Event Kind"},{"parameters":{"operation":"appendOrUpdate","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":["orderId"],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[1998,130],"id":"a74b21a2-8d36-424d-b963-1df182e9275e","name":"Handle 'created' → Google Sheets","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"method":"POST","url":"https://api.example.com/v1/orders","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify($json) }}","options":{"timeout":20000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2322,640],"id":"dd4b051f-071f-4bfd-af61-cb1f8cffcb05","name":"Handle 'updated' → Forward API","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[2646,1150],"id":"14143239-ff56-4222-8aac-8c1415cf3892","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[3294,400],"id":"265daeb4-23a5-45b1-b188-df94320f1082","name":"Consolidate Handling"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[4266,400],"id":"8527883b-0525-418a-a519-77d9f92e8fd3","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[4590,400],"id":"c3d1899e-2e00-4314-b742-bc4b216625bf","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"2e049663-62ee-49f5-ab46-4de338d722bd","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"742b65ca-ed74-4b73-9815-a0fbb2f99c8e","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"2aba3bac-edb4-4e9c-aec9-4cc4365245aa","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"4bdf03a1-297c-483d-84bd-6ee304d9a59e","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5238,400],"id":"e7aa9a3f-c3b5-4b18-b4a3-323865fd6083","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=✅ Broadcast stakeholders on changes with Twilio hands-free — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5562,400],"id":"c94895e1-7fc5-4eb8-87e1-a867f186c1e2","name":"Send Summary to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"43e05bbe-d0fc-4fdb-ab20-fae725971acf","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"a200a6a0-abf8-46dd-882c-3784c10da529","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"c3b5a419-5bf5-41d6-b8da-3d0b078d7216","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,1420],"id":"5eb36b3f-ddf6-417d-b662-1113b1f4f921","name":"Capture Failure Context"},{"parameters":{"from":"+15550100000","to":"={{ $json.phone || 'ONCALL_NUMBER' }}","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.twilio","typeVersion":1,"position":[5238,1420],"id":"da7515b1-a5e7-4727-a83b-5be512240b9e","name":"Escalate Failure to Twilio","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5562,1420],"id":"317a6cbb-8d16-43c8-b0b5-2b97abbe5518","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf09153-order`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Compute HMAC Signature","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"d0d519f6-10c7-29f6-e44b-48eb1c754ef0","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Compute HMAC Signature\n\nComputes the HMAC-SHA256 of the raw payload to verify the sender's signature before trusting the data.\n\nNext: Signature Valid?","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"e6eb52e7-56b4-32cb-81b3-f969974f5e30","name":"Note: Compute HMAC Signature"},{"parameters":{"content":"### Signature Valid?\n\nTwo-way gate on `={{ $json.computedSignature === $json.headers['x-signature']`. TRUE continues the happy path, FALSE takes the alternate branch.\n\nPorts: ①→ Map to Canonical Schema · ②→ Reject (HTTP 401)","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"68896758-d9bb-c93d-4a8a-0260c30bc56d","name":"Note: Signature Valid?"},{"parameters":{"content":"### Reject (HTTP 401)\n\nSends the HTTP 401 response back to the caller — keep this fast; heavy work happens after/async.","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,1000],"id":"3bb1d828-7ab1-8380-8d5e-573b48576ec2","name":"Note: Reject (HTTP 401)"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `orderId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Acknowledge Fast (HTTP 202)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"1f2d7a2a-f706-b3d4-727a-434f595ecf10","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Acknowledge Fast (HTTP 202)\n\nSends the HTTP 202 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Route by Event Kind","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,520],"id":"5a46bdb7-208e-5617-b7e3-542afd468c0a","name":"Note: Acknowledge Fast (HTTP 202)"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 3 lanes: created, updated + fallback.\n\nPorts: ①→ Handle 'created' → Google Sheets · ②→ Handle 'updated' → Forward API · ③→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,520],"id":"16e91ad4-f738-bb40-7599-67217ee1c1fe","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'created' → Google Sheets\n\nUpserts a row into 'Order Tracker', matched on `orderId` — re-running with the same key updates the row instead of duplicating it.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,250],"id":"b7162c36-9827-e050-5cc7-32b6da77e1e2","name":"Note: Handle 'created' → Google Sheets"},{"parameters":{"content":"### Handle 'updated' → Forward API\n\nPOST https://api.example.com/v1/orders — retries 3× with backoff on failure.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,760],"id":"010ded13-6b54-6622-7224-ee8b6f896992","name":"Note: Handle 'updated' → Forward API"},{"parameters":{"content":"### Log Unrecognized Kind\n\nAppends a new row to 'Order Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,1270],"id":"c71bd28d-12fb-b442-b6a4-afccea8bc9ee","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"451c906e-030c-5ba7-4feb-85bc87e86ce0","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"5edd3761-b88d-1b62-14fb-1551c0d8c9ac","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nAppends a new row to 'Order Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"8ee81841-24bf-6229-de67-dd787058374b","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"14066bc6-6062-0334-549c-e7c78d233154","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\nAppends a new row to 'Order Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\nPorts: ①→ Send Summary to Twilio · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"89556870-a583-13ca-84c1-ab6717ac3381","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Twilio\n\nSends an SMS via Twilio — reserved for urgent alerts since SMS costs money per message, unlike chat notifications.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Twilio SID + token","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"96acd6cb-81ca-73fb-6f40-2de566463db6","name":"Note: Send Summary to Twilio"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Twilio","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,1540],"id":"2885e114-fc52-92b8-c30c-71c71c5d217f","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Twilio\n\nSends an SMS via Twilio — reserved for urgent alerts since SMS costs money per message, unlike chat notifications.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Twilio SID + token","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"cfbff38c-8273-3248-2824-c256fdc2a0e2","name":"Note: Escalate Failure to Twilio"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\nAppends a new row to 'Order Tracker' — a human-readable audit trail that doesn't require opening n8n to inspect.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"e669eea8-778f-769a-269b-d91a1e160dc2","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Broadcast stakeholders on changes with Twilio hands-free\n\n**Pattern:** Event Notification · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nBroadcast stakeholders on changes with Twilio hands-free. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual inventory is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Compute HMAC Signature → Signature Valid? → Map to Canonical Schema → Acknowledge Fast (HTTP 202) → Route by Event Kind → Handle 'created' → Google Sheets → …\n\n## Use it for\n- Teams that want to event notification without manual effort\n- Anyone automating inventory in e-commerce\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Responds in seconds\n- Standardizes the process every time\n- Improves response time\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Google OAuth2 / service account; Twilio SID + token.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"c91c8265-592b-e400-66d5-3016dee60d15","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe optional HMAC check runs before any business logic touches the payload — bad signatures are rejected at the door rather than after work has already been done with untrusted data. Acking fast (HTTP 202) and doing the real work after the response is what stops the sender's webhook delivery from timing out and re-delivering the same event.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"26c89450-7529-955a-bf2e-f06f7d091b78","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nAlready production-grade — deepen your understanding:\n\n1. Turn on signature verification and trace what a tampered payload does at the 'Signature Valid?' gate.\n2. Add a new event kind to the switch and give it its own handler.\n3. Remove the fast-ack step and observe how response time changes under a slow downstream write.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"641a8dee-5ef3-e862-f83a-ef220ce37645","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"5843809b-cc61-3260-11a4-dd1da68d33e4","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable, and the HMAC signature is verified before any processing. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"021d86d9-743a-df94-6b04-9b5be3d7b69b","name":"🔐 Security"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your inventory process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"2d844f9f-5a2e-1728-5c16-a412bb1de228","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Compute HMAC Signature","type":"main","index":0}]]},"Compute HMAC Signature":{"main":[[{"node":"Signature Valid?","type":"main","index":0}]]},"Signature Valid?":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}],[{"node":"Reject (HTTP 401)","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Acknowledge Fast (HTTP 202)","type":"main","index":0}]]},"Acknowledge Fast (HTTP 202)":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'created' → Google Sheets","type":"main","index":0}],[{"node":"Handle 'updated' → Forward API","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'created' → Google Sheets":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'updated' → Forward API":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Serialize Run Output (CSV)","type":"main","index":0}]]},"Serialize Run Output (CSV)":{"main":[[{"node":"Archive Row Snapshot","type":"main","index":0}]]},"Archive Row Snapshot":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Google Sheets)","type":"main","index":0}]]},"Append Audit Row (Google Sheets)":{"main":[[{"node":"Send Summary to Twilio","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Twilio","type":"main","index":0}]]},"Escalate Failure to Twilio":{"main":[[{"node":"Park in Dead-Letter Queue","type":"main","index":0}]]},"Send Summary to Twilio":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Receive Inbound Webhook":[{"json":{"orderId":"ORD-55211","email":"chris.owusu@example.com","total":129.99,"status":"paid"}},{"json":{"orderId":"ORD-55212","email":"nina.silva@example.com","total":64.5,"status":"pending"}}]},"versionId":"3771e175-bac2-4e85-a50e-ceb0e6f79f22","id":"FDX09153"}