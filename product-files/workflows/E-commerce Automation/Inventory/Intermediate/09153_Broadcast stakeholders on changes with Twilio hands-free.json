{"name":"Broadcast stakeholders on changes with Twilio hands-free","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09153-order","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"72ca6eb2-045a-4b3d-b9d3-01d371a7543e","name":"Receive Inbound Webhook","webhookId":"86a7d53a-a1db-4b3b-ae11-60252c876c1e"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"5e7b4918-2d8c-486a-ba32-a37246821408","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"2068f06d-f6dd-43ee-99c6-485df0da8e62","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"cc906277-0ae8-4d28-b8b0-eca95cf44c70","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"2be76d36-94ec-42ad-8c5e-aeb59d5f8a90","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"5c9f26e3-d248-44f5-be1f-153de2cd7f03","name":"orderId","value":"={{ $json.body?.orderId || $json.body?.id }}","type":"string"},{"id":"68969d21-bf1f-49fb-95f1-4c488a87caa7","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"caf963a7-30a1-4a39-b57b-a670862fac75","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"658a9a7b-4e08-4f