{"name":"Process paid orders with Shopify and Google Drive without manual work","nodes":[{"parameters":{"topic":"orders/create"},"type":"n8n-nodes-base.shopifyTrigger","typeVersion":1,"position":[-270,400],"id":"64d66871-8f1f-4763-8eea-b39150093c38","name":"On Shopify Event","webhookId":"64a6a605-d39e-4177-8860-600b10fd7c19"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[54,130],"id":"5eda95f6-c50b-426a-af45-e965c062459a","name":"Pull Side A (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"getAll","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"returnAll":true,"options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[378,670],"id":"418385ce-6853-4978-aeb5-24bc9a270893","name":"Pull Side B (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mergeByFields":{"values":[{"field1":"orderId","field2":"orderId"}]},"options":{}},"type":"n8n-nodes-base.compareDatasets","typeVersion":2.3,"position":[1026,400],"id":"9ecbb2c7-fcf9-4773-a546-30c705c0febb","name":"Diff the Two Systems"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1998,-200],"id":"1910a822-5e1e-4606-9bcb-fcbe902969d2","name":"Create Missing in Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"aggregate":"aggregateAllItemData","options":{}},"type":"n8n-nodes-base.aggregat