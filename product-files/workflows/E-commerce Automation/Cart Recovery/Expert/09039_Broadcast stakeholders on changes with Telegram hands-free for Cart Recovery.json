{"name":"Broadcast stakeholders on changes with Telegram hands-free for Cart Recovery","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09039-order","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"27f0a8e9-369c-48d8-9498-10581f3049e8","name":"Receive Inbound Webhook","webhookId":"c6d565c8-6c1f-496a-9b9e-b08ebf614d29"},{"parameters":{"assignments":{"assignments":[{"id":"990fdb89-83ce-428b-9899-b68689674d92","name":"orderId","value":"={{ $json.orderId || $json.id || $execution.id }}","type":"string"},{"id":"657da2a2-b844-41df-8a4c-68852b0d6709","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"cca2e7a9-36cf-4a60-a31c-3cf75cf6930a","name":"Stamp & Shape Order"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"5f470b0b-e719-406f-ab75-197897f994d5","leftValue":"={{ $json.orderId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"b36716e1-a21d-4720-bc91-e00070bf0cf5","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"664ed88d-57c3-49b5-9253-ffca8f5b808b","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"72a89793-c2cf-4e9e-a131-2448fc3cc5c5","leftValue":"={{ $json.kind || $json.