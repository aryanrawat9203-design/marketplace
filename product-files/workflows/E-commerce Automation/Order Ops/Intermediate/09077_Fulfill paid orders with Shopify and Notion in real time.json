{"name":"Fulfill paid orders with Shopify and Notion in real time","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09077-order","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"c3024446-0c2b-4b8a-823f-08f7498330a0","name":"Receive Inbound Webhook","webhookId":"1d5bc3b3-7239-4da6-ab44-44c6828d163a"},{"parameters":{"assignments":{"assignments":[{"id":"2599d9a0-3ca6-40f5-a894-496eb6e00517","name":"orderId","value":"={{ $json.body?.orderId || $json.body?.id }}","type":"string"},{"id":"02d753b1-dc41-49a5-84d4-e16af632944b","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"9442ec3d-7bb1-4ec3-8fd4-193c95538b7a","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"221be4c6-85cb-456f-95d5-6130c685be70","name":"Map to Canonical Schema"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"accepted\": true, \"id\": $json.orderId } }}","options":{"responseCode":202}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[378,400],"id":"471e618a-44f3-43a7-a648-92df2cc49e7c","name":"Acknowledge Fast (HTTP 202)"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"eb69f154-6233-45ee-8254-3d1cd3dbc6a0","leftValue":"={{ $json.kind }}","rightValue":"order.paid","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"order.paid"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a565f3d1-3c36-4401-ac6c-4ff8eee04fb2","leftValue":"={{ $json.kind }}","rightValue":"order.cancelled","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"order.cancelled"}]},"options":{"fallbackOutput":"extra"}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[702,400],"id":"e477c984-de92-435f-aee1-b8c1d121dc72","name":"Route by Event Kind"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1026,130],"id":"6cd1c354-1406-4935-acbe-68b1dd0401dd","name":"Handle 'order.paid' → Notion","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"order","operation":"update","orderId":"={{ $json.id || $json.orderId }}","options":{}},"type":"n8n-nodes-base.shopify","typeVersion":1,"position":[1350,640],"id":"0f86b406-b7f1-49d4-8163-152326ba969c","name":"Handle 'order.cancelled' → Shopify","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[1674,1150],"id":"81c3766f-4e79-42e7-85c5-a08e5b17dc1c","name":"Log Unrecognized Kind","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"mode":"append","numberInputs":3},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2322,400],"id":"4d1ec151-b139-4654-879b-c7c284284e1a","name":"Consolidate Handling"},{"parameters":{"maxItems":25},"type":"n8n-nodes-base.limit","typeVersion":1,"position":[3294,400],"id":"6844c9a2-810f-4d86-a2ae-235b5f541377","name":"Cap Batch Volume"},{"parameters":{"keys":{"key":[{"currentKey":"id","newKey":"orderId"}]},"additionalOptions":{}},"type":"n8n-nodes-base.renameKeys","typeVersion":1,"position":[3618,400],"id":"58bd301d-f580-4687-9e1d-b5f1b9f35d7f","name":"Align Field Names"},{"parameters":{"dataToSave":{"values":[{"key":"orderId","value":"={{ $json.orderId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[3942,400],"id":"639475d7-b0ca-483b-9dd5-a6b3dbfe12ee","name":"Save Execution Metadata"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"de2515f4-cd9c-43ae-9fff-c89cee0d5ad3","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[4266,400],"id":"88a6eb3d-f305-44e5-9724-ad9133560560","name":"Guard Non-Empty email"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[4590,400],"id":"566ace8a-30c6-490a-9410-c9b3001a9aa8","name":"Sort Orders Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"8e91ac14-b9a7-471d-8205-1077ac84a441","name":"pipeline","value":"Order Ops","type":"string"},{"id":"ac1fcab5-d1f8-4c17-b378-39f702ffa38d","name":"version","value":"2.0","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[4914,400],"id":"d322038a-041a-4827-bcb5-ea931ffe2574","name":"Tag Pipeline Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"2a4628f1-537a-487c-bcee-f450febc0a31","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"5977b4f5-f37c-4ded-8357-105de4cb9582","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"deb47885-1727-4b43-8eb6-c687df14ed27","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,400],"id":"a0c308d2-68cd-4e46-a3a4-5fed264c960c","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[5562,400],"id":"5729cfdc-9c95-4e33-a093-49cf2de723b0","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#orders","cachedResultName":"#orders"},"text":"=✅ Fulfill paid orders with Shopify and Notion in real time — run completed at {{ $now.toFormat('HH:mm') }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[5886,400],"id":"a044677d-8ded-470b-b57c-8d0f338dda93","name":"Send Summary to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"94597db0-3106-4759-8fd9-0bd8ab7369d7","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"2fc5917d-b682-4c08-811e-34683e3d7417","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"7df9b5c4-7b6e-4c7a-94c0-7f6a845c9914","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5238,1420],"id":"c44dddec-2e93-4393-856f-f9e1961eb4d0","name":"Capture Failure Context"},{"parameters":{"sendTo":"={{ $json.email || 'ops@company.com' }}","subject":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage ","message":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[5562,1420],"id":"ad82bc4a-b971-49af-a7d4-07a7307cdd61","name":"Escalate Failure to Gmail","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf09077-order`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Map to Canonical Schema","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"b04c9337-b1b0-1d10-7bde-885b9f7961b5","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Map to Canonical Schema\n\nShapes the item: writes `orderId`, `kind`, `payload`. Keeps the schema explicit between stages.\n\nNext: Acknowledge Fast (HTTP 202)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,520],"id":"4ad1640f-385a-6fe9-f824-b07fab982648","name":"Note: Map to Canonical Schema"},{"parameters":{"content":"### Acknowledge Fast (HTTP 202)\n\nSends the HTTP 202 response back to the caller — keep this fast; heavy work happens after/async.\n\nNext: Route by Event Kind","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,520],"id":"a5babe9a-3d4c-f0c4-ab7e-64f3cd6d1796","name":"Note: Acknowledge Fast (HTTP 202)"},{"parameters":{"content":"### Route by Event Kind\n\nRoutes each item to one of 3 lanes: order.paid, order.cancelled + fallback.\n\nPorts: ①→ Handle 'order.paid' → Notion · ②→ Handle 'order.cancelled' → Shopify · ③→ Log Unrecognized Kind","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[642,520],"id":"d0ab420b-649c-b1cb-189b-1709a9ebfeff","name":"Note: Route by Event Kind"},{"parameters":{"content":"### Handle 'order.paid' → Notion\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,250],"id":"d9a3e16a-a525-21fd-8edb-c0e8b5fcbb2e","name":"Note: Handle 'order.paid' → Notion"},{"parameters":{"content":"### Handle 'order.cancelled' → Shopify\n\nWrites to Shopify (upserts the matching order/customer record) — the commerce system of record for this pipeline.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Shopify access token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1290,760],"id":"1774f671-f6f9-4e74-40c1-ef0589ea784e","name":"Note: Handle 'order.cancelled' → Shopify"},{"parameters":{"content":"### Log Unrecognized Kind\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Consolidate Handling · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1614,1270],"id":"efa4a52d-7340-5e91-3e8a-25acfd155f1b","name":"Note: Log Unrecognized Kind"},{"parameters":{"content":"### Consolidate Handling\n\nRejoins 3 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Cap Batch Volume","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,520],"id":"36e63d88-24c7-6f8c-5ddc-f9a3ab076061","name":"Note: Consolidate Handling"},{"parameters":{"content":"### Cap Batch Volume\n\nCaps the stream at 25 items to protect downstream quotas.\n\nNext: Align Field Names","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3234,520],"id":"fc99cf0f-608f-e68e-1e72-47ff97de705d","name":"Note: Cap Batch Volume"},{"parameters":{"content":"### Align Field Names\n\nNormalizes field names so every source feeds the same downstream schema.\n\nNext: Save Execution Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"0417410c-3f7d-ab04-23e4-908438cd936b","name":"Note: Align Field Names"},{"parameters":{"content":"### Save Execution Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Guard Non-Empty email","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3882,520],"id":"41fcd56b-1bcf-1082-70e4-095c8d2baa55","name":"Note: Save Execution Metadata"},{"parameters":{"content":"### Guard Non-Empty email\n\nDrops items that fail the condition; only qualifying items continue (no false branch).\n\nNext: Sort Orders Newest First","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4206,520],"id":"da9ee584-d1a4-95d5-23e8-c00ac6f812ec","name":"Note: Guard Non-Empty email"},{"parameters":{"content":"### Sort Orders Newest First\n\nOrders items (newest first) so limits and digests pick the most relevant records.\n\nNext: Tag Pipeline Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"e8fa24a1-db86-425e-9ae7-1715f18d3344","name":"Note: Sort Orders Newest First"},{"parameters":{"content":"### Tag Pipeline Metadata\n\nShapes the item: writes `pipeline`, `version`. Keeps the schema explicit between stages.\n\nNext: Summarize Run Stats","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"1c0d69f9-b29e-22aa-eb83-40999b0c97ad","name":"Note: Tag Pipeline Metadata"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Notion)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"b47a2b33-2721-aa83-a6d0-b201a905eba3","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Notion)\n\nCreates a new page in the Notion database — the title is pulled straight from the item's key field.\n\nPorts: ①→ Send Summary to Slack · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Notion integration token","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"2da8b1f6-8740-3a90-6a1e-a8cfed478d76","name":"Note: Append Audit Row (Notion)"},{"parameters":{"content":"### Send Summary to Slack\n\nPosts a message to Slack (`#orders`) — a low-latency way for the team to see automation activity without checking a dashboard.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Slack OAuth2","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"26e1611a-34fb-8cde-95c2-db7709859867","name":"Note: Send Summary to Slack"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Gmail","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,1540],"id":"815424f9-4f8f-6c31-cedd-78417662490d","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Gmail\n\nSends an email via Gmail — subject is the first line of the message body, recipient comes from the item's `email` field.\n\n↻ retries 3×/2s · 🔑 Google OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,1540],"id":"5d14d2ea-3a59-7925-8d42-58a8c2af6f23","name":"Note: Escalate Failure to Gmail"},{"parameters":{"content":"# Fulfill paid orders with Shopify and Notion in real time\n\n**Pattern:** Order Fulfillment · **Level:** Advanced · **Trigger:** Webhook\n\n## What it does\nFulfill paid orders with Shopify and Notion in real time. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual order ops is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Map to Canonical Schema → Acknowledge Fast (HTTP 202) → Route by Event Kind → Handle 'order.paid' → Notion → Consolidate Handling → Cap Batch Volume → …\n\n## Use it for\n- Teams that want to order fulfillment without manual effort\n- Anyone automating order ops in e-commerce\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Runs 24/7 in the background\n- Keeps your systems in sync\n- Responds in seconds\n\n## Before first run\nConnect credentials: Google OAuth2; Notion integration token; Shopify access token; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.\n\n## Try it now\nSample data is pinned on the trigger — hit **Execute Workflow** to watch it flow through every node before connecting any real credentials. Unpin the trigger (right-click → Unpin) when you're ready to go live.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"7d84b059-3e3d-e329-9d81-bf18bbd0acfa","name":"📘 Workflow Overview"},{"parameters":{"content":"## Design decisions\n\nThe optional HMAC check runs before any business logic touches the payload — bad signatures are rejected at the door rather than after work has already been done with untrusted data. Acking fast (HTTP 202) and doing the real work after the response is what stops the sender's webhook delivery from timing out and re-delivering the same event.","width":480,"height":300,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1020],"id":"7c51866d-6df8-42e7-1d7d-3a0571199b32","name":"🎓 Design Decisions"},{"parameters":{"content":"## Practice exercises\n\nYou've got the basics covered — push further:\n\n1. Turn on signature verification and trace what a tampered payload does at the 'Signature Valid?' gate.\n2. Add a new event kind to the switch and give it its own handler.\n3. Remove the fast-ack step and observe how response time changes under a slow downstream write.","width":480,"height":340,"color":6},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,1360],"id":"6d4a6fd7-0bbd-239d-d0fa-5f047fad8018","name":"🧪 Practice Exercises"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-290],"id":"d270f11a-5121-e1ab-e573-35ef2e1bce3f","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-290],"id":"c6d89903-ec4b-8834-7f60-7bc77e121a6d","name":"🔐 Security"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your order ops process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-290],"id":"ade1be21-f56a-68a7-680a-31aa5a9e00a0","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Map to Canonical Schema","type":"main","index":0}]]},"Map to Canonical Schema":{"main":[[{"node":"Acknowledge Fast (HTTP 202)","type":"main","index":0}]]},"Acknowledge Fast (HTTP 202)":{"main":[[{"node":"Route by Event Kind","type":"main","index":0}]]},"Route by Event Kind":{"main":[[{"node":"Handle 'order.paid' → Notion","type":"main","index":0}],[{"node":"Handle 'order.cancelled' → Shopify","type":"main","index":0}],[{"node":"Log Unrecognized Kind","type":"main","index":0}]]},"Handle 'order.paid' → Notion":{"main":[[{"node":"Consolidate Handling","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Handle 'order.cancelled' → Shopify":{"main":[[{"node":"Consolidate Handling","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Log Unrecognized Kind":{"main":[[{"node":"Consolidate Handling","type":"main","index":2}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Consolidate Handling":{"main":[[{"node":"Cap Batch Volume","type":"main","index":0}]]},"Cap Batch Volume":{"main":[[{"node":"Align Field Names","type":"main","index":0}]]},"Align Field Names":{"main":[[{"node":"Save Execution Metadata","type":"main","index":0}]]},"Save Execution Metadata":{"main":[[{"node":"Guard Non-Empty email","type":"main","index":0}]]},"Guard Non-Empty email":{"main":[[{"node":"Sort Orders Newest First","type":"main","index":0}]]},"Sort Orders Newest First":{"main":[[{"node":"Tag Pipeline Metadata","type":"main","index":0}]]},"Tag Pipeline Metadata":{"main":[[{"node":"Summarize Run Stats","type":"main","index":0}]]},"Summarize Run Stats":{"main":[[{"node":"Append Audit Row (Notion)","type":"main","index":0}]]},"Append Audit Row (Notion)":{"main":[[{"node":"Send Summary to Slack","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Capture Failure Context":{"main":[[{"node":"Escalate Failure to Gmail","type":"main","index":0}]]},"Send Summary to Slack":{"main":[[],[{"node":"Capture Failure Context","type":"main","index":0}]]}},"active":false,"settings":{"executionOrder":"v1","saveDataErrorExecution":"all","saveManualExecutions":true,"executionTimeout":3600},"meta":{"templateCredsSetupCompleted":false},"tags":[],"pinData":{"Receive Inbound Webhook":[{"json":{"orderId":"ORD-55211","email":"chris.owusu@example.com","total":129.99,"status":"paid"}},{"json":{"orderId":"ORD-55212","email":"nina.silva@example.com","total":64.5,"status":"pending"}}]},"versionId":"9d57318d-9237-453c-973a-dcdbcb91a402","id":"FDX09077"}