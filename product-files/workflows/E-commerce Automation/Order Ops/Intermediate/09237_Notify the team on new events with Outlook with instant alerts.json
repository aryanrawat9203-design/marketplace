-base.dateTime","typeVersion":2,"position":[7830,400],"id":"e6917ce6-3fb8-4be9-abac-3f466629585c","name":"Stamp Completion Time"},{"parameters":{"dataToSave":{"values":[{"key":"runId","value":"={{ $execution.id }}"},{"key":"itemCount","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8154,400],"id":"a7c7c340-2205-4f6a-9c55-50e261d2b436","name":"Persist Run Metadata"},{"parameters":{"assignments":{"assignments":[{"id":"7a023353-0c12-411a-afd0-09767701808f","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"64ab3f68-4b0b-41b2-9285-08c73673e748","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"953453c7-d574-46c4-98cf-15f6b5860fd1","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[8478,400],"id":"8858789d-9e28-434e-b189-eb8414d94830","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $json.orderId }}","options":{}},"type":"n8n-nodes-base.notion","typeVersion":2.2,"position":[8802,400],"id":"94ffe22c-cd98-4b8e-a2a6-7ab52e8f2346","name":"Append Audit Row (Notion)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"subject":"=✅ Notify the team on new events with Outlook with instant alerts — run complete","bodyContent":"=✅ Notify the team on new events with Outlook with instant alerts — run completed at {{ $now.toFormat('HH:mm') }}","toRecipients":"={{ $json.email || 'ops@company.com' }}","additionalFields":{}},"type":"n8n-nodes-base.microsoftOutlook","typeVersion":2,"position":[9126,400],"id":"126ce1a4-69dc-4ae2-907f-f54fff159a82","name":"Send Summary to Outlook","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignme