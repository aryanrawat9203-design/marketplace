{"name":"Broadcast the team on new events with Slack","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09134-order","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"66f2a362-695e-4243-9912-2f838d465985","name":"Receive Inbound Webhook","webhookId":"5f102dfa-39aa-4f5f-9ce6-4fd8afb9263d"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"a9fcdd17-5c48-4fe2-af8d-a631dee52966","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c3af30d6-6ae9-4963-8ea5-571b7c6e133f","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"f55bdcbf-380d-4ef7-a919-e068ee1e13ba","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"4a388d70-8094-43b3-b108-4e79a550dbbb","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"bbd72fa8-df46-4bc3-8ed9-c4269037e651","name":"orderId","value":"={{ $json.body?.orderId || $json.body?.id }}","type":"string"},{"id":"bd045846-e48d-4d0f-a544-4813c8892cf5","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"3b3e56b1-8c4b-4fdf-bf72-d494ce56b869","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"cd1358b9-6fec-4c72-be68-3b013