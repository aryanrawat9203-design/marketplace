 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[8154,400],"id":"14e8b283-8a70-451c-82c4-b18b9bab4540","name":"Compute Drift vs Snapshot"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"b6088c02-2be3-476e-9a4d-aaebcb913804","leftValue":"={{ $json.email }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[8478,400],"id":"1cdf2365-f4bc-4bf2-8fdf-6305a8bba80c","name":"Guard Non-Empty email"},{"parameters":{"dataToSave":{"values":[{"key":"orderId","value":"={{ $json.orderId }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[8802,400],"id":"00ab2413-064f-44bf-8af9-9b72fbddc4e3","name":"Save Execution Metadata"},{"parameters":{"sortFieldsUi":{"sortField":[{"fieldName":"status","order":"descending"}]},"options":{}},"type":"n8n-nodes-base.sort","typeVersion":1,"position":[9126,400],"id":"7cf69784-9ee6-4776-8c67-54defa4dc042","name":"Sort Orders Newest First"},{"parameters":{"assignments":{"assignments":[{"id":"369a68c8-69ed-4340-b0eb-86db67c0f754","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"d71a308f-f11e-4d9f-979d-eaa54ad5b960","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"d3aa7a21-ad04-45f9-aaf6-c76da41e6052","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[9450,400],"id":"68ec92b7-d6ad-405c-9e9c-5456049b6dc7","name":"Summarize Run Stats"},{"parameters":{"resource":"databasePage","operation":"create","databaseId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Database"},"title":"={{ $json.email || $jso