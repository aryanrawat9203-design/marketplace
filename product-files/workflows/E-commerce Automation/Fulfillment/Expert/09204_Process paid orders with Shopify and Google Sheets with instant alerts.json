{"name":"Process paid orders with Shopify and Google Sheets with instant alerts","nodes":[{"parameters":{"topic":"orders/create"},"type":"n8n-nodes-base.shopifyTrigger","typeVersion":1,"position":[-270,400],"id":"0e9abd1e-9bfe-4b50-b177-b5d83c792cad","name":"On Shopify Event","webhookId":"fd689028-7563-4058-bb0d-325f65cca223"},{"parameters":{"assignments":{"assignments":[{"id":"76dad204-69d9-4b64-9570-d13e77530942","name":"orderId","value":"={{ $json.orderId || $json.id || $execution.id }}","type":"string"},{"id":"3b86ff83-f9b5-4fcc-9879-17958d74546b","name":"receivedAt","value":"={{ $now.toISO() }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[54,400],"id":"7c640141-1dc4-4b0a-8d1e-33931f753d21","name":"Stamp & Shape Order"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c9b80864-1f1f-4b22-a4ae-0b996b503900","leftValue":"={{ $json.orderId }}","rightValue":"","operator":{"type":"string","operation":"notEmpty"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"74a8da6d-cab9-4297-bf63-afbe9d3666c1","name":"Payload Valid?"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[378,910],"id":"6bfbf7f0-d4cf-416e-a60c-27beb1e746bc","name":"Record Rejected Input","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"f06b29c4-9e9e-47aa-bbae-0e918aa711e0","leftValue":"={{ $json.kind || $json.type || 'standard' }}","rightValue":"s