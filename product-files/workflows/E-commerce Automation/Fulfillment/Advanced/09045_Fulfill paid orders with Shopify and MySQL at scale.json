{"name":"Fulfill paid orders with Shopify and MySQL at scale","nodes":[{"parameters":{"httpMethod":"POST","path":"wf09045-order","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2,"position":[-270,400],"id":"15fe7f0b-7537-446c-8da0-545562fda3b9","name":"Receive Inbound Webhook","webhookId":"91142105-71bf-4847-b32a-97e84fb15193"},{"parameters":{"action":"hmac","type":"SHA256","value":"={{ JSON.stringify($json.body) }}","secret":"={{ $json.headers['x-signature-secret'] || 'set-in-credentials' }}","dataPropertyName":"computedSignature"},"type":"n8n-nodes-base.crypto","typeVersion":1,"position":[54,400],"id":"ca669590-ed7d-4185-b190-21be35ce5084","name":"Compute HMAC Signature"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"edd344cc-6e77-41a1-abc7-d54108235b19","leftValue":"={{ $json.computedSignature === $json.headers['x-signature'] }}","rightValue":true,"operator":{"type":"boolean","operation":"true"}}],"combinator":"and"}},"type":"n8n-nodes-base.if","typeVersion":2.2,"position":[378,400],"id":"f9b5f711-2257-40cc-9585-186ed6d5b535","name":"Signature Valid?"},{"parameters":{"respondWith":"json","responseBody":"={{ { \"error\": \"invalid signature\" } }}","options":{"responseCode":401}},"type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[702,880],"id":"102db3a1-ee19-45c1-9a09-bf6371c0185d","name":"Reject (HTTP 401)"},{"parameters":{"assignments":{"assignments":[{"id":"4b9f9b3b-4fe9-44a9-8f25-7d9becd584a8","name":"orderId","value":"={{ $json.body?.orderId || $json.body?.id }}","type":"string"},{"id":"f38e2925-5936-4245-849c-2101cb6dd394","name":"kind","value":"={{ $json.body?.type || 'default' }}","type":"string"},{"id":"fbf1c34a-3d4e-42f2-b55d-c7091af06b6a","name":"payload","value":"={{ JSON.stringify($json.body || $json) }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1026,400],"id":"642da311-c1fb-44b4-99