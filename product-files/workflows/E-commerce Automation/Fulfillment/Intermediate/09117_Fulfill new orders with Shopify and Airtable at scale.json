t","value":"={{ $items().length }}"}]}},"type":"n8n-nodes-base.executionData","typeVersion":1,"position":[4914,400],"id":"45cc3e07-ceec-48d4-b957-f581ba79f54f","name":"Persist Run Metadata"},{"parameters":{"method":"GET","url":"https://enrichment.example.com/v2/lookup","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"={{ $json.email }}"}]},"options":{"timeout":15000}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[5238,400],"id":"538aaff8-c8ff-44a1-af78-29cdda0d0bea","name":"Enrich with Reference Data","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4e344d36-6061-47b8-8370-66498c2cefaf","name":"enrichedAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"a0d79bba-da15-40a3-9038-e2751d49ff2a","name":"enrichmentSource","value":"reference-api","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[5562,400],"id":"50e3cacc-4a3d-434a-a2a4-21dfa982b942","name":"Fold In Enrichment Fields"},{"parameters":{"operation":"read","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[5886,400],"id":"fe8ce448-2da5-49ef-906a-c1c45f09f82c","name":"Load Previous Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"alwaysOutputData":true,"onError":"continueErrorOutput"},{"parameters":{"mode":"runOnceForAllItems","jsCode":"// Compare current metrics with the previous snapshot\nconst current = $input.first().json;\nconst prev = $('Load Previous Snapshot').first().json || {};\nconst drift = {};\nfor (const k of Object.keys(current)) {\n  if (typeof current[k] === 'number' && typeof prev[k] === 'number' && prev[k] !== 0) {\n    drift[k] = Math.round(((current[k] - prev[k]) / prev[k]) * 1000) / 10;\n  }\n}\nreturn [{ json: { ...current, driftPct: drift, hasDrift: Object.values(drift).some(v => Math.abs(v) > 10) } }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[6210,400],"id":"feb9c7f3-0e89-430e-aa2e-b94d913651e4","name":"Compute Drift vs Snapshot"},{"parameters":{"operation":"csv","options":{}},"type":"n8n-nodes-base.convertToFile","typeVersion":1.1,"position":[6534,400],"id":"2bfeca0f-1b72-427e-9253-b235e98db8a9","name":"Serialize Run Output (CSV)"},{"parameters":{"operation":"create","base":{"__rl":true,"mode":"list","value":"","cachedResultName":"E-commerce Automation Base"},"table":{"__rl":true,"mode":"list","value":"","cachedResultName":"Orders"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.airtable","typeVersion":2.1,"position":[6858,400],"id":"0f8b3cfd-05c8-4395-b655-2d2998581529","name":"Archive Row Snapshot","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"51df176a-03bc-4a59-829f-148954fc7284","name":"runAt","value":"={{ $now.toISO() }}","type":"string"},{"id":"26c3a130-ebe6-4b8f-9229-817db6aee14e","name":"itemCount","value":"={{ $input.all().length }}","type":"number"},{"id":"737b43a9-5469-42f0-a135-ac40b66cbf6b","name":"status","value":"completed","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,400],"id":"7ae42526-e152-4d85-86cb-0548839b8258","name":"Summarize Run Stats"},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7506,400],"id":"67a62fe5-2d04-4ca8-a6fd-6e80dca98be0","name":"Append Audit Row (Google Sheets)","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"authentication":"webhook","content":"=✅ Fulfill new orders with Shopify and Airtable at scale — run completed at {{ $now.toFormat('HH:mm') }}","options":{}},"type":"n8n-nodes-base.discord","typeVersion":2,"position":[7830,400],"id":"1a68cd59-fd88-4785-a295-471ee0a1f7a0","name":"Send Summary to Discord","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000,"onError":"continueErrorOutput"},{"parameters":{"assignments":{"assignments":[{"id":"4a5c2a3d-db0c-4255-aff4-6c8d979d2d02","name":"failedNode","value":"={{ $json.error?.node?.name || 'unknown' }}","type":"string"},{"id":"edc58446-e71a-46b7-9655-cbf6f9058493","name":"errorMessage","value":"={{ $json.error?.message || JSON.stringify($json).slice(0,200) }}","type":"string"},{"id":"7e31bf90-64e6-46d0-9f2c-8c2eab31a62e","name":"workflow","value":"={{ $workflow.name }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[7182,1420],"id":"d8e7e618-c659-41b7-9007-e31e83e93552","name":"Capture Failure Context"},{"parameters":{"select":"channel","channelId":{"__rl":true,"mode":"name","value":"#orders","cachedResultName":"#orders"},"text":"=🚨 {{ $json.workflow }} failed at {{ $json.failedNode }}: {{ $json.errorMessage }}","otherOptions":{}},"type":"n8n-nodes-base.slack","typeVersion":2.3,"position":[7506,1420],"id":"774b05d7-0a83-43b3-b427-3aa8037129bd","name":"Escalate Failure to Slack","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"operation":"append","documentId":{"__rl":true,"mode":"list","value":"","cachedResultName":"Order Tracker"},"sheetName":{"__rl":true,"mode":"name","value":"Main","cachedResultName":"Main"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[7830,1420],"id":"de4e66d0-d706-44e0-a695-7147ff5fcfbe","name":"Park in Dead-Letter Queue","retryOnFail":true,"maxTries":3,"waitBetweenTries":2000},{"parameters":{"content":"### Receive Inbound Webhook\n\nEntry point: listens for POST calls on `/wf09117-order`. Use the TEST url while building, switch callers to the PRODUCTION url after publishing.\n\nNext: Pull Side A (Airtable)","width":280,"height":232,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-330,520],"id":"4b6814db-bd78-8213-8d6e-3f783dc0a6de","name":"Note: Receive Inbound Webhook"},{"parameters":{"content":"### Pull Side A (Airtable)\n\nairtable — `search` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-6,250],"id":"e905f219-c3f3-1262-7009-86e35f6d9dec","name":"Note: Pull Side A (Airtable)"},{"parameters":{"content":"### Pull Side B (Google Sheets)\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Diff the Two Systems · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[318,790],"id":"36007e99-ef87-acaa-1e70-4b5a78764db7","name":"Note: Pull Side B (Google Sheets)"},{"parameters":{"content":"### Diff the Two Systems\n\nDiffs two streams by key into 4 lanes: only-in-A, same, different, only-in-B — the heart of the sync.\n\nPorts: ①→ Create Missing in Google Sheets · ②→ Count In-Sync Rows · ③→ Apply Updates to Google Sheets · ④→ Backfill into Airtable","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[966,520],"id":"372336a2-0df0-0d2d-e3fe-b5170d163cbf","name":"Note: Diff the Two Systems"},{"parameters":{"content":"### Create Missing in Google Sheets\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1938,-80],"id":"da462c67-f521-1e15-8f85-82c524fda998","name":"Note: Create Missing in Google Sheets"},{"parameters":{"content":"### Count In-Sync Rows\n\nCollapses all items into a single summary item (for counts and run stats).\n\nNext: Gather Sync Results","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2262,340],"id":"36b59c89-df76-5dc0-d714-a1810eb0cab4","name":"Note: Count In-Sync Rows"},{"parameters":{"content":"### Apply Updates to Google Sheets\n\ngoogleSheets — `appendOrUpdate` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2586,760],"id":"eb809e25-07a5-4809-aa03-8cf0c1c6bc73","name":"Note: Apply Updates to Google Sheets"},{"parameters":{"content":"### Backfill into Airtable\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Gather Sync Results · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[2910,1180],"id":"1e87ec85-a2ad-79e0-0d87-c39986546410","name":"Note: Backfill into Airtable"},{"parameters":{"content":"### Gather Sync Results\n\nRejoins 4 branches into one stream (mode: append) so downstream logic runs once.\n\nNext: Stamp Completion Time","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[3558,520],"id":"54281656-d6cf-5012-171c-395da05113c2","name":"Note: Gather Sync Results"},{"parameters":{"content":"### Stamp Completion Time\n\nStamps `completedAt` with the current time for auditing.\n\nNext: Persist Run Metadata","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4530,520],"id":"2d47dea3-a3c2-cdd2-5617-d2841f9d1836","name":"Note: Stamp Completion Time"},{"parameters":{"content":"### Persist Run Metadata\n\nSaves key fields onto the execution record — searchable later in n8n's execution list.\n\nNext: Enrich with Reference Data","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[4854,520],"id":"d8188bee-8e06-0d33-e936-881264003b89","name":"Note: Persist Run Metadata"},{"parameters":{"content":"### Enrich with Reference Data\n\nGET https://enrichment.example.com/v2/lookup — retries 3× with backoff on failure.\n\nPorts: ①→ Fold In Enrichment Fields · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 API key / bearer for the target API","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5178,520],"id":"9f023386-9310-9c03-73c2-002af7c96f6f","name":"Note: Enrich with Reference Data"},{"parameters":{"content":"### Fold In Enrichment Fields\n\nShapes the item: writes `enrichedAt`, `enrichmentSource`. Keeps the schema explicit between stages.\n\nNext: Load Previous Snapshot","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5502,520],"id":"3effa54b-4a14-6dea-71ae-2905324f5b3c","name":"Note: Fold In Enrichment Fields"},{"parameters":{"content":"### Load Previous Snapshot\n\ngoogleSheets — `read` operation against the connected account.\n\nPorts: ①→ Compute Drift vs Snapshot · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[5826,520],"id":"29c54f7d-dc60-baeb-7064-7af0142ee16f","name":"Note: Load Previous Snapshot"},{"parameters":{"content":"### Compute Drift vs Snapshot\n\nCustom JavaScript: Compare current metrics with the previous snapshot\n\nNext: Serialize Run Output (CSV)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6150,520],"id":"e1902b92-93ff-1625-1810-617783d2d53b","name":"Note: Compute Drift vs Snapshot"},{"parameters":{"content":"### Serialize Run Output (CSV)\n\nSerializes items to a CSV binary file.\n\nNext: Archive Row Snapshot","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6474,520],"id":"6143789a-d8fa-b17e-90ad-fdb9f6596106","name":"Note: Serialize Run Output (CSV)"},{"parameters":{"content":"### Archive Row Snapshot\n\nairtable — `create` operation against the connected account.\n\nPorts: ①→ Summarize Run Stats · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Airtable PAT","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[6798,520],"id":"b2814e34-9e97-8a19-bdf9-9273a45f5571","name":"Note: Archive Row Snapshot"},{"parameters":{"content":"### Summarize Run Stats\n\nShapes the item: writes `runAt`, `itemCount`, `status`. Keeps the schema explicit between stages.\n\nNext: Append Audit Row (Google Sheets)","width":280,"height":232,"color":7},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,520],"id":"4b058096-979e-4a58-0259-a26d32f83a14","name":"Note: Summarize Run Stats"},{"parameters":{"content":"### Append Audit Row (Google Sheets)\n\ngoogleSheets — `append` operation against the connected account.\n\nPorts: ①→ Send Summary to Discord · ②→ Capture Failure Context\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":2},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,520],"id":"78033a1d-cdce-0f7f-aa2b-25750049b175","name":"Note: Append Audit Row (Google Sheets)"},{"parameters":{"content":"### Send Summary to Discord\n\ndiscord — `action` operation against the connected account.\n\n↻ retries 3×/2s · ⚠ failures exit via the error rail · 🔑 Discord webhook URL","width":280,"height":232,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,520],"id":"8d10a21e-6d41-afb8-89c7-4b6e0dbf09df","name":"Note: Send Summary to Discord"},{"parameters":{"content":"### Capture Failure Context\n\nShapes the item: writes `failedNode`, `errorMessage`, `workflow`. Keeps the schema explicit between stages.\n\nNext: Escalate Failure to Slack","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7122,1540],"id":"90b49468-d37b-5ff3-ed4b-3724d1266d6b","name":"Note: Capture Failure Context"},{"parameters":{"content":"### Escalate Failure to Slack\n\nslack — `action` operation against the connected account.\n\nNext: Park in Dead-Letter Queue\n\n↻ retries 3×/2s · 🔑 Slack OAuth2","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7446,1540],"id":"02da0837-5c5e-4415-2e5c-3fa16cf045da","name":"Note: Escalate Failure to Slack"},{"parameters":{"content":"### Park in Dead-Letter Queue\n\ngoogleSheets — `append` operation against the connected account.\n\n↻ retries 3×/2s · 🔑 Google OAuth2 / service account","width":280,"height":232,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[7770,1540],"id":"a407ea54-4af1-ea8d-cf5c-6d16aa35f0e9","name":"Note: Park in Dead-Letter Queue"},{"parameters":{"content":"# Fulfill new orders with Shopify and Airtable at scale\n\n**Pattern:** Order Fulfillment · **Level:** Production · **Trigger:** Webhook\n\n## What it does\nFulfill new orders with Shopify and Airtable at scale. It fires the moment an external system calls its webhook.\n\n## Why it exists\nManual fulfillment is slow and error-prone; this workflow makes the process repeatable, monitored and hands-off, with failures surfaced instead of silently lost.\n\n## Main flow\nReceive Inbound Webhook → Pull Side A (Airtable) → Diff the Two Systems → Create Missing in Google Sheets → Gather Sync Results → Stamp Completion Time → Persist Run Metadata → …\n\n## Use it for\n- Teams that want to order fulfillment without manual effort\n- Anyone automating fulfillment in e-commerce\n- Replacing a fragile manual process with a reliable workflow\n\n## You get\n- Saves hours of manual work each week\n- Removes copy-paste errors\n- Scales without extra headcount\n\n## Before first run\nConnect credentials: API key / bearer for the target API; Airtable PAT; Discord webhook URL; Google OAuth2 / service account; Slack OAuth2.\nFollow the color key: 🟦 entry · 🟪 AI · 🟫 actions · ⬜ utilities · 🟩 outputs · 🟥 error rail.\nEach node has its own doc card underneath — read those before editing.","width":480,"height":900},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-830,80],"id":"44325332-ba2e-dc3b-979a-4289a84763cb","name":"📘 Workflow Overview"},{"parameters":{"content":"## 🛟 Error handling & retries\n\nExternal calls retry **3× with 2s backoff**. Anything still failing exits through its node's error output into the red error rail → context is captured and the on-call channel is alerted. Failures are also parked in a dead-letter queue for replay. Set an n8n **Error Workflow** in settings as the final safety net.","width":360,"height":260,"color":3},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-230,-620],"id":"198ea22d-79c7-06b9-9eea-3b914813da31","name":"🛟 Error handling & retries"},{"parameters":{"content":"## 🔐 Security\n\nNever trust inbound payloads: the webhook path is unguessable. Add header auth or IP allow-listing for defense in depth. Secrets live in n8n credentials — never in node parameters.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[190,-620],"id":"a8b6e7be-f84c-93e0-e657-774522e51cf5","name":"🔐 Security"},{"parameters":{"content":"## 🧹 Data quality\n\nDedupe/diff steps make re-runs safe: the same input twice will not create duplicate records. If you change the key fields, clear n8n's dedupe memory (node → 'Clear stored keys') before the next run.","width":360,"height":260,"color":1},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[610,-620],"id":"559ced8d-adf7-f87d-49ba-04763f050cff","name":"🧹 Data quality"},{"parameters":{"content":"## 🛠 Customize me\n\nQuick wins: point the data nodes at your own accounts (see 🔑 lines on each card), adjust the trigger cadence, and tune thresholds/labels to your fulfillment process. Every node card explains its role — safe to extend at any marked branch.","width":360,"height":260,"color":4},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1030,-620],"id":"382f5041-e60a-c5f0-bf01-e000386d5578","name":"🛠 Customize me"}],"connections":{"Receive Inbound Webhook":{"main":[[{"node":"Pull Side A (Airtable)","type":"main","index":0},{"node":"Pull Side B (Google Sheets)","type":"main","index":0}]]},"Pull Side A (Airtable)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Pull Side B (Google Sheets)":{"main":[[{"node":"Diff the Two Systems","type":"main","index":1}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Diff the Two Systems":{"main":[[{"node":"Create Missing in Google Sheets","type":"main","index":0}],[{"node":"Count In-Sync Rows","type":"main","index":0}],[{"node":"Apply Updates to Google Sheets","type":"main","index":0}],[{"node":"Backfill into Airtable","type":"main","index":0}]]},"Create Missing in Google Sheets":{"main":[[{"node":"Gather Sync Results","type":"main","index":0}],[{"node":"Capture Failure Context","type":"main","index":0}]]},"Count In-Sync Rows":{"main":[[{"node":"Gather Sync 